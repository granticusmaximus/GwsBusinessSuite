@page "/admin/access-denied"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization

<PageTitle>Access Denied</PageTitle>

<div style="max-width:36rem;margin:4rem auto;text-align:center;padding:0 1rem;">
    <i class="bi bi-shield-lock-fill text-danger" style="font-size:3rem;"></i>
    <h1 class="mt-3 h4 fw-bold">Access Denied</h1>
    <p class="text-secondary mt-2">You don't have permission to view that page.</p>
    <a href="/admin" class="btn btn-primary mt-3">
        <i class="bi bi-arrow-left me-2"></i>Go to my workspace
    </a>
</div>
