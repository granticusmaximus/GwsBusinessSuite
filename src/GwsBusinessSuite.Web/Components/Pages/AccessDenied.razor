@page "/admin/access-denied"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<PageTitle>Access Denied</PageTitle>

<div style="max-width:36rem;margin:4rem auto;text-align:center;padding:0 1rem;">
    <i class="bi bi-shield-lock-fill text-danger" style="font-size:3rem;"></i>
    <h1 class="mt-3 h4 fw-bold">Access Denied</h1>
    <p class="text-secondary mt-2">You don't have permission to view that page.</p>
    <a href="@ReturnHref" class="btn btn-primary mt-3">
        <i class="bi bi-arrow-left me-2"></i>Go to my workspace
    </a>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private string ReturnHref { get; set; } = "/admin/content-studio";

    protected override async Task OnParametersSetAsync()
    {
        if (AuthenticationStateTask is null) return;
        var state = await AuthenticationStateTask;
        var role  = state.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;

        ReturnHref = role == GwsBusinessSuite.Domain.Entities.AppRoles.Admin
            ? "/admin"
            : "/admin/content-studio";
    }
}
