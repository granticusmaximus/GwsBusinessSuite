@page "/admin/podcasts"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "ContributorAccess")]
@implements IAsyncDisposable
@using GwsBusinessSuite.Application.Podcasts
@using Microsoft.AspNetCore.Authorization
@inject IPodcastDirectoryService PodcastService
@inject IPodcastListenProgressService ProgressService
@inject ILogger<PodcastDirectory> Logger
@inject IJSRuntime JS

<PageTitle>Podcast Directory</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-mic-fill me-2 text-danger"></i>Podcast Directory</h1>
    <p>Search Apple Podcasts, curate a saved library, and refresh live episodes from each show's RSS feed.</p>
</div>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <div class="alert alert-success" role="alert">@_statusMessage</div>
}

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger" role="alert">@_errorMessage</div>
}

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button type="button" class="nav-link @(_activeTab == "discover" ? "active" : "")" @onclick='() => _activeTab = "discover"'>
            Discover
        </button>
    </li>
    <li class="nav-item">
        <button type="button" class="nav-link @(_activeTab == "library" ? "active" : "")" @onclick='() => _activeTab = "library"'>
            Library <span class="badge text-bg-secondary rounded-pill ms-1">@_library.Count</span>
        </button>
    </li>
</ul>

@if (_initialLoading)
{
    <div class="d-flex align-items-center gap-2 text-secondary">
        <span class="spinner-border spinner-border-sm"></span>
        <span>Loading podcast directory…</span>
    </div>
}
else if (_activeTab == "discover")
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-8">
                    <label class="form-label fw-semibold small" for="podcast-search">Search Apple Podcasts</label>
                    <form @onsubmit="SubmitDiscoverSearchAsync">
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input id="podcast-search" class="form-control" placeholder="Search for podcasts, hosts, or topics" @bind="_discoverSearchInput" />
                        </div>
                    </form>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button class="btn btn-primary flex-grow-1" @onclick="SubmitDiscoverSearchAsync" disabled="@_discoverLoading">Search</button>
                    <button class="btn btn-outline-secondary" @onclick="ResetDiscoverView" disabled="@_discoverLoading">Reset</button>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <button class="btn btn-sm rounded-pill @(_activeDiscoverChip == "Featured" ? "btn-dark" : "btn-outline-secondary")"
                        @onclick="ResetDiscoverView">
                    Featured
                </button>
                <button class="btn btn-sm rounded-pill @(_activeDiscoverChip == "All" ? "btn-dark" : "btn-outline-secondary")"
                        @onclick='() => LoadDiscoverCategoryAsync("All")'>
                    All
                </button>
                @foreach (var category in DiscoverCategories)
                {
                    <button class="btn btn-sm rounded-pill @(_activeDiscoverChip == category ? "btn-dark" : "btn-outline-secondary")"
                            @onclick='() => LoadDiscoverCategoryAsync(category)'>
                        @category
                    </button>
                }
            </div>
        </div>
    </div>

    @if (_discoverLoading)
    {
        <div class="d-flex align-items-center gap-2 text-secondary">
            <span class="spinner-border spinner-border-sm"></span>
            <span>Loading podcasts…</span>
        </div>
    }
    else if (_showFeaturedSections)
    {
        @foreach (var featuredSection in _featuredSections)
        {
            <div class="d-flex justify-content-between align-items-start gap-3 mb-2 mt-4">
                <div>
                    <div class="small text-uppercase fw-semibold text-secondary">@featuredSection.Icon Featured Category</div>
                    <h2 class="h5 mb-0">@featuredSection.Category</h2>
                </div>
                <button class="btn btn-sm btn-outline-secondary" @onclick='() => LoadDiscoverCategoryAsync(featuredSection.Category)'>
                    View More
                </button>
            </div>

            @if (featuredSection.Podcasts.Count == 0)
            {
                <p class="text-secondary small mb-0">No podcasts are available in this category right now.</p>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                    @foreach (var item in featuredSection.Podcasts)
                    {
                        @RenderDiscoverCard(item)
                    }
                </div>
            }
        }
    }
    else if (_discoverResults.Count == 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-secondary py-5">
                <i class="bi bi-broadcast display-6 d-block mb-2"></i>
                <h2 class="h5">No podcasts found</h2>
                <p class="mb-0">Try a different search term or switch to another category.</p>
            </div>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
            <div>
                <div class="small text-uppercase fw-semibold text-secondary">Discover Results</div>
                <h2 class="h5 mb-0">@_discoverHeading</h2>
            </div>
            <span class="text-secondary small">@_discoverResults.Count podcast@(_discoverResults.Count == 1 ? "" : "s")</span>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
            @foreach (var item in _discoverResults)
            {
                @RenderDiscoverCard(item)
            }
        </div>
    }
}
else
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-8">
                    <label class="form-label fw-semibold small" for="library-search">Search saved library</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input id="library-search" class="form-control" placeholder="Filter by title, author, or description"
                               @bind="_librarySearch" @bind:event="oninput" />
                    </div>
                </div>
                <div class="col-md-4 d-flex justify-content-md-end align-items-center gap-2">
                    <span class="text-secondary small">@FilteredLibrary.Count podcast@((FilteredLibrary.Count == 1) ? "" : "s")</span>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ReloadLibraryAsync">Refresh Library</button>
                </div>
            </div>

            @if (LibraryCategories.Count > 0)
            {
                <div class="d-flex flex-wrap gap-2 mt-3">
                    <button class="btn btn-sm rounded-pill @(_selectedLibraryCategory == "All" ? "btn-dark" : "btn-outline-secondary")"
                            @onclick='() => _selectedLibraryCategory = "All"'>
                        All <span class="badge text-bg-light rounded-pill ms-1">@_library.Count</span>
                    </button>
                    @foreach (var category in LibraryCategories)
                    {
                        <button class="btn btn-sm rounded-pill @(_selectedLibraryCategory == category.Name ? "btn-dark" : "btn-outline-secondary")"
                                @onclick='() => _selectedLibraryCategory = category.Name'>
                            @category.Name <span class="badge text-bg-light rounded-pill ms-1">@category.Count</span>
                        </button>
                    }
                </div>
            }
        </div>
    </div>

    @if (_library.Count == 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-secondary py-5">
                <i class="bi bi-journal-plus display-6 d-block mb-2"></i>
                <h2 class="h5">Your library is empty</h2>
                <p class="mb-0">Save a show from the Discover tab to start tracking episodes here.</p>
            </div>
        </div>
    }
    else if (FilteredLibrary.Count == 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-secondary py-5">
                <i class="bi bi-funnel display-6 d-block mb-2"></i>
                <h2 class="h5">No saved podcasts match</h2>
                <p class="mb-0">Clear the current search or category filter to see the rest of your library.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
            @foreach (var item in FilteredLibrary)
            {
                <div class="col">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="ratio ratio-16x9 bg-light rounded-top overflow-hidden">
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="" loading="lazy" class="w-100 h-100" style="object-fit:cover;" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center display-6 text-danger fw-bold">@GetInitial(item.Title)</div>
                            }
                        </div>
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="badge text-bg-primary rounded-pill">@item.Category</span>
                                <span class="text-secondary small">@item.EpisodeCount episode@(item.EpisodeCount == 1 ? "" : "s")</span>
                            </div>
                            <h3 class="h6">@item.Title</h3>
                            @if (!string.IsNullOrWhiteSpace(item.Author))
                            {
                                <p class="text-secondary small mb-1">by @item.Author</p>
                            }
                            <p class="small text-secondary">@Describe(item.Description)</p>
                            <div class="d-flex flex-wrap gap-2 mt-auto">
                                <button class="btn btn-primary btn-sm" @onclick='() => OpenPodcastAsync(item.Id)'>Open Episodes</button>
                                @if (!string.IsNullOrWhiteSpace(item.AppleUrl))
                                {
                                    <a class="btn btn-outline-secondary btn-sm" href="@item.AppleUrl" target="_blank" rel="noopener noreferrer">Apple</a>
                                }
                            </div>
                            @if (item.LastEpisodeRefreshAt.HasValue)
                            {
                                <div class="text-secondary small mt-2">Updated @TimeAgo(item.LastEpisodeRefreshAt.Value)</div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@if (_detailOpen)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <div class="small text-uppercase fw-semibold text-secondary">Podcast Detail</div>
                        <h2 class="h5 mb-0">@(_selectedDetail?.Podcast.Title ?? "Loading…")</h2>
                    </div>
                    <button type="button" class="btn-close" @onclick="CloseDetail" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (_detailLoading)
                    {
                        <div class="d-flex align-items-center gap-2 text-secondary">
                            <span class="spinner-border spinner-border-sm"></span>
                            <span>Loading podcast detail…</span>
                        </div>
                    }
                    else if (_selectedDetail is { } detail)
                    {
                        <div class="row g-4 mb-3">
                            <div class="col-md-4">
                                <div class="ratio ratio-1x1 bg-light rounded overflow-hidden">
                                    @if (!string.IsNullOrWhiteSpace(detail.Podcast.ImageUrl))
                                    {
                                        <img src="@detail.Podcast.ImageUrl" alt="" loading="lazy" class="w-100 h-100" style="object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center display-4 text-danger fw-bold">@GetInitial(detail.Podcast.Title)</div>
                                    }
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="badge text-bg-primary rounded-pill">@detail.Podcast.Category</span>
                                    <span class="text-secondary small">@detail.Podcast.EpisodeCount episode@(detail.Podcast.EpisodeCount == 1 ? "" : "s")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(detail.Podcast.Author))
                                {
                                    <p class="text-secondary small mb-1">by @detail.Podcast.Author</p>
                                }
                                <p class="small text-secondary">@Describe(detail.Podcast.Description, 320)</p>
                                <div class="d-flex flex-wrap gap-2">
                                    <button class="btn btn-primary btn-sm" @onclick="RefreshSelectedPodcastAsync">Refresh Episodes</button>
                                    <button class="btn btn-outline-danger btn-sm" @onclick='() => RemoveSavedPodcastAsync(detail.Podcast.Id, detail.Podcast.Title)'>Remove</button>
                                    @if (!string.IsNullOrWhiteSpace(detail.Podcast.FeedUrl))
                                    {
                                        <a class="btn btn-outline-secondary btn-sm" href="@detail.Podcast.FeedUrl" target="_blank" rel="noopener noreferrer">Feed</a>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(detail.Podcast.AppleUrl))
                                    {
                                        <a class="btn btn-outline-secondary btn-sm" href="@detail.Podcast.AppleUrl" target="_blank" rel="noopener noreferrer">Apple</a>
                                    }
                                </div>
                                @if (detail.Podcast.LastEpisodeRefreshAt.HasValue)
                                {
                                    <div class="text-secondary small mt-2">Episodes refreshed @TimeAgo(detail.Podcast.LastEpisodeRefreshAt.Value)</div>
                                }
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                            <div>
                                <div class="small text-uppercase fw-semibold text-secondary">Episodes</div>
                                <h3 class="h6 mb-0">@detail.Episodes.Count episode@(detail.Episodes.Count == 1 ? "" : "s") ready</h3>
                            </div>
                            <select class="form-select form-select-sm" style="max-width:10rem;" @bind="_episodeSort">
                                <option value="newest">Newest first</option>
                                <option value="oldest">Oldest first</option>
                            </select>
                        </div>

                        @if (SortedEpisodes.Count == 0)
                        {
                            <div class="text-center text-secondary py-4">
                                <i class="bi bi-radioactive display-6 d-block mb-2"></i>
                                <h2 class="h6">No episodes yet</h2>
                                <p class="mb-0 small">This feed did not return any playable episodes. Try refreshing the feed.</p>
                            </div>
                        }
                        else
                        {
                            <div class="list-group">
                                @foreach (var episode in SortedEpisodes)
                                {
                                    <div class="list-group-item" @key="episode.Id">
                                        <div class="d-flex justify-content-between align-items-start gap-3 mb-1">
                                            <h4 class="h6 mb-0">@episode.Title</h4>
                                            <div class="d-flex align-items-center gap-2 text-secondary small flex-shrink-0">
                                                @if (episode.PublishedAt.HasValue)
                                                {
                                                    <span>@episode.PublishedAt.Value.ToLocalTime().ToString("MMM d, yyyy")</span>
                                                }
                                                @if (episode.DurationSeconds.HasValue)
                                                {
                                                    <span>@FormatDuration(episode.DurationSeconds.Value)</span>
                                                }
                                            </div>
                                        </div>
                                        <p class="small text-secondary">@Describe(episode.Description, 380)</p>

                                        @if (_progress.TryGetValue(episode.Id, out var progress))
                                        {
                                            if (progress.IsCompleted)
                                            {
                                                <div class="mb-2">
                                                    <span class="badge text-bg-success"><i class="bi bi-check-circle-fill me-1"></i>Listened</span>
                                                </div>
                                            }
                                            else if (progress.PositionSeconds > 0)
                                            {
                                                <div class="mb-2">
                                                    <div class="progress" style="height:4px;" role="progressbar">
                                                        <div class="progress-bar" style="width:@(GetProgressPercent(progress))%"></div>
                                                    </div>
                                                    <div class="small text-secondary mt-1">Resume from @FormatDuration(progress.PositionSeconds)</div>
                                                </div>
                                            }
                                        }

                                        <div class="d-flex flex-column gap-1">
                                            <audio controls preload="none" class="w-100" src="@episode.AudioUrl"
                                                   data-episode-id="@episode.Id"
                                                   data-resume-seconds="@(_progress.TryGetValue(episode.Id, out var resumeProgress) ? resumeProgress.PositionSeconds : 0)"></audio>
                                            <a class="small align-self-start" href="@episode.AudioUrl" target="_blank" rel="noopener noreferrer">Open audio</a>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private static readonly string[] DiscoverCategories =
    [
        "Comedy",
        "True Crime",
        "News",
        "Technology",
        "Business",
        "Health",
        "Sports",
        "Music",
        "Arts",
        "Science",
        "History",
        "Education"
    ];

    private readonly StringComparer _categoryComparer = StringComparer.OrdinalIgnoreCase;
    private List<FeaturedPodcastSection> _featuredSections = [];
    private List<PodcastCatalogItem> _discoverResults = [];
    private List<SavedPodcastSummary> _library = [];
    private Dictionary<string, SavedPodcastSummary> _libraryIndex = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<Guid, PodcastListenProgressView> _progress = new();

    private bool _initialLoading = true;
    private bool _discoverLoading;
    private bool _detailLoading;
    private bool _detailOpen;

    private string _activeTab = "discover";
    private string _activeDiscoverChip = "Featured";
    private bool _showFeaturedSections = true;
    private string _discoverHeading = "Explore by Category";
    private string _discoverSearchInput = string.Empty;
    private string _librarySearch = string.Empty;
    private string _selectedLibraryCategory = "All";
    private string _episodeSort = "newest";
    private string _statusMessage = string.Empty;
    private string _errorMessage = string.Empty;

    private PodcastDetailView? _selectedDetail;

    private DotNetObjectReference<PodcastDirectory>? _progressJsRef;
    private bool _progressJsInitialized;

    private IReadOnlyList<SavedPodcastSummary> FilteredLibrary =>
        _library
            .Where(item =>
                _selectedLibraryCategory == "All" ||
                _categoryComparer.Equals(item.Category, _selectedLibraryCategory))
            .Where(item =>
                string.IsNullOrWhiteSpace(_librarySearch) ||
                MatchesLibrarySearch(item, _librarySearch))
            .ToList();

    private IReadOnlyList<LibraryCategoryOption> LibraryCategories =>
        _library
            .GroupBy(item => item.Category)
            .Select(group => new LibraryCategoryOption(group.Key, group.Count()))
            .OrderByDescending(option => option.Count)
            .ThenBy(option => option.Name)
            .ToList();

    private IReadOnlyList<PodcastEpisodeView> SortedEpisodes =>
        _selectedDetail is null
            ? []
            : (_episodeSort == "oldest"
                ? _selectedDetail.Episodes.OrderBy(x => x.PublishedAt ?? DateTimeOffset.MinValue).ToList()
                : _selectedDetail.Episodes.OrderByDescending(x => x.PublishedAt ?? DateTimeOffset.MinValue).ToList());

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(InitializeLibraryAsync(), InitializeFeaturedAsync());
        _initialLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_progressJsInitialized)
        {
            _progressJsRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("gwsPodcastProgress.init", _progressJsRef);
            _progressJsInitialized = true;
        }
    }

    private async Task InitializeLibraryAsync()
    {
        try
        {
            await LoadLibraryAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize podcast library");
            AppendError("Saved podcasts are temporarily unavailable.");
        }
    }

    private async Task InitializeFeaturedAsync()
    {
        try
        {
            await LoadFeaturedAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize featured podcasts");
            AppendError("Featured podcast recommendations are temporarily unavailable.");
        }
    }

    private async Task LoadFeaturedAsync()
    {
        _featuredSections = (await PodcastService.GetFeaturedSectionsAsync()).ToList();
    }

    private async Task LoadLibraryAsync()
    {
        _library = (await PodcastService.ListLibraryAsync()).ToList();
        RebuildLibraryIndex();
    }

    private void AppendError(string message)
    {
        if (string.IsNullOrWhiteSpace(_errorMessage))
        {
            _errorMessage = message;
            return;
        }

        if (!_errorMessage.Contains(message, StringComparison.OrdinalIgnoreCase))
        {
            _errorMessage = $"{_errorMessage} {message}";
        }
    }

    private void RebuildLibraryIndex()
    {
        _libraryIndex = new Dictionary<string, SavedPodcastSummary>(StringComparer.OrdinalIgnoreCase);

        foreach (var item in _library)
        {
            foreach (var key in PodcastDirectoryIdentity.BuildKeys(item.ItunesId, item.FeedUrl, item.AppleUrl, item.Title, item.Author))
            {
                _libraryIndex[key] = item;
            }
        }
    }

    private async Task SubmitDiscoverSearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_discoverSearchInput))
        {
            _errorMessage = "Enter a podcast search term first.";
            return;
        }

        _discoverLoading = true;
        _errorMessage = string.Empty;
        _statusMessage = string.Empty;

        try
        {
            _discoverResults = (await PodcastService.SearchCatalogAsync(_discoverSearchInput.Trim())).ToList();
            _discoverHeading = $"Search results for \"{_discoverSearchInput.Trim()}\"";
            _activeDiscoverChip = string.Empty;
            _showFeaturedSections = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Podcast search failed");
            _errorMessage = "Podcast search failed.";
        }
        finally
        {
            _discoverLoading = false;
        }
    }

    private async Task LoadDiscoverCategoryAsync(string category)
    {
        _discoverLoading = true;
        _errorMessage = string.Empty;
        _statusMessage = string.Empty;

        try
        {
            _discoverResults = (await PodcastService.DiscoverAsync(category == "All" ? null : category)).ToList();
            _discoverHeading = category == "All" ? "All categories" : category;
            _activeDiscoverChip = category;
            _showFeaturedSections = false;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load discover category {Category}", category);
            _errorMessage = "Failed to load podcasts for that category.";
        }
        finally
        {
            _discoverLoading = false;
        }
    }

    private void ResetDiscoverView()
    {
        _discoverResults = [];
        _discoverHeading = "Explore by Category";
        _discoverSearchInput = string.Empty;
        _activeDiscoverChip = "Featured";
        _showFeaturedSections = true;
        _errorMessage = string.Empty;
        _statusMessage = string.Empty;
    }

    private async Task ReloadLibraryAsync()
    {
        _errorMessage = string.Empty;
        _statusMessage = string.Empty;

        try
        {
            await LoadLibraryAsync();
            _statusMessage = "Library refreshed.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to reload podcast library");
            _errorMessage = "Failed to refresh the library.";
        }
    }

    private SavedPodcastSummary? FindSavedMatch(PodcastCatalogItem item)
    {
        foreach (var key in PodcastDirectoryIdentity.BuildKeys(item.ItunesId, item.FeedUrl, item.AppleUrl, item.Title, item.Author))
        {
            if (_libraryIndex.TryGetValue(key, out var saved))
            {
                return saved;
            }
        }

        return null;
    }

    private async Task SavePodcastAsync(PodcastCatalogItem item)
    {
        _errorMessage = string.Empty;
        _statusMessage = string.Empty;

        try
        {
            var result = await PodcastService.SavePodcastAsync(item);
            await LoadLibraryAsync();
            _statusMessage = result.AlreadySaved
                ? $"\"{result.Podcast.Title}\" is already in your library."
                : $"\"{result.Podcast.Title}\" was added to your library.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save podcast {Title}", item.Title);
            _errorMessage = ex.Message;
        }
    }

    private async Task OpenPodcastAsync(Guid podcastId, bool forceRefresh = false)
    {
        _detailOpen = true;
        _detailLoading = true;
        _errorMessage = string.Empty;

        try
        {
            _selectedDetail = await PodcastService.GetPodcastDetailAsync(podcastId, forceRefresh);
            if (_selectedDetail is not null)
            {
                await LoadLibraryAsync();
                await LoadProgressAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load podcast detail {PodcastId}", podcastId);
            _errorMessage = "Failed to load the podcast detail.";
        }
        finally
        {
            _detailLoading = false;
        }
    }

    private async Task LoadProgressAsync()
    {
        if (_selectedDetail is null)
        {
            return;
        }

        var episodeIds = _selectedDetail.Episodes.Select(e => e.Id).ToList();
        _progress = (await ProgressService.GetProgressForEpisodesAsync(episodeIds))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
    }

    private static double GetProgressPercent(PodcastListenProgressView progress) =>
        progress.DurationSeconds is > 0
            ? Math.Clamp(progress.PositionSeconds * 100.0 / progress.DurationSeconds.Value, 0, 100)
            : 0;

    [JSInvokable]
    public async Task SaveProgress(string episodeId, int positionSeconds, int? durationSeconds)
    {
        if (!Guid.TryParse(episodeId, out var id))
        {
            return;
        }

        // Reflects whatever the service actually persisted (including the completion
        // threshold check) rather than recomputing it here, so the two can never disagree.
        _progress[id] = await ProgressService.SaveProgressAsync(id, positionSeconds, durationSeconds);
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task MarkCompleted(string episodeId)
    {
        if (!Guid.TryParse(episodeId, out var id))
        {
            return;
        }

        _progress[id] = await ProgressService.MarkCompletedAsync(id);
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshSelectedPodcastAsync()
    {
        if (_selectedDetail is null)
        {
            return;
        }

        await OpenPodcastAsync(_selectedDetail.Podcast.Id, forceRefresh: true);
        _statusMessage = "Episodes refreshed.";
    }

    private async Task RemoveSavedPodcastAsync(Guid podcastId, string title)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Remove \"{title}\" from the library?"))
        {
            return;
        }

        _errorMessage = string.Empty;
        _statusMessage = string.Empty;

        try
        {
            await PodcastService.DeletePodcastAsync(podcastId);
            await LoadLibraryAsync();

            if (_selectedDetail?.Podcast.Id == podcastId)
            {
                CloseDetail();
            }

            _statusMessage = $"\"{title}\" was removed from the library.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to remove podcast {PodcastId}", podcastId);
            _errorMessage = "Failed to remove that podcast.";
        }
    }

    private void CloseDetail()
    {
        _detailOpen = false;
        _selectedDetail = null;
        _detailLoading = false;
        _progress = new();
    }

    private static bool MatchesLibrarySearch(SavedPodcastSummary item, string search)
    {
        var query = search.Trim();
        return item.Title.Contains(query, StringComparison.OrdinalIgnoreCase) ||
               item.Author.Contains(query, StringComparison.OrdinalIgnoreCase) ||
               item.Description.Contains(query, StringComparison.OrdinalIgnoreCase);
    }

    private RenderFragment RenderDiscoverCard(PodcastCatalogItem item) => @<div class="col">
        <div class="card border-0 shadow-sm h-100">
            <div class="ratio ratio-16x9 bg-light rounded-top overflow-hidden">
                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                {
                    <img src="@item.ImageUrl" alt="" loading="lazy" class="w-100 h-100" style="object-fit:cover;" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center display-6 text-danger fw-bold">@GetInitial(item.Title)</div>
                }
            </div>
            <div class="card-body d-flex flex-column">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge text-bg-primary rounded-pill">@item.Category</span>
                    @if (FindSavedMatch(item) is not null)
                    {
                        <span class="badge text-bg-light">Saved</span>
                    }
                </div>
                <h3 class="h6">@item.Title</h3>
                @if (!string.IsNullOrWhiteSpace(item.Author))
                {
                    <p class="text-secondary small mb-1">by @item.Author</p>
                }
                <p class="small text-secondary">@Describe(item.Description)</p>
                <div class="d-flex flex-wrap gap-2 mt-auto">
                    @if (FindSavedMatch(item) is { } saved)
                    {
                        <button class="btn btn-primary btn-sm" @onclick='() => OpenPodcastAsync(saved.Id)'>Open Library Entry</button>
                    }
                    else if (string.IsNullOrWhiteSpace(item.FeedUrl))
                    {
                        <button class="btn btn-outline-secondary btn-sm" disabled>Feed unavailable</button>
                    }
                    else
                    {
                        <button class="btn btn-primary btn-sm" @onclick='() => SavePodcastAsync(item)'>Save to Library</button>
                    }

                    @if (!string.IsNullOrWhiteSpace(item.AppleUrl))
                    {
                        <a class="btn btn-outline-secondary btn-sm" href="@item.AppleUrl" target="_blank" rel="noopener noreferrer">Apple</a>
                    }
                </div>
            </div>
        </div>
    </div>;

    private static string GetInitial(string value) =>
        string.IsNullOrWhiteSpace(value) ? "?" : value.Trim()[..1].ToUpperInvariant();

    private static string Describe(string? value, int maxLength = 180)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "No summary is available for this podcast yet.";
        }

        var trimmed = value.Trim();
        return trimmed.Length <= maxLength ? trimmed : $"{trimmed[..maxLength].TrimEnd()}…";
    }

    private static string TimeAgo(DateTimeOffset value)
    {
        var diff = DateTimeOffset.UtcNow - value;
        if (diff.TotalMinutes < 60)
        {
            return $"{Math.Max(1, (int)diff.TotalMinutes)}m ago";
        }

        if (diff.TotalHours < 24)
        {
            return $"{(int)diff.TotalHours}h ago";
        }

        return $"{(int)diff.TotalDays}d ago";
    }

    private static string FormatDuration(int seconds)
    {
        var duration = TimeSpan.FromSeconds(seconds);
        return duration.TotalHours >= 1
            ? $"{(int)duration.TotalHours}h {duration.Minutes}m"
            : $"{Math.Max(1, duration.Minutes)}m";
    }

    public async ValueTask DisposeAsync()
    {
        if (_progressJsInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("gwsPodcastProgress.dispose");
            }
            catch (JSDisconnectedException)
            {
                // The circuit is already gone (e.g. browser closed); nothing to clean up client-side.
            }
        }

        _progressJsRef?.Dispose();
    }

    private sealed record LibraryCategoryOption(string Name, int Count);
