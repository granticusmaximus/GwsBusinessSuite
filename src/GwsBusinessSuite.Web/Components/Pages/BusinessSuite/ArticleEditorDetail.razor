    private string PublishedAtInput
    {
        get => PublishedAtValue?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm") ?? string.Empty;
    }

    private void OnPublishedAtChanged(ChangeEventArgs args) =>
        PublishedAtValue = ParseDateTimeLocal(args.Value?.ToString());

    private static DateTimeOffset? ParseDateTimeLocal(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        if (!DateTime.TryParse(value, out var parsed))
        {
            return null;
        }

        var local = DateTime.SpecifyKind(parsed, DateTimeKind.Local);
        return new DateTimeOffset(local);
    }

    private static bool IsScheduledArticle(Article article) =>
        article.Status == ArticleStatuses.Published
        && article.PublishedAt is { } publishAt
        && publishAt > DateTimeOffset.UtcNow;

    private void ToggleReviseWithAiPanel()
    {
        ShowReviseWithAiPanel = !ShowReviseWithAiPanel;
        ReviseWithAiError = string.Empty;
        if (!ShowReviseWithAiPanel)
        {
            ReviseWithAiNotes = string.Empty;
        }
    }

    // Reuses the same Ollama revision loop Content Studio's own draft workspace
    // uses (RequestRevisionAsync then PublishDraftToSiteAsync) - publishing again
    // updates the existing Article row in place since it matches by slug, so this
    // never creates a duplicate post.
    private async Task ReviseWithAiAsync()
    {
        if (CurrentArticle?.SourceDraftId is not { } draftId || string.IsNullOrWhiteSpace(ReviseWithAiNotes))
        {
            return;
        }

        IsBusy = true;
        ReviseWithAiError = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            await ContentStudioService.RequestRevisionAsync(new DraftRevisionRequest
            {
                DraftId = draftId,
                RequestedModifications = ReviseWithAiNotes,
                PerformedBy = "article-editor-ui"
            });

            await ContentStudioService.PublishDraftToSiteAsync(new DraftPublishRequest
            {
                DraftId = draftId,
                Notes = ReviseWithAiNotes,
                PerformedBy = "article-editor-ui"
            });

            ShowReviseWithAiPanel = false;
            ReviseWithAiNotes = string.Empty;
            await LoadArticle();
            StatusMessage = "Article regenerated with AI and republished live.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to revise article {Id} with AI via draft {DraftId}.", ArticleId, draftId);
            ReviseWithAiError = $"Unable to regenerate with AI. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void OpenPlacementModal(ArticleAffiliatePlacement? existing)
    {
        PlacementMessage = string.Empty;
        PlacementMessageIsError = false;

        if (existing is null)
        {
            EditingPlacementId = null;
            SelectedAdvertiserId = string.Empty;
            SelectedOfferId = string.Empty;
            PlacementCallToActionText = "Explore Offer";
        }
        else
        {
            EditingPlacementId = existing.Id;
            SelectedAdvertiserId = existing.AdvertiserId;
            SelectedOfferId = AllOffers
                .FirstOrDefault(x => x.AdvertiserId == existing.AdvertiserId && x.TrackingUrl == existing.TrackingUrl)
                ?.Id.ToString() ?? string.Empty;
            PlacementCallToActionText = existing.CallToActionText;
        }

        ShowPlacementModal = true;
    }

