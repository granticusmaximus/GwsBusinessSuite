    private async Task SavePlacement()
    {
        if (string.IsNullOrWhiteSpace(SelectedOfferId) || !Guid.TryParse(SelectedOfferId, out var offerId))
        {
            PlacementMessage = "Select an advertiser and offer before saving.";
            PlacementMessageIsError = true;
            return;
        }

        var offer = AllOffers.FirstOrDefault(x => x.Id == offerId);
        if (offer is null)
        {
            PlacementMessage = "The selected offer could not be found.";
            PlacementMessageIsError = true;
            return;
        }

        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            if (EditingPlacementId is { } id)
            {
                var existing = await db.ArticleAffiliatePlacements.FindAsync(id);
                if (existing is null)
                {
                    PlacementMessage = "Placement could not be found.";
                    PlacementMessageIsError = true;
                    return;
                }

                existing.AdvertiserId = offer.AdvertiserId;
                existing.AdvertiserName = offer.AdvertiserName;
                existing.LinkName = offer.LinkName;
                existing.Category = offer.Category ?? string.Empty;
                existing.TrackingUrl = offer.TrackingUrl ?? string.Empty;
                existing.ImageUrl = offer.ImageUrl;
                existing.CallToActionText = string.IsNullOrWhiteSpace(PlacementCallToActionText)
                    ? "Explore Offer"
                    : PlacementCallToActionText.Trim();
                existing.UpdatedAt = DateTimeOffset.UtcNow;
                existing.UpdatedBy = "manual-editor";
            }
            else
            {
                db.ArticleAffiliatePlacements.Add(new ArticleAffiliatePlacement
                {
                    ArticleId = ArticleId,
                    SlotToken = ArticleMarkdownRenderer.GenerateSlotToken(),
                    AdvertiserId = offer.AdvertiserId,
                    AdvertiserName = offer.AdvertiserName,
                    LinkName = offer.LinkName,
                    Category = offer.Category ?? string.Empty,
                    TrackingUrl = offer.TrackingUrl ?? string.Empty,
                    ImageUrl = offer.ImageUrl,
                    CallToActionText = string.IsNullOrWhiteSpace(PlacementCallToActionText)
                        ? "Explore Offer"
                        : PlacementCallToActionText.Trim(),
                    SortOrder = Placements.Count,
                    CreatedBy = "manual-editor"
                });
            }

            await db.SaveChangesAsync();

            Placements = await db.ArticleAffiliatePlacements
                .Where(x => x.ArticleId == ArticleId)
                .OrderBy(x => x.SortOrder)
                .ToListAsync();

            ShowPlacementModal = false;
            StatusMessage = EditingPlacementId is null
                ? "Ad placement added. Use \"Insert at Cursor\" to drop its token into the markdown."
                : "Ad placement updated.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save ad placement for article {Id}.", ArticleId);
            PlacementMessage = $"Unable to save placement. {ex.Message}";
            PlacementMessageIsError = true;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task DeletePlacement(ArticleAffiliatePlacement placement)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"Remove the {placement.AdvertiserName} ad placement? Its token will be removed from the published article the next time it's served.");
        if (!confirmed) return;

        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var existing = await db.ArticleAffiliatePlacements.FindAsync(placement.Id);
            if (existing is not null)
            {
                db.ArticleAffiliatePlacements.Remove(existing);
                await db.SaveChangesAsync();
            }

            Placements = await db.ArticleAffiliatePlacements
                .Where(x => x.ArticleId == ArticleId)
                .OrderBy(x => x.SortOrder)
                .ToListAsync();

            StatusMessage = "Ad placement removed.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete ad placement for article {Id}.", ArticleId);
            ErrorMessage = $"Unable to remove placement. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task InsertTokenAtCursor(string slotToken)
    {
        await JS.InvokeVoidAsync("gwsMarkdownEditor.insertAtCursor", MarkdownEditorElementId, slotToken);
    }

    public async ValueTask DisposeAsync()
    {
        if (_markdownEditorInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("gwsMarkdownEditor.destroy", MarkdownEditorElementId);
            }
            catch (JSDisconnectedException)
            {
                // The circuit is already gone (e.g. browser closed); nothing to clean up client-side.
            }
        }

        _markdownEditorRef?.Dispose();
    }

    private static string ToSlug(string title)
    {
        var s = title.ToLowerInvariant().Trim();
        s = Regex.Replace(s, @"[^a-z0-9\s-]", string.Empty);
        s = Regex.Replace(s, @"\s+", "-");
        return s.Trim('-');
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        ArticleStatuses.Published => "text-bg-success",
        ArticleStatuses.Draft     => "text-bg-warning",
        _                         => "text-bg-secondary"
    };

    private static string FormatSource(string source) => source switch
    {
        ArticleSource.Manual          => "Manual",
        ArticleSource.OllamaGenerated => "Ollama",
        _                             => source
    };

    private static string FormatDate(DateTimeOffset value) =>
        value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
