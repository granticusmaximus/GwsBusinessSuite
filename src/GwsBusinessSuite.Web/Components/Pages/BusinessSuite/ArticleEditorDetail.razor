@page "/admin/article-editor/{ArticleId:guid}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "ContentAccess")]
@using Microsoft.AspNetCore.Authorization
@using GwsBusinessSuite.Domain.Entities
@using GwsBusinessSuite.Infrastructure.Data
@using Markdig
@using Microsoft.EntityFrameworkCore
@using System.Text.RegularExpressions
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation
@inject ILogger<ArticleEditorDetail> Logger

<PageTitle>@(CurrentArticle?.Title ?? "Article Editor")</PageTitle>

<div class="page-header d-flex align-items-start justify-content-between gap-3">
    <div>
        <h1><i class="bi bi-pencil me-2 text-primary"></i>@(CurrentArticle?.Title ?? "Article")</h1>
        @if (CurrentArticle is not null)
        {
            <div class="d-flex align-items-center gap-2 mt-1">
                <span class="badge @GetStatusBadgeClass(CurrentArticle.Status)">@CurrentArticle.Status</span>
                <span class="badge text-bg-light">@FormatSource(CurrentArticle.Source)</span>
                @if (CurrentArticle.PublishedAt.HasValue)
                {
                    <span class="small text-secondary">Published @FormatDate(CurrentArticle.PublishedAt.Value)</span>
                }
            </div>
        }
    </div>
    <button class="btn btn-outline-secondary d-inline-flex align-items-center" @onclick="BackToList" title="All Articles">
        <i class="bi bi-arrow-left-circle-fill"></i>
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger d-flex align-items-start gap-2 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
        <div>@ErrorMessage</div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-info d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <div>@StatusMessage</div>
    </div>
}

@if (CurrentArticle is null)
{
    <div class="card border-0 shadow-sm"><div class="card-body"><p class="text-secondary mb-0">Article not found.</p></div></div>
}
else
{
    <!-- Metadata card -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3">
            <span class="fw-semibold">Metadata</span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold small">Title</label>
                    <input class="form-control" value="@Title"
                           @oninput="OnTitleInput" placeholder="Article title" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold small">Author</label>
                    <input class="form-control" @bind="Author" placeholder="Grant Watson" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">
                        Slug
                        @if (!SlugManuallyEdited)
                        {
                            <span class="text-secondary small fw-normal ms-1">(auto)</span>
                        }
                    </label>
                    <input class="form-control font-monospace" value="@Slug"
                           @oninput="OnSlugInput" placeholder="url-friendly-slug" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">Topic</label>
                    <input class="form-control" @bind="Topic" placeholder="e.g. ASP.NET Core, Blazor" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">Primary Keyword</label>
                    <input class="form-control" @bind="PrimaryKeyword" placeholder="e.g. blazor server tutorial" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">Secondary Keywords</label>
                    <input class="form-control" @bind="SecondaryKeywords" placeholder="comma-separated" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold small">Meta Description</label>
                    <textarea class="form-control" rows="2" @bind="MetaDescription"
                              placeholder="Short description for search engine results (150–160 chars)"></textarea>
                    <div class="form-text">@MetaDescription.Length / 160 characters</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold small">Estimated Reading Time</label>
                    <input class="form-control" @bind="EstimatedReadingTime" placeholder="e.g. 6 min read" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold small">Hero Image</label>
                    @if (!string.IsNullOrWhiteSpace(HeroImageDataUri))
                    {
                        <img class="hero-preview-image mb-2" src="@HeroImageDataUri" alt="@HeroImageAltText" />
                    }
                    else if (!string.IsNullOrWhiteSpace(HeroImageUrl))
                    {
                        <img class="hero-preview-image mb-2" src="@HeroImageUrl" alt="@HeroImageAltText" />
                    }
                    <div class="upload-drop-zone mb-2">
                        <InputFile OnChange="HandleHeroImageUpload" accept="image/*" class="upload-input" />
                        <div class="upload-prompt">
                            <i class="bi bi-cloud-upload fs-4 mb-1"></i>
                            <span>@(string.IsNullOrWhiteSpace(HeroImageDataUri) && string.IsNullOrWhiteSpace(HeroImageUrl) ? "Upload hero image" : "Replace hero image")</span>
                            <small class="text-secondary">PNG, JPG, WebP · max 5 MB · drag &amp; drop or click</small>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(HeroUploadError))
                    {
                        <div class="text-danger small mb-1">@HeroUploadError</div>
                    }
                    <label class="form-label fw-semibold small mt-1">Hero Image URL <span class="text-secondary fw-normal">(optional — overrides upload)</span></label>
                    <input class="form-control" @bind="HeroImageUrl" placeholder="https://..." />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">Hero Image Alt Text</label>
                    <input class="form-control" @bind="HeroImageAltText" placeholder="Descriptive alt text" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">Hero Image Caption</label>
                    <input class="form-control" @bind="HeroImageCaption" placeholder="Optional caption" />
                </div>
            </div>
        </div>
    </div>

    <!-- Body editor + live preview -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3">
            <span class="fw-semibold">Article Body</span>
        </div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-xl-6">
                    <label class="form-label fw-semibold small">Markdown</label>
                    <textarea class="form-control article-body-editor font-monospace"
                              @bind="BodyMarkdown" @bind:event="oninput"
                              placeholder="Write your article in Markdown..."></textarea>
                </div>
                <div class="col-xl-6">
                    <label class="form-label fw-semibold small">Preview</label>
                    <div class="article-preview surface-panel">
                        @((MarkupString)RenderedBodyHtml)
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Action bar -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex flex-wrap gap-2">
            <button class="btn btn-outline-primary d-inline-flex align-items-center"
                    @onclick="SaveDraft" disabled="@IsBusy" title="Save Draft">
                <i class="bi bi-floppy-fill"></i>
            </button>
            @if (CurrentArticle.Status == ArticleStatuses.Draft)
            {
                <button class="btn btn-success d-inline-flex align-items-center"
                        @onclick="SaveAndPublish" disabled="@IsBusy" title="Save &amp; Publish">
                    <i class="bi bi-send-check-fill"></i>
                </button>
            }
            else
            {
                <button class="btn btn-outline-secondary d-inline-flex align-items-center"
                        @onclick="Unpublish" disabled="@IsBusy" title="Unpublish">
                    <i class="bi bi-arrow-down-circle-fill"></i>
                </button>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid ArticleId { get; set; }

    private Article? CurrentArticle { get; set; }
    private bool IsBusy { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;

    // Form fields
    private string Title { get; set; } = string.Empty;
    private string Slug { get; set; } = string.Empty;
    private string? Topic { get; set; }
    private string Author { get; set; } = "Grant Watson";
    private string PrimaryKeyword { get; set; } = string.Empty;
    private string SecondaryKeywords { get; set; } = string.Empty;
    private string MetaDescription { get; set; } = string.Empty;
    private string EstimatedReadingTime { get; set; } = string.Empty;
    private string? HeroImageUrl { get; set; }
    private string? HeroImageDataUri { get; set; }
    private string HeroImageAltText { get; set; } = string.Empty;
    private string HeroImageCaption { get; set; } = string.Empty;
    private string HeroUploadError { get; set; } = string.Empty;
    private string BodyMarkdown { get; set; } = string.Empty;
    private bool SlugManuallyEdited { get; set; }

    private static readonly MarkdownPipeline Pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private string RenderedBodyHtml => string.IsNullOrWhiteSpace(BodyMarkdown)
        ? "<p class=\"text-secondary mb-0\">Nothing to preview yet.</p>"
        : Markdown.ToHtml(BodyMarkdown, Pipeline);

    protected override async Task OnParametersSetAsync()
    {
        await LoadArticle();
    }

    private async Task LoadArticle()
    {
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;
        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            CurrentArticle = await db.Articles.FindAsync(ArticleId);
            if (CurrentArticle is null)
            {
                ErrorMessage = "Article not found.";
                return;
            }
            PopulateForm(CurrentArticle);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load article {Id}.", ArticleId);
            ErrorMessage = $"Unable to load article. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void PopulateForm(Article a)
    {
        Title                = a.Title;
        Slug                 = a.Slug;
        Topic                = a.Topic;
        Author               = a.Author;
        PrimaryKeyword       = a.PrimaryKeyword;
        SecondaryKeywords    = a.SecondaryKeywords;
        MetaDescription      = a.MetaDescription;
        EstimatedReadingTime = a.EstimatedReadingTime;
        HeroImageUrl         = a.HeroImageUrl;
        HeroImageDataUri     = a.HeroImageDataUri;
        HeroImageAltText     = a.HeroImageAltText;
        HeroImageCaption     = a.HeroImageCaption;
        BodyMarkdown         = a.BodyMarkdown;
        SlugManuallyEdited   = false;
    }

    private void OnTitleInput(ChangeEventArgs e)
    {
        Title = e.Value?.ToString() ?? string.Empty;
        if (!SlugManuallyEdited)
        {
            Slug = ToSlug(Title);
        }
    }

    private void OnSlugInput(ChangeEventArgs e)
    {
        Slug = e.Value?.ToString() ?? string.Empty;
        SlugManuallyEdited = true;
    }

    private async Task SaveDraft()
    {
        await PersistArticle(publish: false);
    }

    private async Task SaveAndPublish()
    {
        await PersistArticle(publish: true);
    }

    private async Task Unpublish()
    {
        if (CurrentArticle is null) return;
        ErrorMessage = string.Empty;
        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var article = await db.Articles.FindAsync(CurrentArticle.Id);
            if (article is null) { ErrorMessage = "Article not found."; return; }

            article.Status    = ArticleStatuses.Draft;
            article.UpdatedAt = DateTimeOffset.UtcNow;
            article.UpdatedBy = "manual-editor";
            await db.SaveChangesAsync();

            CurrentArticle = article;
            StatusMessage = "Article unpublished and moved back to Draft.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to unpublish article {Id}.", ArticleId);
            ErrorMessage = $"Unable to unpublish. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task HandleHeroImageUpload(InputFileChangeEventArgs e)
    {
        HeroUploadError = string.Empty;
        const long maxBytes = 5 * 1024 * 1024;

        if (e.File.Size > maxBytes)
        {
            HeroUploadError = "Image must be under 5 MB.";
            return;
        }

        IsBusy = true;
        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: maxBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            HeroImageDataUri = $"data:{e.File.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
            if (string.IsNullOrWhiteSpace(HeroImageAltText))
                HeroImageAltText = Title;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Hero image upload failed.");
            HeroUploadError = $"Upload failed. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
            StateHasChanged();
        }
    }

    private async Task PersistArticle(bool publish)
    {
        if (CurrentArticle is null) return;
        if (string.IsNullOrWhiteSpace(Title))
        {
            ErrorMessage = "Title is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(Slug))
        {
            ErrorMessage = "Slug is required.";
            return;
        }

        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;
        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var article = await db.Articles.FindAsync(CurrentArticle.Id);
            if (article is null) { ErrorMessage = "Article not found."; return; }

            article.Title             = Title.Trim();
            article.Slug              = Slug.Trim();
            article.Topic             = string.IsNullOrWhiteSpace(Topic) ? null : Topic.Trim();
            article.Author            = string.IsNullOrWhiteSpace(Author) ? "Grant Watson" : Author.Trim();
            article.PrimaryKeyword    = PrimaryKeyword.Trim();
            article.SecondaryKeywords = SecondaryKeywords.Trim();
            article.MetaDescription   = MetaDescription.Trim();
            article.EstimatedReadingTime = EstimatedReadingTime.Trim();
            article.HeroImageUrl      = string.IsNullOrWhiteSpace(HeroImageUrl) ? null : HeroImageUrl.Trim();
            article.HeroImageDataUri  = HeroImageDataUri ?? string.Empty;
            article.HeroImageAltText  = HeroImageAltText.Trim();
            article.HeroImageCaption  = HeroImageCaption.Trim();
            article.BodyMarkdown      = BodyMarkdown;
            article.UpdatedAt         = DateTimeOffset.UtcNow;
            article.UpdatedBy         = "manual-editor";

            if (publish)
            {
                article.Status      = ArticleStatuses.Published;
                article.PublishedAt ??= DateTimeOffset.UtcNow;
            }

            await db.SaveChangesAsync();
            CurrentArticle = article;
            StatusMessage = publish
                ? $"Article published and live at /blog/{article.Slug}."
                : "Draft saved.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save article {Id}.", ArticleId);
            ErrorMessage = $"Unable to save. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void BackToList()
    {
        Navigation.NavigateTo("/admin/article-editor");
    }

    private static string ToSlug(string title)
    {
        var s = title.ToLowerInvariant().Trim();
        s = Regex.Replace(s, @"[^a-z0-9\s-]", string.Empty);
        s = Regex.Replace(s, @"\s+", "-");
        return s.Trim('-');
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        ArticleStatuses.Published => "text-bg-success",
        ArticleStatuses.Draft     => "text-bg-warning",
        _                         => "text-bg-secondary"
    };

    private static string FormatSource(string source) => source switch
    {
        ArticleSource.Manual          => "Manual",
        ArticleSource.OllamaGenerated => "Ollama",
        _                             => source
    };

    private static string FormatDate(DateTimeOffset value) =>
        value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
}

<style>
    .article-body-editor {
        min-height: 480px;
        resize: vertical;
        font-size: 0.85rem;
        line-height: 1.6;
    }

    .article-preview {
        min-height: 480px;
        padding: 1rem 1.25rem;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        overflow-y: auto;
        font-size: 0.9rem;
        line-height: 1.7;
    }

    .surface-panel {
        background: #f8fafc;
    }

    .hero-preview-image {
        display: block;
        width: 100%;
        max-height: 220px;
        object-fit: cover;
        border-radius: 10px;
        border: 1px solid #dbe6f3;
    }

    .upload-drop-zone {
        position: relative;
        border: 2px dashed #93c5fd;
        border-radius: 10px;
        background: #f0f7ff;
        padding: 1.5rem 1rem;
        text-align: center;
        transition: border-color 0.15s, background 0.15s;
        cursor: pointer;
    }

    .upload-drop-zone:hover {
        border-color: #3b82f6;
        background: #e0effe;
    }

    .upload-input {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;
    }

    .upload-prompt {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
        pointer-events: none;
        color: #3b82f6;
    }
</style>
