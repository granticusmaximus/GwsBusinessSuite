@page "/admin/article-editor/{ArticleId:guid}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "ContentAccess")]
@implements IAsyncDisposable
@using Microsoft.AspNetCore.Authorization
@using GwsBusinessSuite.Application.AffiliateSuggestions
@using GwsBusinessSuite.Application.Articles
@using GwsBusinessSuite.Application.ContentStudio
@using GwsBusinessSuite.Application.Settings
@using GwsBusinessSuite.Domain.Entities
@using GwsBusinessSuite.Infrastructure.Data
@using Markdig
@using Microsoft.EntityFrameworkCore
@using System.Text.RegularExpressions
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISiteSettingsService SiteSettingsService
@inject IContentStudioService ContentStudioService
@inject IAffiliateSuggestionService AffiliateSuggestionService
@inject NavigationManager Navigation
@inject ILogger<ArticleEditorDetail> Logger
@inject IJSRuntime JS

<PageTitle>@(CurrentArticle?.Title ?? "Article Editor")</PageTitle>

<div class="page-header d-flex align-items-start justify-content-between gap-3">
    <div>
        <h1><i class="bi bi-pencil me-2 text-primary"></i>@(CurrentArticle?.Title ?? "Article")</h1>
        @if (CurrentArticle is not null)
        {
            <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
                <span class="badge @GetStatusBadgeClass(CurrentArticle.Status)">@CurrentArticle.Status</span>
                <span class="badge text-bg-light">@FormatSource(CurrentArticle.Source)</span>
                @if (CurrentArticle.PublishedAt.HasValue)
                {
                    <span class="small text-secondary">@(IsScheduledArticle(CurrentArticle) ? "Scheduled" : "Published") @FormatDate(CurrentArticle.PublishedAt.Value)</span>
                }
                @if (CurrentArticle.SourceDraftId.HasValue)
                {
                    <a href="/admin/content-studio/draft/@CurrentArticle.SourceDraftId" class="small">
                        <i class="bi bi-box-arrow-up-right me-1"></i>View AI Draft
                    </a>
                    <button class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"
                            @onclick="ToggleReviseWithAiPanel" disabled="@IsBusy">
                        <i class="bi bi-magic"></i>
                        <span>Revise with AI</span>
                    </button>
                }
            </div>
        }
    </div>
    <button class="btn btn-outline-secondary d-inline-flex align-items-center" @onclick="BackToList" title="All Articles">
        <i class="bi bi-arrow-left-circle-fill"></i>
    </button>
</div>

@if (ShowReviseWithAiPanel && CurrentArticle is not null)
{
    <div class="card border-0 shadow-sm mb-4 border-start border-primary border-3">
        <div class="card-header bg-white border-bottom py-3">
            <span class="fw-semibold"><i class="bi bi-magic me-1 text-primary"></i>Revise with AI</span>
            <div class="small text-secondary">Ollama regenerates the article from your notes, then republishes it live in place.</div>
        </div>
        <div class="card-body">
            <label class="form-label fw-semibold small">Revision notes</label>
            <textarea class="form-control mb-3" rows="3" @bind="ReviseWithAiNotes" @bind:event="oninput"
                      placeholder="e.g. Make the introduction shorter and add a section on error handling."></textarea>
            @if (!string.IsNullOrWhiteSpace(ReviseWithAiError))
            {
                <div class="alert alert-danger py-2 small mb-3">@ReviseWithAiError</div>
            }
            <div class="d-flex gap-2">
                <button class="btn btn-primary" @onclick="ReviseWithAiAsync" disabled="@(IsBusy || string.IsNullOrWhiteSpace(ReviseWithAiNotes))">
                    @if (IsBusy)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        <span>Regenerating…</span>
                    }
                    else
                    {
                        <span>Regenerate &amp; Republish</span>
                    }
                </button>
                <button class="btn btn-outline-secondary" @onclick="ToggleReviseWithAiPanel" disabled="@IsBusy">Cancel</button>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger d-flex align-items-start gap-2 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
        <div>@ErrorMessage</div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-info d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <div>@StatusMessage</div>
    </div>
}

@if (CurrentArticle is null)
{
    <div class="card border-0 shadow-sm"><div class="card-body"><p class="text-secondary mb-0">Article not found.</p></div></div>
}
else
{
    <!-- Metadata card -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3">
            <span class="fw-semibold">Metadata</span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold small">Title</label>
                    <input class="form-control" value="@Title"
                           @oninput="OnTitleInput" placeholder="Article title" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold small">Author</label>
                    <input class="form-control" @bind="Author" placeholder="Grant Watson" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">
                        Slug
                        @if (!SlugManuallyEdited)
                        {
                            <span class="text-secondary small fw-normal ms-1">(auto)</span>
                        }
                    </label>
                    <input class="form-control font-monospace" value="@Slug"
                           @oninput="OnSlugInput" placeholder="url-friendly-slug" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">Topic</label>
                    <input class="form-control" @bind="Topic" placeholder="e.g. ASP.NET Core, Blazor" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">Primary Keyword</label>
                    <input class="form-control" @bind="PrimaryKeyword" placeholder="e.g. blazor server tutorial" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">Secondary Keywords</label>
                    <input class="form-control" @bind="SecondaryKeywords" placeholder="comma-separated" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">Category</label>
                    <select class="form-select" @bind="CategoryId">
                        <option value="">Uncategorized</option>
                        @foreach (var cat in Categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">Tags</label>
                    <input class="form-control" @bind="Tags" placeholder="comma-separated, e.g. dotnet, blazor, tutorial" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold small">Meta Description</label>
                    <textarea class="form-control" rows="2" @bind="MetaDescription"
                              placeholder="Short description for search engine results (150–160 chars)"></textarea>
                    <div class="form-text">@MetaDescription.Length / 160 characters</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold small">Estimated Reading Time</label>
                    <input class="form-control" @bind="EstimatedReadingTime" placeholder="e.g. 6 min read" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold small">Publish At</label>
                    <input class="form-control" type="datetime-local" value="@PublishedAtInput" @onchange="OnPublishedAtChanged" />
                    <div class="form-text">Future dates keep the article scheduled until that time.</div>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold small">Hero Image</label>
                    @if (!string.IsNullOrWhiteSpace(HeroImageDataUri))
                    {
                        <img class="hero-preview-image mb-2" src="@HeroImageDataUri" alt="@HeroImageAltText" />
                    }
                    else if (!string.IsNullOrWhiteSpace(HeroImageUrl))
                    {
                        <img class="hero-preview-image mb-2" src="@HeroImageUrl" alt="@HeroImageAltText" />
                    }
                    <div class="upload-drop-zone mb-2">
                        <InputFile OnChange="HandleHeroImageUpload" accept="image/*" class="upload-input" />
                        <div class="upload-prompt">
                            <i class="bi bi-cloud-upload fs-4 mb-1"></i>
                            <span>@(string.IsNullOrWhiteSpace(HeroImageDataUri) && string.IsNullOrWhiteSpace(HeroImageUrl) ? "Upload hero image" : "Replace hero image")</span>
                            <small class="text-secondary">PNG, JPG, WebP · max @MaxUploadSizeMb MB · drag &amp; drop or click</small>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(HeroUploadError))
                    {
                        <div class="text-danger small mb-1">@HeroUploadError</div>
                    }
                    <label class="form-label fw-semibold small mt-1">Hero Image URL <span class="text-secondary fw-normal">(optional — overrides upload)</span></label>
                    <input class="form-control" @bind="HeroImageUrl" placeholder="https://..." />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">Hero Image Alt Text</label>
                    <input class="form-control" @bind="HeroImageAltText" placeholder="Descriptive alt text" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold small">Hero Image Caption</label>
                    <input class="form-control" @bind="HeroImageCaption" placeholder="Optional caption" />
                </div>
            </div>
        </div>
    </div>

    <!-- Body editor + live preview -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3">
            <span class="fw-semibold">Article Body</span>
        </div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-xl-6">
                    <label class="form-label fw-semibold small">Markdown</label>
                    <textarea id="article-body-textarea">@BodyMarkdown</textarea>
                </div>
                <div class="col-xl-6">
                    <label class="form-label fw-semibold small">Preview</label>
                    <div class="article-preview surface-panel">
                        @((MarkupString)RenderedBodyHtml)
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- CJ ad placements -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between">
            <span class="fw-semibold">CJ Ad Placements</span>
            <button class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"
                    @onclick="() => OpenPlacementModal(null)" disabled="@IsBusy">
                <i class="bi bi-plus-circle"></i>
                <span>Add Ad Placement</span>
            </button>
        </div>
        <div class="card-body">
            @if (Placements.Count == 0)
            {
                <p class="text-secondary mb-0">No ads placed in this article yet. Add one, then use "Insert at Cursor"
                    to drop its token into the markdown wherever you want it to appear.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Advertiser</th>
                                <th>CTA Text</th>
                                <th>Slot Token</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var placement in Placements)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@placement.AdvertiserName</div>
                                        <div class="small text-secondary">@placement.Category</div>
                                    </td>
                                    <td>@placement.CallToActionText</td>
                                    <td><code class="small">@placement.SlotToken</code></td>
                                    <td class="text-end">
                                        <div class="d-inline-flex gap-1">
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => InsertTokenAtCursor(placement.SlotToken)"
                                                    title="Insert at Cursor">
                                                <i class="bi bi-cursor-text"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => OpenPlacementModal(placement)" title="Edit">
                                                <i class="bi bi-pencil-fill"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => DeletePlacement(placement)" title="Remove">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Action bar -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex flex-wrap gap-2">
            <button class="btn btn-outline-primary d-inline-flex align-items-center"
                    @onclick="SaveDraft" disabled="@IsBusy" title="Save Draft">
                <i class="bi bi-floppy-fill"></i>
            </button>
            @if (CurrentArticle.Status == ArticleStatuses.Draft)
            {
                <button class="btn btn-success d-inline-flex align-items-center"
                        @onclick="SaveAndPublish" disabled="@IsBusy" title="Save &amp; Publish">
                    <i class="bi bi-send-check-fill"></i>
                </button>
            }
            else
            {
                <button class="btn btn-outline-secondary d-inline-flex align-items-center"
                        @onclick="Unpublish" disabled="@IsBusy" title="Unpublish">
                    <i class="bi bi-arrow-down-circle-fill"></i>
                </button>
            }
        </div>
    </div>
}

@if (ShowPlacementModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(EditingPlacementId is null ? "Add Ad Placement" : "Edit Ad Placement")</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="ClosePlacementModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Advertiser</label>
                            <select class="form-select" value="@SelectedAdvertiserId" @onchange="OnAdvertiserChanged">
                                <option value="">Select an advertiser...</option>
                                @foreach (var advertiser in AvailableAdvertisers)
                                {
                                    <option value="@advertiser.AdvertiserId">@advertiser.AdvertiserName</option>
                                }
                            </select>
                            @if (AvailableAdvertisers.Count == 0)
                            {
                                <div class="form-text text-secondary">
                                    No advertisers with offers found. Use "Import Offers" on the
                                    <a href="/admin/cj-ads">CJ Ads page</a> first.
                                </div>
                            }
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Offer</label>
                            <select class="form-select" value="@SelectedOfferId" @onchange="OnOfferChanged"
                                    disabled="@(string.IsNullOrWhiteSpace(SelectedAdvertiserId))">
                                <option value="">Select an offer...</option>
                                @foreach (var offer in AvailableOffersForSelectedAdvertiser)
                                {
                                    <option value="@offer.Id">@offer.LinkName</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Call To Action Text</label>
                            <input class="form-control" @bind="PlacementCallToActionText" placeholder="Explore Offer" />
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(PlacementMessage))
                    {
                        <div class="alert @(PlacementMessageIsError ? "alert-danger" : "alert-info") mt-3 mb-0">@PlacementMessage</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="ClosePlacementModal" disabled="@IsBusy">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SavePlacement" disabled="@IsBusy">
                        <i class="bi bi-floppy-fill me-1"></i>Save Placement
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid ArticleId { get; set; }

    private Article? CurrentArticle { get; set; }
    private bool IsBusy { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;

    // Form fields
    private string Title { get; set; } = string.Empty;
    private string Slug { get; set; } = string.Empty;
    private string? Topic { get; set; }
    private string Author { get; set; } = "Grant Watson";
    private string PrimaryKeyword { get; set; } = string.Empty;
    private string SecondaryKeywords { get; set; } = string.Empty;
    private Guid? CategoryId { get; set; }
    private string Tags { get; set; } = string.Empty;
    private List<ArticleCategory> Categories { get; set; } = new();
    private string MetaDescription { get; set; } = string.Empty;
    private string EstimatedReadingTime { get; set; } = string.Empty;
    private DateTimeOffset? PublishedAtValue { get; set; }
    private string? HeroImageUrl { get; set; }
    private string? HeroImageDataUri { get; set; }
    private string HeroImageAltText { get; set; } = string.Empty;
    private string HeroImageCaption { get; set; } = string.Empty;
    private string HeroUploadError { get; set; } = string.Empty;
    private string BodyMarkdown { get; set; } = string.Empty;
    private bool SlugManuallyEdited { get; set; }
    private int MaxUploadSizeMb { get; set; } = 8;

    // Revise with AI (Phase 12: bridges back into the Content Studio draft this
    // article was published from, so a live AI post can be regenerated without
    // hunting it down in a separate list).
    private bool ShowReviseWithAiPanel { get; set; }
    private string ReviseWithAiNotes { get; set; } = string.Empty;
    private string ReviseWithAiError { get; set; } = string.Empty;

    private const string MarkdownEditorElementId = "article-body-textarea";
    private bool _markdownEditorInitialized;
    private string? _lastSyncedMarkdown;
    private DotNetObjectReference<ArticleEditorDetail>? _markdownEditorRef;

    // CJ ad placements
    private List<ArticleAffiliatePlacement> Placements { get; set; } = new();
    private bool ShowPlacementModal { get; set; }
    private Guid? EditingPlacementId { get; set; }
    private List<AffiliateOffer> AllOffers { get; set; } = new();
    private string SelectedAdvertiserId { get; set; } = string.Empty;
    private string SelectedOfferId { get; set; } = string.Empty;
    private string PlacementCallToActionText { get; set; } = "Explore Offer";
    private string PlacementMessage { get; set; } = string.Empty;
    private bool PlacementMessageIsError { get; set; }

    private List<AffiliateOffer> AvailableAdvertisers =>
        AllOffers
            .GroupBy(x => new { x.AdvertiserId, x.AdvertiserName }, (key, group) => group.First())
            .OrderBy(x => x.AdvertiserName)
            .ToList();

    private List<AffiliateOffer> AvailableOffersForSelectedAdvertiser =>
        string.IsNullOrWhiteSpace(SelectedAdvertiserId)
            ? new List<AffiliateOffer>()
            : AllOffers.Where(x => x.AdvertiserId == SelectedAdvertiserId).OrderBy(x => x.LinkName).ToList();

    private static readonly MarkdownPipeline Pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private string RenderedBodyHtml
    {
        get
        {
            if (string.IsNullOrWhiteSpace(BodyMarkdown))
            {
                return "<p class=\"text-secondary mb-0\">Nothing to preview yet.</p>";
            }

            var resolvedMarkdown = ArticleMarkdownRenderer.Render(BodyMarkdown, Placements);
            return Markdown.ToHtml(resolvedMarkdown, Pipeline);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        var settings = await SiteSettingsService.GetSettingsAsync();
        MaxUploadSizeMb = settings.MaxMediaUploadSizeMb;
        await LoadArticle();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (CurrentArticle is null)
        {
            return;
        }

        if (!_markdownEditorInitialized)
        {
            _markdownEditorRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("gwsMarkdownEditor.init", MarkdownEditorElementId, _markdownEditorRef);
            _markdownEditorInitialized = true;
            _lastSyncedMarkdown = BodyMarkdown;
        }
        else if (!string.Equals(BodyMarkdown, _lastSyncedMarkdown, StringComparison.Ordinal))
        {
            await JS.InvokeVoidAsync("gwsMarkdownEditor.setValue", MarkdownEditorElementId, BodyMarkdown);
            _lastSyncedMarkdown = BodyMarkdown;
        }
    }

    [JSInvokable]
    public async Task OnMarkdownChanged(string value)
    {
        BodyMarkdown = value;
        _lastSyncedMarkdown = value;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadArticle()
    {
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;
        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            CurrentArticle = await db.Articles.FindAsync(ArticleId);
            if (CurrentArticle is null)
            {
                ErrorMessage = "Article not found.";
                return;
            }
            PopulateForm(CurrentArticle);

            Categories = await db.ArticleCategories.OrderBy(c => c.Name).ToListAsync();

            Placements = await db.ArticleAffiliatePlacements
                .Where(x => x.ArticleId == ArticleId)
                .OrderBy(x => x.SortOrder)
                .ToListAsync();

            AllOffers = await db.AffiliateOffers
                .Where(x => x.Network == "CJ" && x.TrackingUrl != null && x.TrackingUrl != "")
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load article {Id}.", ArticleId);
            ErrorMessage = $"Unable to load article. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void PopulateForm(Article a)
    {
        Title                = a.Title;
        Slug                 = a.Slug;
        Topic                = a.Topic;
        Author               = a.Author;
        PrimaryKeyword       = a.PrimaryKeyword;
        SecondaryKeywords    = a.SecondaryKeywords;
        CategoryId           = a.CategoryId;
        Tags                 = a.Tags;
        MetaDescription      = a.MetaDescription;
        EstimatedReadingTime = a.EstimatedReadingTime;
        PublishedAtValue     = a.PublishedAt;
        HeroImageUrl         = a.HeroImageUrl;
        HeroImageDataUri     = a.HeroImageDataUri;
        HeroImageAltText     = a.HeroImageAltText;
        HeroImageCaption     = a.HeroImageCaption;
        BodyMarkdown         = a.BodyMarkdown;
        SlugManuallyEdited   = false;
    }

    private void OnTitleInput(ChangeEventArgs e)
    {
        Title = e.Value?.ToString() ?? string.Empty;
        if (!SlugManuallyEdited)
        {
            Slug = ToSlug(Title);
        }
    }

    private void OnSlugInput(ChangeEventArgs e)
    {
        Slug = e.Value?.ToString() ?? string.Empty;
        SlugManuallyEdited = true;
    }

    private async Task SaveDraft()
    {
        await PersistArticle(publish: false);
    }

    private async Task SaveAndPublish()
    {
        await PersistArticle(publish: true);
    }

    private async Task Unpublish()
    {
        if (CurrentArticle is null) return;
        ErrorMessage = string.Empty;
        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var article = await db.Articles.FindAsync(CurrentArticle.Id);
            if (article is null) { ErrorMessage = "Article not found."; return; }

            article.Status    = ArticleStatuses.Draft;
            article.UpdatedAt = DateTimeOffset.UtcNow;
            article.UpdatedBy = "manual-editor";
            await db.SaveChangesAsync();

            CurrentArticle = article;
            StatusMessage = "Article unpublished and moved back to Draft.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to unpublish article {Id}.", ArticleId);
            ErrorMessage = $"Unable to unpublish. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task HandleHeroImageUpload(InputFileChangeEventArgs e)
    {
        HeroUploadError = string.Empty;
        var maxBytes = MaxUploadSizeMb * 1024L * 1024L;

        if (e.File.Size > maxBytes)
        {
            HeroUploadError = $"Image must be under {MaxUploadSizeMb} MB.";
            return;
        }

        IsBusy = true;
        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: maxBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            HeroImageDataUri = $"data:{e.File.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
            if (string.IsNullOrWhiteSpace(HeroImageAltText))
                HeroImageAltText = Title;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Hero image upload failed.");
            HeroUploadError = $"Upload failed. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
            StateHasChanged();
        }
    }

    private async Task PersistArticle(bool publish)
    {
        if (CurrentArticle is null) return;
        if (string.IsNullOrWhiteSpace(Title))
        {
            ErrorMessage = "Title is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(Slug))
        {
            ErrorMessage = "Slug is required.";
            return;
        }

        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;
        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var article = await db.Articles.FindAsync(CurrentArticle.Id);
            if (article is null) { ErrorMessage = "Article not found."; return; }

            article.Title             = Title.Trim();
            article.Slug              = Slug.Trim();
            article.Topic             = string.IsNullOrWhiteSpace(Topic) ? null : Topic.Trim();
            article.Author            = string.IsNullOrWhiteSpace(Author) ? "Grant Watson" : Author.Trim();
            article.PrimaryKeyword    = PrimaryKeyword.Trim();
            article.SecondaryKeywords = SecondaryKeywords.Trim();
            article.CategoryId        = CategoryId;
            article.Tags              = Tags.Trim();
            article.MetaDescription   = MetaDescription.Trim();
            article.EstimatedReadingTime = EstimatedReadingTime.Trim();
            if (PublishedAtValue.HasValue)
            {
                article.PublishedAt = PublishedAtValue.Value;
            }
            article.HeroImageUrl      = string.IsNullOrWhiteSpace(HeroImageUrl) ? null : HeroImageUrl.Trim();
            article.HeroImageDataUri  = HeroImageDataUri ?? string.Empty;
            article.HeroImageAltText  = HeroImageAltText.Trim();
            article.HeroImageCaption  = HeroImageCaption.Trim();
            article.BodyMarkdown      = BodyMarkdown;
            article.UpdatedAt         = DateTimeOffset.UtcNow;
            article.UpdatedBy         = "manual-editor";

            if (publish)
            {
                article.Status      = ArticleStatuses.Published;
                if (article.PublishedAt is null || article.PublishedAt > DateTimeOffset.UtcNow)
                {
                    article.PublishedAt = DateTimeOffset.UtcNow;
                }
            }

            await db.SaveChangesAsync();
            CurrentArticle = article;
            StatusMessage = publish
                ? $"Article published and live at /blog/{article.Slug}."
                : "Draft saved.";

            if (publish)
            {
                // Best-effort: a failed AI match shouldn't undo a successful publish. Review
                // and apply happens on the Affiliate Suggestions page, not here.
                try
                {
                    await AffiliateSuggestionService.GenerateForArticleAsync(article.Id);
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Affiliate suggestion generation failed for newly published article {Id}.", article.Id);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save article {Id}.", ArticleId);
            ErrorMessage = $"Unable to save. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

