@page "/admin/crm"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "AdminOnly")]
@using GwsBusinessSuite.Application.Crm
@using GwsBusinessSuite.Domain.Entities
@inject ICrmService CrmService
@inject IJSRuntime JS
@inject ILogger<Crm> Logger

<PageTitle>CRM</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-people-fill me-2 text-primary"></i>CRM</h1>
    <p>Track leads and contacts with local SQLite persistence.</p>
</div>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger d-flex align-items-start gap-2 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
        <div>@ErrorMessage</div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-info d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <div>@StatusMessage</div>
    </div>
}

@if (DueFollowUps.Count > 0)
{
    <div class="alert alert-warning d-flex align-items-start gap-2 mb-4" role="alert">
        <i class="bi bi-alarm-fill mt-1 flex-shrink-0"></i>
        <div>
            <div class="fw-semibold">@DueFollowUps.Count follow-up(s) due</div>
            <ul class="mb-0 mt-1 ps-3">
                @foreach (var contact in DueFollowUps)
                {
                    <li>
                        <button type="button" class="btn btn-link p-0 align-baseline" @onclick="() => OpenContactAsync(contact.Id)">@contact.FullName</button>
                        &mdash; due @contact.FollowUpDate?.ToLocalTime().ToString("MMM d, yyyy")
                    </li>
                }
            </ul>
        </div>
    </div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div
                class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between gap-2">
                <span class="fw-semibold">@(ShowTrash ? "Trash" : "Contacts")</span>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm @(ShowTrash ? "btn-secondary" : "btn-outline-secondary")" @onclick="ToggleTrashViewAsync" disabled="@IsBusy">
                        <i class="bi bi-trash3 me-1"></i>Trash@(TrashedContacts.Count > 0 ? $" ({TrashedContacts.Count})" : "")
                    </button>
                    @if (!ShowTrash)
                    {
                        <button class="btn btn-sm btn-outline-primary" @onclick="CreateNewContact" disabled="@IsBusy">
                            <i class="bi bi-plus-lg me-1"></i>New Contact
                        </button>
                    }
                </div>
            </div>
            <div class="card-body p-0">
                @if (ShowTrash)
                {
                    @if (TrashedContacts.Count == 0)
                    {
                        <div class="p-4 text-secondary">
                            <p class="mb-0">Trash is empty.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var contact in TrashedContacts)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <div class="fw-semibold">@contact.FullName</div>
                                            <div class="small text-secondary">trashed @contact.TrashedAt?.ToLocalTime().ToString("g")</div>
                                        </div>
                                        <div class="d-flex gap-1 flex-shrink-0">
                                            <button class="btn btn-xs btn-outline-primary" @onclick="() => RestoreContactAsync(contact.Id)" disabled="@IsBusy">Restore</button>
                                            <button class="btn btn-xs btn-outline-danger" @onclick="() => DeletePermanentlyAsync(contact.Id)" disabled="@IsBusy">Delete Permanently</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="p-2 border-bottom d-flex gap-2">
                        <input type="search" class="form-control form-control-sm" placeholder="Search name, email, company..."
                               value="@SearchText" @oninput="e => SearchText = e.Value?.ToString() ?? string.Empty" />
                        <select class="form-select form-select-sm" style="max-width:9rem;" value="@StatusFilter"
                                @onchange="OnStatusFilterChange">
                            <option value="All">All statuses</option>
                            @foreach (var option in ContactStatuses.All)
                            {
                                <option value="@option">@option</option>
                            }
                        </select>
                    </div>
                    @if (VisibleContacts.Count == 0)
                    {
                        <div class="p-4 text-secondary">
                            <p class="mb-0">@(Contacts.Count == 0 ? "No contacts yet. Add your first lead or customer to get started." : "No contacts match your search.")</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var contact in VisibleContacts)
                            {
                                <button type="button"
                                        class="list-group-item list-group-item-action d-flex justify-content-between align-items-start gap-2 @(SelectedContactId == contact.Id ? "active" : string.Empty)"
                                        @onclick="() => OpenContactAsync(contact.Id)" disabled="@IsBusy">
                                    <div>
                                        <div class="fw-semibold">@contact.FullName</div>
                                        <div class="small @(SelectedContactId == contact.Id ? "text-white-50" : "text-secondary")">
                                            @(!string.IsNullOrWhiteSpace(contact.Company) ? contact.Company : "No company")
                                        </div>
                                    </div>
                                    <span class="badge @(SelectedContactId == contact.Id ? "text-bg-light" : "text-bg-secondary")">
                                        @contact.Status
                                    </span>
                                </button>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">
            <div
                class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between gap-2">
                <span class="fw-semibold">@EditorHeader</span>
                <span class="badge @(SelectedContactId.HasValue ? "text-bg-primary" : "text-bg-secondary")">
                    @(SelectedContactId.HasValue ? "Editing Existing Contact" : "New Contact")
                </span>
            </div>
            <div class="card-body">
                <EditForm Model="Editor" OnValidSubmit="SaveContactAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Full Name</label>
                            <InputText class="form-control" @bind-Value="Editor.FullName" placeholder="Contact name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Status</label>
                            <InputSelect class="form-select" @bind-Value="Editor.Status">
                                @foreach (var option in ContactStatuses.All)
                                {
                                    <option value="@option">@option</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Email</label>
                            <InputText class="form-control" @bind-Value="Editor.Email" placeholder="name@example.com" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Company</label>
                            <InputText class="form-control" @bind-Value="Editor.Company" placeholder="Company name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Follow-up Date <span class="text-muted">(optional)</span></label>
                            <InputDate class="form-control" @bind-Value="Editor.FollowUpDate" />
                        </div>
                    </div>

                    <div class="mt-3 d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@IsBusy">
                            <i class="bi bi-floppy-fill me-1"></i>Save Contact
                        </button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="CreateNewContact"
                                disabled="@IsBusy">
                            Reset
                        </button>
                        <button type="button" class="btn btn-outline-danger" @onclick="TrashSelectedContactAsync"
                                disabled="@(IsBusy || !SelectedContactId.HasValue)">
                            Move to Trash
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>

        @if (SelectedContactId.HasValue)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <span class="fw-semibold">Notes &amp; Activity</span>
                </div>
                <div class="card-body">
                    <div class="d-flex gap-2 mb-3">
                        <input class="form-control" placeholder="Log a call, email, or note..."
                               value="@NewActivityNote" @oninput="e => NewActivityNote = e.Value?.ToString() ?? string.Empty"
                               @onkeydown="OnActivityNoteKeyDown" />
                        <button class="btn btn-outline-primary flex-shrink-0" @onclick="AddActivityAsync" disabled="@(IsBusy || string.IsNullOrWhiteSpace(NewActivityNote))">
                            <i class="bi bi-plus-lg me-1"></i>Log
                        </button>
                    </div>
                    @if (Activities.Count == 0)
                    {
                        <p class="text-secondary mb-0">No activity logged yet.</p>
                    }
                    else
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var activity in Activities)
                            {
                                <li class="mb-2 pb-2 border-bottom">
                                    <div>@activity.Note</div>
                                    <div class="small text-secondary">@activity.CreatedBy &middot; @activity.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<Contact> Contacts { get; set; } = new();
    private List<Contact> TrashedContacts { get; set; } = new();
    private List<Contact> DueFollowUps { get; set; } = new();
    private List<ContactActivityView> Activities { get; set; } = new();
    private ContactEditorModel Editor { get; set; } = new();
    private Guid? SelectedContactId { get; set; }
    private bool ShowTrash { get; set; }
    private bool IsBusy { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;
    private string SearchText { get; set; } = string.Empty;
    private string StatusFilter { get; set; } = "All";
    private string NewActivityNote { get; set; } = string.Empty;

    private string EditorHeader => SelectedContactId.HasValue ? "Edit Contact" : "Create Contact";

    private void OnStatusFilterChange(ChangeEventArgs e) => StatusFilter = e.Value?.ToString() ?? "All";

    private List<Contact> VisibleContacts
    {
        get
        {
            IEnumerable<Contact> query = Contacts;
            if (StatusFilter != "All")
            {
                query = query.Where(c => c.Status == StatusFilter);
            }

            if (!string.IsNullOrWhiteSpace(SearchText))
            {
                query = query.Where(c =>
                    c.FullName.Contains(SearchText, StringComparison.OrdinalIgnoreCase)
                    || (c.Email ?? string.Empty).Contains(SearchText, StringComparison.OrdinalIgnoreCase)
                    || (c.Company ?? string.Empty).Contains(SearchText, StringComparison.OrdinalIgnoreCase));
            }

            return query.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        try
        {
            var dashboard = await CrmService.GetDashboardAsync();
            Contacts = dashboard.Contacts.ToList();
            DueFollowUps = dashboard.DueFollowUps.ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load CRM dashboard.");
            ErrorMessage = $"Unable to load contacts. {ex.Message}";
        }
    }

    private async Task ToggleTrashViewAsync()
    {
        ShowTrash = !ShowTrash;
        if (ShowTrash)
        {
            IsBusy = true;
            try
            {
                TrashedContacts = (await CrmService.ListTrashedContactsAsync()).ToList();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Unable to load trashed CRM contacts.");
                ErrorMessage = $"Unable to load Trash. {ex.Message}";
            }
            finally
            {
                IsBusy = false;
            }
        }
    }

    private void CreateNewContact()
    {
        SelectedContactId = null;
        Editor = new ContactEditorModel();
        Activities = new();
        NewActivityNote = string.Empty;
        StatusMessage = "Ready to create a new contact.";
        ErrorMessage = string.Empty;
    }

    private async Task OpenContactAsync(Guid contactId)
    {
        try
        {
            var contact = await CrmService.GetContactAsync(contactId);
            if (contact is null)
            {
                StatusMessage = "The selected contact no longer exists.";
                return;
            }

            SelectedContactId = contact.Id;
            Editor = new ContactEditorModel
            {
                ContactId = contact.Id,
                FullName = contact.FullName,
                Email = contact.Email,
                Company = contact.Company,
                Status = contact.Status,
                FollowUpDate = contact.FollowUpDate
            };
            StatusMessage = $"Opened contact '{contact.FullName}'.";
            ErrorMessage = string.Empty;
            NewActivityNote = string.Empty;
            Activities = (await CrmService.ListActivitiesAsync(contactId)).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to open CRM contact {ContactId}.", contactId);
            ErrorMessage = $"Unable to open contact. {ex.Message}";
        }
    }

    private async Task SaveContactAsync()
    {
        // Guards against a double-click/double-submit creating duplicate contacts -
        // disabled="@IsBusy" on the submit button re-renders asynchronously, so it alone
        // doesn't close the window between two rapid clicks.
        if (IsBusy) return;

        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            var saved = await CrmService.SaveContactAsync(Editor);
            SelectedContactId = saved.Id;
            Editor = new ContactEditorModel
            {
                ContactId = saved.Id,
                FullName = saved.FullName,
                Email = saved.Email,
                Company = saved.Company,
                Status = saved.Status,
                FollowUpDate = saved.FollowUpDate
            };
            StatusMessage = $"Saved contact '{saved.FullName}'.";
            await LoadDashboardAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to save CRM contact.");
            ErrorMessage = $"Unable to save contact. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task TrashSelectedContactAsync()
    {
        if (IsBusy || SelectedContactId is not { } contactId)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Move this contact to Trash?");
        if (!confirmed) return;

        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            await CrmService.TrashContactAsync(contactId);
            StatusMessage = "Contact moved to Trash.";
            CreateNewContact();
            await LoadDashboardAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to trash CRM contact {ContactId}.", contactId);
            ErrorMessage = $"Unable to move contact to Trash. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task RestoreContactAsync(Guid contactId)
    {
        if (IsBusy) return;

        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            await CrmService.RestoreContactAsync(contactId);
            TrashedContacts = (await CrmService.ListTrashedContactsAsync()).ToList();
            await LoadDashboardAsync();
            StatusMessage = "Restored the contact from Trash.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to restore CRM contact {ContactId}.", contactId);
            ErrorMessage = $"Unable to restore contact. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task DeletePermanentlyAsync(Guid contactId)
    {
        if (IsBusy) return;

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Permanently delete this contact? This cannot be undone.");
        if (!confirmed) return;

        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            await CrmService.DeleteContactPermanentlyAsync(contactId);
            TrashedContacts = (await CrmService.ListTrashedContactsAsync()).ToList();
            StatusMessage = "Permanently deleted the contact.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to permanently delete CRM contact {ContactId}.", contactId);
            ErrorMessage = $"Unable to permanently delete contact. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task AddActivityAsync()
    {
        if (IsBusy || SelectedContactId is not { } contactId || string.IsNullOrWhiteSpace(NewActivityNote))
        {
            return;
        }

        IsBusy = true;
        ErrorMessage = string.Empty;

        try
        {
            var activity = await CrmService.AddActivityAsync(contactId, NewActivityNote);
            Activities.Insert(0, activity);
            NewActivityNote = string.Empty;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to log CRM activity for contact {ContactId}.", contactId);
            ErrorMessage = $"Unable to log activity. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task OnActivityNoteKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddActivityAsync();
        }
    }
}
