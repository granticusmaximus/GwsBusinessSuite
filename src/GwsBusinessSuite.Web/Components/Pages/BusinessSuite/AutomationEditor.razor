@page "/admin/automation/{WorkflowId:guid}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "AdminOnly")]
@implements IAsyncDisposable
@using GwsBusinessSuite.Application.Automation
@using GwsBusinessSuite.Domain.Entities
@using Microsoft.JSInterop
@inject IAutomationWorkflowService WorkflowService
@inject IAutomationExecutionService ExecutionService
@inject IAutomationNodeRegistry NodeRegistry
@inject IAutomationCredentialService CredentialService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject ILogger<AutomationEditor> Logger

<PageTitle>@(_view?.Name ?? "Workflow Editor")</PageTitle>

@if (_loading)
{
    <div class="text-secondary py-5 text-center"><span class="spinner-border spinner-border-sm me-2"></span>Opening workflow…</div>
}
else if (_view is null)
{
    <div class="alert alert-danger">Workflow not found.</div>
}
else
{
    <div class="automation-shell">
        <header class="automation-toolbar">
            <div class="d-flex align-items-center gap-2 min-w-0">
                <button class="btn btn-sm btn-light" title="Back to workflows" @onclick="Back"><i class="bi bi-arrow-left"></i></button>
                <div class="min-w-0">
                    <input class="automation-title" @bind="_name" aria-label="Workflow name" />
                    <div class="small text-secondary">Version @_view.CurrentVersion · @_view.Status</div>
                </div>
            </div>
            <div class="d-flex flex-wrap align-items-center justify-content-end gap-2">
                <button class="btn btn-sm btn-outline-secondary" @onclick="SaveMetadata" disabled="@_busy"><i class="bi bi-floppy me-1"></i>Save</button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="Validate" disabled="@_busy"><i class="bi bi-check2-circle me-1"></i>Validate</button>
                <button class="btn btn-sm btn-outline-primary" @onclick="Publish" disabled="@_busy"><i class="bi bi-cloud-arrow-up me-1"></i>Publish</button>
                <button class="btn btn-sm @(_view.Status == AutomationWorkflowStatuses.Active ? "btn-success" : "btn-outline-success")" @onclick="ToggleActive" disabled="@(_busy || _view.CurrentVersion == 0)">
                    <i class="bi @(_view.Status == AutomationWorkflowStatuses.Active ? "bi-toggle-on" : "bi-toggle-off") me-1"></i>@(_view.Status == AutomationWorkflowStatuses.Active ? "Active" : "Inactive")
                </button>
                <button class="btn btn-sm btn-primary" @onclick="RunWorkflow" disabled="@(_busy || _view.CurrentVersion == 0)"><i class="bi bi-play-fill me-1"></i>Run workflow</button>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="automation-notice alert @(_messageIsError ? "alert-danger" : "alert-info") mb-0 rounded-0">@_message</div>
        }

        <div class="automation-workspace">
            <aside class="automation-palette">
                <div class="palette-heading">Nodes</div>
                <input class="form-control form-control-sm mb-3" @bind="_paletteSearch" @bind:event="oninput" placeholder="Search nodes" aria-label="Search nodes" />
                @foreach (var group in FilteredDefinitions.GroupBy(definition => definition.Category))
                {
                    <div class="palette-category">@group.Key</div>
                    @foreach (var definition in group)
                    {
                        <button type="button" class="palette-node" @onclick="() => AddNode(definition)" title="@definition.Description">
                            <span class="palette-node-icon"><i class="bi @definition.IconClass"></i></span>
                            <span><strong>@definition.DisplayName</strong><small>@definition.Description</small></span>
                        </button>
                    }
                }
            </aside>

            <main class="automation-canvas-viewport">
                <div class="automation-canvas" @ref="_canvas" @onclick="ClearSelection">
                    <svg class="automation-connections" width="2400" height="1400" aria-hidden="true">
                        @foreach (var connection in _view.Connections)
                        {
                            <path d="@ConnectionPath(connection)" class="automation-connection @ConnectionClass(connection.SourceOutput)" />
                        }
                    </svg>
                    @foreach (var node in _view.Nodes)
                    {
                        var definition = NodeRegistry.Find(node.TypeKey, node.TypeVersion);
                        <article class="automation-node @(node.Id == _selectedNodeId ? "is-selected" : "") @(node.IsDisabled ? "is-disabled" : "")"
                                 data-automation-node="@node.Id" style="left:@(node.PositionX)px; top:@(node.PositionY)px"
                                 @onclick="() => SelectNode(node.Id)" @onclick:stopPropagation="true">
                            <div class="node-output node-output-main" title="Output"></div>
                            @if (definition?.Outputs.Contains("true") == true)
                            {
                                <div class="node-output node-output-true" title="True output"></div><div class="node-output node-output-false" title="False output"></div>
                            }
                            <div class="node-input" title="Input"></div>
                            <div class="node-icon"><i class="bi @(definition?.IconClass ?? "bi-box")"></i></div>
                            <div class="node-copy"><strong>@node.Name</strong><small>@(definition?.DisplayName ?? node.TypeKey)</small></div>
                            @if (node.RetryOnFail) { <i class="bi bi-arrow-repeat node-policy" title="Retries enabled"></i> }
                        </article>
                    }
                </div>
                <div class="canvas-help"><i class="bi bi-arrows-move me-1"></i>Drag nodes to arrange · select a node to configure</div>
            </main>

            <aside class="automation-inspector">
                @if (_selectedNode is null)
                {
                    <div class="inspector-empty">
                        <i class="bi bi-sliders2 fs-3"></i><h2 class="h6 mt-2">Nothing selected</h2><p>Select a node to edit its parameters and execution policy.</p>
                    </div>
                }
                else
                {
                    <div class="inspector-heading"><span>Node settings</span><button class="btn btn-sm btn-light" @onclick="ClearSelection"><i class="bi bi-x-lg"></i></button></div>
                    <label class="form-label small fw-semibold">Name</label>
                    <input class="form-control form-control-sm mb-3" @bind="_nodeName" />
                    <label class="form-label small fw-semibold">Parameters (JSON)</label>
                    <textarea class="form-control form-control-sm font-monospace mb-2" rows="12" @bind="_nodeParameters"></textarea>
                    <div class="small text-secondary mb-3">Use expressions such as <code>{{ExpressionExample}}</code>.</div>
                    <label class="form-label small fw-semibold">Notes</label>
                    <textarea class="form-control form-control-sm mb-3" rows="2" @bind="_nodeNotes"></textarea>
                    <label class="form-label small fw-semibold">Credential</label>
                    <select class="form-select form-select-sm mb-3" @bind="_nodeCredentialId">
                        <option value="">No credential</option>
                        @foreach (var credential in _credentials) { <option value="@credential.Id">@credential.Name (@credential.TypeKey)</option> }
                    </select>
                    <div class="form-check mb-2"><input id="nodeDisabled" class="form-check-input" type="checkbox" @bind="_nodeDisabled" /><label for="nodeDisabled" class="form-check-label small">Disabled</label></div>
                    <div class="form-check mb-2"><input id="nodeContinue" class="form-check-input" type="checkbox" @bind="_nodeContinueOnFail" /><label for="nodeContinue" class="form-check-label small">Continue on failure</label></div>
                    <div class="form-check mb-3"><input id="nodeRetry" class="form-check-input" type="checkbox" @bind="_nodeRetryOnFail" /><label for="nodeRetry" class="form-check-label small">Retry on failure</label></div>
                    @if (_nodeRetryOnFail)
                    {
                        <div class="row g-2 mb-3"><div class="col-6"><label class="form-label small">Max tries</label><input class="form-control form-control-sm" type="number" min="1" max="10" @bind="_nodeMaxTries" /></div><div class="col-6"><label class="form-label small">Wait (ms)</label><input class="form-control form-control-sm" type="number" min="0" max="60000" @bind="_nodeWaitMs" /></div></div>
                    }
                    <label class="form-label small fw-semibold">Timeout (ms, 0 = none)</label>
                    <input class="form-control form-control-sm mb-3" type="number" min="0" max="600000" @bind="_nodeTimeoutMs" />
                    <div class="d-grid gap-2"><button class="btn btn-sm btn-primary" @onclick="SaveSelectedNode" disabled="@_busy">Save node</button><button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelectedNode" disabled="@_busy">Delete node</button></div>
                }
            </aside>
        </div>

        <section class="automation-bottom-panel">
            <div class="bottom-panel-tabs">
                <button class="@(_bottomTab == "connections" ? "active" : "")" @onclick="ShowConnections">Connections</button>
                <button class="@(_bottomTab == "runs" ? "active" : "")" @onclick="ShowRuns">Executions <span>@_view.RecentExecutions.Count</span></button>
                <button class="@(_bottomTab == "settings" ? "active" : "")" @onclick="ShowSettings">Workflow settings</button>
            </div>
            <div class="bottom-panel-body">
                @if (_bottomTab == "connections")
                {
                    <div class="connection-builder">
                        <select class="form-select form-select-sm" @bind="_connectionSource"><option value="">Source node</option>@foreach (var node in _view.Nodes) { <option value="@node.Id">@node.Name</option> }</select>
                        <select class="form-select form-select-sm" @bind="_connectionOutput"><option value="main">main</option><option value="true">true</option><option value="false">false</option></select>
                        <i class="bi bi-arrow-right"></i>
                        <select class="form-select form-select-sm" @bind="_connectionTarget"><option value="">Target node</option>@foreach (var node in _view.Nodes) { <option value="@node.Id">@node.Name</option> }</select>
                        <input class="form-control form-control-sm" @bind="_connectionTargetInput" placeholder="Target input" aria-label="Target input label" />
                        <button class="btn btn-sm btn-outline-primary" @onclick="AddConnection" disabled="@_busy">Connect</button>
                    </div>
                    <div class="connection-list">
                        @foreach (var connection in _view.Connections)
                        {
                            <div><span>@NodeName(connection.SourceNodeId)</span><code>@connection.SourceOutput</code><i class="bi bi-arrow-right"></i><code>@connection.TargetInput</code><span>@NodeName(connection.TargetNodeId)</span><button class="btn btn-sm btn-link text-danger" @onclick="() => DeleteConnection(connection.Id)"><i class="bi bi-x-lg"></i></button></div>
                        }
                    </div>
                }
                else if (_bottomTab == "runs")
                {
                    @if (_latestExecution is not null)
                    {
                        <div class="execution-result @(_latestExecution.Status == AutomationExecutionStatuses.Succeeded ? "is-success" : _latestExecution.Status == AutomationExecutionStatuses.Waiting ? "is-waiting" : "is-failure")">
                            <strong>@_latestExecution.Status</strong><span>@_latestExecution.ErrorMessage</span><pre>@_latestExecution.OutputJson</pre>
                        </div>
                        @if (_latestExecution.Status == AutomationExecutionStatuses.Waiting && _latestExecution.Wait is not null)
                        {
                            <div class="execution-wait-actions mb-3">
                                @if (_latestExecution.Wait.WaitingNodeTypeKey == "core.approval")
                                {
                                    <span class="me-2">Waiting for approval at <strong>@_latestExecution.Wait.WaitingNodeName</strong></span>
                                    <button class="btn btn-sm btn-success me-1" @onclick="() => ResolveApproval(true)" disabled="@_busy">Approve</button>
                                    <button class="btn btn-sm btn-outline-danger me-1" @onclick="() => ResolveApproval(false)" disabled="@_busy">Reject</button>
                                }
                                else
                                {
                                    <span class="me-2">Waiting at <strong>@_latestExecution.Wait.WaitingNodeName</strong>@(_latestExecution.Wait.ResumeAt is not null ? $" until {FormatDate(_latestExecution.Wait.ResumeAt)}" : " for a resume webhook")</span>
                                }
                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelLatestExecution" disabled="@_busy">Cancel</button>
                            </div>
                        }
                        else if (_latestExecution.Status == AutomationExecutionStatuses.Running)
                        {
                            <div class="execution-wait-actions mb-3"><button class="btn btn-sm btn-outline-secondary" @onclick="CancelLatestExecution" disabled="@_busy">Cancel</button></div>
                        }
                    }
                    <div class="table-responsive"><table class="table table-sm align-middle mb-0"><thead><tr><th>Status</th><th>Mode</th><th>Started</th><th>Duration</th><th></th></tr></thead><tbody>
                        @foreach (var run in _view.RecentExecutions)
                        {
                            <tr><td><span class="badge @(run.Status == AutomationExecutionStatuses.Succeeded ? "text-bg-success" : run.Status == AutomationExecutionStatuses.Failed ? "text-bg-danger" : run.Status == AutomationExecutionStatuses.Waiting ? "text-bg-warning" : "text-bg-secondary")">@run.Status</span></td><td>@run.Mode</td><td>@FormatDate(run.StartedAt)</td><td>@Duration(run.StartedAt, run.FinishedAt)</td><td class="text-end"><button class="btn btn-sm btn-link" @onclick="() => LoadExecution(run.Id)">Inspect</button></td></tr>
                        }
                    </tbody></table></div>
                }
                else
                {
                    <div class="row g-3"><div class="col-md-5"><label class="form-label small fw-semibold">Description</label><textarea class="form-control form-control-sm" rows="3" @bind="_description"></textarea></div><div class="col-md-4"><label class="form-label small fw-semibold">Tags</label><input class="form-control form-control-sm" @bind="_tags" placeholder="sales, notifications" /></div><div class="col-md-3"><label class="form-label small fw-semibold">Manual input JSON</label><textarea class="form-control form-control-sm font-monospace" rows="3" @bind="_runInput"></textarea></div></div>
                }
            </div>
        </section>
    </div>
}

@code {
    [Parameter] public Guid WorkflowId { get; set; }
    private const string ExpressionExample = "{{ $json.customer.email }}";
    private AutomationWorkflowView? _view;
    private AutomationExecutionView? _latestExecution;
    private IReadOnlyList<AutomationNodeDefinition> _definitions = [];
    private IReadOnlyList<AutomationCredentialSummary> _credentials = [];
    private Guid? _selectedNodeId;
    private AutomationNodeView? _selectedNode => _view?.Nodes.FirstOrDefault(node => node.Id == _selectedNodeId);
    private bool _loading = true, _busy, _messageIsError;
    private string _message = "", _name = "", _description = "", _tags = "", _paletteSearch = "", _bottomTab = "connections", _runInput = "{}";
    private string _nodeName = "", _nodeParameters = "{}", _nodeNotes = "";
    private Guid? _nodeCredentialId;
    private bool _nodeDisabled, _nodeContinueOnFail, _nodeRetryOnFail;
    private int _nodeMaxTries = 1, _nodeWaitMs, _nodeTimeoutMs;
    private Guid? _connectionSource, _connectionTarget;
    private string _connectionOutput = "main", _connectionTargetInput = "main";
    private ElementReference _canvas;
    private IJSObjectReference? _module;
    private DotNetObjectReference<AutomationEditor>? _dotNetRef;

    private IEnumerable<AutomationNodeDefinition> FilteredDefinitions => _definitions.Where(definition => string.IsNullOrWhiteSpace(_paletteSearch) || definition.DisplayName.Contains(_paletteSearch, StringComparison.OrdinalIgnoreCase) || definition.Category.Contains(_paletteSearch, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() { _definitions = NodeRegistry.ListDefinitions(); _credentials = await CredentialService.ListAsync(); await Reload(); }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_view is null || _module is not null) return;
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/automation-editor.js");
        _dotNetRef = DotNetObjectReference.Create(this);
        await _module.InvokeVoidAsync("initialize", _canvas, _dotNetRef);
    }

    private async Task Reload()
    {
        try
        {
            _view = await WorkflowService.GetAsync(WorkflowId);
            if (_view is not null) { _name = _view.Name; _description = _view.Description; _tags = _view.TagsCsv; }
        }
        catch (Exception ex) { Fail(ex, "Unable to open workflow."); }
        finally { _loading = false; }
    }

    [JSInvokable]
    public async Task UpdateNodePosition(string nodeId, double x, double y)
    {
        if (!Guid.TryParse(nodeId, out var id)) return;
        try { await WorkflowService.MoveNodeAsync(WorkflowId, id, x, y); await Reload(); await InvokeAsync(StateHasChanged); }
        catch (Exception ex) { Fail(ex, "Unable to save node position."); }
    }

    private void SelectNode(Guid id)
    {
        _selectedNodeId = id;
        var node = _selectedNode;
        if (node is null) return;
        _nodeName = node.Name; _nodeParameters = node.ParametersJson; _nodeNotes = node.Notes; _nodeDisabled = node.IsDisabled;
        _nodeCredentialId = node.CredentialId;
        _nodeContinueOnFail = node.ContinueOnFail; _nodeRetryOnFail = node.RetryOnFail; _nodeMaxTries = node.MaxTries; _nodeWaitMs = node.WaitBetweenTriesMs; _nodeTimeoutMs = node.TimeoutMs;
    }
    private void ClearSelection() => _selectedNodeId = null;
    private void Back() => Navigation.NavigateTo("/admin/automation");
    private void ShowConnections() => _bottomTab = "connections";
    private void ShowRuns() => _bottomTab = "runs";
    private void ShowSettings() => _bottomTab = "settings";

    private async Task AddNode(AutomationNodeDefinition definition) => await Work(async () =>
    {
        var count = _view!.Nodes.Count(node => node.TypeKey == definition.TypeKey) + 1;
        var node = await WorkflowService.SaveNodeAsync(WorkflowId, new AutomationNodeEditor { Name = count == 1 ? definition.DisplayName : $"{definition.DisplayName} {count}", TypeKey = definition.TypeKey, TypeVersion = definition.Version, PositionX = 360 + ((_view.Nodes.Count * 35) % 500), PositionY = 160 + ((_view.Nodes.Count * 55) % 500), ParametersJson = definition.DefaultParametersJson });
        await Reload(); SelectNode(node.Id); _message = $"Added {node.Name}.";
    });

    private async Task SaveSelectedNode()
    {
        if (_selectedNode is null) return;
        await Work(async () =>
        {
            await WorkflowService.SaveNodeAsync(WorkflowId, new AutomationNodeEditor { Id = _selectedNode.Id, Name = _nodeName, TypeKey = _selectedNode.TypeKey, TypeVersion = _selectedNode.TypeVersion, PositionX = _selectedNode.PositionX, PositionY = _selectedNode.PositionY, ParametersJson = _nodeParameters, CredentialId = _nodeCredentialId, IsDisabled = _nodeDisabled, ContinueOnFail = _nodeContinueOnFail, RetryOnFail = _nodeRetryOnFail, MaxTries = _nodeMaxTries, WaitBetweenTriesMs = _nodeWaitMs, TimeoutMs = _nodeTimeoutMs, Notes = _nodeNotes });
            await Reload(); SelectNode(_selectedNodeId!.Value); _message = "Node saved.";
        });
    }
    private async Task DeleteSelectedNode()
    {
        if (_selectedNodeId is null) return;
        await Work(async () => { await WorkflowService.DeleteNodeAsync(WorkflowId, _selectedNodeId.Value); _selectedNodeId = null; await Reload(); _message = "Node deleted."; });
    }
    private async Task AddConnection()
    {
        if (_connectionSource is null || _connectionTarget is null) { Show("Choose a source and target node.", true); return; }
        await Work(async () => { await WorkflowService.AddConnectionAsync(WorkflowId, _connectionSource.Value, _connectionOutput, _connectionTarget.Value, _connectionTargetInput); await Reload(); _message = "Connection added."; });
    }
    private async Task DeleteConnection(Guid id) => await Work(async () => { await WorkflowService.DeleteConnectionAsync(WorkflowId, id); await Reload(); _message = "Connection removed."; });
    private async Task SaveMetadata() => await Work(async () => { await WorkflowService.UpdateMetadataAsync(WorkflowId, _name, _description, _tags); await Reload(); _message = "Workflow saved."; });
    private async Task Validate() => await Work(async () => { var result = await WorkflowService.ValidateAsync(WorkflowId); Show(result.IsValid ? "Workflow is valid and ready to publish." : string.Join(" ", result.Errors), !result.IsValid); });
    private async Task Publish() => await Work(async () => { await WorkflowService.UpdateMetadataAsync(WorkflowId, _name, _description, _tags); var version = await WorkflowService.PublishAsync(WorkflowId, "Published from visual editor"); await Reload(); _message = $"Published immutable version {version}."; });
    private async Task ToggleActive() => await Work(async () => { await WorkflowService.SetActiveAsync(WorkflowId, _view!.Status != AutomationWorkflowStatuses.Active); await Reload(); _message = _view!.Status == AutomationWorkflowStatuses.Active ? "Workflow activated." : "Workflow deactivated."; });
    private async Task RunWorkflow() => await Work(async () => { _latestExecution = await ExecutionService.ExecuteAsync(WorkflowId, _runInput); _bottomTab = "runs"; await Reload(); Show(_latestExecution.Status == AutomationExecutionStatuses.Succeeded ? "Workflow completed successfully." : _latestExecution.ErrorMessage, _latestExecution.Status != AutomationExecutionStatuses.Succeeded); });
    private async Task LoadExecution(Guid id) => await Work(async () => { _latestExecution = await WorkflowService.GetExecutionAsync(id); _bottomTab = "runs"; });
    private async Task ResolveApproval(bool approved) => await Work(async () =>
    {
        if (_latestExecution is null) return;
        _latestExecution = await ExecutionService.ResolveApprovalAsync(_latestExecution.Id, approved);
        await Reload();
        _message = approved ? "Approved. Workflow resumed." : "Rejected. Workflow resumed.";
    });
    private async Task CancelLatestExecution() => await Work(async () =>
    {
        if (_latestExecution is null) return;
        _latestExecution = await ExecutionService.CancelAsync(_latestExecution.Id);
        await Reload();
        _message = "Execution canceled.";
    });

    private async Task Work(Func<Task> action)
    {
        _busy = true; _message = ""; _messageIsError = false;
        try { await action(); }
        catch (Exception ex) { Fail(ex, ex.Message); }
        finally { _busy = false; }
    }
    private void Show(string message, bool error = false) { _message = message; _messageIsError = error; }
    private void Fail(Exception ex, string message) { Logger.LogError(ex, "Workflow editor operation failed for {WorkflowId}.", WorkflowId); Show(message, true); }
    private string NodeName(Guid id) => _view?.Nodes.FirstOrDefault(node => node.Id == id)?.Name ?? "Missing node";
    private string ConnectionPath(AutomationConnectionView connection)
    {
        var source = _view?.Nodes.FirstOrDefault(node => node.Id == connection.SourceNodeId); var target = _view?.Nodes.FirstOrDefault(node => node.Id == connection.TargetNodeId);
        if (source is null || target is null) return "";
        var sx = source.PositionX + 196; var sy = source.PositionY + (connection.SourceOutput == "true" ? 38 : connection.SourceOutput == "false" ? 72 : 55); var tx = target.PositionX; var ty = target.PositionY + 55; var bend = Math.Max(70, Math.Abs(tx - sx) * .45);
        return $"M {sx} {sy} C {sx + bend} {sy}, {tx - bend} {ty}, {tx} {ty}";
    }
    private static string ConnectionClass(string output) => output == "true" ? "is-true" : output == "false" ? "is-false" : "";
    private static string FormatDate(DateTimeOffset? value) => value?.ToLocalTime().ToString("MMM d, h:mm:ss tt") ?? "—";
    private static string Duration(DateTimeOffset? start, DateTimeOffset? end) => start is null || end is null ? "—" : $"{(end.Value - start.Value).TotalMilliseconds:N0} ms";

    public async ValueTask DisposeAsync()
    {
        if (_module is not null) { try { await _module.InvokeVoidAsync("dispose", _canvas); await _module.DisposeAsync(); } catch (JSDisconnectedException) { } }
        _dotNetRef?.Dispose();
    }
}
