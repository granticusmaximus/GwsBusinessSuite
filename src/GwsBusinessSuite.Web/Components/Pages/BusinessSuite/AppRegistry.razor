@page "/admin/app-registry"
@rendermode InteractiveServer
@using GwsBusinessSuite.Application.AppRegistry
@using GwsBusinessSuite.Domain.Entities
@inject IAppRegistryService AppRegistryService
@inject ILogger<AppRegistry> Logger

<PageTitle>App Registry</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-grid-1x2-fill me-2 text-primary"></i>App Registry</h1>
    <p>Track internal apps, ownership status, subdomains, and local ports.</p>
</div>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger d-flex align-items-start gap-2 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
        <div>@ErrorMessage</div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-info d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <div>@StatusMessage</div>
    </div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div
                class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between gap-2">
                <span class="fw-semibold">Registered Apps</span>
                <button class="btn btn-sm btn-outline-primary" @onclick="CreateNewApp" disabled="@IsBusy">
                    <i class="bi bi-plus-lg me-1"></i>New App
                </button>
            </div>
            <div class="card-body p-0">
                @if (Apps.Count == 0)
                {
                    <div class="p-4 text-secondary">
                        <p class="mb-0">No apps in the registry yet. Create the first app record.</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var app in Apps)
                        {
                            <button type="button"
                                    class="list-group-item list-group-item-action d-flex justify-content-between align-items-start gap-2 @(SelectedAppId == app.Id ? "active" : string.Empty)"
                                    @onclick="() => OpenAppAsync(app.Id)" disabled="@IsBusy">
                                <div>
                                    <div class="fw-semibold">@app.Name</div>
                                    <div class="small @(SelectedAppId == app.Id ? "text-white-50" : "text-secondary")">
                                        @app.AppType
                                    </div>
                                </div>
                                <span
                                class="badge @(SelectedAppId == app.Id ? "text-bg-light" : "text-bg-secondary")">@app.Status</span>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div
                class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between gap-2">
                <span class="fw-semibold">@EditorHeader</span>
                <span class="badge @(SelectedAppId.HasValue ? "text-bg-primary" : "text-bg-secondary")">
                    @(SelectedAppId.HasValue ? "Editing Existing App" : "New App")
                </span>
            </div>
            <div class="card-body">
                <EditForm Model="Editor" OnValidSubmit="SaveAppAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">App Name</label>
                            <InputText class="form-control" @bind-Value="Editor.Name" placeholder="Public Site" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">App Type</label>
                            <InputText class="form-control" @bind-Value="Editor.AppType" placeholder="WebsiteCms" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Subdomain</label>
                            <InputText class="form-control" @bind-Value="Editor.Subdomain" placeholder="public-site" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold small">Port</label>
                            <InputNumber class="form-control" @bind-Value="Editor.Port" placeholder="5173" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold small">Status</label>
                            <InputSelect class="form-select" @bind-Value="Editor.Status">
                                @foreach (var option in AppStatusOptions)
                                {
                                    <option value="@option">@option</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="mt-3 d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@IsBusy">
                            <i class="bi bi-floppy-fill me-1"></i>Save App
                        </button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="CreateNewApp"
                                disabled="@IsBusy">Reset</button>
                        <button type="button" class="btn btn-outline-danger" @onclick="DeleteSelectedAppAsync"
                                disabled="@(IsBusy || !SelectedAppId.HasValue)">Delete</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private static readonly string[] AppStatusOptions = ["Draft", "Active", "Paused", "Archived"];

    private List<BusinessApp> Apps { get; set; } = new();
    private AppRegistryEditorModel Editor { get; set; } = new();
    private Guid? SelectedAppId { get; set; }
    private bool IsBusy { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;

    private string EditorHeader => SelectedAppId.HasValue ? "Edit Registered App" : "Create App Record";

    protected override async Task OnInitializedAsync()
    {
        await LoadAppsAsync();
    }

    private async Task LoadAppsAsync()
    {
        try
        {
            Apps = (await AppRegistryService.ListAppsAsync()).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load app registry records.");
            ErrorMessage = $"Unable to load app registry records. {ex.Message}";
        }
    }

    private void CreateNewApp()
    {
        SelectedAppId = null;
        Editor = new AppRegistryEditorModel();
        StatusMessage = "Ready to create a new app registry record.";
        ErrorMessage = string.Empty;
    }

    private async Task OpenAppAsync(Guid appId)
    {
        try
        {
            var app = await AppRegistryService.GetAppAsync(appId);
            if (app is null)
            {
                StatusMessage = "The selected app record no longer exists.";
                return;
            }

            SelectedAppId = app.Id;
            Editor = new AppRegistryEditorModel
            {
                AppId = app.Id,
                Name = app.Name,
                AppType = app.AppType,
                Subdomain = app.Subdomain,
                Port = app.Port,
                Status = app.Status
            };
            StatusMessage = $"Opened app record '{app.Name}'.";
            ErrorMessage = string.Empty;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to open app registry record {AppId}.", appId);
            ErrorMessage = $"Unable to open app record. {ex.Message}";
        }
    }

    private async Task SaveAppAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            var saved = await AppRegistryService.SaveAppAsync(Editor);
            SelectedAppId = saved.Id;
            Editor = new AppRegistryEditorModel
            {
                AppId = saved.Id,
                Name = saved.Name,
                AppType = saved.AppType,
                Subdomain = saved.Subdomain,
                Port = saved.Port,
                Status = saved.Status
            };
            StatusMessage = $"Saved app record '{saved.Name}'.";
            await LoadAppsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to save app registry record.");
            ErrorMessage = $"Unable to save app record. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task DeleteSelectedAppAsync()
    {
        if (SelectedAppId is not { } appId)
        {
            return;
        }

        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            await AppRegistryService.DeleteAppAsync(appId);
            StatusMessage = "App record deleted.";
            CreateNewApp();
            await LoadAppsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to delete app registry record {AppId}.", appId);
            ErrorMessage = $"Unable to delete app record. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }
}
