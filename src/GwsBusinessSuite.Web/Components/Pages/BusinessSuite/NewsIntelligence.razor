@page "/admin/news-intelligence"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "AdminOnly")]
@using GwsBusinessSuite.Application.NewsIntelligence
@using GwsBusinessSuite.Domain.Entities
@using GwsBusinessSuite.Infrastructure.Services
@inject INewsIntelligenceService NewsService
@inject ILogger<NewsIntelligence> Logger

<PageTitle>News Intelligence</PageTitle>

<div class="page-header d-flex align-items-start justify-content-between gap-3">
    <div>
        <h1><i class="bi bi-newspaper me-2 text-primary"></i>News Intelligence</h1>
        <p class="mb-0">
            @FeedHeading()
            @if (_feed?.LastRefreshedAt.HasValue == true)
            {
                <span class="text-muted small">&middot; Updated @TimeAgo(_feed.LastRefreshedAt.Value)</span>
            }
        </p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary d-inline-flex align-items-center gap-2" disabled="@(_refreshing || _refreshingTopNews)" @onclick="RefreshTopNewsOnlyAsync" title="Refresh just the general Top News feed (auto-refreshes every 20 minutes)">
            <i class="bi bi-lightning-charge @(_refreshingTopNews ? "gws-spin" : "")"></i>
            <span>@(_refreshingTopNews ? "Refreshing…" : "Refresh Top News")</span>
        </button>
        <button class="btn btn-primary d-inline-flex align-items-center gap-2" disabled="@(_refreshing || _refreshingTopNews)" @onclick="RefreshAllAsync">
            <i class="bi bi-arrow-clockwise @(_refreshing ? "gws-spin" : "")"></i>
            <span>@(_refreshing ? "Refreshing…" : "Refresh All")</span>
        </button>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-3">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Watched Topics</span>
                <button class="btn btn-sm btn-outline-primary" title="Add topic" @onclick="OpenAddForm">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </div>

            @if (_showTopicForm)
            {
                <div class="card-body border-bottom">
                    <input class="form-control form-control-sm mb-2" placeholder="Topic name"
                           value="@_formName" @oninput="e => _formName = e.Value?.ToString() ?? string.Empty" />
                    <textarea class="form-control form-control-sm mb-2" placeholder="Keywords (comma-separated)"
                              @oninput="e => _formKeywords = e.Value?.ToString() ?? string.Empty"
                              rows="2">@_formKeywords</textarea>
                    <label class="form-label small mb-1">Topic type</label>
                    <select class="form-select form-select-sm mb-1" @bind="_formTopicType">
                        <option value="@WatchedTopicTypes.General">General (Google News + dev.to)</option>
                        <option value="@WatchedTopicTypes.Technical">Technical / Programming (Hacker News + dev.to)</option>
                    </select>
                    <div class="small text-secondary mb-2">
                        @(_formTopicType == WatchedTopicTypes.Technical
                            ? "Best for languages/frameworks - searches Hacker News and dev.to instead of general news."
                            : "Best for regions, people, or current events - searches Google News and dev.to.")
                    </div>
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <label class="form-label small mb-0">Badge color</label>
                        <input type="color" class="form-control form-control-color form-control-sm" @bind="_formColor" />
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary btn-sm" @onclick="SaveTopicAsync">
                            @(_editingTopicId.HasValue ? "Save" : "Add")
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="CloseForm">Cancel</button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_formError))
                    {
                        <p class="text-danger small mt-2 mb-0">@_formError</p>
                    }
                </div>
            }

            <div class="list-group list-group-flush">
                <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(_activeFilter == "all" ? "active" : "")"
                        @onclick='() => SelectFilter("all")'>
                    <span><span class="gws-topic-dot me-2" style="background:#64748b"></span>All News</span>
                    <span class="badge @(_activeFilter == "all" ? "text-bg-light" : "text-bg-secondary") rounded-pill">@_topics.Sum(t => t.UnreadCount)</span>
                </button>

                <button type="button" class="list-group-item list-group-item-action @(_activeFilter == "top" ? "active" : "")"
                        @onclick='() => SelectFilter("top")'>
                    <span class="gws-topic-dot me-2" style="background:#0f172a"></span>Top News
                </button>

                @foreach (var topic in _topics)
                {
                    <div class="list-group-item p-0">
                        <div class="d-flex align-items-center">
                            <button type="button" class="list-group-item list-group-item-action border-0 flex-grow-1 d-flex justify-content-between align-items-center @(_activeFilter == topic.Id.ToString() ? "active" : "")"
                                    @onclick="() => SelectFilter(topic.Id.ToString())">
                                <span>
                                    <span class="gws-topic-dot me-2" style="background:@topic.ColorHex"></span>
                                    @if (topic.TopicType == WatchedTopicTypes.Technical)
                                    {
                                        <i class="bi bi-code-slash me-1" title="Technical topic (Hacker News + dev.to)"></i>
                                    }
                                    <span class="@(topic.IsActive ? "" : "text-decoration-line-through text-muted")">@topic.Name</span>
                                </span>
                                @if (topic.UnreadCount > 0)
                                {
                                    <span class="badge @(_activeFilter == topic.Id.ToString() ? "text-bg-light" : "text-bg-secondary") rounded-pill">@topic.UnreadCount</span>
                                }
                            </button>
                            <div class="d-flex flex-shrink-0 pe-2">
                                <button class="btn btn-sm btn-link text-secondary p-1" title="Refresh now" @onclick="() => RefreshTopicAsync(topic.Id)">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </button>
                                <button class="btn btn-sm btn-link text-secondary p-1" title="Edit" @onclick="() => OpenEditForm(topic)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-link text-danger p-1" title="Delete" @onclick="() => DeleteTopicAsync(topic.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-9">
        @if (ShowSourceFilters)
        {
            <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle d-inline-flex align-items-center gap-2"
                            type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                        <i class="bi bi-funnel"></i>
                        <span>@SourceButtonLabel()</span>
                    </button>
                    <div class="dropdown-menu p-2 shadow" style="width:22rem;">
                        <input type="text" class="form-control form-control-sm mb-2" placeholder="Search outlets by name…"
                               value="@_sourceSearch" @oninput="e => _sourceSearch = e.Value?.ToString() ?? string.Empty" />
                        <div style="max-height:18rem; overflow-y:auto;">
                            <button type="button" class="dropdown-item d-flex justify-content-between align-items-center @(_selectedSources.Count == 0 ? "active" : "")"
                                    @onclick="ClearSourceFilter">
                                <span><i class="bi bi-asterisk me-2"></i>All outlets</span>
                                <span class="badge text-bg-light">@CurrentViewItems().Count</span>
                            </button>
                            <div class="dropdown-divider"></div>
                            @foreach (var source in FilteredSourceOptions)
                            {
                                <button type="button" class="dropdown-item d-flex justify-content-between align-items-center @(_selectedSources.Contains(source.Name) ? "active" : "")"
                                        @onclick="() => ToggleSource(source.Name)">
                                    <span><i class="bi @(_selectedSources.Contains(source.Name) ? "bi-check-square-fill" : "bi-square") me-2"></i>@source.Name</span>
                                    <span class="badge text-bg-light">@source.ArticleCount</span>
                                </button>
                            }
                            @if (FilteredSourceOptions.Count == 0)
                            {
                                <div class="text-secondary small px-2 py-1">No outlets match "@_sourceSearch".</div>
                            }
                        </div>
                    </div>
                </div>
                <span class="text-secondary small">@SourceFilterSummary()</span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="alert alert-info" role="alert"><i class="bi bi-info-circle me-2"></i>@_statusMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="alert alert-danger" role="alert"><i class="bi bi-exclamation-triangle me-2"></i>@_errorMessage</div>
        }

        @if (_loading)
        {
            <div class="d-flex align-items-center gap-2 text-secondary">
                <span class="spinner-border spinner-border-sm"></span>
                <span>Loading feed…</span>
            </div>
        }
        else if (_activeFilter == "all")
        {
            @RenderAllView()
        }
        else if (_feed is null || CurrentItems().Count == 0)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center text-secondary py-5">
                    <i class="bi bi-newspaper display-6 d-block mb-2"></i>
                    <p class="mb-0">No articles yet. Click <strong>Refresh All</strong> to fetch the latest news,
                        or add keywords to a topic and click <strong>Refresh All</strong>.</p>
                </div>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                @foreach (var item in CurrentItems())
                {
                    @RenderCard(item)
                }
            </div>
        }
    </div>
</div>

@code {
    // ── State ────────────────────────────────────────────────
    private List<WatchedTopicSummary> _topics = [];
    private NewsFeedResult? _feed;
    private string _activeFilter = "all";   // "all" | "top" | topic-id string
    private bool _loading;
    private bool _refreshing;
    private bool _refreshingTopNews;
    private string _statusMessage = string.Empty;
    private string _errorMessage = string.Empty;

    // Empty means "no filter" (show every source). Populated with the sources the user
    // has explicitly chosen to show - can combine any number of sources at once.
    private readonly HashSet<string> _selectedSources = new(StringComparer.OrdinalIgnoreCase);
    private string _sourceSearch = string.Empty;

    // Topic form
    private bool _showTopicForm;
    private Guid? _editingTopicId;
    private string _formName = string.Empty;
    private string _formKeywords = string.Empty;
    private string _formColor = "#6366f1";
    private string _formTopicType = WatchedTopicTypes.General;
    private string _formError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadTopicsAsync();
        await LoadFeedAsync();
    }

    // ── Data loading ─────────────────────────────────────────

    private async Task LoadTopicsAsync()
    {
        try { _topics = (await NewsService.ListTopicsAsync()).ToList(); }
        catch (Exception ex) { Logger.LogError(ex, "Failed to load topics"); }
    }

    private async Task LoadFeedAsync()
    {
        _loading = true;
        _errorMessage = string.Empty;
        try
        {
            // For "top" filter we pass null topicId (Top News has null in DB).
            // For "all" we also pass null so the service returns everything.
            Guid? queryTopicId = _activeFilter == "all" || _activeFilter == "top"
                ? null
                : Guid.Parse(_activeFilter);

            _feed = await NewsService.GetFeedAsync(queryTopicId);
            PruneSelectedSources();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load feed");
            _errorMessage = "Failed to load news feed.";
        }
        finally { _loading = false; }
    }

    // ── Actions ──────────────────────────────────────────────

    private async Task SelectFilter(string filter)
    {
        _activeFilter = filter;
        // Sources are scoped to whatever's in the newly selected view - a source picked
        // in one topic may not exist in another, so carrying it over would silently
        // empty the feed with no visible explanation.
        _selectedSources.Clear();
        await LoadFeedAsync();
    }

    private void ToggleSource(string source)
    {
        if (!_selectedSources.Add(source))
        {
            _selectedSources.Remove(source);
        }
    }

    private void ClearSourceFilter() => _selectedSources.Clear();

    private async Task RefreshAllAsync()
    {
        _refreshing = true;
        _statusMessage = string.Empty;
        _errorMessage = string.Empty;

        // Try to acquire the shared refresh lock (non-blocking).
        // If the background service is already refreshing, wait up to 3s then give up.
        var acquired = await NewsRefreshBackgroundService.RefreshLock.WaitAsync(3000);
        try
        {
            if (!acquired)
            {
                _statusMessage = "A background refresh is already running — try again in a moment.";
                return;
            }

            await NewsService.RefreshAllAsync();
            await LoadTopicsAsync();
            await LoadFeedAsync();
            _statusMessage = "Feed refreshed.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Refresh failed");
            _errorMessage = $"Refresh failed: {ex.Message}";
        }
        finally
        {
            if (acquired) NewsRefreshBackgroundService.RefreshLock.Release();
            _refreshing = false;
        }
    }

    private async Task RefreshTopNewsOnlyAsync()
    {
        _refreshingTopNews = true;
        _statusMessage = string.Empty;
        _errorMessage = string.Empty;

        // Same shared lock as RefreshAllAsync and the two scheduled background services -
        // without it, this could run concurrently with either and double-write the Top
        // News rows.
        var acquired = await NewsRefreshBackgroundService.RefreshLock.WaitAsync(3000);
        try
        {
            if (!acquired)
            {
                _statusMessage = "A background refresh is already running — try again in a moment.";
                return;
            }

            await NewsService.RefreshTopNewsAsync();
            await LoadFeedAsync();
            _statusMessage = "Top News refreshed.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Top News refresh failed");
            _errorMessage = $"Top News refresh failed: {ex.Message}";
        }
        finally
        {
            if (acquired) NewsRefreshBackgroundService.RefreshLock.Release();
            _refreshingTopNews = false;
        }
    }

    private async Task RefreshTopicAsync(Guid topicId)
    {
        _statusMessage = string.Empty;
        _errorMessage = string.Empty;

        // Same shared lock as RefreshAllAsync - without it, this per-topic refresh could
        // run concurrently with the hourly background refresh (or a bulk refresh) and
        // both would delete+insert the same topic's rows at once.
        var acquired = await NewsRefreshBackgroundService.RefreshLock.WaitAsync(3000);
        try
        {
            if (!acquired)
            {
                _statusMessage = "A background refresh is already running — try again in a moment.";
                return;
            }

            await NewsService.RefreshTopicAsync(topicId);
            await LoadTopicsAsync();
            await LoadFeedAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Topic refresh failed");
            _errorMessage = "Topic refresh failed.";
        }
        finally
        {
            if (acquired) NewsRefreshBackgroundService.RefreshLock.Release();
        }
    }

    private async Task DeleteTopicAsync(Guid topicId)
    {
        try
        {
            await NewsService.DeleteTopicAsync(topicId);
            if (_activeFilter == topicId.ToString()) _activeFilter = "all";
            await LoadTopicsAsync();
            await LoadFeedAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Delete topic failed");
            _errorMessage = "Failed to delete topic.";
        }
    }

    // ── Topic form ───────────────────────────────────────────

    private void OpenAddForm()
    {
        _editingTopicId = null;
        _formName = _formKeywords = _formError = string.Empty;
        _formColor = "#6366f1";
        _formTopicType = WatchedTopicTypes.General;
        _showTopicForm = true;
    }

    private void OpenEditForm(WatchedTopicSummary topic)
    {
        _editingTopicId = topic.Id;
        _formName = topic.Name;
        _formKeywords = topic.Keywords;
        _formColor = topic.ColorHex;
        _formTopicType = topic.TopicType;
        _formError = string.Empty;
        _showTopicForm = true;
    }

    private void CloseForm() { _showTopicForm = false; _formError = string.Empty; }

    private async Task SaveTopicAsync()
    {
        if (string.IsNullOrWhiteSpace(_formName)) { _formError = "Name is required."; return; }
        _formError = string.Empty;
        try
        {
            if (_editingTopicId.HasValue)
            {
                var existing = _topics.First(t => t.Id == _editingTopicId.Value);
                await NewsService.UpdateTopicAsync(_editingTopicId.Value, _formName, _formKeywords, _formColor, existing.IsActive, _formTopicType);
            }
            else
            {
                await NewsService.CreateTopicAsync(_formName, _formKeywords, _formColor, _formTopicType);
            }
            CloseForm();
            await LoadTopicsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Save topic failed");
            _formError = "Failed to save topic.";
        }
    }

    // ── Render helpers ───────────────────────────────────────

    private string FeedHeading() => _activeFilter switch
    {
        "all" => "All News",
        "top" => "Today's Top News",
        _ => _topics.FirstOrDefault(t => t.Id.ToString() == _activeFilter)?.Name ?? "Feed"
    };

    private List<SourceFilterOption> AllSourceFilters =>
        CurrentViewItems()
            .Select(x => NormalizeSourceName(x.Source))
            .Where(source => source.Length > 0)
            .GroupBy(source => source, StringComparer.OrdinalIgnoreCase)
            .Select(group => new SourceFilterOption(group.First(), group.Count()))
            .OrderByDescending(option => option.ArticleCount)
            .ThenBy(option => option.Name)
            .ToList();

    // Search narrows the dropdown list itself (not the feed) - selected sources always stay
    // visible at the top even if they no longer match the search text, so toggling one off
    // is never blocked by whatever's currently typed in the box.
    private List<SourceFilterOption> FilteredSourceOptions =>
        AllSourceFilters
            .Where(option => _selectedSources.Contains(option.Name) ||
                             string.IsNullOrWhiteSpace(_sourceSearch) ||
                             option.Name.Contains(_sourceSearch, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(option => _selectedSources.Contains(option.Name))
            .ThenByDescending(option => option.ArticleCount)
            .ThenBy(option => option.Name)
            .ToList();

    private bool ShowSourceFilters => _activeFilter == "all" && AllSourceFilters.Count > 1;

    private string SourceButtonLabel() => _selectedSources.Count switch
    {
        0 => "All Outlets",
        1 => _selectedSources.First(),
        _ => $"{_selectedSources.Count} outlets selected"
    };

    private bool SourceMatches(NewsItemDto item) =>
        _selectedSources.Count == 0 || _selectedSources.Contains(NormalizeSourceName(item.Source));

    private List<NewsItemDto> CurrentViewItems()
    {
        if (_feed is null) return [];

        return _activeFilter == "top"
            ? _feed.Items.Where(x => x.TopicId == null).ToList()
            : _feed.Items.ToList();
    }

    private List<NewsItemDto> CurrentItems()
    {
        return CurrentViewItems().Where(SourceMatches).ToList();
    }

    private RenderFragment RenderAllView() => @<text>
        @{
            var filteredItems = CurrentViewItems().Where(SourceMatches).ToList();
        }
        @if (_feed is null || _feed.Items.Count == 0)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center text-secondary py-5">
                    <i class="bi bi-newspaper display-6 d-block mb-2"></i>
                    <p class="mb-0">No articles yet. Click <strong>Refresh All</strong> to fetch the latest news.</p>
                </div>
            </div>
        }
        else if (filteredItems.Count == 0)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center text-secondary py-5">
                    <i class="bi bi-funnel display-6 d-block mb-2"></i>
                    <p class="mb-0">No articles match the selected source filter.</p>
                </div>
            </div>
        }
        else
        {
            var topNews = filteredItems.Where(x => x.TopicId == null).ToList();
            var topicGroups = filteredItems
                .Where(x => x.TopicId != null)
                .GroupBy(x => x.TopicId)
                .OrderBy(g => g.First().TopicName)
                .ToList();

            if (topNews.Count > 0)
            {
                <section class="mb-4">
                    <h2 class="h5 d-flex align-items-center mb-3">
                        <span class="gws-topic-dot me-2" style="background:#0f172a"></span>Today's Top News
                    </h2>
                    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                        @foreach (var item in topNews)
                        {
                            @RenderCard(item)
                        }
                    </div>
                </section>
            }

            foreach (var group in topicGroups)
            {
                var first = group.First();
                <section class="mb-4">
                    <h2 class="h5 d-flex align-items-center mb-3">
                        <span class="gws-topic-dot me-2" style="background:@first.TopicColorHex"></span>
                        @first.TopicName
                        <span class="text-secondary small ms-2">(@group.Count())</span>
                    </h2>
                    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                        @foreach (var item in group)
                        {
                            @RenderCard(item)
                        }
                    </div>
                </section>
            }
        }
    </text>;

    private RenderFragment RenderCard(NewsItemDto item) => @<div class="col">
        <article class="card border-0 shadow-sm h-100">
            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
            {
                <div class="ratio ratio-16x9 bg-light rounded-top overflow-hidden">
                    <img src="@item.ImageUrl" alt="" loading="lazy" class="w-100 h-100" style="object-fit:cover;" />
                </div>
            }
            <div class="card-body d-flex flex-column">
                <div class="d-flex align-items-center gap-2 mb-2 small text-secondary">
                    <span class="gws-avatar-circle" style="background:@(string.IsNullOrWhiteSpace(item.TopicColorHex) ? "#64748b" : item.TopicColorHex)">
                        @(string.IsNullOrWhiteSpace(item.Source) ? "?" : item.Source.Trim()[..1].ToUpperInvariant())
                    </span>
                    <span class="fw-semibold">@item.Source</span>
                    @if (item.PublishedAt.HasValue)
                    {
                        <span>&middot; @TimeAgo(item.PublishedAt.Value)</span>
                    }
                </div>
                <a href="@item.Url" target="_blank" rel="noopener noreferrer" class="h6 d-block mb-2 text-body text-decoration-none">@item.Title</a>
                @{
                    var takeText = string.IsNullOrWhiteSpace(item.OllamaSummary) ? item.Description : item.OllamaSummary;
                }
                @if (!string.IsNullOrWhiteSpace(takeText))
                {
                    <p class="small text-secondary flex-grow-1">@takeText</p>
                }
                <a href="@item.Url" target="_blank" rel="noopener noreferrer" class="small fw-semibold mt-auto">Open <i class="bi bi-box-arrow-up-right"></i></a>
            </div>
        </article>
    </div>;

    private static string TimeAgo(DateTimeOffset dt)
    {
        var diff = DateTimeOffset.UtcNow - dt;
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }

    private string SourceFilterSummary()
    {
        var itemCount = CurrentViewItems().Count;
        var outletCount = AllSourceFilters.Count;
        return $"{itemCount} {Pluralize(itemCount, "article")} across {outletCount} {Pluralize(outletCount, "outlet")}.";
    }

    private void PruneSelectedSources()
    {
        if (_selectedSources.Count == 0)
        {
            return;
        }

        var availableSources = CurrentViewItems()
            .Select(x => NormalizeSourceName(x.Source))
            .Where(source => source.Length > 0)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        _selectedSources.RemoveWhere(source => !availableSources.Contains(source));
    }

    private static string NormalizeSourceName(string? source) => source?.Trim() ?? string.Empty;

    private static string Pluralize(int count, string singular) =>
        count == 1 ? singular : $"{singular}s";

    private sealed record SourceFilterOption(string Name, int ArticleCount);
}
