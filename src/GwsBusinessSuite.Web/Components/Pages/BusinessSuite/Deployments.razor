@page "/admin/deployments"
@rendermode InteractiveServer
@using GwsBusinessSuite.Application.Deployments
@inject IDeploymentWorkspaceService DeploymentWorkspaceService
@inject NavigationManager Navigation
@inject ILogger<Deployments> Logger

<PageTitle>Deployments</PageTitle>

<div class="page-header d-flex flex-wrap justify-content-between align-items-start gap-3">
    <div>
        <h1><i class="bi bi-cloud-upload-fill me-2 text-primary"></i>Deployments</h1>
        <p class="mb-0">Track deployable apps, route readiness, infrastructure configuration, and the handoff gaps still blocking release work.</p>
    </div>
    <button class="btn btn-outline-secondary" @onclick="LoadSnapshotAsync" disabled="@IsBusy">
        <i class="bi bi-arrow-repeat me-1"></i>Refresh
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger d-flex align-items-start gap-2 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
        <div>@ErrorMessage</div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-info d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="bi bi-info-circle-fill flex-shrink-0"></i>
        <div>@StatusMessage</div>
    </div>
}

@if (Snapshot is null)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <p class="text-secondary mb-0">Loading deployment workspace.</p>
        </div>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold lh-1 mb-1">@Snapshot.Summary.TotalApps</div>
                    <div class="fw-semibold text-dark">Tracked Apps</div>
                    <div class="text-secondary small mt-2">App Registry entries mapped into deployment readiness.</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold lh-1 mb-1">@Snapshot.Summary.ActiveApps</div>
                    <div class="fw-semibold text-dark">Active Apps</div>
                    <div class="text-secondary small mt-2">Apps currently marked active in the registry.</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold lh-1 mb-1">@Snapshot.Summary.RouteReadyApps</div>
                    <div class="fw-semibold text-dark">Route Ready</div>
                    <div class="text-secondary small mt-2">Apps with a port, subdomain, and Cloudflare routing config.</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold lh-1 mb-1">@Snapshot.Summary.AppsMissingPort</div>
                    <div class="fw-semibold text-dark">Missing Ports</div>
                    <div class="text-secondary small mt-2">App records that cannot be routed or smoke-tested yet.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        @foreach (var integration in GetIntegrations())
        {
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <div class="fw-semibold">@integration.Name</div>
                                <div class="small text-secondary">@integration.Message</div>
                            </div>
                            <span class="badge @GetIntegrationBadgeClass(integration.IsConfigured)">@integration.StatusLabel</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3">
            <div class="fw-semibold">Repository Deployment Assets</div>
            <div class="small text-secondary">Current repo state after replacing the stale submodule wiring with the vendored React app path.</div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="small text-secondary">React App Path</div>
                    <div class="fw-semibold font-monospace">@Snapshot.ReactAppRelativePath</div>
                </div>
                <div class="col-md-4">
                    <div class="small text-secondary">Dockerfile</div>
                    <div class="fw-semibold">@(Snapshot.HasDockerfile ? "Present" : "Missing")</div>
                </div>
                <div class="col-md-4">
                    <div class="small text-secondary">docker-compose.yml</div>
                    <div class="fw-semibold">@(Snapshot.HasDockerComposeFile ? "Present" : "Missing")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center gap-3">
            <div>
                <div class="fw-semibold">Deployment Readiness Board</div>
                <div class="small text-secondary">Operational view of each registered app with the next concrete action.</div>
            </div>
            <button class="btn btn-sm btn-outline-primary" @onclick="OpenAppRegistry">Open App Registry</button>
        </div>
        <div class="card-body p-0">
            @if (Snapshot.Apps.Count == 0)
            {
                <div class="p-4">
                    <p class="text-secondary mb-3">No apps are tracked yet. Start by creating records in App Registry.</p>
                    <button class="btn btn-primary" @onclick="OpenAppRegistry">Create First App</button>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>App</th>
                                <th>Status</th>
                                <th>Local</th>
                                <th>Public Route</th>
                                <th>Readiness</th>
                                <th>Next Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var app in Snapshot.Apps)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@app.Name</div>
                                        <div class="small text-secondary">@app.AppType</div>
                                    </td>
                                    <td>
                                        <span class="badge text-bg-light me-2">@app.Status</span>
                                        @if (!string.IsNullOrWhiteSpace(app.Subdomain))
                                        {
                                            <span class="badge text-bg-secondary">@app.Subdomain</span>
                                        }
                                    </td>
                                    <td>
                                        @if (string.IsNullOrWhiteSpace(app.LocalUrl))
                                        {
                                            <span class="text-secondary small">No port assigned</span>
                                        }
                                        else
                                        {
                                            <a href="@app.LocalUrl" target="_blank" rel="noreferrer">@app.LocalUrl</a>
                                        }
                                    </td>
                                    <td>
                                        @if (string.IsNullOrWhiteSpace(app.PublicUrl))
                                        {
                                            <span class="text-secondary small">Route not derivable yet</span>
                                        }
                                        else
                                        {
                                            <a href="@app.PublicUrl" target="_blank" rel="noreferrer">@app.PublicUrl</a>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @GetReadinessBadgeClass(app.ReadinessLabel)">@app.ReadinessLabel</span>
                                    </td>
                                    <td class="small text-secondary">@app.NextAction</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom py-3">
            <div class="fw-semibold">Registered Infrastructure Targets</div>
            <div class="small text-secondary">Persisted deployment targets already known to the suite.</div>
        </div>
        <div class="card-body">
            @if (Snapshot.Targets.Count == 0)
            {
                <p class="text-secondary mb-0">No deployment targets are stored yet.</p>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var target in Snapshot.Targets)
                    {
                        <div class="col-md-6">
                            <div class="border rounded-4 p-3 h-100">
                                <div class="d-flex justify-content-between gap-3 mb-2">
                                    <div class="fw-semibold">@target.Name</div>
                                    <span class="badge text-bg-light">@target.Provider</span>
                                </div>
                                <div class="small text-secondary mb-1">@(string.IsNullOrWhiteSpace(target.Host) ? "No host recorded" : target.Host)</div>
                                <div class="small">@target.Notes</div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private DeploymentWorkspaceSnapshot? Snapshot { get; set; }
    private bool IsBusy { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadSnapshotAsync();
    }

    private async Task LoadSnapshotAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            Snapshot = await DeploymentWorkspaceService.GetSnapshotAsync();
            StatusMessage = $"Loaded deployment workspace for {Snapshot.Summary.TotalApps} tracked app{(Snapshot.Summary.TotalApps == 1 ? string.Empty : "s")}.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load deployment workspace.");
            ErrorMessage = $"Unable to load deployment workspace. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private IReadOnlyList<DeploymentIntegrationStatus> GetIntegrations()
    {
        return Snapshot is null
            ? Array.Empty<DeploymentIntegrationStatus>()
            : [Snapshot.Docker, Snapshot.Cloudflare, Snapshot.DigitalOcean];
    }

    private void OpenAppRegistry()
    {
        Navigation.NavigateTo("/admin/app-registry");
    }

    private static string GetIntegrationBadgeClass(bool isConfigured)
    {
        return isConfigured ? "text-bg-success" : "text-bg-warning";
    }

    private static string GetReadinessBadgeClass(string readinessLabel)
    {
        return readinessLabel switch
        {
            "Ready" => "text-bg-success",
            "Tunnel Config Needed" => "text-bg-warning",
            "Missing Subdomain" => "text-bg-warning",
            "Missing Port" => "text-bg-danger",
            _ => "text-bg-secondary"
        };
    }
}
