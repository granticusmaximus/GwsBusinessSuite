@using GwsBusinessSuite.Application.Abstractions
@using GwsBusinessSuite.Application.Wiki
@inject ISentinelTemplateService TemplateService
@inject ICurrentUserAccessor CurrentUserAccessor
@inject ILogger<SentinelTemplates> Logger

<div class="card border-0 shadow-sm mt-3 sentinel-template-panel">
    <div class="card-header bg-white border-bottom py-2 d-flex align-items-center justify-content-between">
        <span class="fw-semibold small"><i class="bi bi-copy me-1"></i>Templates</span>
        <span class="badge text-bg-secondary">@(Templates.Count + BlockTemplates.Count + DatabaseTemplates.Count)</span>
    </div>

    <div class="card-body p-2 border-bottom">
        <div class="small fw-semibold mb-2"><i class="bi bi-blockquote-left me-1"></i>Block templates</div>
        @if (IsPageEditorActive)
        {
            <div class="input-group input-group-sm">
                <input class="form-control" @bind="NewBlockTemplateName" placeholder="Template name" maxlength="120" />
                <button type="button" class="btn btn-outline-primary" @onclick="SaveBlockTemplateAsync"
                        disabled="@(IsBusy || string.IsNullOrWhiteSpace(NewBlockTemplateName))" title="Save the current page blocks as a template">
                    <i class="bi bi-bookmark-plus"></i>
                </button>
            </div>
            <div class="small text-secondary mt-1">Saves the blocks currently in the editor, including unsaved changes.</div>
        }
        else
        {
            <div class="small text-secondary">Open a page to save or insert reusable blocks.</div>
        }
    </div>

    <div class="card-body p-2 border-bottom">
        <div class="small fw-semibold mb-2"><i class="bi bi-grid-3x3-gap me-1"></i>Database templates</div>
        @if (CurrentDatabaseId.HasValue)
        {
            <div class="input-group input-group-sm">
                <input class="form-control" @bind="NewDatabaseTemplateName" placeholder="Template name" maxlength="120" />
                <button type="button" class="btn btn-outline-primary" @onclick="SaveDatabaseTemplateAsync"
                        disabled="@(IsBusy || string.IsNullOrWhiteSpace(NewDatabaseTemplateName))" title="Save this database as a template">
                    <i class="bi bi-bookmark-plus"></i>
                </button>
            </div>
        }
        else
        {
            <div class="small text-secondary">Open a database to turn it into a reusable template.</div>
        }
    </div>
    <div class="card-body p-2 border-bottom">
        <div class="small fw-semibold mb-2"><i class="bi bi-file-earmark-text me-1"></i>Page templates</div>
        @if (CurrentPageId.HasValue)
        {
            <div class="input-group input-group-sm">
                <input class="form-control" @bind="NewTemplateName" placeholder="Template name" maxlength="120" />
                <button type="button" class="btn btn-outline-primary" @onclick="SaveTemplateAsync"
                        disabled="@(IsBusy || string.IsNullOrWhiteSpace(NewTemplateName))" title="Save this page as a template">
                    <i class="bi bi-bookmark-plus"></i>
                </button>
            </div>
        }
        else
        {
            <div class="small text-secondary">Open and save a page to turn it into a template.</div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="small text-danger p-2 border-bottom">@ErrorMessage</div>
    }

    @if (BlockTemplates.Count == 0)
    {
        <div class="small text-secondary p-3">No block templates yet.</div>
    }
    else
    {
        <div class="list-group list-group-flush">
            @foreach (var template in BlockTemplates)
            {
                <div class="list-group-item p-2">
                    <div class="d-flex align-items-center gap-2">
                        <span>▦</span>
                        <div class="min-w-0 flex-grow-1">
                            <div class="small fw-semibold text-truncate">@template.Name</div>
                            <div class="small text-secondary text-truncate">@template.BlockCount blocks · @template.Preview</div>
                        </div>
                        @if (PendingBlockDeleteId == template.Id)
                        {
                            <button type="button" class="btn btn-xs btn-danger" @onclick="() => DeleteBlockTemplateAsync(template.Id)" disabled="@IsBusy">Confirm</button>
                            <button type="button" class="btn btn-xs btn-link" @onclick="CancelBlockDelete" disabled="@IsBusy">Cancel</button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-xs btn-outline-primary" @onclick="() => UseBlockTemplateAsync(template.Id)" disabled="@(IsBusy || !IsPageEditorActive)">Insert</button>
                            <button type="button" class="btn btn-xs btn-link text-danger" @onclick="() => PendingBlockDeleteId = template.Id" disabled="@IsBusy" title="Delete block template">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @if (Templates.Count == 0)
    {
        <div class="small text-secondary p-3">No page templates yet.</div>
    }
    else
    {
        <div class="list-group list-group-flush">
            @foreach (var template in Templates)
            {
                <div class="list-group-item p-2">
                    <div class="d-flex align-items-center gap-2">
                        <span>@(string.IsNullOrWhiteSpace(template.Icon) ? "📄" : template.Icon)</span>
                        <div class="min-w-0 flex-grow-1">
                            <div class="small fw-semibold text-truncate">@template.Name</div>
                            <div class="small text-secondary text-truncate">@template.PageTitle · @template.BlockCount blocks</div>
                        </div>
                        @if (PendingDeleteId == template.Id)
                        {
                            <button type="button" class="btn btn-xs btn-danger" @onclick="() => DeleteAsync(template.Id)" disabled="@IsBusy">Confirm</button>
                            <button type="button" class="btn btn-xs btn-link" @onclick="CancelDelete" disabled="@IsBusy">Cancel</button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-xs btn-outline-primary" @onclick="() => UseAsync(template.Id)" disabled="@IsBusy">Use</button>
                            <button type="button" class="btn btn-xs btn-link text-danger" @onclick="() => PendingDeleteId = template.Id" disabled="@IsBusy" title="Delete template">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @if (DatabaseTemplates.Count == 0)
    {
        <div class="small text-secondary p-3 border-top">No database templates yet.</div>
    }
    else
    {
        <div class="small fw-semibold px-2 pt-3 pb-1 border-top">Database templates</div>
        <div class="list-group list-group-flush">
            @foreach (var template in DatabaseTemplates)
            {
                <div class="list-group-item p-2">
                    <div class="d-flex align-items-center gap-2">
                        <span>@(string.IsNullOrWhiteSpace(template.Icon) ? "🗄️" : template.Icon)</span>
                        <div class="min-w-0 flex-grow-1">
                            <div class="small fw-semibold text-truncate">@template.Name</div>
                            <div class="small text-secondary text-truncate">
                                @template.DatabaseTitle · @template.PropertyCount properties · @template.RowCount rows · @template.ViewCount views
                            </div>
                        </div>
                        @if (PendingDatabaseDeleteId == template.Id)
                        {
                            <button type="button" class="btn btn-xs btn-danger" @onclick="() => DeleteDatabaseTemplateAsync(template.Id)" disabled="@IsBusy">Confirm</button>
                            <button type="button" class="btn btn-xs btn-link" @onclick="CancelDatabaseDelete" disabled="@IsBusy">Cancel</button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-xs btn-outline-primary" @onclick="() => UseDatabaseTemplateAsync(template.Id)" disabled="@IsBusy">Use</button>
                            <button type="button" class="btn btn-xs btn-link text-danger" @onclick="() => PendingDatabaseDeleteId = template.Id" disabled="@IsBusy" title="Delete database template">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public Guid? CurrentPageId { get; set; }
    [Parameter] public string CurrentPageTitle { get; set; } = string.Empty;
    [Parameter] public Guid? CurrentDatabaseId { get; set; }
    [Parameter] public string CurrentDatabaseTitle { get; set; } = string.Empty;
    [Parameter] public bool IsPageEditorActive { get; set; }
    [Parameter, EditorRequired] public Func<Task<string>> CaptureBlocks { get; set; } = default!;
    [Parameter] public EventCallback<Guid> OnPageCreated { get; set; }
    [Parameter] public EventCallback<Guid> OnDatabaseCreated { get; set; }
    [Parameter] public EventCallback<string> OnBlocksInserted { get; set; }

    private List<SentinelPageTemplateView> Templates { get; set; } = new();
    private List<SentinelBlockTemplateView> BlockTemplates { get; set; } = new();
    private List<SentinelDatabaseTemplateView> DatabaseTemplates { get; set; } = new();
    private string NewTemplateName { get; set; } = string.Empty;
    private string NewBlockTemplateName { get; set; } = string.Empty;
    private string NewDatabaseTemplateName { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;
    private Guid? PendingDeleteId { get; set; }
    private Guid? PendingBlockDeleteId { get; set; }
    private Guid? PendingDatabaseDeleteId { get; set; }
    private bool IsBusy { get; set; }
    private Guid? _previousPageId;
    private Guid? _previousDatabaseId;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override void OnParametersSet()
    {
        if (_previousPageId != CurrentPageId)
        {
            _previousPageId = CurrentPageId;
            NewTemplateName = CurrentPageId.HasValue && !string.IsNullOrWhiteSpace(CurrentPageTitle)
                ? $"{CurrentPageTitle} template"
                : string.Empty;
            NewBlockTemplateName = CurrentPageId.HasValue && !string.IsNullOrWhiteSpace(CurrentPageTitle)
                ? $"{CurrentPageTitle} blocks"
                : "Reusable blocks";
        }

        if (_previousDatabaseId != CurrentDatabaseId)
        {
            _previousDatabaseId = CurrentDatabaseId;
            NewDatabaseTemplateName = CurrentDatabaseId.HasValue && !string.IsNullOrWhiteSpace(CurrentDatabaseTitle)
                ? $"{CurrentDatabaseTitle} template"
                : string.Empty;
        }
    }

    private async Task SaveTemplateAsync()
    {
        if (CurrentPageId is not { } pageId) return;
        await RunAsync(async () =>
        {
            var user = await CurrentUserAccessor.GetCurrentUsernameAsync();
            await TemplateService.CreateFromPageAsync(pageId, NewTemplateName, user);
            await LoadAsync();
            NewTemplateName = $"{CurrentPageTitle} template";
        });
    }

    private async Task UseAsync(Guid templateId) => await RunAsync(async () =>
    {
        var user = await CurrentUserAccessor.GetCurrentUsernameAsync();
        var page = await TemplateService.CreatePageAsync(templateId, null, user);
        await OnPageCreated.InvokeAsync(page.Id);
    });

    private async Task SaveBlockTemplateAsync() => await RunAsync(async () =>
    {
        var blocksJson = await CaptureBlocks();
        var user = await CurrentUserAccessor.GetCurrentUsernameAsync();
        await TemplateService.CreateBlockTemplateAsync(NewBlockTemplateName, blocksJson, user);
        await LoadAsync();
        NewBlockTemplateName = "Reusable blocks";
    });

    private async Task UseBlockTemplateAsync(Guid templateId) => await RunAsync(async () =>
    {
        var blocksJson = await TemplateService.MaterializeBlockTemplateAsync(templateId);
        await OnBlocksInserted.InvokeAsync(blocksJson);
    });

    private async Task SaveDatabaseTemplateAsync()
    {
        if (CurrentDatabaseId is not { } databaseId) return;
        await RunAsync(async () =>
        {
            var user = await CurrentUserAccessor.GetCurrentUsernameAsync();
            await TemplateService.CreateFromDatabaseAsync(databaseId, NewDatabaseTemplateName, user);
            await LoadAsync();
            NewDatabaseTemplateName = $"{CurrentDatabaseTitle} template";
        });
    }

    private async Task UseDatabaseTemplateAsync(Guid templateId) => await RunAsync(async () =>
    {
        var user = await CurrentUserAccessor.GetCurrentUsernameAsync();
        var database = await TemplateService.CreateDatabaseAsync(templateId, null, user);
        await OnDatabaseCreated.InvokeAsync(database.Id);
    });

    private async Task DeleteAsync(Guid templateId) => await RunAsync(async () =>
    {
        await TemplateService.DeleteAsync(templateId);
        PendingDeleteId = null;
        await LoadAsync();
    });

    private void CancelDelete() => PendingDeleteId = null;

    private async Task DeleteBlockTemplateAsync(Guid templateId) => await RunAsync(async () =>
    {
        await TemplateService.DeleteBlockTemplateAsync(templateId);
        PendingBlockDeleteId = null;
        await LoadAsync();
    });

    private void CancelBlockDelete() => PendingBlockDeleteId = null;

    private async Task DeleteDatabaseTemplateAsync(Guid templateId) => await RunAsync(async () =>
    {
        await TemplateService.DeleteDatabaseTemplateAsync(templateId);
        PendingDatabaseDeleteId = null;
        await LoadAsync();
    });

    private void CancelDatabaseDelete() => PendingDatabaseDeleteId = null;

    private async Task LoadAsync()
    {
        Templates = (await TemplateService.ListAsync()).ToList();
        BlockTemplates = (await TemplateService.ListBlockTemplatesAsync()).ToList();
        DatabaseTemplates = (await TemplateService.ListDatabaseTemplatesAsync()).ToList();
    }

    private async Task RunAsync(Func<Task> action)
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        try
        {
            await action();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Sentinel template action failed.");
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }
}
