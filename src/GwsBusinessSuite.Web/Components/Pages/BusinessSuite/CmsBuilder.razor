@page "/admin/canvas"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = "ContributorAccess")]
@using Microsoft.AspNetCore.Authorization
@using GwsBusinessSuite.Application.CmsBuilder
@using GwsBusinessSuite.Domain.Entities
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.Json
@inject ICmsBuilderService CmsBuilderService
@inject IMediaLibraryService MediaLibraryService
@inject IFormSubmissionService FormSubmissionService
@inject IPageRevisionService PageRevisionService
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject IJSRuntime JS
@inject ILogger<CmsBuilder> Logger

<PageTitle>Canvas</PageTitle>

<div class="cms-builder-shell">

<div class="cms-builder-exit">
    <a href="/admin" class="cms-builder-exit-link">
        <i class="bi bi-arrow-left"></i>Exit to Dashboard
    </a>
    <a href="/auth/logout" class="cms-builder-exit-link cms-builder-exit-link-subtle">Sign Out</a>
</div>

<div class="cms-builder-hero page-header">
    <div>
        <div class="cms-builder-kicker">Visual editing studio</div>
        <h1><i class="bi bi-window-stack me-2 text-primary"></i>Canvas</h1>
        <p>Build and edit every page on @(CurrentSite?.Name ?? "the live site") here — no code, no deploy. Add pages and edit their content and forms; changes go live immediately.</p>
    </div>

    <div class="cms-builder-hero-metrics">
        <div class="cms-builder-metric">
            <span>Pages</span>
            <strong>@CmsPages.Count</strong>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(CmsErrorMessage))
{
    <div class="alert alert-danger d-flex align-items-start gap-2 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
        <div>@CmsErrorMessage</div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(CmsStatusMessage))
{
    <div class="alert alert-info d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="bi bi-info-circle-fill flex-shrink-0"></i>
        <div>@CmsStatusMessage</div>
    </div>
}

<div class="row g-4">
    <div class="col-xl-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-bottom py-3">
                <div class="fw-semibold">Site Settings</div>
                <div class="small text-secondary">@(CurrentSite?.Name ?? "Site") · /@(CurrentSite?.Slug)</div>
            </div>
            <div class="card-body">
                <label class="form-label fw-semibold small">Global Design</label>
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label small text-secondary mb-1">Accent Color</label>
                        <input type="color" class="form-control form-control-color w-100" @bind="SiteAccentColorInput" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small text-secondary mb-1">Font Pairing</label>
                        <select class="form-select form-select-sm" @bind="SiteFontPairingInput">
                            <option value="@CmsFontPairings.Elegant">Elegant (Playfair + Inter)</option>
                            <option value="@CmsFontPairings.Modern">Modern (Manrope + Inter)</option>
                            <option value="@CmsFontPairings.Classic">Classic (Merriweather + Source Sans)</option>
                        </select>
                    </div>
                </div>
                <div class="small text-secondary mb-3">Applies site-wide, across every Canvas page and the blog.</div>

                <label class="form-label fw-semibold small">Site-wide Custom CSS</label>
                <InputTextArea class="form-control font-monospace cms-custom-css-editor" @bind-Value="SiteCustomCssInput"
                               placeholder="Applies to every page on this site. Page-level CSS below can override it." spellcheck="false" />

                <hr class="my-3" />

                <label class="form-label fw-semibold small mb-2">Navigation Menus</label>
                <div class="btn-group btn-group-sm mb-2" role="group" aria-label="Navigation menu location">
                    <button type="button" class="btn @(ActiveNavLocation == "Primary" ? "btn-primary" : "btn-outline-primary")"
                            @onclick='() => ActiveNavLocation = "Primary"'>
                        Primary
                    </button>
                    <button type="button" class="btn @(ActiveNavLocation == "Footer" ? "btn-primary" : "btn-outline-primary")"
                            @onclick='() => ActiveNavLocation = "Footer"'>
                        Footer
                    </button>
                </div>

                @{
                    var isFooterLocation = ActiveNavLocation == "Footer";
                    var activeNavItems = isFooterLocation ? FooterNavMenuItems : NavMenuItems;
                }
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="small text-secondary">@(isFooterLocation ? "Shown in the site footer." : "Shown in the site header.")</span>
                    <button type="button" class="btn btn-xs btn-outline-primary" @onclick="() => AddNavItem(activeNavItems)">
                        <i class="bi bi-plus-lg"></i> Add Link
                    </button>
                </div>
                @if (activeNavItems.Count == 0)
                {
                    <p class="small text-secondary mb-0">
                        No @(isFooterLocation ? "footer" : "nav") links yet — click "Add Link" to build @(isFooterLocation ? "the site's footer links" : "the site's top navigation").
                    </p>
                }
                else
                {
                    @for (var i = 0; i < activeNavItems.Count; i++)
                    {
                        var index = i;
                        var item = activeNavItems[index];
                        <div class="cms-nav-item-editor d-flex gap-2 align-items-center mb-2">
                            <input class="form-control form-control-sm" placeholder="Label" value="@item.Label"
                                   @oninput="(e) => UpdateNavItem(activeNavItems, index, item with { Label = e.Value?.ToString() ?? string.Empty })" />
                            <input class="form-control form-control-sm font-monospace" placeholder="/path" value="@item.Href"
                                   @oninput="(e) => UpdateNavItem(activeNavItems, index, item with { Href = e.Value?.ToString() ?? string.Empty })" />
                            <div class="form-check form-check-inline flex-shrink-0 mb-0" title="Open in new tab">
                                <input class="form-check-input" type="checkbox" id="@($"nav-newtab-{ActiveNavLocation}-{index}")"
                                       checked="@item.OpenInNewTab"
                                       @onchange="(e) => UpdateNavItem(activeNavItems, index, item with { OpenInNewTab = (bool)(e.Value ?? false) })" />
                                <label class="form-check-label small" for="@($"nav-newtab-{ActiveNavLocation}-{index}")">↗</label>
                            </div>
                            <div class="btn-group btn-group-sm flex-shrink-0">
                                <button type="button" class="btn btn-outline-secondary" title="Move up" disabled="@(index == 0)" @onclick="() => MoveNavItem(activeNavItems, index, -1)">
                                    <i class="bi bi-arrow-up"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary" title="Move down" disabled="@(index == activeNavItems.Count - 1)" @onclick="() => MoveNavItem(activeNavItems, index, 1)">
                                    <i class="bi bi-arrow-down"></i>
                                </button>
                                <button type="button" class="btn btn-outline-danger" title="Remove" @onclick="() => RemoveNavItem(activeNavItems, index)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                }

                <div class="d-flex flex-wrap gap-2 mt-3">
                    <button class="btn btn-primary btn-sm" @onclick="SaveSiteSettingsAsync" disabled="@IsCmsBusy">Save</button>
                    @if (SiteExportUrl is { } exportUrl)
                    {
                        <a class="btn btn-sm btn-outline-secondary" href="@exportUrl" download>
                            <i class="bi bi-file-zip me-1"></i>Export ZIP
                        </a>
                    }
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center gap-3">
                <div>
                    <div class="fw-semibold">@(ShowTrash ? "Trash" : "Pages")</div>
                    <div class="small text-secondary">@(ShowTrash ? "Restore a page or delete it permanently." : "Create, edit, and preview pages on this site.")</div>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm @(ShowTrash ? "btn-secondary" : "btn-outline-secondary")" @onclick="ToggleTrashViewAsync" disabled="@IsCmsBusy">
                        <i class="bi bi-trash3 me-1"></i>Trash@(TrashedPages.Count > 0 ? $" ({TrashedPages.Count})" : "")
                    </button>
                    @if (!ShowTrash)
                    {
                        <button class="btn btn-sm btn-outline-primary" @onclick="CreateNewPage" disabled="@(IsCmsBusy || !SelectedSiteId.HasValue)">
                            <i class="bi bi-file-earmark-plus me-1"></i>New Page
                        </button>
                    }
                </div>
            </div>
            <div class="card-body p-0">
                @if (ShowTrash)
                {
                    @if (TrashedPages.Count == 0)
                    {
                        <div class="p-4">
                            <p class="text-secondary mb-0">Trash is empty.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var trashedPage in TrashedPages)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <div class="fw-semibold">@trashedPage.Title</div>
                                            <div class="small text-secondary">/@trashedPage.Slug &middot; trashed @trashedPage.TrashedAt?.ToLocalTime().ToString("g")</div>
                                        </div>
                                        <div class="d-flex gap-1 flex-shrink-0">
                                            <button class="btn btn-xs btn-outline-primary" @onclick="() => RestoreTrashedPageAsync(trashedPage.Id)" disabled="@IsCmsBusy">Restore</button>
                                            <button class="btn btn-xs btn-outline-danger" @onclick="() => PermanentlyDeleteTrashedPageAsync(trashedPage.Id)" disabled="@IsCmsBusy">Delete Permanently</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
                else if (CmsPages.Count == 0)
                {
                    <div class="p-4">
                        <p class="text-secondary mb-0">No pages exist for this site yet.</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var cmsPage in OrderedPagesByHierarchy())
                        {
                            <button type="button"
                                    class="list-group-item list-group-item-action @(SelectedPageId == cmsPage.Id ? "active" : string.Empty)"
                                    style="padding-left:@(1 + GetPageDepth(cmsPage) * 1.25)rem"
                                    @onclick="() => OpenPageAsync(cmsPage.Id)"
                                    disabled="@IsCmsBusy">
                                <div class="fw-semibold d-flex align-items-center gap-2">
                                    @(GetPageDepth(cmsPage) > 0 ? "— " : "")@cmsPage.Title
                                    @if (cmsPage.Status != CmsPageStatuses.Published)
                                    {
                                        <span class="badge @(SelectedPageId == cmsPage.Id ? "text-bg-light" : "text-bg-secondary")">Draft</span>
                                    }
                                </div>
                                <div class="small @(SelectedPageId == cmsPage.Id ? "text-white-50" : "text-secondary")">/@BuildFullPath(cmsPage)</div>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-white border-bottom py-3">
                <div class="fw-semibold">Media Library</div>
                <div class="small text-secondary">Upload images and insert them into the selected page's blocks.</div>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(MediaErrorMessage))
                {
                    <div class="alert alert-danger py-2 small mb-3">@MediaErrorMessage</div>
                }
                @if (!string.IsNullOrEmpty(MediaStatusMessage))
                {
                    <div class="alert alert-info py-2 small mb-3">@MediaStatusMessage</div>
                }

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Alt Text (applied to next upload)</label>
                    <InputText class="form-control form-control-sm mb-2" @bind-Value="MediaAltTextInput" placeholder="Describe the image" />
                    <InputFile OnChange="OnMediaFileSelectedAsync" disabled="@IsMediaBusy" class="form-control form-control-sm" accept="image/*" />
                </div>

                @if (MediaAssets.Count == 0)
                {
                    <p class="text-secondary small mb-0">No media uploaded yet.</p>
                }
                else
                {
                    <div class="cms-media-grid">
                        @foreach (var asset in MediaAssets)
                        {
                            <div class="cms-media-item">
                                <img src="@asset.Url" alt="@asset.AltText" />
                                <div class="cms-media-item-name small text-truncate" title="@asset.FileName">@asset.FileName</div>
                                <div class="d-flex gap-1 mt-1">
                                    <button class="btn btn-xs btn-outline-primary" disabled="@(!SelectedPageId.HasValue)"
                                            @onclick="() => InsertImageBlock(asset.Url, asset.AltText)">
                                        Insert
                                    </button>
                                    <button class="btn btn-xs btn-outline-danger" disabled="@IsMediaBusy"
                                            @onclick="() => DeleteMediaAssetAsync(asset.Id)">
                                        Delete
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center gap-3">
                <div>
                    <div class="fw-semibold">Structured Page Editor</div>
                    <div class="small text-secondary">Edit JSON blocks and preview them as rendered sections without leaving the builder.</div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge @(PageEditor.Status == CmsPageStatuses.Published ? "text-bg-success" : "text-bg-secondary")">
                        @(PageEditor.Status == CmsPageStatuses.Published ? "Published" : "Draft")
                    </span>
                    <span class="badge @(SelectedPageId.HasValue ? "text-bg-primary" : "text-bg-secondary")">
                        @(SelectedPageId.HasValue ? "Editing Existing Page" : "New Page")
                    </span>
                </div>
            </div>
            <div class="card-body">
                @if (!SelectedSiteId.HasValue)
                {
                    <p class="text-secondary mb-0">Select a site before editing pages.</p>
                }
                else
                {
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small">Page Title</label>
                            <InputText class="form-control" @bind-Value="PageEditor.Title" placeholder="Home" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small">Slug</label>
                            <InputText class="form-control" @bind-Value="PageEditor.Slug" placeholder="home" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small">Parent Page</label>
                            <select class="form-select" @bind="ParentPageIdSelection">
                                <option value="">— Top level —</option>
                                @foreach (var candidate in ParentPageOptions())
                                {
                                    <option value="@candidate.Id">/@BuildFullPath(candidate)</option>
                                }
                            </select>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(PageEditor.Slug))
                    {
                        <p class="small text-secondary mb-3">Live path: <span class="font-monospace">/@PreviewFullPath()</span></p>
                    }

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">SEO Meta Title</label>
                            <InputText class="form-control" @bind-Value="PageEditor.MetaTitle" placeholder="Falls back to Page Title if blank" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">OG Image URL</label>
                            <InputText class="form-control" @bind-Value="PageEditor.OgImageUrl" placeholder="/media/{id} or external URL" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">SEO Meta Description</label>
                            <InputText class="form-control" @bind-Value="PageEditor.MetaDescription" placeholder="Shown in search results and link previews" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Page Custom CSS</label>
                            <InputTextArea class="form-control font-monospace cms-custom-css-editor" @bind-Value="PageEditor.CustomCss"
                                           placeholder="Applies only to this page, after the site-wide CSS." spellcheck="false" />
                        </div>
                    </div>

                    @if (LivePageUrl is { } livePageUrl && SelectedPageId.HasValue)
                    {
                        <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
                            <a class="btn btn-sm btn-outline-success" href="@livePageUrl" target="_blank" rel="noopener noreferrer">
                                <i class="bi bi-box-arrow-up-right me-1"></i>View Live Page
                            </a>
                            @if (!IsCurrentPageInNav())
                            {
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddCurrentPageToNavAsync" disabled="@IsCmsBusy">
                                    <i class="bi bi-list me-1"></i>Add to Nav
                                </button>
                            }
                        </div>
                    }

                    <div class="cms-structured-toolbar mb-3">
                        <div class="cms-structured-toolbar-group">
                            <label class="form-label fw-semibold small mb-1">Workflow Blueprint</label>
                            <select class="form-select" @bind="SelectedBlueprintKey">
                                <option value="">Select blueprint</option>
                                @foreach (var blueprint in CmsBlueprints)
                                {
                                    <option value="@blueprint.Key">@blueprint.Name (@blueprint.Category)</option>
                                }
                            </select>
                        </div>
                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox" id="replaceExistingBlocks" @bind="ReplaceExistingBlocks" />
                            <label class="form-check-label small" for="replaceExistingBlocks">Replace existing blocks</label>
                        </div>
                        <div class="d-flex gap-2 mt-4">
                            <button class="btn btn-outline-secondary btn-sm" @onclick="ApplyBlueprintAsync" disabled="@(IsCmsBusy || !SelectedPageId.HasValue || string.IsNullOrWhiteSpace(SelectedBlueprintKey))">
                                Apply Blueprint
                            </button>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <button class="btn btn-primary" @onclick="SavePageAsync" disabled="@IsCmsBusy">Save Page Details</button>
                        @if (PageEditor.Status == CmsPageStatuses.Published)
                        {
                            <button class="btn btn-outline-secondary" @onclick="() => SetStatusAndSaveAsync(CmsPageStatuses.Draft)" disabled="@IsCmsBusy">
                                <i class="bi bi-eye-slash me-1"></i>Unpublish
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-success" @onclick="() => SetStatusAndSaveAsync(CmsPageStatuses.Published)" disabled="@IsCmsBusy">
                                <i class="bi bi-cloud-upload me-1"></i>Publish
                            </button>
                        }
                        <button class="btn btn-outline-secondary" @onclick="CreateNewPage" disabled="@IsCmsBusy">Reset</button>
                        <button class="btn btn-outline-danger" @onclick="TrashSelectedPageAsync" disabled="@(IsCmsBusy || !SelectedPageId.HasValue)">
                            <i class="bi bi-trash3 me-1"></i>Move to Trash
                        </button>
                    </div>

                    @if (SelectedPageId.HasValue)
                    {
                        <div class="cms-block-preview-empty">
                            <i class="bi bi-magic"></i>
                            <div>
                                <strong>Edit this page's content in the Studio.</strong>
                                <div class="text-secondary mb-2">Add sections and widgets, write copy, and build forms visually — changes go live the moment you save.</div>
                                <button class="btn btn-primary" @onclick="() => OpenStudio(SelectedPageId.Value)">
                                    <i class="bi bi-magic me-1"></i>Open Studio
                                </button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-secondary small mb-0">Save this page's details first, then open the Studio to build its content.</p>
                    }
                }
            </div>
        </div>

        @if (SelectedPageId.HasValue)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center gap-3">
                    <div>
                        <div class="fw-semibold">Form Submissions</div>
                        <div class="small text-secondary">Visitor submissions from this page's form widgets.</div>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="LoadFormSubmissionsAsync" disabled="@IsSubmissionsBusy">
                        <i class="bi bi-arrow-repeat me-1"></i>Refresh
                    </button>
                </div>
                <div class="card-body p-0">
                    @if (!string.IsNullOrEmpty(SubmissionsErrorMessage))
                    {
                        <div class="alert alert-danger m-3 mb-0 py-2 small">@SubmissionsErrorMessage</div>
                    }
                    @if (FormSubmissions.Count == 0)
                    {
                        <div class="p-4">
                            <p class="text-secondary mb-0">No submissions yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var submission in FormSubmissions)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <div class="fw-semibold">
                                                @submission.CreatedAt.ToLocalTime().ToString("g")
                                                @if (!submission.IsRead)
                                                {
                                                    <span class="badge text-bg-primary ms-2">New</span>
                                                }
                                            </div>
                                            <dl class="row small mb-0 mt-2">
                                                @foreach (var field in ParseSubmissionFields(submission.FieldsJson))
                                                {
                                                    <dt class="col-4 text-secondary">@field.Key</dt>
                                                    <dd class="col-8">@field.Value</dd>
                                                }
                                            </dl>
                                        </div>
                                        <div class="d-flex flex-column gap-1 flex-shrink-0">
                                            @if (!submission.IsRead)
                                            {
                                                <button class="btn btn-xs btn-outline-secondary" @onclick="() => MarkSubmissionReadAsync(submission.Id)">Mark read</button>
                                            }
                                            <button class="btn btn-xs btn-outline-danger" @onclick="() => DeleteSubmissionAsync(submission.Id)">Delete</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        @if (SelectedPageId.HasValue)
        {
            <div class="card border-0 shadow-sm mt-4">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center gap-3">
                    <div>
                        <div class="fw-semibold">Revision History</div>
                        <div class="small text-secondary">Snapshots captured before each save. Restoring a revision saves a checkpoint first so you can undo it.</div>
                    </div>
                    <span class="badge text-bg-secondary">@PageRevisions.Count revision@(PageRevisions.Count == 1 ? "" : "s")</span>
                </div>
                <div class="card-body p-0">
                    @if (!string.IsNullOrEmpty(RevisionErrorMessage))
                    {
                        <div class="alert alert-danger m-3 mb-0 py-2 small">@RevisionErrorMessage</div>
                    }
                    @if (PageRevisions.Count == 0)
                    {
                        <div class="p-4">
                            <p class="text-secondary mb-0">No revisions yet — a snapshot is captured automatically before each save.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var rev in PageRevisions)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <div class="fw-semibold small">
                                                <span class="badge text-bg-secondary me-1">#@rev.RevisionNumber</span>
                                                @if (!string.IsNullOrWhiteSpace(rev.Label))
                                                {
                                                    <span class="text-secondary">@rev.Label</span>
                                                }
                                                else
                                                {
                                                    <span>@rev.Title</span>
                                                }
                                            </div>
                                            <div class="small text-secondary mt-1">
                                                @rev.CreatedAt.ToLocalTime().ToString("g")
                                                @if (!string.IsNullOrWhiteSpace(rev.Label) && rev.Label != rev.Title)
                                                {
                                                    <span> · @rev.Title</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="d-flex gap-1 flex-shrink-0">
                                            <button class="btn btn-xs btn-outline-secondary" @onclick="() => PreviewRevision(rev)">
                                                Preview
                                            </button>
                                            <button class="btn btn-xs btn-outline-primary" @onclick="() => RestoreRevisionAsync(rev.Id)"
                                                    disabled="@IsRevisionBusy">
                                                Restore
                                            </button>
                                            <button class="btn btn-xs btn-outline-danger" @onclick="() => DeleteRevisionAsync(rev.Id)"
                                                    disabled="@IsRevisionBusy">
                                                Delete
                                            </button>
                                        </div>
                                    </div>
                                    @if (PreviewedRevisionId == rev.Id)
                                    {
                                        <div class="mt-3 border-top pt-3">
                                            <div class="small fw-semibold text-secondary mb-2">Preview of revision #@rev.RevisionNumber</div>
                                            <CmsBlockPreview BlocksJson="@rev.BlocksJson" />
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

</div>

@code {
    private static readonly JsonSerializerOptions NavJsonOptions = new() { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };

    private CmsSite? CurrentSite { get; set; }
    private string SiteCustomCssInput { get; set; } = string.Empty;
    private string SiteAccentColorInput { get; set; } = "#f59e0b";
    private string SiteFontPairingInput { get; set; } = CmsFontPairings.Elegant;
    private List<NavMenuItem> NavMenuItems { get; set; } = new();
    private List<NavMenuItem> FooterNavMenuItems { get; set; } = new();
    private string ActiveNavLocation { get; set; } = "Primary";
    private List<CmsPage> CmsPages { get; set; } = new();
    private List<CmsWorkflowBlueprintSummary> CmsBlueprints { get; set; } = new();
    private CmsPageEditorModel PageEditor { get; set; } = new() { BlocksJson = "{\"sections\":[]}" };
    private Guid? SelectedSiteId { get; set; }
    private Guid? SelectedPageId { get; set; }
    private bool IsCmsBusy { get; set; }
    private string CmsStatusMessage { get; set; } = string.Empty;
    private string CmsErrorMessage { get; set; } = string.Empty;
    private string SelectedBlueprintKey { get; set; } = string.Empty;
    private bool ReplaceExistingBlocks { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadCmsWorkspaceAsync();
        await LoadMediaAssetsAsync();
    }

    private async Task LoadCmsWorkspaceAsync()
    {
        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;
        CmsStatusMessage = string.Empty;

        try
        {
            CmsBlueprints = (await CmsBuilderService.ListWorkflowBlueprintsAsync()).ToList();
            await LoadDefaultSiteAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load structured CMS workspace.");
            CmsErrorMessage = $"Unable to load structured CMS workspace. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    // Canvas manages exactly one site — the one behind the live React frontend,
    // identified by Canvas:SiteSlug — rather than exposing general multi-site CRUD.
    // It's auto-provisioned on first load if it doesn't exist yet.
    private async Task LoadDefaultSiteAsync()
    {
        var slug = Configuration["Canvas:SiteSlug"] ?? "grantwatson-dev";
        var name = Configuration["Canvas:SiteName"] ?? slug;

        var site = await CmsBuilderService.GetSiteBySlugAsync(slug);
        if (site is null)
        {
            site = await CmsBuilderService.SaveSiteAsync(new CmsSiteEditorModel
            {
                Name = name,
                Slug = slug,
                Theme = "Default"
            });
        }

        CurrentSite = site;
        SelectedSiteId = site.Id;
        SiteCustomCssInput = site.CustomCss;
        SiteAccentColorInput = site.AccentColorHex;
        SiteFontPairingInput = site.FontPairingKey;
        NavMenuItems = ParseNavMenuJson(site.NavMenuJson);
        FooterNavMenuItems = ParseNavMenuJson(site.FooterNavMenuJson);

        CmsPages = (await CmsBuilderService.ListPagesAsync(site.Id)).ToList();
        TrashedPages = (await CmsBuilderService.ListTrashedPagesAsync(site.Id)).ToList();

        if (!SelectedPageId.HasValue || CmsPages.All(page => page.Id != SelectedPageId.Value))
        {
            if (CmsPages.Count > 0)
            {
                await LoadSelectedPageAsync(CmsPages[0].Id, updateStatus: false);
            }
            else
            {
                CreateNewPage();
            }
        }
    }

    private async Task SaveSiteSettingsAsync()
    {
        if (CurrentSite is null) return;

        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;
        CmsStatusMessage = string.Empty;

        try
        {
            var saved = await CmsBuilderService.SaveSiteAsync(new CmsSiteEditorModel
            {
                SiteId = CurrentSite.Id,
                Name = CurrentSite.Name,
                Slug = CurrentSite.Slug,
                Theme = CurrentSite.Theme,
                CustomCss = SiteCustomCssInput,
                NavMenuJson = JsonSerializer.Serialize(NavMenuItems, NavJsonOptions),
                FooterNavMenuJson = JsonSerializer.Serialize(FooterNavMenuItems, NavJsonOptions),
                AccentColorHex = SiteAccentColorInput,
                FontPairingKey = SiteFontPairingInput
            });
            CurrentSite = saved;
            SiteAccentColorInput = saved.AccentColorHex;
            SiteFontPairingInput = saved.FontPairingKey;
            NavMenuItems = ParseNavMenuJson(saved.NavMenuJson);
            FooterNavMenuItems = ParseNavMenuJson(saved.FooterNavMenuJson);
            CmsStatusMessage = "Saved site settings.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to save CMS site settings.");
            CmsErrorMessage = $"Unable to save site settings. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    // ── Site navigation ──────────────────────────────────────────────────────

    private static List<NavMenuItem> ParseNavMenuJson(string navMenuJson)
    {
        if (string.IsNullOrWhiteSpace(navMenuJson))
        {
            return new();
        }

        try
        {
            return JsonSerializer.Deserialize<List<NavMenuItem>>(navMenuJson, NavJsonOptions) ?? new();
        }
        catch (JsonException)
        {
            return new();
        }
    }

    // Shared by both the Primary and Footer editors below — each just passes in whichever
    // list ("NavMenuItems" or "FooterNavMenuItems") is currently active, so there's one copy
    // of the add/update/remove/reorder logic instead of two.
    private void AddNavItem(List<NavMenuItem> items)
    {
        items.Add(new NavMenuItem(Guid.NewGuid().ToString("N")[..8], "New Link", "/", false));
    }

    private void UpdateNavItem(List<NavMenuItem> items, int index, NavMenuItem updated)
    {
        if (index < 0 || index >= items.Count) return;
        items[index] = updated;
    }

    private void RemoveNavItem(List<NavMenuItem> items, int index)
    {
        if (index < 0 || index >= items.Count) return;
        items.RemoveAt(index);
    }

    private void MoveNavItem(List<NavMenuItem> items, int index, int direction)
    {
        var target = index + direction;
        if (index < 0 || index >= items.Count || target < 0 || target >= items.Count) return;
        (items[index], items[target]) = (items[target], items[index]);
    }

    private bool IsCurrentPageInNav()
    {
        var path = "/" + PreviewFullPath();
        return NavMenuItems.Any(n => string.Equals(n.Href, path, StringComparison.OrdinalIgnoreCase));
    }

    private async Task AddCurrentPageToNavAsync()
    {
        if (string.IsNullOrWhiteSpace(PageEditor.Title) || string.IsNullOrWhiteSpace(PageEditor.Slug)) return;

        NavMenuItems.Add(new NavMenuItem(Guid.NewGuid().ToString("N")[..8], PageEditor.Title, "/" + PreviewFullPath(), false));
        await SaveSiteSettingsAsync();
    }

    // ── Page hierarchy ───────────────────────────────────────────────────────

    // Top-level pages in their existing order, each immediately followed by its own
    // descendants (depth-first) — a simple indented list rather than a collapsible tree,
    // which is enough at the scale of a personal site's page count.
    private List<CmsPage> OrderedPagesByHierarchy()
    {
        var byParent = CmsPages.ToLookup(p => p.ParentPageId);
        var result = new List<CmsPage>();

        void Visit(Guid? parentId)
        {
            foreach (var page in byParent[parentId])
            {
                result.Add(page);
                Visit(page.Id);
            }
        }

        Visit(null);
        return result;
    }

    private int GetPageDepth(CmsPage page)
    {
        var byId = CmsPages.ToDictionary(p => p.Id);
        var depth = 0;
        var current = page;
        var guard = 0;
        while (current?.ParentPageId is { } parentId && byId.TryGetValue(parentId, out var parent) && guard++ < 64)
        {
            depth++;
            current = parent;
        }

        return depth;
    }

    private string BuildFullPath(CmsPage page) => CmsBuilderService.BuildFullPath(page, CmsPages);

    // Full path preview for the page currently being edited, which may not be saved yet —
    // can't look it up in CmsPages, so it walks the selected parent's ancestry directly
    // and appends the in-progress slug.
    private string PreviewFullPath()
    {
        var slug = string.IsNullOrWhiteSpace(PageEditor.Slug) ? "" : PageEditor.Slug.Trim();
        if (PageEditor.ParentPageId is not { } parentId)
        {
            return slug;
        }

        var byId = CmsPages.ToDictionary(p => p.Id);
        return byId.TryGetValue(parentId, out var parent)
            ? $"{BuildFullPath(parent)}/{slug}"
            : slug;
    }

    // Every page in the site except the one being edited and its own descendants —
    // choosing either as a parent would create a cycle (CmsBuilderService rejects this
    // too, but filtering the dropdown avoids the round-trip error).
    private List<CmsPage> ParentPageOptions()
    {
        if (!SelectedPageId.HasValue)
        {
            return CmsPages;
        }

        var byParent = CmsPages.ToLookup(p => p.ParentPageId);
        var excluded = new HashSet<Guid> { SelectedPageId.Value };
        var frontier = new Queue<Guid>();
        frontier.Enqueue(SelectedPageId.Value);
        while (frontier.Count > 0)
        {
            foreach (var child in byParent[frontier.Dequeue()])
            {
                if (excluded.Add(child.Id)) frontier.Enqueue(child.Id);
            }
        }

        return CmsPages.Where(p => !excluded.Contains(p.Id)).ToList();
    }

    private string ParentPageIdSelection
    {
        get => PageEditor.ParentPageId?.ToString() ?? string.Empty;
        set => PageEditor.ParentPageId = Guid.TryParse(value, out var id) ? id : null;
    }

    private void CreateNewPage()
    {
        SelectedPageId = null;
        PageEditor = new CmsPageEditorModel
        {
            SiteId = SelectedSiteId,
            BlocksJson = "{\"sections\":[]}"
        };
        SelectedBlueprintKey = string.Empty;
        ReplaceExistingBlocks = false;
        FormSubmissions = new();
        PageRevisions = new();
        PreviewedRevisionId = null;
    }

    private async Task OpenPageAsync(Guid pageId)
    {
        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;

        try
        {
            await LoadSelectedPageAsync(pageId, updateStatus: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to open CMS page {PageId}.", pageId);
            CmsErrorMessage = $"Unable to open CMS page. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    private async Task LoadSelectedPageAsync(Guid pageId, bool updateStatus)
    {
        var page = await CmsBuilderService.GetPageAsync(pageId);
        if (page is null)
        {
            CmsErrorMessage = "The selected CMS page no longer exists.";
            CreateNewPage();
            return;
        }

        SelectedPageId = page.Id;
        PageEditor = new CmsPageEditorModel
        {
            PageId = page.Id,
            SiteId = page.SiteId,
            ParentPageId = page.ParentPageId,
            Title = page.Title,
            Slug = page.Slug,
            BlocksJson = page.BlocksJson,
            MetaTitle = page.MetaTitle,
            MetaDescription = page.MetaDescription,
            OgImageUrl = page.OgImageUrl,
            CustomCss = page.CustomCss,
            Status = page.Status
        };

        if (updateStatus)
        {
            CmsStatusMessage = $"Opened CMS page '{page.Title}'.";
        }

        await LoadFormSubmissionsAsync();
        await LoadRevisionsAsync();
    }

    // ── Form submissions ────────────────────────────────────────────────────

    private List<FormSubmission> FormSubmissions { get; set; } = new();
    private bool IsSubmissionsBusy { get; set; }
    private string SubmissionsErrorMessage { get; set; } = string.Empty;

    private async Task LoadFormSubmissionsAsync()
    {
        if (!SelectedPageId.HasValue)
        {
            FormSubmissions = new();
            return;
        }

        IsSubmissionsBusy = true;
        SubmissionsErrorMessage = string.Empty;

        try
        {
            FormSubmissions = (await FormSubmissionService.ListAsync(SelectedPageId.Value)).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load form submissions for page {PageId}.", SelectedPageId);
            SubmissionsErrorMessage = $"Unable to load form submissions. {ex.Message}";
        }
        finally
        {
            IsSubmissionsBusy = false;
        }
    }

    private async Task MarkSubmissionReadAsync(Guid submissionId)
    {
        await FormSubmissionService.MarkReadAsync(submissionId);
        await LoadFormSubmissionsAsync();
    }

    private async Task DeleteSubmissionAsync(Guid submissionId)
    {
        await FormSubmissionService.DeleteAsync(submissionId);
        await LoadFormSubmissionsAsync();
    }

    private static Dictionary<string, string> ParseSubmissionFields(string fieldsJson)
    {
        try
        {
            return JsonSerializer.Deserialize<Dictionary<string, string>>(
                string.IsNullOrWhiteSpace(fieldsJson) ? "{}" : fieldsJson) ?? [];
        }
        catch
        {
            return [];
        }
    }

    // ── Revision history ────────────────────────────────────────────────────

    private List<CmsPageRevision> PageRevisions { get; set; } = new();
    private bool IsRevisionBusy { get; set; }
    private string RevisionErrorMessage { get; set; } = string.Empty;
    private Guid? PreviewedRevisionId { get; set; }

    private async Task LoadRevisionsAsync()
    {
        if (!SelectedPageId.HasValue)
        {
            PageRevisions = new();
            return;
        }

        try
        {
            PageRevisions = (await PageRevisionService.ListAsync(SelectedPageId.Value)).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load revisions for page {PageId}.", SelectedPageId);
            RevisionErrorMessage = $"Unable to load revisions. {ex.Message}";
        }
    }

    private void PreviewRevision(CmsPageRevision revision)
    {
        PreviewedRevisionId = PreviewedRevisionId == revision.Id ? null : revision.Id;
    }

    private async Task RestoreRevisionAsync(Guid revisionId)
    {
        if (!SelectedPageId.HasValue) return;

        IsRevisionBusy = true;
        RevisionErrorMessage = string.Empty;

        try
        {
            var restored = await PageRevisionService.RestoreAsync(SelectedPageId.Value, revisionId);
            CmsPages = (await CmsBuilderService.ListPagesAsync(SelectedSiteId!.Value)).ToList();
            await LoadSelectedPageAsync(restored.Id, updateStatus: false);
            PreviewedRevisionId = null;
            CmsStatusMessage = "Revision restored. A checkpoint of the previous state was saved as the latest revision.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to restore revision {RevisionId}.", revisionId);
            RevisionErrorMessage = $"Unable to restore revision. {ex.Message}";
        }
        finally
        {
            IsRevisionBusy = false;
        }
    }

    private async Task DeleteRevisionAsync(Guid revisionId)
    {
        IsRevisionBusy = true;
        try
        {
            await PageRevisionService.DeleteAsync(revisionId);
            await LoadRevisionsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to delete revision {RevisionId}.", revisionId);
            RevisionErrorMessage = $"Unable to delete revision. {ex.Message}";
        }
        finally
        {
            IsRevisionBusy = false;
        }
    }

    private async Task SavePageAsync()
    {
        if (!SelectedSiteId.HasValue)
        {
            CmsErrorMessage = "Create or select a CMS site before saving pages.";
            return;
        }

        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;
        CmsStatusMessage = string.Empty;

        try
        {
            // Checkpoint the current state before overwriting so any save is undoable.
            if (SelectedPageId.HasValue)
            {
                var currentPage = await CmsBuilderService.GetPageAsync(SelectedPageId.Value);
                if (currentPage is not null)
                {
                    await PageRevisionService.CreateRevisionAsync(currentPage);
                }
            }

            PageEditor.SiteId = SelectedSiteId;
            var saved = await CmsBuilderService.SavePageAsync(PageEditor);
            SelectedPageId = saved.Id;
            CmsPages = (await CmsBuilderService.ListPagesAsync(SelectedSiteId.Value)).ToList();
            await LoadSelectedPageAsync(saved.Id, updateStatus: false);
            CmsStatusMessage = $"Saved CMS page '{saved.Title}'.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to save CMS page.");
            CmsErrorMessage = $"Unable to save CMS page. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    // Publish/Unpublish is just a status flip + the normal save path — reuses SavePageAsync
    // so it gets the same revision checkpoint (unpublishing is undoable like any other edit).
    private async Task SetStatusAndSaveAsync(string status)
    {
        PageEditor.Status = status;
        await SavePageAsync();
    }

    private async Task TrashSelectedPageAsync()
    {
        if (!SelectedPageId.HasValue || !SelectedSiteId.HasValue)
        {
            return;
        }

        var pageId = SelectedPageId.Value;
        var siteId = SelectedSiteId.Value;

        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;
        CmsStatusMessage = string.Empty;

        try
        {
            await CmsBuilderService.TrashPageAsync(pageId);
            SelectedPageId = null;
            CmsPages = (await CmsBuilderService.ListPagesAsync(siteId)).ToList();
            TrashedPages = (await CmsBuilderService.ListTrashedPagesAsync(siteId)).ToList();
            if (CmsPages.Count > 0)
            {
                await LoadSelectedPageAsync(CmsPages[0].Id, updateStatus: false);
            }
            else
            {
                CreateNewPage();
            }

            CmsStatusMessage = "Moved the page to Trash.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to trash CMS page {PageId}.", pageId);
            CmsErrorMessage = $"Unable to move page to Trash. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    // ── Trash ────────────────────────────────────────────────────────────────

    private List<CmsPage> TrashedPages { get; set; } = new();
    private bool ShowTrash { get; set; }

    private async Task ToggleTrashViewAsync()
    {
        ShowTrash = !ShowTrash;
        if (ShowTrash && SelectedSiteId.HasValue)
        {
            IsCmsBusy = true;
            try
            {
                TrashedPages = (await CmsBuilderService.ListTrashedPagesAsync(SelectedSiteId.Value)).ToList();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Unable to load trashed pages.");
                CmsErrorMessage = $"Unable to load Trash. {ex.Message}";
            }
            finally
            {
                IsCmsBusy = false;
            }
        }
    }

    private async Task RestoreTrashedPageAsync(Guid pageId)
    {
        if (!SelectedSiteId.HasValue) return;

        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;
        CmsStatusMessage = string.Empty;

        try
        {
            await CmsBuilderService.RestorePageAsync(pageId);
            TrashedPages = (await CmsBuilderService.ListTrashedPagesAsync(SelectedSiteId.Value)).ToList();
            CmsPages = (await CmsBuilderService.ListPagesAsync(SelectedSiteId.Value)).ToList();
            CmsStatusMessage = "Restored the page from Trash.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to restore CMS page {PageId}.", pageId);
            CmsErrorMessage = $"Unable to restore page. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    private async Task PermanentlyDeleteTrashedPageAsync(Guid pageId)
    {
        if (!SelectedSiteId.HasValue) return;

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Permanently delete this page? This cannot be undone.");
        if (!confirmed) return;

        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;
        CmsStatusMessage = string.Empty;

        try
        {
            await CmsBuilderService.DeletePageAsync(pageId);
            TrashedPages = (await CmsBuilderService.ListTrashedPagesAsync(SelectedSiteId.Value)).ToList();
            CmsStatusMessage = "Permanently deleted the page.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to permanently delete CMS page {PageId}.", pageId);
            CmsErrorMessage = $"Unable to permanently delete page. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    private async Task ApplyBlueprintAsync()
    {
        if (!SelectedPageId.HasValue || string.IsNullOrWhiteSpace(SelectedBlueprintKey))
        {
            return;
        }

        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;
        CmsStatusMessage = string.Empty;

        try
        {
            var updated = await CmsBuilderService.ApplyWorkflowBlueprintAsync(
                SelectedPageId.Value,
                SelectedBlueprintKey,
                ReplaceExistingBlocks);

            await LoadSelectedPageAsync(updated.Id, updateStatus: false);
            CmsStatusMessage = $"Applied blueprint '{SelectedBlueprintKey}' to '{updated.Title}'.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to apply blueprint {BlueprintKey} to page {PageId}.", SelectedBlueprintKey, SelectedPageId.Value);
            CmsErrorMessage = $"Unable to apply blueprint. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    // Points at the real live site (Canvas:PublicBaseUrl, e.g. https://grantwatson.dev), not
    // the bare /cms/ SSR fallback — that stopped being the actual site once grantwatson.dev
    // moved to the RequireHost-gated routes in Program.cs.
    private string? LivePageUrl =>
        !string.IsNullOrWhiteSpace(PageEditor.Slug)
            ? $"{(Configuration["Canvas:PublicBaseUrl"] ?? string.Empty).TrimEnd('/')}/{PreviewFullPath()}"
            : null;

    private void OpenStudio(Guid pageId) => Navigation.NavigateTo($"/admin/canvas/editor/{pageId}");

    private string? SiteExportUrl =>
        CurrentSite is { } exportSite
            ? $"/admin/api/cms/{exportSite.Slug}/export.zip"
            : null;

    // ── Media library ───────────────────────────────────────────────────────

    private List<MediaAssetSummary> MediaAssets { get; set; } = new();
    private bool IsMediaBusy { get; set; }
    private string MediaErrorMessage { get; set; } = string.Empty;
    private string MediaStatusMessage { get; set; } = string.Empty;
    private string MediaAltTextInput { get; set; } = string.Empty;

    private async Task LoadMediaAssetsAsync()
    {
        try
        {
            MediaAssets = (await MediaLibraryService.ListAsync()).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load media library.");
            MediaErrorMessage = $"Unable to load media library. {ex.Message}";
        }
    }

    private async Task OnMediaFileSelectedAsync(InputFileChangeEventArgs e)
    {
        IsMediaBusy = true;
        MediaErrorMessage = string.Empty;
        MediaStatusMessage = string.Empty;

        try
        {
            const long maxFileBytes = 8 * 1024 * 1024;
            var file = e.File;
            using var stream = file.OpenReadStream(maxFileBytes);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);

            var uploaded = await MediaLibraryService.UploadAsync(
                file.Name,
                memory.ToArray(),
                MediaAltTextInput);

            MediaAltTextInput = string.Empty;
            await LoadMediaAssetsAsync();
            MediaStatusMessage = $"Uploaded '{uploaded.FileName}'.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to upload media asset.");
            MediaErrorMessage = $"Unable to upload file. {ex.Message}";
        }
        finally
        {
            IsMediaBusy = false;
        }
    }

    private async Task DeleteMediaAssetAsync(Guid mediaAssetId)
    {
        IsMediaBusy = true;
        MediaErrorMessage = string.Empty;

        try
        {
            await MediaLibraryService.DeleteAsync(mediaAssetId);
            await LoadMediaAssetsAsync();
            MediaStatusMessage = "Deleted media asset.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to delete media asset {MediaAssetId}.", mediaAssetId);
            MediaErrorMessage = $"Unable to delete media asset. {ex.Message}";
        }
        finally
        {
            IsMediaBusy = false;
        }
    }

    private void InsertImageBlock(string url, string altText)
    {
        var node = System.Text.Json.Nodes.JsonNode.Parse(
            string.IsNullOrWhiteSpace(PageEditor.BlocksJson) ? "[]" : PageEditor.BlocksJson) as System.Text.Json.Nodes.JsonArray
            ?? new System.Text.Json.Nodes.JsonArray();

        node.Add(new System.Text.Json.Nodes.JsonObject
        {
            ["type"] = "image",
            ["src"] = url,
            ["alt"] = altText
        });

        PageEditor.BlocksJson = node.ToJsonString(new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        MediaStatusMessage = "Inserted image block into the page's Blocks JSON.";
    }
}
