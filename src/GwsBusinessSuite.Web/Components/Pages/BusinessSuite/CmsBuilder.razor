@page "/cms-builder"
@rendermode InteractiveServer
@using GwsBusinessSuite.Application.CmsBuilder
@inject IReactPageBuilderService ReactPageBuilderService
@inject NavigationManager Navigation
@inject ILogger<CmsBuilder> Logger

<PageTitle>CMS Builder</PageTitle>

<div class="page-header">
  <h1><i class="bi bi-window-stack me-2 text-primary"></i>CMS Builder</h1>
    <p>Manage live React pages and open each page in the visual builder workspace.</p>
</div>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
  <div class="alert alert-danger d-flex align-items-start gap-2 mb-4" role="alert">
    <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
    <div>@ErrorMessage</div>
  </div>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
  <div class="alert alert-info d-flex align-items-center gap-2 mb-4" role="alert">
    <i class="bi bi-info-circle-fill flex-shrink-0"></i>
    <div>@StatusMessage</div>
  </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between gap-2">
        <span class="fw-semibold">Active React Pages</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="LoadPagesAsync" disabled="@IsBusy">
            <i class="bi bi-arrow-repeat me-1"></i>Refresh
        </button>
    </div>
    <div class="card-body">
        @if (ReactPages.Count == 0)
        {
            <p class="text-secondary mb-0">No React pages were discovered from the connected app.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Page</th>
                            <th>Route</th>
                            <th>React File</th>
                            <th class="text-end">Builder</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reactPage in ReactPages)
                        {
                            <tr>
                                <td class="fw-semibold">@reactPage.DisplayName</td>
                                <td class="font-monospace">@reactPage.RoutePath</td>
                                <td class="small text-secondary">
                                    <a href="@BuildFileOpenLink(reactPage.FilePath)">@reactPage.FilePath</a>
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-primary"
                                            @onclick="() => OpenVisualBuilder(reactPage.PageKey)">
                                        Open Visual Builder
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<ReactPageReference> ReactPages { get; set; } = new();
    private bool IsBusy { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadPagesAsync();
    }

    private async Task LoadPagesAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            ReactPages = (await ReactPageBuilderService.ListReactPagesAsync()).ToList();
            StatusMessage = $"Loaded {ReactPages.Count} React pages from the active app.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load React pages for CMS Builder.");
            ErrorMessage = $"Unable to load React pages. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void OpenVisualBuilder(string pageKey)
    {
        Navigation.NavigateTo($"/cms-builder/editor/{Uri.EscapeDataString(pageKey)}");
    }

    private static string BuildFileOpenLink(string filePath)
    {
        return $"vscode://file/{Uri.EscapeDataString(filePath)}";
    }
}
