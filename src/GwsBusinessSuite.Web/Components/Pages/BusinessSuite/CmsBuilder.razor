@page "/admin/canvas"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = "ContributorAccess")]
@using Microsoft.AspNetCore.Authorization
@using GwsBusinessSuite.Application.CmsBuilder
@using GwsBusinessSuite.Domain.Entities
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.Json
@inject ICmsBuilderService CmsBuilderService
@inject IMediaLibraryService MediaLibraryService
@inject IFormSubmissionService FormSubmissionService
@inject IPageRevisionService PageRevisionService
@inject NavigationManager Navigation
@inject ILogger<CmsBuilder> Logger

<PageTitle>Canvas</PageTitle>

<div class="cms-builder-shell">

<div class="cms-builder-exit">
    <a href="/admin" class="cms-builder-exit-link">
        <i class="bi bi-arrow-left"></i>Exit to Dashboard
    </a>
    <a href="/auth/logout" class="cms-builder-exit-link cms-builder-exit-link-subtle">Sign Out</a>
</div>

<div class="cms-builder-hero page-header">
    <div>
        <div class="cms-builder-kicker">Visual editing studio</div>
        <h1><i class="bi bi-window-stack me-2 text-primary"></i>Canvas</h1>
        <p>Build and edit every page on the live site here — no code, no deploy. Create sites, add pages, and edit their content and forms; changes go live immediately.</p>
    </div>

    <div class="cms-builder-hero-metrics">
        <div class="cms-builder-metric">
            <span>CMS sites</span>
            <strong>@CmsSites.Count</strong>
        </div>
        <div class="cms-builder-metric">
            <span>Selected site pages</span>
            <strong>@CmsPages.Count</strong>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(CmsErrorMessage))
{
    <div class="alert alert-danger d-flex align-items-start gap-2 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
        <div>@CmsErrorMessage</div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(CmsStatusMessage))
{
    <div class="alert alert-info d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="bi bi-info-circle-fill flex-shrink-0"></i>
        <div>@CmsStatusMessage</div>
    </div>
}

<div class="row g-4">
    <div class="col-xl-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center gap-3">
                <div>
                    <div class="fw-semibold">Structured CMS Sites</div>
                    <div class="small text-secondary">Persisted CMS site records backed by the internal page model.</div>
                </div>
                <button class="btn btn-sm btn-outline-primary" @onclick="CreateNewSite" disabled="@IsCmsBusy">
                    <i class="bi bi-plus-lg me-1"></i>New Site
                </button>
            </div>
            <div class="card-body p-0">
                @if (CmsSites.Count == 0)
                {
                    <div class="p-4">
                        <p class="text-secondary mb-0">No CMS sites exist yet. Create a site record to start building structured pages.</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var site in CmsSites)
                        {
                            <button type="button"
                                    class="list-group-item list-group-item-action @(SelectedSiteId == site.Id ? "active" : string.Empty)"
                                    @onclick="() => OpenSiteAsync(site.Id)"
                                    disabled="@IsCmsBusy">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div>
                                        <div class="fw-semibold">@site.Name</div>
                                        <div class="small @(SelectedSiteId == site.Id ? "text-white-50" : "text-secondary")">/@site.Slug</div>
                                    </div>
                                    <span class="badge @(SelectedSiteId == site.Id ? "text-bg-light" : "text-bg-secondary")">@site.Theme</span>
                                </div>
                            </button>
                        }
                    </div>
                }
            </div>
            <div class="card-footer bg-white border-top">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold small">Site Name</label>
                        <InputText class="form-control" @bind-Value="SiteEditor.Name" placeholder="Public Site" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold small">Slug</label>
                        <InputText class="form-control" @bind-Value="SiteEditor.Slug" placeholder="public-site" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold small">Theme</label>
                        <InputText class="form-control" @bind-Value="SiteEditor.Theme" placeholder="Editorial" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold small">Site-wide Custom CSS</label>
                        <InputTextArea class="form-control font-monospace cms-custom-css-editor" @bind-Value="SiteEditor.CustomCss"
                                       placeholder="Applies to every page on this site. Page-level CSS below can override it." spellcheck="false" />
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-3">
                    <button class="btn btn-primary btn-sm" @onclick="SaveSiteAsync" disabled="@IsCmsBusy">Save Site</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CreateNewSite" disabled="@IsCmsBusy">Reset</button>
                    <button class="btn btn-outline-danger btn-sm" @onclick="DeleteSelectedSiteAsync" disabled="@(IsCmsBusy || !SelectedSiteId.HasValue)">Delete</button>
                    @if (SiteExportUrl is { } exportUrl)
                    {
                        <a class="btn btn-sm btn-outline-secondary" href="@exportUrl" download>
                            <i class="bi bi-file-zip me-1"></i>Export ZIP
                        </a>
                    }
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center gap-3">
                <div>
                    <div class="fw-semibold">Pages For Selected Site</div>
                    <div class="small text-secondary">Create, edit, and preview JSON block pages for the active site.</div>
                </div>
                <button class="btn btn-sm btn-outline-primary" @onclick="CreateNewPage" disabled="@(IsCmsBusy || !SelectedSiteId.HasValue)">
                    <i class="bi bi-file-earmark-plus me-1"></i>New Page
                </button>
            </div>
            <div class="card-body p-0">
                @if (!SelectedSiteId.HasValue)
                {
                    <div class="p-4">
                        <p class="text-secondary mb-0">Select or create a site to manage its pages.</p>
                    </div>
                }
                else if (CmsPages.Count == 0)
                {
                    <div class="p-4">
                        <p class="text-secondary mb-0">No pages exist for this site yet.</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var cmsPage in CmsPages)
                        {
                            <button type="button"
                                    class="list-group-item list-group-item-action @(SelectedPageId == cmsPage.Id ? "active" : string.Empty)"
                                    @onclick="() => OpenPageAsync(cmsPage.Id)"
                                    disabled="@IsCmsBusy">
                                <div class="fw-semibold">@cmsPage.Title</div>
                                <div class="small @(SelectedPageId == cmsPage.Id ? "text-white-50" : "text-secondary")">/@cmsPage.Slug</div>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-white border-bottom py-3">
                <div class="fw-semibold">Media Library</div>
                <div class="small text-secondary">Upload images and insert them into the selected page's blocks.</div>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(MediaErrorMessage))
                {
                    <div class="alert alert-danger py-2 small mb-3">@MediaErrorMessage</div>
                }
                @if (!string.IsNullOrEmpty(MediaStatusMessage))
                {
                    <div class="alert alert-info py-2 small mb-3">@MediaStatusMessage</div>
                }

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Alt Text (applied to next upload)</label>
                    <InputText class="form-control form-control-sm mb-2" @bind-Value="MediaAltTextInput" placeholder="Describe the image" />
                    <InputFile OnChange="OnMediaFileSelectedAsync" disabled="@IsMediaBusy" class="form-control form-control-sm" accept="image/*" />
                </div>

                @if (MediaAssets.Count == 0)
                {
                    <p class="text-secondary small mb-0">No media uploaded yet.</p>
                }
                else
                {
                    <div class="cms-media-grid">
                        @foreach (var asset in MediaAssets)
                        {
                            <div class="cms-media-item">
                                <img src="@asset.Url" alt="@asset.AltText" />
                                <div class="cms-media-item-name small text-truncate" title="@asset.FileName">@asset.FileName</div>
                                <div class="d-flex gap-1 mt-1">
                                    <button class="btn btn-xs btn-outline-primary" disabled="@(!SelectedPageId.HasValue)"
                                            @onclick="() => InsertImageBlock(asset.Url, asset.AltText)">
                                        Insert
                                    </button>
                                    <button class="btn btn-xs btn-outline-danger" disabled="@IsMediaBusy"
                                            @onclick="() => DeleteMediaAssetAsync(asset.Id)">
                                        Delete
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center gap-3">
                <div>
                    <div class="fw-semibold">Structured Page Editor</div>
                    <div class="small text-secondary">Edit JSON blocks and preview them as rendered sections without leaving the builder.</div>
                </div>
                <span class="badge @(SelectedPageId.HasValue ? "text-bg-primary" : "text-bg-secondary")">
                    @(SelectedPageId.HasValue ? "Editing Existing Page" : "New Page")
                </span>
            </div>
            <div class="card-body">
                @if (!SelectedSiteId.HasValue)
                {
                    <p class="text-secondary mb-0">Select a site before editing pages.</p>
                }
                else
                {
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Page Title</label>
                            <InputText class="form-control" @bind-Value="PageEditor.Title" placeholder="Home" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Slug</label>
                            <InputText class="form-control" @bind-Value="PageEditor.Slug" placeholder="home" />
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">SEO Meta Title</label>
                            <InputText class="form-control" @bind-Value="PageEditor.MetaTitle" placeholder="Falls back to Page Title if blank" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">OG Image URL</label>
                            <InputText class="form-control" @bind-Value="PageEditor.OgImageUrl" placeholder="/media/{id} or external URL" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">SEO Meta Description</label>
                            <InputText class="form-control" @bind-Value="PageEditor.MetaDescription" placeholder="Shown in search results and link previews" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Page Custom CSS</label>
                            <InputTextArea class="form-control font-monospace cms-custom-css-editor" @bind-Value="PageEditor.CustomCss"
                                           placeholder="Applies only to this page, after the site-wide CSS." spellcheck="false" />
                        </div>
                    </div>

                    @if (LivePageUrl is { } livePageUrl && SelectedPageId.HasValue)
                    {
                        <div class="mb-3">
                            <a class="btn btn-sm btn-outline-success" href="@livePageUrl" target="_blank" rel="noopener noreferrer">
                                <i class="bi bi-box-arrow-up-right me-1"></i>View Live Page
                            </a>
                        </div>
                    }

                    <div class="cms-structured-toolbar mb-3">
                        <div class="cms-structured-toolbar-group">
                            <label class="form-label fw-semibold small mb-1">Workflow Blueprint</label>
                            <select class="form-select" @bind="SelectedBlueprintKey">
                                <option value="">Select blueprint</option>
                                @foreach (var blueprint in CmsBlueprints)
                                {
                                    <option value="@blueprint.Key">@blueprint.Name (@blueprint.Category)</option>
                                }
                            </select>
                        </div>
                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox" id="replaceExistingBlocks" @bind="ReplaceExistingBlocks" />
                            <label class="form-check-label small" for="replaceExistingBlocks">Replace existing blocks</label>
                        </div>
                        <div class="d-flex gap-2 mt-4">
                            <button class="btn btn-outline-secondary btn-sm" @onclick="ApplyBlueprintAsync" disabled="@(IsCmsBusy || !SelectedPageId.HasValue || string.IsNullOrWhiteSpace(SelectedBlueprintKey))">
                                Apply Blueprint
                            </button>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <button class="btn btn-primary" @onclick="SavePageAsync" disabled="@IsCmsBusy">Save Page Details</button>
                        <button class="btn btn-outline-secondary" @onclick="CreateNewPage" disabled="@IsCmsBusy">Reset</button>
                        <button class="btn btn-outline-danger" @onclick="DeleteSelectedPageAsync" disabled="@(IsCmsBusy || !SelectedPageId.HasValue)">Delete</button>
                    </div>

                    @if (SelectedPageId.HasValue)
                    {
                        <div class="cms-block-preview-empty">
                            <i class="bi bi-magic"></i>
                            <div>
                                <strong>Edit this page's content in the Studio.</strong>
                                <div class="text-secondary mb-2">Add sections and widgets, write copy, and build forms visually — changes go live the moment you save.</div>
                                <button class="btn btn-primary" @onclick="() => OpenStudio(SelectedPageId.Value)">
                                    <i class="bi bi-magic me-1"></i>Open Studio
                                </button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-secondary small mb-0">Save this page's details first, then open the Studio to build its content.</p>
                    }
                }
            </div>
        </div>

        @if (SelectedPageId.HasValue)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center gap-3">
                    <div>
                        <div class="fw-semibold">Form Submissions</div>
                        <div class="small text-secondary">Visitor submissions from this page's form widgets.</div>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="LoadFormSubmissionsAsync" disabled="@IsSubmissionsBusy">
                        <i class="bi bi-arrow-repeat me-1"></i>Refresh
                    </button>
                </div>
                <div class="card-body p-0">
                    @if (!string.IsNullOrEmpty(SubmissionsErrorMessage))
                    {
                        <div class="alert alert-danger m-3 mb-0 py-2 small">@SubmissionsErrorMessage</div>
                    }
                    @if (FormSubmissions.Count == 0)
                    {
                        <div class="p-4">
                            <p class="text-secondary mb-0">No submissions yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var submission in FormSubmissions)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <div class="fw-semibold">
                                                @submission.CreatedAt.ToLocalTime().ToString("g")
                                                @if (!submission.IsRead)
                                                {
                                                    <span class="badge text-bg-primary ms-2">New</span>
                                                }
                                            </div>
                                            <dl class="row small mb-0 mt-2">
                                                @foreach (var field in ParseSubmissionFields(submission.FieldsJson))
                                                {
                                                    <dt class="col-4 text-secondary">@field.Key</dt>
                                                    <dd class="col-8">@field.Value</dd>
                                                }
                                            </dl>
                                        </div>
                                        <div class="d-flex flex-column gap-1 flex-shrink-0">
                                            @if (!submission.IsRead)
                                            {
                                                <button class="btn btn-xs btn-outline-secondary" @onclick="() => MarkSubmissionReadAsync(submission.Id)">Mark read</button>
                                            }
                                            <button class="btn btn-xs btn-outline-danger" @onclick="() => DeleteSubmissionAsync(submission.Id)">Delete</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        @if (SelectedPageId.HasValue)
        {
            <div class="card border-0 shadow-sm mt-4">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center gap-3">
                    <div>
                        <div class="fw-semibold">Revision History</div>
                        <div class="small text-secondary">Snapshots captured before each save. Restoring a revision saves a checkpoint first so you can undo it.</div>
                    </div>
                    <span class="badge text-bg-secondary">@PageRevisions.Count revision@(PageRevisions.Count == 1 ? "" : "s")</span>
                </div>
                <div class="card-body p-0">
                    @if (!string.IsNullOrEmpty(RevisionErrorMessage))
                    {
                        <div class="alert alert-danger m-3 mb-0 py-2 small">@RevisionErrorMessage</div>
                    }
                    @if (PageRevisions.Count == 0)
                    {
                        <div class="p-4">
                            <p class="text-secondary mb-0">No revisions yet — a snapshot is captured automatically before each save.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var rev in PageRevisions)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <div class="fw-semibold small">
                                                <span class="badge text-bg-secondary me-1">#@rev.RevisionNumber</span>
                                                @if (!string.IsNullOrWhiteSpace(rev.Label))
                                                {
                                                    <span class="text-secondary">@rev.Label</span>
                                                }
                                                else
                                                {
                                                    <span>@rev.Title</span>
                                                }
                                            </div>
                                            <div class="small text-secondary mt-1">
                                                @rev.CreatedAt.ToLocalTime().ToString("g")
                                                @if (!string.IsNullOrWhiteSpace(rev.Label) && rev.Label != rev.Title)
                                                {
                                                    <span> · @rev.Title</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="d-flex gap-1 flex-shrink-0">
                                            <button class="btn btn-xs btn-outline-secondary" @onclick="() => PreviewRevision(rev)">
                                                Preview
                                            </button>
                                            <button class="btn btn-xs btn-outline-primary" @onclick="() => RestoreRevisionAsync(rev.Id)"
                                                    disabled="@IsRevisionBusy">
                                                Restore
                                            </button>
                                            <button class="btn btn-xs btn-outline-danger" @onclick="() => DeleteRevisionAsync(rev.Id)"
                                                    disabled="@IsRevisionBusy">
                                                Delete
                                            </button>
                                        </div>
                                    </div>
                                    @if (PreviewedRevisionId == rev.Id)
                                    {
                                        <div class="mt-3 border-top pt-3">
                                            <div class="small fw-semibold text-secondary mb-2">Preview of revision #@rev.RevisionNumber</div>
                                            <CmsBlockPreview BlocksJson="@rev.BlocksJson" />
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

</div>

@code {
    private List<CmsSite> CmsSites { get; set; } = new();
    private List<CmsPage> CmsPages { get; set; } = new();
    private List<CmsWorkflowBlueprintSummary> CmsBlueprints { get; set; } = new();
    private CmsSiteEditorModel SiteEditor { get; set; } = new() { Theme = "Default" };
    private CmsPageEditorModel PageEditor { get; set; } = new() { BlocksJson = "{\"sections\":[]}" };
    private Guid? SelectedSiteId { get; set; }
    private Guid? SelectedPageId { get; set; }
    private bool IsCmsBusy { get; set; }
    private string CmsStatusMessage { get; set; } = string.Empty;
    private string CmsErrorMessage { get; set; } = string.Empty;
    private string SelectedBlueprintKey { get; set; } = string.Empty;
    private bool ReplaceExistingBlocks { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadCmsWorkspaceAsync();
        await LoadMediaAssetsAsync();
    }

    private async Task LoadCmsWorkspaceAsync()
    {
        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;
        CmsStatusMessage = string.Empty;

        try
        {
            CmsSites = (await CmsBuilderService.ListSitesAsync()).ToList();
            CmsBlueprints = (await CmsBuilderService.ListWorkflowBlueprintsAsync()).ToList();

            if (!SelectedSiteId.HasValue || CmsSites.All(site => site.Id != SelectedSiteId.Value))
            {
                SelectedSiteId = CmsSites.FirstOrDefault()?.Id;
            }

            if (SelectedSiteId.HasValue)
            {
                await LoadSelectedSiteAsync(SelectedSiteId.Value, updateStatus: false);
            }
            else
            {
                CreateNewSite();
                CreateNewPage();
            }

            CmsStatusMessage = $"Loaded {CmsSites.Count} CMS site{(CmsSites.Count == 1 ? string.Empty : "s")} and {CmsBlueprints.Count} workflow blueprint{(CmsBlueprints.Count == 1 ? string.Empty : "s")}.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load structured CMS workspace.");
            CmsErrorMessage = $"Unable to load structured CMS workspace. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    private void CreateNewSite()
    {
        SelectedSiteId = null;
        SelectedPageId = null;
        CmsPages = new List<CmsPage>();
        SiteEditor = new CmsSiteEditorModel
        {
            Theme = "Default"
        };
        CreateNewPage();
        CmsErrorMessage = string.Empty;
        CmsStatusMessage = "Ready to create a new structured CMS site.";
    }

    private async Task OpenSiteAsync(Guid siteId)
    {
        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;

        try
        {
            await LoadSelectedSiteAsync(siteId, updateStatus: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to open CMS site {SiteId}.", siteId);
            CmsErrorMessage = $"Unable to open CMS site. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    private async Task LoadSelectedSiteAsync(Guid siteId, bool updateStatus)
    {
        var site = await CmsBuilderService.GetSiteAsync(siteId);
        if (site is null)
        {
            CmsErrorMessage = "The selected CMS site no longer exists.";
            SelectedSiteId = null;
            CmsPages = new List<CmsPage>();
            CreateNewSite();
            CreateNewPage();
            return;
        }

        SelectedSiteId = site.Id;
        SiteEditor = new CmsSiteEditorModel
        {
            SiteId = site.Id,
            Name = site.Name,
            Slug = site.Slug,
            Theme = site.Theme,
            CustomCss = site.CustomCss
        };

        CmsPages = (await CmsBuilderService.ListPagesAsync(site.Id)).ToList();

        if (!SelectedPageId.HasValue || CmsPages.All(page => page.Id != SelectedPageId.Value))
        {
            if (CmsPages.Count > 0)
            {
                await LoadSelectedPageAsync(CmsPages[0].Id, updateStatus: false);
            }
            else
            {
                CreateNewPage();
            }
        }

        if (updateStatus)
        {
            CmsStatusMessage = $"Opened CMS site '{site.Name}'.";
        }
    }

    private async Task SaveSiteAsync()
    {
        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;
        CmsStatusMessage = string.Empty;

        try
        {
            var saved = await CmsBuilderService.SaveSiteAsync(SiteEditor);
            SelectedSiteId = saved.Id;
            await LoadCmsWorkspaceAsync();
            CmsStatusMessage = $"Saved CMS site '{saved.Name}'.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to save CMS site.");
            CmsErrorMessage = $"Unable to save CMS site. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    private async Task DeleteSelectedSiteAsync()
    {
        if (!SelectedSiteId.HasValue)
        {
            return;
        }

        var siteId = SelectedSiteId.Value;

        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;
        CmsStatusMessage = string.Empty;

        try
        {
            await CmsBuilderService.DeleteSiteAsync(siteId);
            SelectedSiteId = null;
            SelectedPageId = null;
            CmsPages = new List<CmsPage>();
            await LoadCmsWorkspaceAsync();
            CmsStatusMessage = "Deleted the selected CMS site and its pages.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to delete CMS site {SiteId}.", siteId);
            CmsErrorMessage = $"Unable to delete CMS site. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    private void CreateNewPage()
    {
        SelectedPageId = null;
        PageEditor = new CmsPageEditorModel
        {
            SiteId = SelectedSiteId,
            BlocksJson = "{\"sections\":[]}"
        };
        SelectedBlueprintKey = string.Empty;
        ReplaceExistingBlocks = false;
        FormSubmissions = new();
        PageRevisions = new();
        PreviewedRevisionId = null;
    }

    private async Task OpenPageAsync(Guid pageId)
    {
        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;

        try
        {
            await LoadSelectedPageAsync(pageId, updateStatus: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to open CMS page {PageId}.", pageId);
            CmsErrorMessage = $"Unable to open CMS page. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    private async Task LoadSelectedPageAsync(Guid pageId, bool updateStatus)
    {
        var page = await CmsBuilderService.GetPageAsync(pageId);
        if (page is null)
        {
            CmsErrorMessage = "The selected CMS page no longer exists.";
            CreateNewPage();
            return;
        }

        SelectedPageId = page.Id;
        PageEditor = new CmsPageEditorModel
        {
            PageId = page.Id,
            SiteId = page.SiteId,
            Title = page.Title,
            Slug = page.Slug,
            BlocksJson = page.BlocksJson,
            MetaTitle = page.MetaTitle,
            MetaDescription = page.MetaDescription,
            OgImageUrl = page.OgImageUrl,
            CustomCss = page.CustomCss
        };

        if (updateStatus)
        {
            CmsStatusMessage = $"Opened CMS page '{page.Title}'.";
        }

        await LoadFormSubmissionsAsync();
        await LoadRevisionsAsync();
    }

    // ── Form submissions ────────────────────────────────────────────────────

    private List<FormSubmission> FormSubmissions { get; set; } = new();
    private bool IsSubmissionsBusy { get; set; }
    private string SubmissionsErrorMessage { get; set; } = string.Empty;

    private async Task LoadFormSubmissionsAsync()
    {
        if (!SelectedPageId.HasValue)
        {
            FormSubmissions = new();
            return;
        }

        IsSubmissionsBusy = true;
        SubmissionsErrorMessage = string.Empty;

        try
        {
            FormSubmissions = (await FormSubmissionService.ListAsync(SelectedPageId.Value)).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load form submissions for page {PageId}.", SelectedPageId);
            SubmissionsErrorMessage = $"Unable to load form submissions. {ex.Message}";
        }
        finally
        {
            IsSubmissionsBusy = false;
        }
    }

    private async Task MarkSubmissionReadAsync(Guid submissionId)
    {
        await FormSubmissionService.MarkReadAsync(submissionId);
        await LoadFormSubmissionsAsync();
    }

    private async Task DeleteSubmissionAsync(Guid submissionId)
    {
        await FormSubmissionService.DeleteAsync(submissionId);
        await LoadFormSubmissionsAsync();
    }

    private static Dictionary<string, string> ParseSubmissionFields(string fieldsJson)
    {
        try
        {
            return JsonSerializer.Deserialize<Dictionary<string, string>>(
                string.IsNullOrWhiteSpace(fieldsJson) ? "{}" : fieldsJson) ?? [];
        }
        catch
        {
            return [];
        }
    }

    // ── Revision history ────────────────────────────────────────────────────

    private List<CmsPageRevision> PageRevisions { get; set; } = new();
    private bool IsRevisionBusy { get; set; }
    private string RevisionErrorMessage { get; set; } = string.Empty;
    private Guid? PreviewedRevisionId { get; set; }

    private async Task LoadRevisionsAsync()
    {
        if (!SelectedPageId.HasValue)
        {
            PageRevisions = new();
            return;
        }

        try
        {
            PageRevisions = (await PageRevisionService.ListAsync(SelectedPageId.Value)).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load revisions for page {PageId}.", SelectedPageId);
            RevisionErrorMessage = $"Unable to load revisions. {ex.Message}";
        }
    }

    private void PreviewRevision(CmsPageRevision revision)
    {
        PreviewedRevisionId = PreviewedRevisionId == revision.Id ? null : revision.Id;
    }

    private async Task RestoreRevisionAsync(Guid revisionId)
    {
        if (!SelectedPageId.HasValue) return;

        IsRevisionBusy = true;
        RevisionErrorMessage = string.Empty;

        try
        {
            var restored = await PageRevisionService.RestoreAsync(SelectedPageId.Value, revisionId);
            CmsPages = (await CmsBuilderService.ListPagesAsync(SelectedSiteId!.Value)).ToList();
            await LoadSelectedPageAsync(restored.Id, updateStatus: false);
            PreviewedRevisionId = null;
            CmsStatusMessage = "Revision restored. A checkpoint of the previous state was saved as the latest revision.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to restore revision {RevisionId}.", revisionId);
            RevisionErrorMessage = $"Unable to restore revision. {ex.Message}";
        }
        finally
        {
            IsRevisionBusy = false;
        }
    }

    private async Task DeleteRevisionAsync(Guid revisionId)
    {
        IsRevisionBusy = true;
        try
        {
            await PageRevisionService.DeleteAsync(revisionId);
            await LoadRevisionsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to delete revision {RevisionId}.", revisionId);
            RevisionErrorMessage = $"Unable to delete revision. {ex.Message}";
        }
        finally
        {
            IsRevisionBusy = false;
        }
    }

    private async Task SavePageAsync()
    {
        if (!SelectedSiteId.HasValue)
        {
            CmsErrorMessage = "Create or select a CMS site before saving pages.";
            return;
        }

        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;
        CmsStatusMessage = string.Empty;

        try
        {
            // Checkpoint the current state before overwriting so any save is undoable.
            if (SelectedPageId.HasValue)
            {
                var currentPage = await CmsBuilderService.GetPageAsync(SelectedPageId.Value);
                if (currentPage is not null)
                {
                    await PageRevisionService.CreateRevisionAsync(currentPage);
                }
            }

            PageEditor.SiteId = SelectedSiteId;
            var saved = await CmsBuilderService.SavePageAsync(PageEditor);
            SelectedPageId = saved.Id;
            CmsPages = (await CmsBuilderService.ListPagesAsync(SelectedSiteId.Value)).ToList();
            await LoadSelectedPageAsync(saved.Id, updateStatus: false);
            CmsStatusMessage = $"Saved CMS page '{saved.Title}'.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to save CMS page.");
            CmsErrorMessage = $"Unable to save CMS page. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    private async Task DeleteSelectedPageAsync()
    {
        if (!SelectedPageId.HasValue || !SelectedSiteId.HasValue)
        {
            return;
        }

        var pageId = SelectedPageId.Value;
        var siteId = SelectedSiteId.Value;

        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;
        CmsStatusMessage = string.Empty;

        try
        {
            await CmsBuilderService.DeletePageAsync(pageId);
            SelectedPageId = null;
            CmsPages = (await CmsBuilderService.ListPagesAsync(siteId)).ToList();
            if (CmsPages.Count > 0)
            {
                await LoadSelectedPageAsync(CmsPages[0].Id, updateStatus: false);
            }
            else
            {
                CreateNewPage();
            }

            CmsStatusMessage = "Deleted the selected CMS page.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to delete CMS page {PageId}.", pageId);
            CmsErrorMessage = $"Unable to delete CMS page. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    private async Task ApplyBlueprintAsync()
    {
        if (!SelectedPageId.HasValue || string.IsNullOrWhiteSpace(SelectedBlueprintKey))
        {
            return;
        }

        IsCmsBusy = true;
        CmsErrorMessage = string.Empty;
        CmsStatusMessage = string.Empty;

        try
        {
            var updated = await CmsBuilderService.ApplyWorkflowBlueprintAsync(
                SelectedPageId.Value,
                SelectedBlueprintKey,
                ReplaceExistingBlocks);

            await LoadSelectedPageAsync(updated.Id, updateStatus: false);
            CmsStatusMessage = $"Applied blueprint '{SelectedBlueprintKey}' to '{updated.Title}'.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to apply blueprint {BlueprintKey} to page {PageId}.", SelectedBlueprintKey, SelectedPageId.Value);
            CmsErrorMessage = $"Unable to apply blueprint. {ex.Message}";
        }
        finally
        {
            IsCmsBusy = false;
        }
    }

    private string? LivePageUrl =>
        SelectedSiteId.HasValue && CmsSites.FirstOrDefault(s => s.Id == SelectedSiteId.Value) is { } selectedSite
            && !string.IsNullOrWhiteSpace(PageEditor.Slug)
            ? $"/cms/{selectedSite.Slug}/{PageEditor.Slug}"
            : null;

    private void OpenStudio(Guid pageId) => Navigation.NavigateTo($"/admin/canvas/editor/{pageId}");

    private string? SiteExportUrl =>
        SelectedSiteId.HasValue && CmsSites.FirstOrDefault(s => s.Id == SelectedSiteId.Value) is { } exportSite
            ? $"/admin/api/cms/{exportSite.Slug}/export.zip"
            : null;

    // ── Media library ───────────────────────────────────────────────────────

    private List<MediaAssetSummary> MediaAssets { get; set; } = new();
    private bool IsMediaBusy { get; set; }
    private string MediaErrorMessage { get; set; } = string.Empty;
    private string MediaStatusMessage { get; set; } = string.Empty;
    private string MediaAltTextInput { get; set; } = string.Empty;

    private async Task LoadMediaAssetsAsync()
    {
        try
        {
            MediaAssets = (await MediaLibraryService.ListAsync()).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load media library.");
            MediaErrorMessage = $"Unable to load media library. {ex.Message}";
        }
    }

    private async Task OnMediaFileSelectedAsync(InputFileChangeEventArgs e)
    {
        IsMediaBusy = true;
        MediaErrorMessage = string.Empty;
        MediaStatusMessage = string.Empty;

        try
        {
            const long maxFileBytes = 8 * 1024 * 1024;
            var file = e.File;
            using var stream = file.OpenReadStream(maxFileBytes);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);

            var uploaded = await MediaLibraryService.UploadAsync(
                file.Name,
                memory.ToArray(),
                MediaAltTextInput);

            MediaAltTextInput = string.Empty;
            await LoadMediaAssetsAsync();
            MediaStatusMessage = $"Uploaded '{uploaded.FileName}'.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to upload media asset.");
            MediaErrorMessage = $"Unable to upload file. {ex.Message}";
        }
        finally
        {
            IsMediaBusy = false;
        }
    }

    private async Task DeleteMediaAssetAsync(Guid mediaAssetId)
    {
        IsMediaBusy = true;
        MediaErrorMessage = string.Empty;

        try
        {
            await MediaLibraryService.DeleteAsync(mediaAssetId);
            await LoadMediaAssetsAsync();
            MediaStatusMessage = "Deleted media asset.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to delete media asset {MediaAssetId}.", mediaAssetId);
            MediaErrorMessage = $"Unable to delete media asset. {ex.Message}";
        }
        finally
        {
            IsMediaBusy = false;
        }
    }

    private void InsertImageBlock(string url, string altText)
    {
        var node = System.Text.Json.Nodes.JsonNode.Parse(
            string.IsNullOrWhiteSpace(PageEditor.BlocksJson) ? "[]" : PageEditor.BlocksJson) as System.Text.Json.Nodes.JsonArray
            ?? new System.Text.Json.Nodes.JsonArray();

        node.Add(new System.Text.Json.Nodes.JsonObject
        {
            ["type"] = "image",
            ["src"] = url,
            ["alt"] = altText
        });

        PageEditor.BlocksJson = node.ToJsonString(new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        MediaStatusMessage = "Inserted image block into the page's Blocks JSON.";
    }
}
