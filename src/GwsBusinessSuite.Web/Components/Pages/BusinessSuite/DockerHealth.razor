@page "/admin/docker-health"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "AdminOnly")]
@using Microsoft.AspNetCore.Authorization
@using GwsBusinessSuite.Application.DockerHealth
@using GwsBusinessSuite.Application.DigitalOcean
@using GwsBusinessSuite.Application.Abstractions
@inject IDockerHealthService DockerHealthService
@inject IDigitalOceanService DigitalOceanService
@inject IDockerDeploymentService DockerDeploymentService
@inject IWebHostEnvironment Env
@inject ICurrentUserAccessor CurrentUserAccessor
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<DockerHealth> Logger

<PageTitle>Docker Management</PageTitle>

<div class="page-header d-flex align-items-center justify-content-between gap-3">
    <div>
        <h1><i class="bi bi-box-seam me-2 text-primary"></i>Docker Management</h1>
        <p>Manage every container on the droplet, and bridge into DigitalOcean for droplet-level actions.</p>
    </div>
    <button class="btn btn-outline-primary d-inline-flex align-items-center gap-2" @onclick="LoadContainersAsync" disabled="@IsBusy">
        @if (IsBusy)
        {
            <span class="spinner-border spinner-border-sm"></span>
        }
        else
        {
            <i class="bi bi-arrow-clockwise"></i>
        }
        <span>Refresh Now</span>
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger" role="alert">@ErrorMessage</div>
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-bottom py-3">
        <span class="fw-semibold"><i class="bi bi-cloud-fill me-1 text-primary"></i>DigitalOcean Connection</span>
    </div>
    <div class="card-body">
        @if (!_doLoaded)
        {
            <div class="d-flex align-items-center gap-2 text-secondary">
                <span class="spinner-border spinner-border-sm"></span>
                <span>Loading...</span>
            </div>
        }
        else
        {
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label small text-secondary">API Token</label>
                    <input type="password" class="form-control" @bind="DoApiToken" @bind:event="oninput"
                           placeholder="@(DoTokenUnreadable ? "Saved token could not be decrypted - re-enter it" : "dop_v1_...")" />
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-secondary">Droplet ID <span class="text-muted">(optional - auto-detected in production)</span></label>
                    <input type="text" class="form-control" @bind="DoDropletId" @bind:event="oninput" placeholder="Leave blank to auto-detect" />
                </div>
            </div>
            <button class="btn btn-sm btn-primary" @onclick="SaveDoSettingsAsync" disabled="@IsDoSaving">
                @(IsDoSaving ? "Saving..." : "Save Connection")
            </button>
            @if (!string.IsNullOrWhiteSpace(DoSaveMessage))
            {
                <span class="small text-secondary ms-2">@DoSaveMessage</span>
            }

            @if (DropletResult is { Available: true, Droplet: { } droplet })
            {
                <hr />
                <div class="row g-3 align-items-center">
                    <div class="col-md-8">
                        <div class="fw-semibold">@droplet.Name <span class="badge text-bg-success ms-1">@droplet.Status</span></div>
                        <div class="small text-secondary">
                            @droplet.Region &middot; @droplet.Size
                            @if (droplet.VcpuDescription is not null) { <text> &middot; @droplet.VcpuDescription</text> }
                            @if (droplet.MemoryDescription is not null) { <text> &middot; @droplet.MemoryDescription</text> }
                            @if (droplet.DiskDescription is not null) { <text> &middot; @droplet.DiskDescription</text> }
                        </div>
                        @if (droplet.PublicIpAddress is not null)
                        {
                            <div class="small text-secondary">IP: @droplet.PublicIpAddress</div>
                        }
                    </div>
                    <div class="col-md-4 d-flex flex-wrap gap-2 justify-content-md-end">
                        <button class="btn btn-sm btn-outline-danger" @onclick="RebootDropletAsync" disabled="@IsDoActionBusy">Reboot</button>
                        <button class="btn btn-sm btn-outline-warning" @onclick="ShowResizePrompt" disabled="@IsDoActionBusy">Resize</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ShowSnapshotPrompt" disabled="@IsDoActionBusy">Snapshot</button>
                        <button class="btn btn-sm btn-outline-info" @onclick="OpenTerminalWindowAsync">
                            <i class="bi bi-box-arrow-up-right me-1"></i>Terminal
                        </button>
                    </div>
                </div>

                @if (DropletActions.Count > 0)
                {
                    <div class="small text-secondary mt-3">
                        <strong>Recent droplet actions</strong>
                        <ul class="list-unstyled mb-0 mt-1">
                            @foreach (var a in DropletActions.Take(5))
                            {
                                <li>@a.Type &mdash; @a.Status &mdash; @a.StartedAt.ToLocalTime().ToString("MMM d, h:mm tt")</li>
                            }
                        </ul>
                    </div>
                }
            }
            else if (DropletResult is { Available: false, UnavailableReason: { } reason })
            {
                <div class="small text-secondary mt-2"><i class="bi bi-info-circle me-1"></i>@reason</div>
            }
        }
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-bottom py-3">
        <span class="fw-semibold"><i class="bi bi-hammer me-1 text-primary"></i>Build App Image</span>
    </div>
    <div class="card-body">
        <p class="small text-secondary mb-2">
            Rebuilds this app's Docker image from the local <code>Dockerfile</code> using the Docker CLI.
            This only works when running locally with Docker installed — production deploys happen via
            <code>docker compose up -d --build</code> over SSH, not from this button.
        </p>
        <button class="btn btn-sm btn-outline-primary" @onclick="BuildImageAsync" disabled="@IsBuildingImage">
            @if (IsBuildingImage)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
                <span>Building...</span>
            }
            else
            {
                <span>Build Image</span>
            }
        </button>
        @if (!string.IsNullOrWhiteSpace(BuildImageMessage))
        {
            <pre class="small mt-2 mb-0 @(BuildImageSucceeded ? "text-success" : "text-danger")" style="white-space: pre-wrap;">@BuildImageMessage</pre>
        }
    </div>
</div>

@if (!_loaded)
{
    <div class="d-flex align-items-center gap-2 text-secondary">
        <span class="spinner-border spinner-border-sm"></span>
        <span>Checking Docker...</span>
    </div>
}
else if (!_available)
{
    <div class="alert alert-warning" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-1"></i>
        @UnavailableReason
    </div>
}
else if (Containers.Count == 0)
{
    <p class="text-secondary">No containers found.</p>
}
else
{
    <div class="row g-3">
        @foreach (var container in Containers)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span class="fw-semibold">@container.Name</span>
                            <span class="badge @StatusBadgeClass(container)">@StatusLabel(container)</span>
                        </div>
                        <div class="small text-secondary mb-1">@container.Image</div>
                        <div class="small text-secondary mb-1">@container.Status</div>
                        @if (container.RestartCount > 0)
                        {
                            <div class="small text-secondary mb-1">Restarts: @container.RestartCount</div>
                        }
                        <div class="d-flex flex-wrap gap-1 mt-2">
                            @if (container.State == "running")
                            {
                                <button class="btn btn-sm btn-outline-secondary" disabled="@IsContainerBusy(container.Name)" @onclick="() => StopAsync(container.Name)">Stop</button>
                                <button class="btn btn-sm btn-outline-secondary" disabled="@IsContainerBusy(container.Name)" @onclick="() => RestartAsync(container.Name)">Restart</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-success" disabled="@IsContainerBusy(container.Name)" @onclick="() => StartAsync(container.Name)">Start</button>
                            }
                            <button class="btn btn-sm btn-outline-primary" disabled="@IsContainerBusy(container.Name)" @onclick="() => PullAsync(container.Name)">Pull Latest</button>
                        </div>
                        @if (ActionMessages.TryGetValue(container.Name, out var msg))
                        {
                            <div class="small mt-2 @(msg.Succeeded ? "text-success" : "text-danger")">@msg.Message</div>
                        }
                        <a href="/admin/docker-health/@Uri.EscapeDataString(container.Name)" class="btn btn-sm btn-outline-secondary mt-2">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<ContainerHealthView> Containers { get; set; } = new();
    private bool _loaded;
    private bool _available;
    private string UnavailableReason { get; set; } = string.Empty;
    private bool IsBusy { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;
    private readonly HashSet<string> _busyContainers = new();
    private Dictionary<string, DockerActionResult> ActionMessages { get; } = new();

    private bool IsBuildingImage { get; set; }
    private string BuildImageMessage { get; set; } = string.Empty;
    private bool BuildImageSucceeded { get; set; }

    private bool _doLoaded;
    private string DoApiToken { get; set; } = string.Empty;
    private string DoDropletId { get; set; } = string.Empty;
    private bool DoTokenUnreadable { get; set; }
    private bool IsDoSaving { get; set; }
    private bool IsDoActionBusy { get; set; }
    private string DoSaveMessage { get; set; } = string.Empty;
    private DropletInfoResult? DropletResult { get; set; }
    private List<DropletActionView> DropletActions { get; set; } = new();

    private Task OpenTerminalWindowAsync() => JS.InvokeVoidAsync("gwsSshTerminal.openWindow").AsTask();

    protected override async Task OnInitializedAsync()
    {
        await LoadContainersAsync();
        _loaded = true;
        await LoadDoAsync();
        _doLoaded = true;
    }

    private Task<string> CurrentUserNameAsync() => CurrentUserAccessor.GetCurrentUsernameAsync();

    private async Task LoadContainersAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        try
        {
            var result = await DockerHealthService.ListContainersAsync();
            _available = result.Available;
            UnavailableReason = result.UnavailableReason ?? string.Empty;
            Containers = result.Containers.ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load container health.");
            ErrorMessage = $"Unable to load container health. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task LoadDoAsync()
    {
        var settings = await DigitalOceanService.GetSettingsAsync();
        DoApiToken = settings?.ApiToken ?? string.Empty;
        DoDropletId = settings?.DropletId ?? string.Empty;
        DoTokenUnreadable = settings?.ApiTokenUnreadable ?? false;

        if (!string.IsNullOrWhiteSpace(DoApiToken))
        {
            DropletResult = await DigitalOceanService.GetDropletInfoAsync();
            if (DropletResult.Available)
            {
                DropletActions = (await DigitalOceanService.ListRecentActionsAsync()).ToList();
            }
        }
    }

    private async Task SaveDoSettingsAsync()
    {
        IsDoSaving = true;
        DoSaveMessage = string.Empty;
        try
        {
            await DigitalOceanService.SaveSettingsAsync(new DigitalOceanSettingsView { ApiToken = DoApiToken, DropletId = DoDropletId });
            DoSaveMessage = "Saved.";
            DoTokenUnreadable = false;
            DropletResult = await DigitalOceanService.GetDropletInfoAsync();
            if (DropletResult.Available)
            {
                DropletActions = (await DigitalOceanService.ListRecentActionsAsync()).ToList();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to save DigitalOcean settings.");
            DoSaveMessage = $"Failed to save: {ex.Message}";
        }
        finally
        {
            IsDoSaving = false;
        }
    }

    private async Task RebootDropletAsync()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            "This restarts the entire droplet, taking every container (including this app and any other services running here) down for roughly a minute. Continue?");
        if (!confirmed) return;

        IsDoActionBusy = true;
        try
        {
            var user = await CurrentUserNameAsync();
            var result = await DigitalOceanService.RebootDropletAsync(user);
            DoSaveMessage = result.Message;
            DropletActions = (await DigitalOceanService.ListRecentActionsAsync()).ToList();
        }
        finally
        {
            IsDoActionBusy = false;
        }
    }

    private async Task ShowResizePrompt()
    {
        var newSize = await JS.InvokeAsync<string?>("prompt",
            "Enter the target DigitalOcean size slug (e.g. s-2vcpu-4gb). Disk-size changes require the droplet to be powered off; CPU/RAM-only resizes can be applied live.");
        if (string.IsNullOrWhiteSpace(newSize)) return;

        var resizeDisk = await JS.InvokeAsync<bool>("confirm",
            "Also resize the disk? Disk resizes are irreversible and require the droplet to be powered off first. Choose Cancel for a live CPU/RAM-only resize.");

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Resize droplet to {newSize}{(resizeDisk ? " (including disk)" : "")}. Continue?");
        if (!confirmed) return;

        IsDoActionBusy = true;
        try
        {
            var user = await CurrentUserNameAsync();
            var result = await DigitalOceanService.ResizeDropletAsync(newSize, resizeDisk, user);
            DoSaveMessage = result.Message;
            DropletActions = (await DigitalOceanService.ListRecentActionsAsync()).ToList();
        }
        finally
        {
            IsDoActionBusy = false;
        }
    }

    private async Task ShowSnapshotPrompt()
    {
        var name = await JS.InvokeAsync<string?>("prompt", "Snapshot name:", $"gwssuite-{DateTime.UtcNow:yyyyMMdd-HHmm}");
        if (string.IsNullOrWhiteSpace(name)) return;

        var confirmed = await JS.InvokeAsync<bool>("confirm",
            "Creating a snapshot can take several minutes. The droplet stays usable throughout. Continue?");
        if (!confirmed) return;

        IsDoActionBusy = true;
        try
        {
            var user = await CurrentUserNameAsync();
            var result = await DigitalOceanService.CreateSnapshotAsync(name, user);
            DoSaveMessage = result.Message;
            DropletActions = (await DigitalOceanService.ListRecentActionsAsync()).ToList();
        }
        finally
        {
            IsDoActionBusy = false;
        }
    }

    private async Task BuildImageAsync()
    {
        IsBuildingImage = true;
        BuildImageMessage = string.Empty;
        try
        {
            // Dockerfile lives at the repo root, two levels above this project's content root.
            var dockerfilePath = Path.GetFullPath(Path.Combine(Env.ContentRootPath, "..", "..", "Dockerfile"));
            var result = await DockerDeploymentService.DeployAsync("gws-business-suite", dockerfilePath);
            BuildImageMessage = result;
            BuildImageSucceeded = result.StartsWith("Docker image", StringComparison.Ordinal);
        }
        finally
        {
            IsBuildingImage = false;
        }
    }

    private bool IsContainerBusy(string name) => _busyContainers.Contains(name);

    private Task StartAsync(string name) => RunContainerActionAsync(name, DockerHealthService.StartContainerAsync);

    private async Task StopAsync(string name)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Stop {name}?");
        if (!confirmed) return;
        await RunContainerActionAsync(name, DockerHealthService.StopContainerAsync);
    }

    private Task RestartAsync(string name) => RunContainerActionAsync(name, DockerHealthService.RestartContainerAsync);

    private Task PullAsync(string name) => RunContainerActionAsync(name, DockerHealthService.PullImageAsync);

    private async Task RunContainerActionAsync(string name, Func<string, string, CancellationToken, Task<DockerActionResult>> action)
    {
        _busyContainers.Add(name);
        StateHasChanged();
        try
        {
            var user = await CurrentUserNameAsync();
            var result = await action(name, user, CancellationToken.None);
            ActionMessages[name] = result;
            await LoadContainersAsync();
        }
        finally
        {
            _busyContainers.Remove(name);
        }
    }

    private static string StatusLabel(ContainerHealthView c) =>
        c.IsError ? "Error" : c.State;

    private static string StatusBadgeClass(ContainerHealthView c) =>
        c.IsError ? "text-bg-danger" : c.State == "running" ? "text-bg-success" : "text-bg-secondary";
}
