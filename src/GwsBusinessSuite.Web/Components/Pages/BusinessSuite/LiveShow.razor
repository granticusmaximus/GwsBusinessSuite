@page "/admin/live-show"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = "AdminOnly")]
@using Microsoft.JSInterop
@using GwsBusinessSuite.Application.LiveShow
@inject IJSRuntime JS
@inject ILiveShowService LiveShowService
@inject NavigationManager Navigation
@inject ILogger<LiveShow> Logger
@implements IAsyncDisposable

<PageTitle>Live Show Studio</PageTitle>

<div class="page-header d-flex align-items-start justify-content-between gap-3">
    <div>
        <div class="studio-kicker">Broadcast studio</div>
        <h1><i class="bi bi-camera-video-fill me-2 text-primary"></i>Live Show</h1>
        <p class="mb-0">Open your camera and microphone, then go live to a small group of invited viewers over a direct connection. Shows are recorded automatically.</p>
    </div>
    <a class="btn btn-outline-secondary btn-sm" href="/admin/live-show-recordings">
        <i class="bi bi-collection-play me-1"></i>Past Shows
    </a>
</div>

<div class="live-studio">
    <div class="live-stage">
        <div class="live-camera-shell @(IsStreaming ? "is-live" : string.Empty)">
            @if (IsLive)
            {
                <div class="live-badge">
                    <span class="live-dot"></span> LIVE
                </div>
            }
            else if (IsStreaming)
            {
                <div class="live-badge">
                    <span class="live-dot"></span> PREVIEW ONLY
                </div>
            }

            <video @ref="_videoRef"
                   class="live-video"
                   autoplay
                   muted
                   playsinline></video>

            @if (!IsStreaming)
            {
                <div class="live-idle-overlay">
                    <div class="live-idle-card">
                        <div class="live-idle-icon">
                            <i class="bi bi-camera-video"></i>
                        </div>
                        <h2>Ready to go live?</h2>
                        <p>Click <strong>Start Preview</strong> below to open your camera and microphone.</p>
                    </div>
                </div>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="alert alert-danger mt-3">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@ErrorMessage
            </div>
        }

        @if (IsLive)
        {
            <div class="alert alert-success mt-3">
                <i class="bi bi-link-45deg me-2"></i>Share this link with viewers:
                <a href="@InviteUrl" target="_blank">@InviteUrl</a>
            </div>
        }
    </div>

    <div class="live-controls">
        @if (!IsStreaming)
        {
            <button class="btn btn-primary live-start-btn" @onclick="StartPreviewAsync">
                <i class="bi bi-camera-video me-2"></i>Start Preview
            </button>
        }
        else
        {
            <div class="live-control-row">
                <button class="live-control-btn @(!IsMicOn ? "is-muted" : string.Empty)"
                        @onclick="ToggleMic"
                        title="@(IsMicOn ? "Mute microphone" : "Unmute microphone")">
                    <i class="bi @(IsMicOn ? "bi-mic-fill" : "bi-mic-mute-fill")"></i>
                    <span>@(IsMicOn ? "Mic On" : "Muted")</span>
                </button>

                <button class="live-control-btn @(!IsCameraOn ? "is-muted" : string.Empty)"
                        @onclick="ToggleCamera"
                        title="@(IsCameraOn ? "Turn off camera" : "Turn on camera")">
                    <i class="bi @(IsCameraOn ? "bi-camera-video-fill" : "bi-camera-video-off-fill")"></i>
                    <span>@(IsCameraOn ? "Camera On" : "Camera Off")</span>
                </button>

                @if (!IsLive)
                {
                    <input class="form-control form-control-sm live-title-input" @bind="ShowTitle" placeholder="Show title" style="max-width:12rem;" />
                    <button class="live-control-btn is-live" @onclick="GoLiveAsync" disabled="@IsBusy">
                        <i class="bi bi-broadcast"></i>
                        <span>Go Live</span>
                    </button>
                }

                <button class="live-control-btn is-stop" @onclick="StopAsync" title="End live show" disabled="@IsBusy">
                    <i class="bi bi-stop-circle-fill"></i>
                    <span>@(IsLive ? "End Show" : "Close Preview")</span>
                </button>
            </div>
        }
    </div>
</div>

@code {
    private ElementReference _videoRef;
    private bool IsStreaming { get; set; }
    private bool IsLive { get; set; }
    private bool IsMicOn { get; set; } = true;
    private bool IsCameraOn { get; set; } = true;
    private bool IsBusy { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;
    private string ShowTitle { get; set; } = string.Empty;
    private Guid? SessionId { get; set; }
    private string InviteUrl { get; set; } = string.Empty;

    private async Task StartPreviewAsync()
    {
        ErrorMessage = string.Empty;

        try
        {
            await JS.InvokeVoidAsync("liveShow.start", _videoRef);
            IsStreaming = true;
            IsMicOn = true;
            IsCameraOn = true;
        }
        catch (JSException ex)
        {
            Logger.LogWarning(ex, "Camera access failed.");
            ErrorMessage = ex.Message.Contains("denied")
                ? "Camera or microphone access was denied. Please allow access in your browser settings and try again."
                : $"Could not open camera: {ex.Message}";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error starting live show.");
            ErrorMessage = $"Unexpected error: {ex.Message}";
        }
    }

    private async Task GoLiveAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        try
        {
            var session = await LiveShowService.StartSessionAsync(ShowTitle);
            SessionId = session.Id;
            InviteUrl = new Uri(new Uri(Navigation.BaseUri), $"watch/{session.InviteToken}").ToString();

            await JS.InvokeVoidAsync("liveShow.startBroadcast", session.Id);
            IsLive = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to go live.");
            ErrorMessage = $"Could not go live: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task StopAsync()
    {
        IsBusy = true;
        try
        {
            if (IsLive)
            {
                await JS.InvokeVoidAsync("liveShow.stopBroadcast");
                if (SessionId is { } id)
                {
                    await LiveShowService.EndSessionAsync(id);
                }
            }

            await JS.InvokeVoidAsync("liveShow.stop");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error stopping live show.");
        }

        IsStreaming = false;
        IsLive = false;
        IsMicOn = true;
        IsCameraOn = true;
        SessionId = null;
        InviteUrl = string.Empty;
        ErrorMessage = string.Empty;
        IsBusy = false;
    }

    private async Task ToggleMic()
    {
        IsMicOn = !IsMicOn;
        await JS.InvokeVoidAsync("liveShow.toggleAudio", IsMicOn);
    }

    private async Task ToggleCamera()
    {
        IsCameraOn = !IsCameraOn;
        await JS.InvokeVoidAsync("liveShow.toggleVideo", IsCameraOn);
    }

    public async ValueTask DisposeAsync()
    {
        if (IsLive && SessionId is { } id)
        {
            try
            {
                await JS.InvokeVoidAsync("liveShow.stopBroadcast");
                await LiveShowService.EndSessionAsync(id);
            }
            catch { /* best-effort cleanup on dispose */ }
        }
        else if (IsStreaming)
        {
            try { await JS.InvokeVoidAsync("liveShow.stop"); }
            catch { /* best-effort cleanup on dispose */ }
        }
    }
}
