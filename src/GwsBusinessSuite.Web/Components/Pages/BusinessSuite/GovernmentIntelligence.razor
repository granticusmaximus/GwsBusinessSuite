@page "/admin/government-intelligence"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "AdminOnly")]
@using System.Globalization
@using GwsBusinessSuite.Application.GovernmentIntelligence
@using GwsBusinessSuite.Infrastructure.Services
@inject IGovernmentIntelligenceService GovernmentService
@inject ILogger<GovernmentIntelligence> Logger

<PageTitle>Government Intelligence</PageTitle>

<div class="page-header d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-end">
    <div>
        <h1><i class="bi bi-building-fill me-2 text-dark"></i>Government Intelligence</h1>
        <p class="mb-0">Official-source tracking for @(_snapshot?.AreaLabel ?? "Kathleen, Houston County, Georgia").</p>
    </div>
    <button class="btn btn-dark" @onclick="RefreshAsync" disabled="@_loading">
        <i class="bi bi-arrow-clockwise me-2 @( _loading ? "gws-spin" : string.Empty)"></i>
        @(_loading ? "Refreshing..." : "Refresh")
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@_errorMessage
    </div>
}

@if (_loading && _snapshot is null)
{
    <div class="d-flex align-items-center gap-2 text-secondary">
        <span class="spinner-border spinner-border-sm"></span>
        <span>Loading government coverage...</span>
    </div>
}
else if (_snapshot is not null)
{
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center text-uppercase small text-secondary">
                    <span class="small text-uppercase fw-semibold text-secondary">Coverage Focus</span>
                    <span class="text-secondary small">Updated @FormatTimestamp(_snapshot.RetrievedAt)</span>
                </div>
                <h2 class="mb-2">@_snapshot.AreaLabel</h2>
                <p class="text-secondary mb-0">@CurrentSummary()</p>
            </div>
        </div>

        <div class="nav nav-pills mb-4">
            <button class="nav-link d-flex align-items-center gap-2 @TabClass("community")" @onclick='() => SelectSection("community")'>
                <i class="bi bi-geo-alt"></i>
                <span>Houston County &amp; Community</span>
            </button>
            <button class="nav-link d-flex align-items-center gap-2 @TabClass("state")" @onclick='() => SelectSection("state")'>
                <i class="bi bi-bank"></i>
                <span>Georgia</span>
            </button>
            <button class="nav-link d-flex align-items-center gap-2 @TabClass("federal")" @onclick='() => SelectSection("federal")'>
                <i class="bi bi-building"></i>
                <span>Congress</span>
            </button>
        </div>

        @if (_activeSection == "community")
        {
            <div class="row g-4">
                <div class="col-xl-7">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between gap-3">
                                <div>
                                    <span class="small text-uppercase fw-semibold text-secondary">Community Watch</span>
                                    <h2 class="h4 mb-1">County notices and meetings</h2>
                                    <p class="text-muted mb-0">@_snapshot.Community.Summary</p>
                                </div>
                            </div>

                            <div class="d-flex flex-column gap-4 mt-4">
                                <section>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h3 class="h6 text-uppercase text-muted mb-0">Announcements</h3>
                                        <span class="badge text-bg-light">@_snapshot.Community.Announcements.Count</span>
                                    </div>
                                    @if (_snapshot.Community.Announcements.Count == 0)
                                    {
                                        <p class="text-muted mb-0">No county announcements were returned.</p>
                                    }
                                    else
                                    {
                                        <div class="list-group">
                                            @foreach (var item in _snapshot.Community.Announcements)
                                            {
                                                <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="@item.Url" target="_blank" rel="noopener noreferrer">
                                                    <div>
                                                        <div class="fw-semibold">@item.Title</div>
                                                        <div class="text-secondary small">@item.Source</div>
                                                    </div>
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </a>
                                            }
                                        </div>
                                    }
                                </section>

                                <section>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h3 class="h6 text-uppercase text-muted mb-0">Meetings</h3>
                                        <span class="badge text-bg-light">@_snapshot.Community.Meetings.Count</span>
                                    </div>
                                    @if (_snapshot.Community.Meetings.Count == 0)
                                    {
                                        <p class="text-muted mb-0">No county meeting dates were returned.</p>
                                    }
                                    else
                                    {
                                        <div class="list-group">
                                            @foreach (var meeting in _snapshot.Community.Meetings)
                                            {
                                                <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="@meeting.Url" target="_blank" rel="noopener noreferrer">
                                                    <div>
                                                        <div class="fw-semibold">@meeting.Title</div>
                                                        <div class="text-secondary small">
                                                            @FormatDate(meeting.MeetingDate)
                                                            @if (!string.IsNullOrWhiteSpace(meeting.Location))
                                                            {
                                                                <span>· @meeting.Location</span>
                                                            }
                                                        </div>
                                                    </div>
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </a>
                                            }
                                        </div>
                                    }
                                </section>

                                <section>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h3 class="h6 text-uppercase text-muted mb-0">Local Events</h3>
                                        <span class="badge text-bg-light">@_snapshot.Community.LocalEvents.Count</span>
                                    </div>
                                    <p class="text-muted small mb-2">Covers Perry's city calendar and Robins Region Chamber of Commerce listings. Refreshes hourly via a background job, independent of the Refresh button above.</p>
                                    @if (_snapshot.Community.LocalEvents.Count == 0)
                                    {
                                        <p class="text-muted mb-0">No local events were returned.</p>
                                    }
                                    else
                                    {
                                        <div class="list-group">
                                            @foreach (var localEvent in _snapshot.Community.LocalEvents)
                                            {
                                                <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="@localEvent.Url" target="_blank" rel="noopener noreferrer">
                                                    <div>
                                                        <div class="fw-semibold">@localEvent.Title</div>
                                                        <div class="text-secondary small">@FormatEventWhen(localEvent) · @localEvent.Source</div>
                                                    </div>
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </a>
                                            }
                                        </div>
                                    }
                                </section>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-5">
                    @foreach (var resourceSection in _snapshot.Community.ResourceSections)
                    {
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body">
                                <h3 class="h5 mb-3">@resourceSection.Title</h3>
                                <div class="list-group">
                                    @foreach (var link in resourceSection.Links)
                                    {
                                        <a class="list-group-item list-group-item-action" href="@link.Url" target="_blank" rel="noopener noreferrer">
                                            <div class="fw-semibold">@link.Title</div>
                                            <div class="text-secondary small mb-0">@link.Description</div>
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <span class="small text-uppercase fw-semibold text-secondary">Local Law</span>
                                    <h3 class="h5 mb-0">How to inspect ordinances and board actions</h3>
                                </div>
                                <span class="badge text-bg-light">@_snapshot.Community.LegislationBriefs.Count</span>
                            </div>

                            @if (_snapshot.Community.LegislationBriefs.Count == 0)
                            {
                                <p class="text-muted mb-0">No local legislation research briefs are available.</p>
                            }
                            else
                            {
                                <div class="d-flex flex-column gap-3">
                                    @foreach (var brief in _snapshot.Community.LegislationBriefs)
                                    {
                                        <LegislationBriefPanel Brief="brief" SummaryLabel="Open local legislation guide" />
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (_activeSection == "state")
        {
            <div class="row g-4">
                <div class="col-xl-7">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <span class="small text-uppercase fw-semibold text-secondary">State Executive</span>
                            <h2 class="h4 mb-1">Governor updates and signed legislation</h2>
                            <p class="text-muted">@_snapshot.State.Summary</p>

                            <div class="d-flex flex-column gap-4 mt-4">
                                <section>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h3 class="h6 text-uppercase text-muted mb-0">Recent press releases</h3>
                                        <span class="badge text-bg-light">@_snapshot.State.PressReleases.Count</span>
                                    </div>
                                    @if (_snapshot.State.PressReleases.Count == 0)
                                    {
                                        <p class="text-muted mb-0">No current press releases were returned.</p>
                                    }
                                    else
                                    {
                                        <div class="list-group">
                                            @foreach (var release in _snapshot.State.PressReleases)
                                            {
                                                <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="@release.Url" target="_blank" rel="noopener noreferrer">
                                                    <div>
                                                        <div class="fw-semibold">@release.Title</div>
                                                        <div class="text-secondary small">@FormatTimestamp(release.PublishedAt)</div>
                                                    </div>
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </a>
                                            }
                                        </div>
                                    }
                                </section>

                                <section>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h3 class="h6 text-uppercase text-muted mb-0">Signed into law</h3>
                                        <span class="badge text-bg-light">@_snapshot.State.SignedLegislation.Count</span>
                                    </div>
                                    @if (_snapshot.State.SignedLegislation.Count == 0)
                                    {
                                        <p class="text-muted mb-0">No current signed legislation entries were returned.</p>
                                    }
                                    else
                                    {
                                        <div class="d-flex flex-column gap-3">
                                            @foreach (var law in _snapshot.State.SignedLegislation)
                                            {
                                                <article class="card border-0 shadow-sm p-3">
                                                    <span class="badge text-bg-warning-subtle text-warning-emphasis">@law.DocumentNumber</span>
                                                    <span class="fw-semibold ms-2">@law.Title</span>
                                                    @if (law.Legislation is not null)
                                                    {
                                                        <LegislationBriefPanel Brief="law.Legislation" SummaryLabel="Open signed-law brief" />
                                                    }
                                                    <div class="mt-3">
                                                        <a class="btn btn-outline-dark btn-sm" href="@law.Url" target="_blank" rel="noopener noreferrer">
                                                            Open signed law PDF
                                                        </a>
                                                    </div>
                                                </article>
                                            }
                                        </div>
                                    }
                                </section>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-5">
                    @foreach (var resourceSection in _snapshot.State.ResourceSections)
                    {
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body">
                                <h3 class="h5 mb-3">@resourceSection.Title</h3>
                                <div class="list-group">
                                    @foreach (var link in resourceSection.Links)
                                    {
                                        <a class="list-group-item list-group-item-action" href="@link.Url" target="_blank" rel="noopener noreferrer">
                                            <div class="fw-semibold">@link.Title</div>
                                            <div class="text-secondary small mb-0">@link.Description</div>
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="row g-4 mt-0">
                <div class="col-12 col-xxl-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <span class="small text-uppercase fw-semibold text-secondary">Georgia House</span>
                                    <h3 class="h4 mb-0">Recent floor votes</h3>
                                </div>
                                <span class="badge text-bg-light">@_snapshot.State.HouseVotes.Count</span>
                            </div>
                            @RenderStateVotes(_snapshot.State.HouseVotes)
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xxl-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <span class="small text-uppercase fw-semibold text-secondary">Georgia Senate</span>
                                    <h3 class="h4 mb-0">Recent floor votes</h3>
                                </div>
                                <span class="badge text-bg-light">@_snapshot.State.SenateVotes.Count</span>
                            </div>
                            @RenderStateVotes(_snapshot.State.SenateVotes)
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <span class="small text-uppercase fw-semibold text-secondary">Congress</span>
                    <h2 class="h4 mb-1">Federal floor action and vote detail</h2>
                    <p class="text-muted mb-2">@_snapshot.Federal.Summary</p>
                    <div class="alert alert-warning mb-0">
                        <i class="bi bi-info-circle me-2"></i>@_snapshot.Federal.StatusNote
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-12 col-xxl-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <span class="small text-uppercase fw-semibold text-secondary">U.S. Senate</span>
                                    <h3 class="h4 mb-0">Recent roll calls</h3>
                                </div>
                                <span class="badge text-bg-light">@_snapshot.Federal.SenateVotes.Count</span>
                            </div>
                            @RenderVotes(_snapshot.Federal.SenateVotes)
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xxl-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <span class="small text-uppercase fw-semibold text-secondary">U.S. House</span>
                                    <h3 class="h4 mb-0">Recent roll calls</h3>
                                </div>
                                <span class="badge text-bg-light">@_snapshot.Federal.HouseVotes.Count</span>
                            </div>
                            @RenderVotes(_snapshot.Federal.HouseVotes)
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mt-4">
                <div class="card-body">
                    <h3 class="h5 mb-3">Official federal links</h3>
                    <div class="list-group">
                        @foreach (var section in _snapshot.Federal.ResourceSections)
                        {
                            @foreach (var link in section.Links)
                            {
                                <a class="list-group-item list-group-item-action" href="@link.Url" target="_blank" rel="noopener noreferrer">
                                    <div class="fw-semibold">@link.Title</div>
                                    <div class="text-secondary small mb-0">@link.Description</div>
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    }
}

@code {
    private GovernmentIntelligenceSnapshot? _snapshot;
    private bool _loading;
    private string _activeSection = "community";
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadSnapshotAsync(forceRefresh: false);
    }

    private async Task RefreshAsync()
    {
        // Same shared lock as the 15-minute GovernmentIntelligenceRefreshBackgroundService,
        // so a manual refresh here can't run concurrently with the scheduled one and
        // double-scrape the external government sites.
        _loading = true;
        _errorMessage = string.Empty;

        var acquired = await GovernmentIntelligenceRefreshBackgroundService.RefreshLock.WaitAsync(3000);
        try
        {
            if (!acquired)
            {
                _errorMessage = "A scheduled refresh is already running - try again in a moment.";
                return;
            }

            await LoadSnapshotAsync(forceRefresh: true);
        }
        finally
        {
            if (acquired) GovernmentIntelligenceRefreshBackgroundService.RefreshLock.Release();
            _loading = false;
        }
    }

    private async Task LoadSnapshotAsync(bool forceRefresh)
    {
        _loading = true;
        _errorMessage = string.Empty;

        try
        {
            _snapshot = await GovernmentService.GetSnapshotAsync(forceRefresh);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load Government Intelligence");
            _errorMessage = "Failed to load government coverage.";
        }
        finally
        {
            _loading = false;
        }
    }

    private void SelectSection(string section) => _activeSection = section;

    private string TabClass(string section) =>
        _activeSection == section ? "active" : string.Empty;

    private string CurrentSummary()
    {
        if (_snapshot is null)
        {
            return string.Empty;
        }

        return _activeSection switch
        {
            "state" => _snapshot.State.Summary,
            "federal" => _snapshot.Federal.Summary,
            _ => _snapshot.Community.Summary
        };
    }

    private string FormatTimestamp(DateTimeOffset? value) =>
        value is null ? "Unavailable" : value.Value.ToString("MMMM dd, yyyy h:mm tt", CultureInfo.InvariantCulture);

    private static string FormatDate(DateOnly? value) =>
        value is null ? "Date unavailable" : value.Value.ToString("MMMM dd, yyyy", CultureInfo.InvariantCulture);

    private static string FormatEventWhen(CivicEvent localEvent) =>
        localEvent.StartAt is null
            ? "Date unavailable"
            : localEvent.StartAt.Value.ToString("MMM dd, yyyy h:mm tt", CultureInfo.InvariantCulture);

    private RenderFragment RenderLegislationBriefComponent(LegislationDetailBrief? brief, string summaryLabel) => builder =>
    {
        if (brief is null)
        {
            return;
        }

        builder.OpenComponent<LegislationBriefPanel>(0);
        builder.AddAttribute(1, nameof(LegislationBriefPanel.Brief), brief);
        builder.AddAttribute(2, nameof(LegislationBriefPanel.SummaryLabel), summaryLabel);
        builder.CloseComponent();
    };

    private RenderFragment RenderStateVotes(IReadOnlyList<StateLegislativeVoteSummary> votes) => builder =>
    {
        if (votes.Count == 0)
        {
            builder.OpenElement(0, "p");
            builder.AddAttribute(1, "class", "text-muted mb-0");
            builder.AddContent(2, "No Georgia floor-vote data was returned.");
            builder.CloseElement();
            return;
        }

        var sequence = 10;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "d-flex flex-column gap-3");

        foreach (var vote in votes)
        {
            builder.OpenElement(sequence++, "article");
            builder.AddAttribute(sequence++, "class", "card border-0 shadow-sm p-3");

            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "d-flex justify-content-between align-items-center text-uppercase small text-secondary");
            builder.AddContent(sequence++, $"{vote.Chamber} Vote {vote.RollCallNumber}");
            builder.OpenElement(sequence++, "span");
            builder.AddContent(sequence++, FormatTimestamp(vote.VotedAt));
            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(sequence++, "h4");
            builder.AddAttribute(sequence++, "class", "fw-semibold my-2");
            builder.AddContent(sequence++, $"{vote.Measure} · {vote.Title}");
            builder.CloseElement();

            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "text-secondary mb-3");
            builder.AddContent(sequence++, vote.Caption);
            builder.CloseElement();

            if (!string.IsNullOrWhiteSpace(vote.Status))
            {
                builder.OpenElement(sequence++, "p");
                builder.AddAttribute(sequence++, "class", "text-secondary small mb-3");
                builder.AddContent(sequence++, $"Latest bill status: {vote.Status}");
                builder.CloseElement();
            }

            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "d-flex flex-wrap gap-2 mb-2");
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "badge text-bg-dark");
            builder.AddContent(sequence++, $"Yea {vote.YeaCount}");
            builder.CloseElement();
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "badge text-bg-light");
            builder.AddContent(sequence++, $"Nay {vote.NayCount}");
            builder.CloseElement();
            if (vote.NotVotingCount > 0)
            {
                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", "badge text-bg-light");
                builder.AddContent(sequence++, $"Not Voting {vote.NotVotingCount}");
                builder.CloseElement();
            }
            if (vote.ExcusedCount > 0)
            {
                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", "badge text-bg-light");
                builder.AddContent(sequence++, $"Excused {vote.ExcusedCount}");
                builder.CloseElement();
            }
            builder.CloseElement();

            builder.OpenElement(sequence++, "details");
            builder.AddAttribute(sequence++, "class", "mt-3 pt-3 border-top");
            builder.OpenElement(sequence++, "summary");
            builder.AddContent(sequence++, "Open Georgia member vote breakdown");
            builder.CloseElement();

            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "table-responsive mt-3");
            builder.OpenElement(sequence++, "table");
            builder.AddAttribute(sequence++, "class", "table table-sm align-middle mb-0");
            builder.OpenElement(sequence++, "thead");
            builder.OpenElement(sequence++, "tr");
            foreach (var heading in new[] { "Member", "Vote" })
            {
                builder.OpenElement(sequence++, "th");
                builder.AddContent(sequence++, heading);
                builder.CloseElement();
            }
            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(sequence++, "tbody");
            foreach (var member in vote.Votes)
            {
                builder.OpenElement(sequence++, "tr");
                builder.OpenElement(sequence++, "td");
                builder.AddContent(sequence++, member.Name);
                builder.CloseElement();
                builder.OpenElement(sequence++, "td");
                builder.AddContent(sequence++, member.Vote);
                builder.CloseElement();
                builder.CloseElement();
            }
            builder.CloseElement();
            builder.CloseElement();
            builder.CloseElement();
            builder.CloseElement();

            builder.AddContent(sequence++, RenderLegislationBriefComponent(vote.Legislation, "Open Georgia legislation brief"));

            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "mt-3");
            builder.OpenElement(sequence++, "a");
            builder.AddAttribute(sequence++, "class", "btn btn-outline-dark btn-sm");
            builder.AddAttribute(sequence++, "href", vote.DetailUrl);
            builder.AddAttribute(sequence++, "target", "_blank");
            builder.AddAttribute(sequence++, "rel", "noopener noreferrer");
            builder.AddContent(sequence++, "Open official bill detail");
            builder.CloseElement();
            builder.CloseElement();

            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private RenderFragment RenderVotes(IReadOnlyList<ChamberVoteSummary> votes) => builder =>
    {
        if (votes.Count == 0)
        {
            builder.OpenElement(0, "p");
            builder.AddAttribute(1, "class", "text-muted mb-0");
            builder.AddContent(2, "No vote data was returned.");
            builder.CloseElement();
            return;
        }

        var sequence = 10;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "d-flex flex-column gap-3");

        foreach (var vote in votes)
        {
            builder.OpenElement(sequence++, "article");
            builder.AddAttribute(sequence++, "class", "card border-0 shadow-sm p-3");

            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "d-flex justify-content-between align-items-center text-uppercase small text-secondary");
            builder.AddContent(sequence++, $"{vote.Chamber} Roll Call {vote.RollCallNumber}");
            builder.CloseElement();

            builder.OpenElement(sequence++, "h4");
            builder.AddAttribute(sequence++, "class", "fw-semibold my-2");
            builder.AddContent(sequence++, string.IsNullOrWhiteSpace(vote.Measure) ? vote.Title : $"{vote.Measure} · {vote.Title}");
            builder.CloseElement();

            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "text-secondary mb-3");
            builder.AddContent(sequence++, vote.Question);
            builder.CloseElement();

            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "d-flex flex-wrap gap-2 mb-2");
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "badge text-bg-dark");
            builder.AddContent(sequence++, vote.Result);
            builder.CloseElement();
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "badge text-bg-light");
            builder.AddContent(sequence++, $"Yea {vote.YeaCount}");
            builder.CloseElement();
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "badge text-bg-light");
            builder.AddContent(sequence++, $"Nay {vote.NayCount}");
            builder.CloseElement();
            if (vote.PresentCount > 0)
            {
                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", "badge text-bg-light");
                builder.AddContent(sequence++, $"Present {vote.PresentCount}");
                builder.CloseElement();
            }
            if (vote.NotVotingCount > 0)
            {
                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", "badge text-bg-light");
                builder.AddContent(sequence++, $"Not Voting {vote.NotVotingCount}");
                builder.CloseElement();
            }
            builder.CloseElement();

            var georgiaVotes = vote.Votes
                .Where(member => string.Equals(member.State, "GA", StringComparison.OrdinalIgnoreCase))
                .ToList();

            if (georgiaVotes.Count > 0)
            {
                builder.OpenElement(sequence++, "div");
                builder.AddAttribute(sequence++, "class", "bg-light border rounded p-3 mt-3");
                builder.OpenElement(sequence++, "div");
                builder.AddAttribute(sequence++, "class", "d-flex justify-content-between align-items-center gap-2 text-uppercase small text-secondary");
                builder.AddContent(sequence++, "Georgia delegation");
                builder.CloseElement();

                builder.OpenElement(sequence++, "div");
                builder.AddAttribute(sequence++, "class", "d-flex flex-wrap gap-2");
                foreach (var member in georgiaVotes)
                {
                    builder.OpenElement(sequence++, "span");
                    builder.AddAttribute(sequence++, "class", "badge text-bg-light border fw-normal");
                    builder.AddContent(sequence++, $"{member.Name} ({member.Party}) · {member.Vote}");
                    builder.CloseElement();
                }
                builder.CloseElement();
                builder.CloseElement();
            }

            builder.AddContent(sequence++, RenderLegislationBriefComponent(vote.Legislation, "Open federal legislation brief"));

            builder.OpenElement(sequence++, "details");
            builder.AddAttribute(sequence++, "class", "mt-3 pt-3 border-top");
            builder.OpenElement(sequence++, "summary");
            builder.AddContent(sequence++, "Open full member vote breakdown");
            builder.CloseElement();

            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "table-responsive mt-3");
            builder.OpenElement(sequence++, "table");
            builder.AddAttribute(sequence++, "class", "table table-sm align-middle mb-0");
            builder.OpenElement(sequence++, "thead");
            builder.OpenElement(sequence++, "tr");
            foreach (var heading in new[] { "Member", "Party", "State", "Vote" })
            {
                builder.OpenElement(sequence++, "th");
                builder.AddContent(sequence++, heading);
                builder.CloseElement();
            }
            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(sequence++, "tbody");
            foreach (var member in vote.Votes)
            {
                builder.OpenElement(sequence++, "tr");

                builder.OpenElement(sequence++, "td");
                builder.AddContent(sequence++, member.Name);
                builder.CloseElement();

                builder.OpenElement(sequence++, "td");
                builder.AddContent(sequence++, member.Party);
                builder.CloseElement();

                builder.OpenElement(sequence++, "td");
                builder.AddContent(sequence++, member.State);
                builder.CloseElement();

                builder.OpenElement(sequence++, "td");
                builder.AddContent(sequence++, member.Vote);
                builder.CloseElement();

                builder.CloseElement();
            }
            builder.CloseElement();
            builder.CloseElement();
            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "mt-3");
            builder.OpenElement(sequence++, "a");
            builder.AddAttribute(sequence++, "class", "btn btn-outline-dark btn-sm");
            builder.AddAttribute(sequence++, "href", vote.DetailUrl);
            builder.AddAttribute(sequence++, "target", "_blank");
            builder.AddAttribute(sequence++, "rel", "noopener noreferrer");
            builder.AddContent(sequence++, "Open official vote detail");
            builder.CloseElement();
            builder.CloseElement();

            builder.CloseElement();
        }

        builder.CloseElement();
    };
}
