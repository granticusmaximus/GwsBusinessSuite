@page "/admin/wiki"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "AdminOnly")]
@implements IAsyncDisposable
@using GwsBusinessSuite.Application.Wiki
@using GwsBusinessSuite.Application.CmsBuilder
@using GwsBusinessSuite.Domain.Entities
@inject IWikiService WikiService
@inject IMediaLibraryService MediaLibraryService
@inject ICurrentUserAccessor CurrentUserAccessor
@inject IJSRuntime JS
@inject ILogger<Wiki> Logger

<PageTitle>Knowledge Base</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-journal-bookmark-fill me-2 text-warning"></i>Knowledge Base</h1>
    <p>Store internal documentation, SOPs, app notes, and business operating knowledge with a block-based editor.
        Every save keeps a version snapshot you can inspect or revert to.</p>
</div>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger d-flex align-items-start gap-2 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
        <div>@ErrorMessage</div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-info d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <div>@StatusMessage</div>
    </div>
}

<div class="row g-4">
    <div class="col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between gap-2">
                <span class="fw-semibold">Pages</span>
                <button class="btn btn-sm btn-outline-primary" @onclick="CreateNewPage" disabled="@IsBusy">
                    <i class="bi bi-plus-lg me-1"></i>New Page
                </button>
            </div>
            <div class="card-body border-bottom py-2">
                <input class="form-control form-control-sm" @bind="SearchQuery" @bind:event="oninput"
                       placeholder="Search pages by title or slug..." />
            </div>
            <div class="card-body p-0">
                @if (WikiPages.Count == 0)
                {
                    <div class="p-4 text-secondary">
                        <p class="mb-0">No wiki pages yet. Create the first page to capture procedures or notes.</p>
                    </div>
                }
                else if (FilteredAndOrderedPages().Count == 0)
                {
                    <div class="p-4 text-secondary">
                        <p class="mb-0">No pages match "@SearchQuery".</p>
                    </div>
                }
                else
                {
                    <div class="wiki-tree">
                        @foreach (var wikiPage in FilteredAndOrderedPages())
                        {
                            <div class="wiki-tree-row @(SelectedPageId == wikiPage.Id ? "active" : "")"
                                 style="padding-left:@(0.5 + GetWikiPageDepth(wikiPage) * 1.25)rem;">
                                @if (HasChildren(wikiPage.Id) && string.IsNullOrWhiteSpace(SearchQuery))
                                {
                                    <button type="button" class="wiki-tree-toggle" @onclick="() => ToggleExpanded(wikiPage.Id)">
                                        <i class="bi @(IsExpanded(wikiPage.Id) ? "bi-caret-down-fill" : "bi-caret-right-fill")"></i>
                                    </button>
                                }
                                else
                                {
                                    <span class="wiki-tree-spacer"></span>
                                }
                                <button type="button" class="wiki-tree-label" @onclick="() => OpenPageAsync(wikiPage.Id)" disabled="@IsBusy">
                                    <span class="wiki-tree-icon">@(string.IsNullOrWhiteSpace(wikiPage.Icon) ? "📄" : wikiPage.Icon)</span>
                                    <span class="wiki-tree-title">@wikiPage.Title</span>
                                </button>
                                <div class="wiki-tree-actions">
                                    <button type="button" class="btn btn-xs btn-link p-0" title="Move up" @onclick="() => MovePageAsync(wikiPage, -1)" disabled="@IsBusy">
                                        <i class="bi bi-chevron-up"></i>
                                    </button>
                                    <button type="button" class="btn btn-xs btn-link p-0" title="Move down" @onclick="() => MovePageAsync(wikiPage, 1)" disabled="@IsBusy">
                                        <i class="bi bi-chevron-down"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-9">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between gap-2">
                <span class="fw-semibold">@EditorHeader</span>
                <span class="badge @(SelectedPageId.HasValue ? "text-bg-primary" : "text-bg-secondary")">
                    @(SelectedPageId.HasValue ? "Editing Existing Page" : "New Page")
                </span>
            </div>
            <div class="card-body">
                <EditForm Model="Editor" OnValidSubmit="SavePageAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row g-3 mb-2">
                        <div class="col-md-1">
                            <label class="form-label fw-semibold small">Icon</label>
                            <input class="form-control text-center" @bind="Editor.Icon" placeholder="📄" maxlength="4" />
                        </div>
                        <div class="col-md-7">
                            <label class="form-label fw-semibold small">Title</label>
                            <InputText class="form-control" @bind-Value="Editor.Title" placeholder="Page title" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small">Slug</label>
                            <InputText class="form-control" @bind-Value="Editor.Slug" placeholder="optional-slug" />
                        </div>
                        @if (SelectedPageId.HasValue)
                        {
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">Parent Page</label>
                                <select class="form-select" @bind="ParentWikiPageIdSelection" @bind:after="MoveToSelectedParentAsync">
                                    <option value="">— Top level —</option>
                                    @foreach (var candidate in WikiParentPageOptions())
                                    {
                                        <option value="@candidate.Id">@candidate.Title</option>
                                    }
                                </select>
                            </div>
                        }
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small d-flex justify-content-between">
                                <span>Cover image</span>
                                <button type="button" class="btn btn-xs btn-outline-secondary" @onclick="ToggleCoverPickerAsync">
                                    <i class="bi bi-image me-1"></i>@(string.IsNullOrWhiteSpace(Editor.CoverImageUrl) ? "Add" : "Change")
                                </button>
                            </label>
                            @if (!string.IsNullOrWhiteSpace(Editor.CoverImageUrl))
                            {
                                <div class="wiki-cover-preview">
                                    <img src="@Editor.CoverImageUrl" alt="Cover" loading="lazy" />
                                    <button type="button" class="btn btn-xs btn-link text-danger" @onclick="() => Editor.CoverImageUrl = null">Remove</button>
                                </div>
                            }
                        </div>
                    </div>

                    @if (_showCoverPicker)
                    {
                        <div class="wiki-media-picker border rounded-3 p-2 mb-3">
                            @if (!string.IsNullOrEmpty(_mediaPickerError))
                            {
                                <div class="text-danger small mb-0">@_mediaPickerError</div>
                            }
                            else if (_mediaAssets.Count == 0)
                            {
                                <p class="text-secondary small mb-0">No media uploaded yet. Upload images from the Media Library.</p>
                            }
                            else
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var asset in _mediaAssets)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary p-1" title="@asset.FileName"
                                                @onclick="() => SelectCoverAsync(asset)">
                                            <img src="@asset.ThumbnailUrl" alt="@asset.AltText" loading="lazy" style="width:64px;height:64px;object-fit:cover;" />
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    }

                    <label class="form-label fw-semibold small mb-1">Content</label>
                    <div class="small text-secondary mb-2">
                        Type <code>/</code> for block commands, <code>[[</code> to link to another page, Tab/Shift+Tab to indent.
                    </div>
                    <div class="wiki-block-editor" @ref="_blockEditorContainer"></div>

                    <div class="mt-3 d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@IsBusy">
                            <i class="bi bi-floppy-fill me-1"></i>Save Page
                        </button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="CreateNewPage" disabled="@IsBusy">
                            Reset
                        </button>
                        <button type="button" class="btn btn-outline-danger" @onclick="DeleteSelectedPageAsync"
                                disabled="@(IsBusy || !SelectedPageId.HasValue)">
                            Delete
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-white border-bottom py-3">
                <span class="fw-semibold">Preview</span>
            </div>
            <div class="card-body">
                <div class="wiki-rendered-preview">@((MarkupString)RenderedHtml)</div>
            </div>
        </div>

        @if (SelectedPageId.HasValue)
        {
            <div class="card border-0 shadow-sm mt-4">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center gap-3">
                    <div>
                        <div class="fw-semibold">History</div>
                        <div class="small text-secondary">Bounded version snapshots - the last @MaxHistoryDisplay are kept.</div>
                    </div>
                    <span class="badge text-bg-secondary">@History.Count version@(History.Count == 1 ? "" : "s")</span>
                </div>
                <div class="card-body p-0">
                    @if (!string.IsNullOrEmpty(HistoryErrorMessage))
                    {
                        <div class="alert alert-danger m-3 mb-0 py-2 small">@HistoryErrorMessage</div>
                    }
                    @if (History.Count == 0)
                    {
                        <div class="p-4">
                            <p class="text-secondary mb-0">No versions yet - saving this page will create the first one.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @for (var i = 0; i < History.Count; i++)
                            {
                                var revision = History[i];
                                var previousRevision = i + 1 < History.Count ? History[i + 1] : null;
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <div class="fw-semibold small">
                                                <code class="me-1">v@(revision.RevisionNumber)</code>@(string.IsNullOrWhiteSpace(revision.Label) ? "Saved" : revision.Label)
                                            </div>
                                            <div class="small text-secondary mt-1">
                                                @revision.AuthorName &middot; @revision.When.ToLocalTime().ToString("g")
                                            </div>
                                        </div>
                                        <div class="d-flex gap-1 flex-shrink-0">
                                            @if (previousRevision is not null)
                                            {
                                                <button class="btn btn-xs btn-outline-secondary" @onclick="() => ToggleDiffAsync(revision, previousRevision)">
                                                    Diff
                                                </button>
                                            }
                                            <button class="btn btn-xs btn-outline-primary" @onclick="() => RevertToRevisionAsync(revision.Id)"
                                                    disabled="@IsHistoryBusy">
                                                Revert
                                            </button>
                                        </div>
                                    </div>
                                    @if (DiffRevisionKey == revision.Id)
                                    {
                                        <div class="mt-3 border-top pt-3">
                                            @if (string.IsNullOrEmpty(DiffText))
                                            {
                                                <div class="small text-secondary">No block changes between these versions.</div>
                                            }
                                            else
                                            {
                                                <div class="p-2 rounded-3 border bg-body-tertiary">
                                                    @foreach (var line in DiffText.Split('\n'))
                                                    {
                                                        <div class="@DiffLineClass(line)" style="white-space:pre-wrap;font-family:var(--bs-font-monospace, monospace);font-size:0.8125rem;">@line</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    private const int MaxHistoryDisplay = 20;

    private List<WikiPage> WikiPages { get; set; } = new();
    private WikiPageEditorModel Editor { get; set; } = new();
    private Guid? SelectedPageId { get; set; }
    private bool IsBusy { get; set; }
    private string SearchQuery { get; set; } = string.Empty;
    private string StatusMessage { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;
    private readonly HashSet<Guid> _expandedPageIds = new();

    private List<WikiRevisionView> History { get; set; } = new();
    private bool IsHistoryBusy { get; set; }
    private string HistoryErrorMessage { get; set; } = string.Empty;
    private Guid? DiffRevisionKey { get; set; }
    private string? DiffText { get; set; }

    private ElementReference _blockEditorContainer;
    private IJSObjectReference? _blockEditorModule;
    private DotNetObjectReference<Wiki>? _blockEditorRef;
    private bool _blockEditorInitialized;
    private int _editorGeneration;
    private int _blockEditorSyncedGeneration = -1;

    private string EditorHeader => SelectedPageId.HasValue ? "Edit Wiki Page" : "Create Wiki Page";

    private string RenderedHtml =>
        WikiBlockHtmlRenderer.RenderPage(WikiBlockJson.ParseBlocks(Editor.BlocksJson), WikiPages);

    private bool _showCoverPicker;
    private string _mediaPickerError = string.Empty;
    private List<MediaAssetSummary> _mediaAssets = new();
    private DotNetObjectReference<Wiki>? _wikiLinksRef;
    private bool _wikiLinksInitialized;

    private async Task ToggleCoverPickerAsync()
    {
        _showCoverPicker = !_showCoverPicker;
        if (!_showCoverPicker)
        {
            return;
        }

        _mediaPickerError = string.Empty;
        try
        {
            _mediaAssets = (await MediaLibraryService.ListAsync()).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load media library for the wiki cover picker.");
            _mediaPickerError = $"Unable to load media library. {ex.Message}";
        }
    }

    private void SelectCoverAsync(MediaAssetSummary asset)
    {
        Editor.CoverImageUrl = asset.Url;
        _showCoverPicker = false;
    }

    [JSInvokable]
    public Task<IReadOnlyList<WikiLinkSuggestion>> SearchWikiLinkSuggestions(string query) =>
        Task.FromResult(WikiMarkdownHelper.SearchLinkSuggestions(query, WikiPages));

    [JSInvokable]
    public async Task NavigateToWikiPageId(string pageId)
    {
        if (Guid.TryParse(pageId, out var id))
        {
            await OpenPageAsync(id);
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnBlocksChanged(string blocksJson)
    {
        Editor.BlocksJson = blocksJson;
        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadPagesAsync(selectFirstPage: false);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_wikiLinksInitialized)
        {
            _wikiLinksRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("gwsWikiLinks.init", _wikiLinksRef);
            _wikiLinksInitialized = true;
        }

        if (!_blockEditorInitialized)
        {
            _blockEditorRef = DotNetObjectReference.Create(this);
            _blockEditorModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/wiki-block-editor.js");
            await _blockEditorModule.InvokeVoidAsync("initialize", _blockEditorContainer, _blockEditorRef, Editor.BlocksJson);
            _blockEditorInitialized = true;
            _blockEditorSyncedGeneration = _editorGeneration;
        }
        else if (_blockEditorSyncedGeneration != _editorGeneration)
        {
            await _blockEditorModule!.InvokeVoidAsync("setBlocks", _blockEditorContainer, Editor.BlocksJson);
            _blockEditorSyncedGeneration = _editorGeneration;
        }
    }

    private Task<string> CurrentUserNameAsync() => CurrentUserAccessor.GetCurrentUsernameAsync();

    private async Task LoadPagesAsync(bool selectFirstPage)
    {
        try
        {
            WikiPages = (await WikiService.ListPagesAsync()).ToList();
            if (selectFirstPage && WikiPages.Count > 0)
            {
                await OpenPageAsync(WikiPages[0].Id);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load wiki pages.");
            ErrorMessage = $"Unable to load wiki pages. {ex.Message}";
        }
    }

    private void CreateNewPage()
    {
        SelectedPageId = null;
        Editor = new WikiPageEditorModel();
        History = new();
        DiffRevisionKey = null;
        _editorGeneration++;
        StatusMessage = "Ready to create a new wiki page.";
        ErrorMessage = string.Empty;
    }

    private async Task OpenPageAsync(Guid wikiPageId)
    {
        try
        {
            var page = await WikiService.GetPageAsync(wikiPageId);
            if (page is null)
            {
                StatusMessage = "The selected wiki page no longer exists.";
                return;
            }

            SelectedPageId = page.Id;
            Editor = new WikiPageEditorModel
            {
                WikiPageId = page.Id,
                Title = page.Title,
                Slug = page.Slug,
                BlocksJson = page.BlocksJson,
                Icon = page.Icon,
                CoverImageUrl = page.CoverImageUrl,
                ParentWikiPageId = page.ParentWikiPageId
            };
            _editorGeneration++;
            DiffRevisionKey = null;
            StatusMessage = $"Opened wiki page '{page.Title}'.";
            ErrorMessage = string.Empty;
            await LoadHistoryAsync(page.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to open wiki page {WikiPageId}.", wikiPageId);
            ErrorMessage = $"Unable to open wiki page. {ex.Message}";
        }
    }

    private async Task LoadHistoryAsync(Guid wikiPageId)
    {
        HistoryErrorMessage = string.Empty;
        try
        {
            History = (await WikiService.GetHistoryAsync(wikiPageId)).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load wiki page history for {WikiPageId}.", wikiPageId);
            HistoryErrorMessage = $"Unable to load history. {ex.Message}";
        }
    }

    private async Task SavePageAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            var user = await CurrentUserNameAsync();
            var saved = await WikiService.SavePageAsync(Editor, user);
            SelectedPageId = saved.Id;
            Editor = new WikiPageEditorModel
            {
                WikiPageId = saved.Id,
                Title = saved.Title,
                Slug = saved.Slug,
                BlocksJson = saved.BlocksJson,
                Icon = saved.Icon,
                CoverImageUrl = saved.CoverImageUrl,
                ParentWikiPageId = saved.ParentWikiPageId
            };
            // Deliberately not bumping _editorGeneration here - the block editor's DOM already
            // reflects exactly what was just saved (that's where BlocksJson came from), so
            // resetting it would only cost the user their cursor position for no benefit.
            StatusMessage = $"Saved wiki page '{saved.Title}'.";
            await LoadPagesAsync(selectFirstPage: false);
            await LoadHistoryAsync(saved.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to save wiki page.");
            ErrorMessage = $"Unable to save wiki page. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task DeleteSelectedPageAsync()
    {
        if (SelectedPageId is not { } wikiPageId)
        {
            return;
        }

        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            var user = await CurrentUserNameAsync();
            await WikiService.DeletePageAsync(wikiPageId, user);
            StatusMessage = "Wiki page deleted.";
            CreateNewPage();
            await LoadPagesAsync(selectFirstPage: false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to delete wiki page {WikiPageId}.", wikiPageId);
            ErrorMessage = $"Unable to delete wiki page. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task MovePageAsync(WikiPage page, int direction)
    {
        var siblings = OrderedPagesByHierarchy()
            .Where(p => p.ParentWikiPageId == page.ParentWikiPageId)
            .ToList();
        var currentIndex = siblings.FindIndex(p => p.Id == page.Id);
        var targetIndex = currentIndex + direction;
        if (currentIndex < 0 || targetIndex < 0 || targetIndex >= siblings.Count)
        {
            return;
        }

        await Work(async () =>
        {
            var user = await CurrentUserNameAsync();
            await WikiService.ReorderPageAsync(page.Id, page.ParentWikiPageId, targetIndex, user);
            await LoadPagesAsync(selectFirstPage: false);
        });
    }

    private async Task MoveToSelectedParentAsync()
    {
        if (SelectedPageId is not { } wikiPageId)
        {
            return;
        }

        await Work(async () =>
        {
            var user = await CurrentUserNameAsync();
            await WikiService.ReorderPageAsync(wikiPageId, Editor.ParentWikiPageId, int.MaxValue, user);
            await LoadPagesAsync(selectFirstPage: false);
            StatusMessage = "Page moved.";
        });
    }

    private async Task Work(Func<Task> action)
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;
        try
        {
            await action();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Wiki page move failed.");
            ErrorMessage = $"Unable to move wiki page. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task ToggleDiffAsync(WikiRevisionView revision, WikiRevisionView previousRevision)
    {
        if (DiffRevisionKey == revision.Id)
        {
            DiffRevisionKey = null;
            DiffText = null;
            return;
        }

        if (SelectedPageId is not { } wikiPageId)
        {
            return;
        }

        try
        {
            DiffText = await WikiService.GetStructuralDiffAsync(wikiPageId, previousRevision.Id, revision.Id);
            DiffRevisionKey = revision.Id;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load diff for wiki page {WikiPageId} between revisions.", wikiPageId);
            HistoryErrorMessage = $"Unable to load diff. {ex.Message}";
        }
    }

    private async Task RevertToRevisionAsync(Guid revisionId)
    {
        if (SelectedPageId is not { } wikiPageId)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Revert to this version? This creates a new version with the old content - nothing is lost.");
        if (!confirmed) return;

        IsHistoryBusy = true;
        try
        {
            var user = await CurrentUserNameAsync();
            var reverted = await WikiService.RevertToRevisionAsync(wikiPageId, revisionId, user);
            Editor = new WikiPageEditorModel
            {
                WikiPageId = reverted.Id,
                Title = reverted.Title,
                Slug = reverted.Slug,
                BlocksJson = reverted.BlocksJson,
                Icon = reverted.Icon,
                CoverImageUrl = reverted.CoverImageUrl,
                ParentWikiPageId = reverted.ParentWikiPageId
            };
            _editorGeneration++;
            DiffRevisionKey = null;
            StatusMessage = $"Reverted '{reverted.Title}' to an earlier version.";
            await LoadPagesAsync(selectFirstPage: false);
            await LoadHistoryAsync(wikiPageId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to revert wiki page {WikiPageId} to revision {RevisionId}.", wikiPageId, revisionId);
            HistoryErrorMessage = $"Unable to revert. {ex.Message}";
        }
        finally
        {
            IsHistoryBusy = false;
        }
    }

    // Recursive depth-first flatten via ToLookup(ParentWikiPageId), rendered as an indented
    // flat list with expand/collapse rather than a nested component - mirrors Pages.razor's
    // OrderedPagesByHierarchy()/GetPageDepth() for CMS pages.
    private List<WikiPage> OrderedPagesByHierarchy()
    {
        var byParent = WikiPages.ToLookup(p => p.ParentWikiPageId);
        var result = new List<WikiPage>();

        void Visit(Guid? parentId)
        {
            foreach (var page in byParent[parentId].OrderBy(p => p.SortOrder))
            {
                result.Add(page);
                if (parentId is null || IsExpanded(parentId.Value))
                {
                    Visit(page.Id);
                }
            }
        }

        Visit(null);
        return result;
    }

    private bool HasChildren(Guid pageId) => WikiPages.Any(p => p.ParentWikiPageId == pageId);
    private bool IsExpanded(Guid pageId) => _expandedPageIds.Contains(pageId);
    private void ToggleExpanded(Guid pageId)
    {
        if (!_expandedPageIds.Add(pageId))
        {
            _expandedPageIds.Remove(pageId);
        }
    }

    private int GetWikiPageDepth(WikiPage page)
    {
        var byId = WikiPages.ToDictionary(p => p.Id);
        var depth = 0;
        var current = page;
        var guard = 0;
        while (current?.ParentWikiPageId is { } parentId && byId.TryGetValue(parentId, out var parent) && guard++ < 64)
        {
            depth++;
            current = parent;
        }

        return depth;
    }

    // With no search query, the tree is shown collapsed to top-level + expanded branches.
    // Once searching, a matched child's ancestors may not themselves be expanded, so tree
    // order stops making sense - fall back to a flat alphabetical list of matches.
    private List<WikiPage> FilteredAndOrderedPages()
    {
        if (string.IsNullOrWhiteSpace(SearchQuery))
        {
            return OrderedPagesByHierarchy();
        }

        return WikiPages
            .Where(p => p.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
                || p.Slug.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase))
            .OrderBy(p => p.Title, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    // Mirrors EditPage.razor's ParentPageOptions() for CMS pages - a BFS from the open page
    // excluding itself and every descendant, so the <select> can never offer a choice that
    // would create a cycle (ReorderPageAsync also guards this server-side).
    private List<WikiPage> WikiParentPageOptions()
    {
        if (!SelectedPageId.HasValue)
        {
            return WikiPages;
        }

        var byParent = WikiPages.ToLookup(p => p.ParentWikiPageId);
        var excluded = new HashSet<Guid> { SelectedPageId.Value };
        var frontier = new Queue<Guid>();
        frontier.Enqueue(SelectedPageId.Value);
        while (frontier.Count > 0)
        {
            foreach (var child in byParent[frontier.Dequeue()])
            {
                if (excluded.Add(child.Id)) frontier.Enqueue(child.Id);
            }
        }

        return WikiPages.Where(p => !excluded.Contains(p.Id)).ToList();
    }

    private string ParentWikiPageIdSelection
    {
        get => Editor.ParentWikiPageId?.ToString() ?? string.Empty;
        set => Editor.ParentWikiPageId = Guid.TryParse(value, out var id) ? id : null;
    }

    private static string DiffLineClass(string line) =>
        line.StartsWith('+') ? "text-success"
        : line.StartsWith('-') ? "text-danger"
        : line.StartsWith('~') ? "text-warning"
        : "text-secondary";

    public async ValueTask DisposeAsync()
    {
        if (_blockEditorInitialized && _blockEditorModule is not null)
        {
            try
            {
                await _blockEditorModule.InvokeVoidAsync("dispose", _blockEditorContainer);
                await _blockEditorModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // The circuit is already gone (e.g. browser closed); nothing to clean up client-side.
            }
        }

        _blockEditorRef?.Dispose();

        if (_wikiLinksInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("gwsWikiLinks.dispose");
            }
            catch (JSDisconnectedException)
            {
                // The circuit is already gone (e.g. browser closed); nothing to clean up client-side.
            }
        }

        _wikiLinksRef?.Dispose();
    }
}
