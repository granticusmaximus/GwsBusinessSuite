@page "/admin/wiki"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using GwsBusinessSuite.Application.Wiki
@using GwsBusinessSuite.Domain.Entities
@using Markdig
@using Microsoft.AspNetCore.Components.Authorization
@inject IWikiService WikiService
@inject IJSRuntime JS
@inject ILogger<Wiki> Logger

<PageTitle>Knowledge Base</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-journal-bookmark-fill me-2 text-warning"></i>Knowledge Base</h1>
    <p>Store internal documentation, SOPs, app notes, and business operating knowledge. Every save is a git commit,
        so full history and diffs are always available.</p>
</div>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger d-flex align-items-start gap-2 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
        <div>@ErrorMessage</div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-info d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <div>@StatusMessage</div>
    </div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div
                class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between gap-2">
                <span class="fw-semibold">Pages</span>
                <button class="btn btn-sm btn-outline-primary" @onclick="CreateNewPage" disabled="@IsBusy">
                    <i class="bi bi-plus-lg me-1"></i>New Page
                </button>
            </div>
            <div class="card-body p-0">
                @if (WikiPages.Count == 0)
                {
                    <div class="p-4 text-secondary">
                        <p class="mb-0">No wiki pages yet. Create the first page to capture procedures or notes.</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var wikiPage in WikiPages)
                        {
                            <button type="button"
                                    class="list-group-item list-group-item-action d-flex justify-content-between align-items-start gap-2 @(SelectedPageId == wikiPage.Id ? "active" : string.Empty)"
                                    @onclick="() => OpenPageAsync(wikiPage.Id)" disabled="@IsBusy">
                                <div>
                                    <div class="fw-semibold">@wikiPage.Title</div>
                                    <div class="small @(SelectedPageId == wikiPage.Id ? "text-white-50" : "text-secondary")">
                                        @wikiPage.Slug
                                    </div>
                                </div>
                                <span class="badge @(SelectedPageId == wikiPage.Id ? "text-bg-light" : "text-bg-secondary")">
                                    @((wikiPage.UpdatedAt ?? wikiPage.CreatedAt).ToLocalTime().ToString("yyyy-MM-dd"))
                                </span>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div
                class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between gap-2">
                <span class="fw-semibold">@EditorHeader</span>
                <span class="badge @(SelectedPageId.HasValue ? "text-bg-primary" : "text-bg-secondary")">
                    @(SelectedPageId.HasValue ? "Editing Existing Page" : "New Page")
                </span>
            </div>
            <div class="card-body">
                <EditForm Model="Editor" OnValidSubmit="SavePageAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold small">Title</label>
                            <InputText class="form-control" @bind-Value="Editor.Title" placeholder="Runbook title" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small">Slug</label>
                            <InputText class="form-control" @bind-Value="Editor.Slug" placeholder="optional-slug" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Markdown</label>
                            <textarea id="@MarkdownEditorElementId">@Editor.Markdown</textarea>
                        </div>
                    </div>

                    <div class="mt-3 d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@IsBusy">
                            <i class="bi bi-floppy-fill me-1"></i>Save Page
                        </button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="CreateNewPage"
                                disabled="@IsBusy">
                            Reset
                        </button>
                        <button type="button" class="btn btn-outline-danger" @onclick="DeleteSelectedPageAsync"
                                disabled="@(IsBusy || !SelectedPageId.HasValue)">
                            Delete
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-white border-bottom py-3">
                <span class="fw-semibold">Preview</span>
            </div>
            <div class="card-body">
                @if (string.IsNullOrWhiteSpace(Editor.Markdown))
                {
                    <p class="text-secondary mb-0">Markdown preview appears here after you enter content.</p>
                }
                else
                {
                    <div class="wiki-rendered-preview">@((MarkupString)RenderedHtml)</div>
                }
            </div>
        </div>

        @if (SelectedPageId.HasValue)
        {
            <div class="card border-0 shadow-sm mt-4">
                <div
                    class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center gap-3">
                    <div>
                        <div class="fw-semibold">History</div>
                        <div class="small text-secondary">Every save is a git commit - full history, diffs, and revert.</div>
                    </div>
                    <span class="badge text-bg-secondary">@History.Count commit@(History.Count == 1 ? "" : "s")</span>
                </div>
                <div class="card-body p-0">
                    @if (!string.IsNullOrEmpty(HistoryErrorMessage))
                    {
                        <div class="alert alert-danger m-3 mb-0 py-2 small">@HistoryErrorMessage</div>
                    }
                    @if (History.Count == 0)
                    {
                        <div class="p-4">
                            <p class="text-secondary mb-0">No commits yet - saving this page will create the first one.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @for (var i = 0; i < History.Count; i++)
                            {
                                var revision = History[i];
                                var previousRevision = i + 1 < History.Count ? History[i + 1] : null;
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <div class="fw-semibold small">
                                                <code class="me-1">@revision.ShortSha</code>@revision.Message
                                            </div>
                                            <div class="small text-secondary mt-1">
                                                @revision.AuthorName &middot; @revision.When.ToLocalTime().ToString("g")
                                            </div>
                                        </div>
                                        <div class="d-flex gap-1 flex-shrink-0">
                                            @if (previousRevision is not null)
                                            {
                                                <button class="btn btn-xs btn-outline-secondary" @onclick="() => ToggleDiffAsync(revision, previousRevision)">
                                                    Diff
                                                </button>
                                            }
                                            <button class="btn btn-xs btn-outline-primary" @onclick="() => RevertToRevisionAsync(revision.Sha)"
                                                    disabled="@IsHistoryBusy">
                                                Revert
                                            </button>
                                        </div>
                                    </div>
                                    @if (DiffShaKey == revision.Sha)
                                    {
                                        <div class="mt-3 border-top pt-3">
                                            @if (string.IsNullOrEmpty(DiffText))
                                            {
                                                <div class="small text-secondary">No textual changes in this commit.</div>
                                            }
                                            else
                                            {
                                                <div class="p-2 rounded-3 border bg-body-tertiary">
                                                    @foreach (var line in DiffText.Split('\n'))
                                                    {
                                                        <div class="@DiffLineClass(line)" style="white-space:pre-wrap;font-family:var(--bs-font-monospace, monospace);font-size:0.8125rem;">@line</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private List<WikiPage> WikiPages { get; set; } = new();
    private WikiPageEditorModel Editor { get; set; } = new();
    private Guid? SelectedPageId { get; set; }
    private bool IsBusy { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;

    private List<WikiRevisionView> History { get; set; } = new();
    private bool IsHistoryBusy { get; set; }
    private string HistoryErrorMessage { get; set; } = string.Empty;
    private string? DiffShaKey { get; set; }
    private string? DiffText { get; set; }

    private const string MarkdownEditorElementId = "wiki-body-textarea";
    private bool _markdownEditorInitialized;
    private string? _lastSyncedMarkdown;
    private DotNetObjectReference<Wiki>? _markdownEditorRef;

    private string EditorHeader => SelectedPageId.HasValue ? "Edit Wiki Page" : "Create Wiki Page";

    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private string RenderedHtml => Markdown.ToHtml(Editor.Markdown, MarkdownPipeline);

    protected override async Task OnInitializedAsync()
    {
        await LoadPagesAsync(selectFirstPage: false);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_markdownEditorInitialized)
        {
            _markdownEditorRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("gwsMarkdownEditor.init", MarkdownEditorElementId, _markdownEditorRef);
            _markdownEditorInitialized = true;
            _lastSyncedMarkdown = Editor.Markdown;
        }
        else if (!string.Equals(Editor.Markdown, _lastSyncedMarkdown, StringComparison.Ordinal))
        {
            await JS.InvokeVoidAsync("gwsMarkdownEditor.setValue", MarkdownEditorElementId, Editor.Markdown);
            _lastSyncedMarkdown = Editor.Markdown;
        }
    }

    [JSInvokable]
    public async Task OnMarkdownChanged(string value)
    {
        Editor.Markdown = value;
        _lastSyncedMarkdown = value;
        await InvokeAsync(StateHasChanged);
    }

    private async Task<string> CurrentUserNameAsync()
    {
        if (AuthState is null) return "admin";
        var state = await AuthState;
        return state.User.Identity?.Name ?? "admin";
    }

    private async Task LoadPagesAsync(bool selectFirstPage)
    {
        try
        {
            WikiPages = (await WikiService.ListPagesAsync()).ToList();
            if (selectFirstPage && WikiPages.Count > 0)
            {
                await OpenPageAsync(WikiPages[0].Id);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load wiki pages.");
            ErrorMessage = $"Unable to load wiki pages. {ex.Message}";
        }
    }

    private void CreateNewPage()
    {
        SelectedPageId = null;
        Editor = new WikiPageEditorModel();
        History = new();
        DiffShaKey = null;
        StatusMessage = "Ready to create a new wiki page.";
        ErrorMessage = string.Empty;
    }

    private async Task OpenPageAsync(Guid wikiPageId)
    {
        try
        {
            var page = await WikiService.GetPageAsync(wikiPageId);
            if (page is null)
            {
                StatusMessage = "The selected wiki page no longer exists.";
                return;
            }

            SelectedPageId = page.Id;
            Editor = new WikiPageEditorModel
            {
                WikiPageId = page.Id,
                Title = page.Title,
                Slug = page.Slug,
                Markdown = page.Markdown
            };
            DiffShaKey = null;
            StatusMessage = $"Opened wiki page '{page.Title}'.";
            ErrorMessage = string.Empty;
            await LoadHistoryAsync(page.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to open wiki page {WikiPageId}.", wikiPageId);
            ErrorMessage = $"Unable to open wiki page. {ex.Message}";
        }
    }

    private async Task LoadHistoryAsync(Guid wikiPageId)
    {
        HistoryErrorMessage = string.Empty;
        try
        {
            History = (await WikiService.GetHistoryAsync(wikiPageId)).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load wiki page history for {WikiPageId}.", wikiPageId);
            HistoryErrorMessage = $"Unable to load history. {ex.Message}";
        }
    }

    private async Task SavePageAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            var user = await CurrentUserNameAsync();
            var saved = await WikiService.SavePageAsync(Editor, user);
            SelectedPageId = saved.Id;
            Editor = new WikiPageEditorModel
            {
                WikiPageId = saved.Id,
                Title = saved.Title,
                Slug = saved.Slug,
                Markdown = saved.Markdown
            };
            StatusMessage = $"Saved wiki page '{saved.Title}'.";
            await LoadPagesAsync(selectFirstPage: false);
            await LoadHistoryAsync(saved.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to save wiki page.");
            ErrorMessage = $"Unable to save wiki page. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task DeleteSelectedPageAsync()
    {
        if (SelectedPageId is not { } wikiPageId)
        {
            return;
        }

        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            var user = await CurrentUserNameAsync();
            await WikiService.DeletePageAsync(wikiPageId, user);
            StatusMessage = "Wiki page deleted.";
            CreateNewPage();
            await LoadPagesAsync(selectFirstPage: false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to delete wiki page {WikiPageId}.", wikiPageId);
            ErrorMessage = $"Unable to delete wiki page. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task ToggleDiffAsync(WikiRevisionView revision, WikiRevisionView previousRevision)
    {
        if (DiffShaKey == revision.Sha)
        {
            DiffShaKey = null;
            DiffText = null;
            return;
        }

        if (SelectedPageId is not { } wikiPageId)
        {
            return;
        }

        try
        {
            DiffText = await WikiService.GetDiffAsync(wikiPageId, previousRevision.Sha, revision.Sha);
            DiffShaKey = revision.Sha;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load diff for wiki page {WikiPageId} at {Sha}.", wikiPageId, revision.Sha);
            HistoryErrorMessage = $"Unable to load diff. {ex.Message}";
        }
    }

    private async Task RevertToRevisionAsync(string sha)
    {
        if (SelectedPageId is not { } wikiPageId)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Revert to this version? This creates a new commit with the old content - nothing is lost.");
        if (!confirmed) return;

        IsHistoryBusy = true;
        try
        {
            var user = await CurrentUserNameAsync();
            var reverted = await WikiService.RevertToRevisionAsync(wikiPageId, sha, user);
            Editor = new WikiPageEditorModel
            {
                WikiPageId = reverted.Id,
                Title = reverted.Title,
                Slug = reverted.Slug,
                Markdown = reverted.Markdown
            };
            DiffShaKey = null;
            StatusMessage = $"Reverted '{reverted.Title}' to an earlier version.";
            await LoadPagesAsync(selectFirstPage: false);
            await LoadHistoryAsync(wikiPageId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to revert wiki page {WikiPageId} to {Sha}.", wikiPageId, sha);
            HistoryErrorMessage = $"Unable to revert. {ex.Message}";
        }
        finally
        {
            IsHistoryBusy = false;
        }
    }

    private static string DiffLineClass(string line) =>
        line.StartsWith('+') && !line.StartsWith("+++") ? "text-success"
        : line.StartsWith('-') && !line.StartsWith("---") ? "text-danger"
        : "text-secondary";

    public async ValueTask DisposeAsync()
    {
        if (_markdownEditorInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("gwsMarkdownEditor.destroy", MarkdownEditorElementId);
            }
            catch (JSDisconnectedException)
            {
                // The circuit is already gone (e.g. browser closed); nothing to clean up client-side.
            }
        }

        _markdownEditorRef?.Dispose();
    }
}
