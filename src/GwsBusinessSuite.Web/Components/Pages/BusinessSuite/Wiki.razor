    private async Task SearchWorkspaceAsync()
    {
        var query = SearchQuery.Trim();
        if (query.Length == 0)
        {
            WorkspaceSearchResults = new();
            return;
        }

        IsSearchBusy = true;
        try
        {
            var results = (await SentinelWorkspaceService.SearchAsync(query)).ToList();
            if (string.Equals(SearchQuery.Trim(), query, StringComparison.Ordinal))
            {
                WorkspaceSearchResults = results;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to search Sentinel.");
            ErrorMessage = $"Unable to search Sentinel. {ex.Message}";
        }
        finally
        {
            IsSearchBusy = false;
        }
    }

