            {
                StatusMessage = "The selected Sentinel page no longer exists.";
                return;
            }

            SelectedDatabaseId = null;
            SelectedPageId = page.Id;
            Editor = new WikiPageEditorModel
            {
                WikiPageId = page.Id,
                ExpectedContentVersion = page.ContentVersion,
                Title = page.Title,
                Slug = page.Slug,
                BlocksJson = page.BlocksJson,
                Icon = page.Icon,
                CoverImageUrl = page.CoverImageUrl,
                ParentWikiPageId = page.ParentWikiPageId
            };
            _editorGeneration++;
            PageConflict = null;
            DiffRevisionKey = null;
            StatusMessage = $"Opened Sentinel page '{page.Title}'.";
            ErrorMessage = string.Empty;
            await LoadHistoryAsync(page.Id);
            Backlinks = (await SentinelWorkspaceService.GetBacklinksAsync(page.Id)).ToList();
            await SentinelWorkspaceService.RecordOpenedAsync(CurrentUsername, page.Id, false);
            await LoadWorkspaceNavigationAsync();
