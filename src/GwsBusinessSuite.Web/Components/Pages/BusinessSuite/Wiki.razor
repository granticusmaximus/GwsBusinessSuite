    private async Task SavePageAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            var user = await CurrentUserNameAsync();
            var saved = await WikiService.SavePageAsync(Editor, user);
            SelectedPageId = saved.Id;
            Editor = new WikiPageEditorModel
            {
                WikiPageId = saved.Id,
                ExpectedContentVersion = saved.ContentVersion,
                Title = saved.Title,
                Slug = saved.Slug,
                BlocksJson = saved.BlocksJson,
                Icon = saved.Icon,
                CoverImageUrl = saved.CoverImageUrl,
                ParentWikiPageId = saved.ParentWikiPageId
            };
            // Deliberately not bumping _editorGeneration here - the block editor's DOM already
            // reflects exactly what was just saved (that's where BlocksJson came from), so
            // resetting it would only cost the user their cursor position for no benefit.
            StatusMessage = $"Saved Sentinel page '{saved.Title}'.";
            PageConflict = null;
            await LoadTreeAsync(selectFirstPage: false);
            await LoadHistoryAsync(saved.Id);
            Backlinks = (await SentinelWorkspaceService.GetBacklinksAsync(saved.Id)).ToList();
            await SentinelWorkspaceService.RecordOpenedAsync(CurrentUsername, saved.Id, false);
            await LoadWorkspaceNavigationAsync();
        }
        catch (WikiPageConcurrencyException ex)
        {
            Logger.LogWarning(ex, "Sentinel page {WikiPageId} had a concurrent edit conflict.", Editor.WikiPageId);
            PageConflict = ex.Conflict;
            StatusMessage = string.Empty;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to save wiki page.");
            ErrorMessage = $"Unable to save Sentinel page. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

