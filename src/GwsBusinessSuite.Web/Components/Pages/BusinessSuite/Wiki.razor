            Logger.LogError(ex, "Unable to load Notion connector settings.");
            NotionMessage = $"Unable to load Notion settings. {ex.Message}";
            NotionMessageIsError = true;
        }
    }

    private void CloseNotionModal() => ShowNotionModal = false;

    private async Task SaveNotionSettingsAsync()
    {
        IsNotionBusy = true;
        NotionMessage = string.Empty;
        try
        {
            var result = await NotionSyncService.SaveSettingsAsync(NotionSettings);
            NotionMessage = result.Message;
            NotionMessageIsError = !result.IsSuccess;
            if (result.IsSuccess)
            {
                NotionSettings.WorkspaceName = result.WorkspaceName;
                NotionSettings.IntegrationTokenUnreadable = false;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to save Notion connector settings.");
            NotionMessage = $"Unable to save Notion settings. {ex.Message}";
            NotionMessageIsError = true;
        }
        finally
        {
            IsNotionBusy = false;
        }
    }

    private async Task SyncNotionNowAsync()
    {
        IsNotionBusy = true;
        NotionMessage = string.Empty;
        var acquired = false;
        try
        {
            var validation = await NotionSyncService.SaveSettingsAsync(NotionSettings);
            if (!validation.IsSuccess)
            {
                NotionMessage = validation.Message;
                NotionMessageIsError = true;
                return;
            }
            NotionSettings.WorkspaceName = validation.WorkspaceName;
            NotionSettings.IntegrationTokenUnreadable = false;

            acquired = await NotionSyncBackgroundService.SyncLock.WaitAsync(0);
            if (!acquired)
            {
                NotionMessage = "A Notion sync is already running.";
                NotionMessageIsError = true;
                return;
            }

            var result = await NotionSyncService.SyncAsync();
            NotionMessage = result.IsSuccess
                ? $"{result.Message} {result.Imported} imported, {result.Updated} updated, {result.Archived} archived."
                : result.Message;
            NotionMessageIsError = !result.IsSuccess;
            NotionSettings = await NotionSyncService.GetSettingsAsync() ?? NotionSettings;
            if (result.IsSuccess)
            {
                await LoadTreeAsync(selectFirstPage: false);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to sync Notion workspace.");
            NotionMessage = $"Unable to sync Notion. {ex.Message}";
            NotionMessageIsError = true;
        }
        finally
        {
            if (acquired)
            {
                NotionSyncBackgroundService.SyncLock.Release();
            }
            IsNotionBusy = false;
        }
    }

