@page "/admin/wiki"
@page "/admin/sentinel"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "AdminOnly")]
@implements IAsyncDisposable
@using GwsBusinessSuite.Application.Wiki
@using GwsBusinessSuite.Application.CmsBuilder
@using GwsBusinessSuite.Domain.Entities
@using GwsBusinessSuite.Infrastructure.Services
@inject IWikiService WikiService
@inject IWikiDatabaseService WikiDatabaseService
@inject ISentinelWorkspaceService SentinelWorkspaceService
@inject INotionSyncService NotionSyncService
@inject IMediaLibraryService MediaLibraryService
@inject ICurrentUserAccessor CurrentUserAccessor
@inject IJSRuntime JS
@inject ILogger<Wiki> Logger

<PageTitle>Sentinel</PageTitle>

<div class="sentinel-workspace">
<div class="sentinel-workspace-header">
    <div class="sentinel-workspace-identity">
        <div class="sentinel-brand-mark" aria-hidden="true">S</div>
        <div>
            <div class="sentinel-eyebrow">GWS connected workspace</div>
            <h1>Sentinel</h1>
            <p>Your operational knowledge, documents, databases, and imported Notion content.</p>
        </div>
    </div>
    <div class="sentinel-workspace-actions">
        <span class="sentinel-workspace-status"><span></span>Workspace online</span>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="OpenNotionModalAsync" disabled="@IsBusy">
            <i class="bi bi-arrow-repeat me-1"></i>Notion sync
        </button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger sentinel-notice d-flex align-items-start gap-2" role="alert">
        <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
        <div>@ErrorMessage</div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-info sentinel-notice d-flex align-items-center gap-2" role="alert">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <div>@StatusMessage</div>
    </div>
}

@if (PageConflict is not null)
{
    <div class="alert alert-warning sentinel-notice" role="alert">
        <div class="d-flex align-items-start gap-2">
            <i class="bi bi-exclamation-diamond-fill mt-1"></i>
            <div class="flex-grow-1">
                <div class="fw-semibold">This page changed while you were editing.</div>
                <div class="small mt-1">
                    Your local draft is still in the editor. The latest content generation is
                    @PageConflict.CurrentContentVersion@(string.IsNullOrWhiteSpace(PageConflict.UpdatedBy) ? "." : $", saved by {PageConflict.UpdatedBy}.")
                </div>
                <div class="d-flex flex-wrap gap-2 mt-3">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ReloadLatestAfterConflictAsync">Reload latest</button>
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="SaveConflictAsCopyAsync">Save my draft as a copy</button>
                    <button type="button" class="btn btn-sm btn-warning" @onclick="OverwriteAfterConflictAsync">Overwrite latest</button>
                </div>
            </div>
        </div>
    </div>
}

<div class="sentinel-layout">
    <aside class="sentinel-local-sidebar">
        <div class="sentinel-nav-panel">
            <div class="sentinel-nav-toolbar">
                <div>
                    <span class="fw-semibold">Private workspace</span>
                    <small>Pages &amp; databases</small>
                </div>
                <div class="d-flex gap-1">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CreateNewPage" disabled="@IsBusy" title="New page">
                        <i class="bi bi-file-earmark-plus"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CreateNewDatabaseAsync" disabled="@IsBusy" title="New database">
                        <i class="bi bi-grid-3x3-gap-fill"></i>
                    </button>
                </div>
            </div>
            <div class="sentinel-nav-search">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input class="form-control" @bind="SearchQuery" @bind:event="oninput" @bind:after="SearchWorkspaceAsync"
                           placeholder="Search Sentinel..." />
                    @if (IsSearchBusy)
                    {
                        <span class="input-group-text bg-white"><span class="spinner-border spinner-border-sm"></span></span>
                    }
                </div>
            </div>
            @if (string.IsNullOrWhiteSpace(SearchQuery)
                && (Navigation.Favorites.Count > 0 || Navigation.Recents.Count > 0 || Mentions.Count > 0))
            {
                <div class="sentinel-quick-navigation border-bottom">
                    @if (Navigation.Favorites.Count > 0)
                    {
                        <div class="sentinel-nav-section">
                            <div class="sentinel-nav-heading"><i class="bi bi-star-fill text-warning"></i> Favorites</div>
                            @foreach (var item in Navigation.Favorites)
                            {
                                <button type="button" class="sentinel-nav-item" @onclick="() => OpenNavigationItemAsync(item)" disabled="@IsBusy">
                                    <span>@(string.IsNullOrWhiteSpace(item.Icon) ? (item.IsDatabase ? "🗄️" : "📄") : item.Icon)</span>
                                    <span class="text-truncate">@item.Title</span>
                                </button>
                            }
                        </div>
                    }
                    @if (Navigation.Recents.Count > 0)
                    {
                        <div class="sentinel-nav-section">
                            <div class="sentinel-nav-heading"><i class="bi bi-clock-history"></i> Recent</div>
                            @foreach (var item in Navigation.Recents.Take(5))
                            {
                                <button type="button" class="sentinel-nav-item" @onclick="() => OpenNavigationItemAsync(item)" disabled="@IsBusy">
                                    <span>@(string.IsNullOrWhiteSpace(item.Icon) ? (item.IsDatabase ? "🗄️" : "📄") : item.Icon)</span>
                                    <span class="text-truncate">@item.Title</span>
                                </button>
                            }
                        </div>
                    }
                    @if (Mentions.Count > 0)
                    {
                        <div class="sentinel-nav-section">
                            <div class="sentinel-nav-heading"><i class="bi bi-at"></i> Mentions</div>
                            @foreach (var mention in Mentions.Take(5))
                            {
                                <button type="button" class="sentinel-nav-item" @onclick="() => OpenPageAsync(mention.SourcePageId)" disabled="@IsBusy" title="@mention.Preview">
                                    <i class="bi bi-file-earmark-text text-secondary"></i>
                                    <span class="text-truncate">@mention.SourcePageTitle</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            }
            <div class="sentinel-tree-scroll">
                @if (AllTreeNodes().Count == 0)
                {
                    <div class="p-4 text-secondary">
                        <p class="mb-0">Nothing here yet. Create a page or database to get started.</p>
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(SearchQuery))
                {
                    @if (WorkspaceSearchResults.Count == 0 && !IsSearchBusy)
                    {
                        <div class="p-4 text-secondary">
                            <p class="mb-0">Nothing in Sentinel matches "@SearchQuery".</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush sentinel-search-results">
                            @foreach (var result in WorkspaceSearchResults)
                            {
                                <button type="button" class="list-group-item list-group-item-action text-start"
                                        @onclick="() => OpenSearchResultAsync(result)" disabled="@IsBusy">
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi @(result.IsDatabase ? "bi-grid-3x3-gap-fill" : "bi-file-earmark-text") text-secondary"></i>
                                        <span class="fw-semibold text-truncate">@HighlightMatches(result.Title, result.MatchedTerms)</span>
                                        <span class="badge text-bg-light border ms-auto">@result.MatchKind</span>
                                    </div>
                                    <div class="small text-secondary text-truncate mt-1">@HighlightMatches(result.Preview, result.MatchedTerms)</div>
                                </button>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="wiki-tree">
                        @foreach (var node in FilteredAndOrderedNodes())
                        {
                            <div class="wiki-tree-row @((node.IsDatabase ? SelectedDatabaseId == node.Id : SelectedPageId == node.Id) ? "active" : "") @(node.IsArchived ? "wiki-tree-archived" : "")"
                                 style="padding-left:@(0.5 + GetNodeDepth(node) * 1.25)rem;">
                                @if (HasChildren(node.Id) && string.IsNullOrWhiteSpace(SearchQuery))
                                {
                                    <button type="button" class="wiki-tree-toggle" @onclick="() => ToggleExpanded(node.Id)">
                                        <i class="bi @(IsExpanded(node.Id) ? "bi-caret-down-fill" : "bi-caret-right-fill")"></i>
                                    </button>
                                }
                                else
                                {
                                    <span class="wiki-tree-spacer"></span>
                                }
                                <button type="button" class="wiki-tree-label" @onclick="() => OpenNodeAsync(node)" disabled="@IsBusy">
                                    <span class="wiki-tree-icon">@(string.IsNullOrWhiteSpace(node.Icon) ? (node.IsDatabase ? "🗄️" : "📄") : node.Icon)</span>
                                    <span class="wiki-tree-title">@node.Title</span>
                                    @if (node.IsNotionSynced)
                                    {
                                        <span class="badge rounded-pill text-bg-light border wiki-notion-badge" title="Imported from Notion">N</span>
                                    }
                                </button>
                                <div class="wiki-tree-actions">
                                    <button type="button" class="btn btn-xs btn-link p-0 @(IsFavorite(node.Id, node.IsDatabase) ? "text-warning" : "text-secondary")"
                                            title="@(IsFavorite(node.Id, node.IsDatabase) ? "Remove from favorites" : "Add to favorites")"
                                            @onclick="() => ToggleFavoriteAsync(node.Id, node.IsDatabase)" disabled="@IsBusy">
                                        <i class="bi @(IsFavorite(node.Id, node.IsDatabase) ? "bi-star-fill" : "bi-star")"></i>
                                    </button>
                                    <button type="button" class="btn btn-xs btn-link p-0" title="Move up" @onclick="() => MoveNodeAsync(node, -1)" disabled="@IsBusy">
                                        <i class="bi bi-chevron-up"></i>
                                    </button>
                                    <button type="button" class="btn btn-xs btn-link p-0" title="Move down" @onclick="() => MoveNodeAsync(node, 1)" disabled="@IsBusy">
                                        <i class="bi bi-chevron-down"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        <SentinelTemplates CurrentPageId="SelectedPageId"
                           CurrentPageTitle="Editor.Title"
                           OnPageCreated="OpenTemplatePageAsync" />
    </aside>

    <main class="sentinel-main">
        @if (SelectedDatabaseId is { } openDatabaseId)
        {
            <WikiDatabaseEditor WikiDatabaseId="openDatabaseId" OnChanged="() => LoadTreeAsync(selectFirstPage: false)" />
        }
        else
        {
        <div class="sentinel-document">
            <div class="sentinel-document-toolbar">
                <div class="sentinel-document-context">
                    <span class="sentinel-document-breadcrumb-root">Sentinel</span>
                    <i class="bi bi-chevron-right"></i>
                    <span class="text-truncate">@(string.IsNullOrWhiteSpace(Editor.Title) ? "Untitled" : Editor.Title)</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    @if (SelectedPageId is { } selectedPageId)
                    {
                        <SentinelPresence WikiPageId="selectedPageId" />
                        <button type="button" class="btn btn-sm @(IsFavorite(selectedPageId, false) ? "btn-warning" : "btn-outline-secondary")"
                                @onclick="() => ToggleFavoriteAsync(selectedPageId, false)" title="Toggle favorite">
                            <i class="bi @(IsFavorite(selectedPageId, false) ? "bi-star-fill" : "bi-star")"></i>
                        </button>
                    }
                    <span class="sentinel-editing-state">
                        @(SelectedPageId.HasValue ? "Saved" : "New page")
                    </span>
                </div>
            </div>
            <EditForm Model="Editor" OnValidSubmit="SavePageAsync" class="sentinel-inline-document-form">
                @if (!string.IsNullOrWhiteSpace(Editor.CoverImageUrl))
                {
                    <div class="sentinel-page-cover">
                        <img src="@Editor.CoverImageUrl" alt="Page cover" loading="lazy" />
                        <div class="sentinel-page-cover-actions">
                            <button type="button" class="btn btn-sm btn-dark" @onclick="ToggleCoverPickerAsync">
                                <i class="bi bi-image me-1"></i>Change cover
                            </button>
                            <button type="button" class="btn btn-sm btn-dark" @onclick="() => Editor.CoverImageUrl = null">
                                <i class="bi bi-trash3 me-1"></i>Remove
                            </button>
                        </div>
                    </div>
                }

                <div class="sentinel-document-canvas @(!string.IsNullOrWhiteSpace(Editor.CoverImageUrl) ? "has-cover" : string.Empty)">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    @if (string.IsNullOrWhiteSpace(Editor.CoverImageUrl))
                    {
                        <div class="sentinel-page-affordances">
                            <button type="button" @onclick="ToggleCoverPickerAsync">
                                <i class="bi bi-image"></i>Add cover
                            </button>
                        </div>
                    }

                    <div class="sentinel-page-heading">
                        <input class="sentinel-icon-input" @bind="Editor.Icon" placeholder="📄" maxlength="4" aria-label="Page icon" />
                        <InputText class="sentinel-title-input" @bind-Value="Editor.Title" placeholder="Untitled" aria-label="Page title" />
                    </div>

                    <div class="sentinel-properties">
                        <div class="sentinel-property-row">
                            <label for="sentinelSlug"><i class="bi bi-link-45deg"></i>Slug</label>
                            <InputText id="sentinelSlug" class="sentinel-property-control" @bind-Value="Editor.Slug" placeholder="Generated from title" />
                        </div>
                        @if (SelectedPageId.HasValue)
                        {
                            <div class="sentinel-property-row">
                                <label for="sentinelParent"><i class="bi bi-diagram-2"></i>Parent</label>
                                <select id="sentinelParent" class="sentinel-property-control" @bind="ParentWikiPageIdSelection" @bind:after="MoveToSelectedParentAsync">
                                    <option value="">— Top level —</option>
                                    @foreach (var candidate in WikiParentPageOptions())
                                    {
                                        <option value="@candidate.Id">@candidate.Title</option>
                                    }
                                </select>
                            </div>
                        }
                    </div>

                    @if (_showCoverPicker)
                    {
                        <div class="wiki-media-picker border rounded-3 p-2 mb-3">
                            @if (!string.IsNullOrEmpty(_mediaPickerError))
                            {
                                <div class="text-danger small mb-0">@_mediaPickerError</div>
                            }
                            else if (_mediaAssets.Count == 0)
                            {
                                <p class="text-secondary small mb-0">No media uploaded yet. Upload images from the Media Library.</p>
                            }
                            else
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var asset in _mediaAssets)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary p-1" title="@asset.FileName"
                                                @onclick="() => SelectCoverAsync(asset)">
                                            <img src="@asset.ThumbnailUrl" alt="@asset.AltText" loading="lazy" style="width:64px;height:64px;object-fit:cover;" />
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    }

                    <div class="sentinel-editor-hint">
                        <i class="bi bi-command"></i>
                        <span><code>/</code> commands · <code>[[</code> page links · <code>@@</code> mentions · Tab to indent</span>
                    </div>
                    <div class="wiki-block-editor" @ref="_blockEditorContainer"></div>

                    <div class="sentinel-editor-actions">
                        <button type="submit" class="btn btn-primary" disabled="@IsBusy">
                            <i class="bi bi-check2 me-1"></i>Save changes
                        </button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="CreateNewPage" disabled="@IsBusy">
                            Reset
                        </button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="DuplicateSelectedPageAsync"
                                disabled="@(IsBusy || !SelectedPageId.HasValue)">
                            <i class="bi bi-copy me-1"></i>Duplicate
                        </button>
                        <button type="button" class="btn btn-outline-danger" @onclick="DeleteSelectedPageAsync"
                                disabled="@(IsBusy || !SelectedPageId.HasValue)">
                            Delete
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>

        @if (SelectedPageId.HasValue)
        {
            <SentinelDiscussions @ref="_sentinelDiscussions"
                                 WikiPageId="SelectedPageId.Value"
                                 BlocksJson="Editor.BlocksJson"
                                 OnOpenPage="OpenPageAsync"
                                 OnDiscussionCountsChanged="UpdateDiscussionCountsAsync" />

            <div class="card border-0 shadow-sm mt-4 sentinel-support-panel">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center gap-3">
                    <div>
                        <div class="fw-semibold"><i class="bi bi-arrow-left-right me-1"></i>Backlinks</div>
                        <div class="small text-secondary">Pages in Sentinel that link to this page.</div>
                    </div>
                    <span class="badge text-bg-secondary">@Backlinks.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (Backlinks.Count == 0)
                    {
                        <div class="p-4 text-secondary small">No pages link here yet.</div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var backlink in Backlinks)
                            {
                                <button type="button" class="list-group-item list-group-item-action text-start"
                                        @onclick="() => OpenPageAsync(backlink.SourcePageId)" disabled="@IsBusy">
                                    <div class="fw-semibold small">@backlink.SourcePageTitle</div>
                                    <div class="small text-secondary text-truncate mt-1">@backlink.Preview</div>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm mt-4 sentinel-support-panel">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center gap-3">
                    <div>
                        <div class="fw-semibold">History</div>
                        <div class="small text-secondary">Bounded version snapshots - the last @MaxHistoryDisplay are kept.</div>
                    </div>
                    <span class="badge text-bg-secondary">@History.Count version@(History.Count == 1 ? "" : "s")</span>
                </div>
                <div class="card-body p-0">
                    @if (!string.IsNullOrEmpty(HistoryErrorMessage))
                    {
                        <div class="alert alert-danger m-3 mb-0 py-2 small">@HistoryErrorMessage</div>
                    }
                    @if (History.Count == 0)
                    {
                        <div class="p-4">
                            <p class="text-secondary mb-0">No versions yet - saving this page will create the first one.</p>
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @for (var i = 0; i < History.Count; i++)
                            {
                                var revision = History[i];
                                var previousRevision = i + 1 < History.Count ? History[i + 1] : null;
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <div class="fw-semibold small">
                                                <code class="me-1">v@(revision.RevisionNumber)</code>@(string.IsNullOrWhiteSpace(revision.Label) ? "Saved" : revision.Label)
                                            </div>
                                            <div class="small text-secondary mt-1">
                                                @revision.AuthorName &middot; @revision.When.ToLocalTime().ToString("g")
                                            </div>
                                        </div>
                                        <div class="d-flex gap-1 flex-shrink-0">
                                            @if (previousRevision is not null)
                                            {
                                                <button class="btn btn-xs btn-outline-secondary" @onclick="() => ToggleDiffAsync(revision, previousRevision)">
                                                    Diff
                                                </button>
                                            }
                                            <button class="btn btn-xs btn-outline-primary" @onclick="() => RevertToRevisionAsync(revision.Id)"
                                                    disabled="@IsHistoryBusy">
                                                Revert
                                            </button>
                                        </div>
                                    </div>
                                    @if (DiffRevisionKey == revision.Id)
                                    {
                                        <div class="mt-3 border-top pt-3">
                                            @if (string.IsNullOrEmpty(DiffText))
                                            {
                                                <div class="small text-secondary">No block changes between these versions.</div>
                                            }
                                            else
                                            {
                                                <div class="p-2 rounded-3 border bg-body-tertiary">
                                                    @foreach (var line in DiffText.Split('\n'))
                                                    {
                                                        <div class="@DiffLineClass(line)" style="white-space:pre-wrap;font-family:var(--bs-font-monospace, monospace);font-size:0.8125rem;">@line</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
        }
    </main>
</div>
</div>

@if (ShowNotionModal)
{
    <div class="modal d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title">Notion Import &amp; Sync</h5>
                        @if (!string.IsNullOrWhiteSpace(NotionSettings.WorkspaceName))
                        {
                            <div class="small text-secondary mt-1">Connected to @NotionSettings.WorkspaceName</div>
                        }
                    </div>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseNotionModal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-secondary">
                        Paste a Notion internal-integration token. Sync is read-only: Notion remains the source of truth,
                        and content shared with the integration is mirrored into Sentinel.
                    </p>

                    <label class="form-label fw-semibold small">Integration token</label>
                    <div class="input-group">
                        <input class="form-control" type="@(ShowNotionToken ? "text" : "password")"
                               @bind="NotionSettings.IntegrationToken" autocomplete="off" />
                        <button type="button" class="btn btn-outline-secondary" title="@(ShowNotionToken ? "Hide token" : "Show token")"
                                @onclick="() => ShowNotionToken = !ShowNotionToken">
                            <i class="bi @(ShowNotionToken ? "bi-eye-slash-fill" : "bi-eye-fill")"></i>
                        </button>
                    </div>
                    @if (NotionSettings.IntegrationTokenUnreadable)
                    {
                        <div class="alert alert-warning py-2 mt-2 mb-0">
                            The stored token can no longer be decrypted. Enter it again to reconnect.
                        </div>
                    }

                    <div class="form-check form-switch mt-3">
                        <input class="form-check-input" type="checkbox" role="switch" id="notionAutoSync"
                               @bind="NotionSettings.AutoSyncEnabled" />
                        <label class="form-check-label" for="notionAutoSync">Sync automatically every hour</label>
                    </div>

                    @if (NotionSettings.LastSyncedAt is { } lastSyncedAt)
                    {
                        <div class="border rounded-3 p-3 mt-3 bg-body-tertiary">
                            <div class="small text-secondary">Last sync @lastSyncedAt.ToLocalTime().ToString("g")</div>
                            <div class="d-flex flex-wrap gap-3 mt-1 small">
                                <span><strong>@NotionSettings.LastSyncImportedCount</strong> imported</span>
                                <span><strong>@NotionSettings.LastSyncUpdatedCount</strong> updated</span>
                                <span><strong>@NotionSettings.LastSyncArchivedCount</strong> archived</span>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(NotionMessage))
                    {
                        <div class="alert @(NotionMessageIsError ? "alert-danger" : "alert-info") mt-3 mb-0">@NotionMessage</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseNotionModal" disabled="@IsNotionBusy">Close</button>
                    <button type="button" class="btn btn-outline-primary" @onclick="SaveNotionSettingsAsync" disabled="@IsNotionBusy">
                        <i class="bi bi-plug-fill me-1"></i>Save connection
                    </button>
                    <button type="button" class="btn btn-primary" @onclick="SyncNotionNowAsync" disabled="@IsNotionBusy">
                        @if (IsNotionBusy)
                        {
                            <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                        }
                        else
                        {
                            <i class="bi bi-arrow-repeat me-1"></i>
                        }
                        Sync now
                    </button>
                </div>
            </div>
        </div>
        <div class="modal-backdrop show" style="z-index:-1"></div>
    </div>
}

@code {
    private const int MaxHistoryDisplay = 20;

    private List<WikiPage> WikiPages { get; set; } = new();
    private List<WikiDatabase> WikiDatabases { get; set; } = new();
    private WikiPageEditorModel Editor { get; set; } = new();
