        var confirmed = await JS.InvokeAsync<bool>("confirm", "Revert to this version? This creates a new version with the old content - nothing is lost.");
        if (!confirmed) return;

        IsHistoryBusy = true;
        try
        {
            var user = await CurrentUserNameAsync();
            var reverted = await WikiService.RevertToRevisionAsync(wikiPageId, revisionId, user);
            Editor = new WikiPageEditorModel
            {
                WikiPageId = reverted.Id,
                ExpectedContentVersion = reverted.ContentVersion,
                Title = reverted.Title,
                Slug = reverted.Slug,
                BlocksJson = reverted.BlocksJson,
                Icon = reverted.Icon,
                CoverImageUrl = reverted.CoverImageUrl,
                ParentWikiPageId = reverted.ParentWikiPageId
            };
            _editorGeneration++;
            DiffRevisionKey = null;
            StatusMessage = $"Reverted '{reverted.Title}' to an earlier version.";
            PageConflict = null;
            await LoadTreeAsync(selectFirstPage: false);
            await LoadHistoryAsync(wikiPageId);
            Backlinks = (await SentinelWorkspaceService.GetBacklinksAsync(wikiPageId)).ToList();
            await LoadWorkspaceNavigationAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to revert wiki page {WikiPageId} to revision {RevisionId}.", wikiPageId, revisionId);
            HistoryErrorMessage = $"Unable to revert. {ex.Message}";
        }
        finally
        {
            IsHistoryBusy = false;
        }
    }

    // A page and a database look interchangeable in the sidebar tree (both have a title,
    // icon, parent, and sort order), so this is what tree rendering/reordering actually
    // operates over - WikiPage/WikiDatabase-specific behavior (opening, saving, deleting)
    // still dispatches through their own services once a node is selected.
    private readonly record struct WikiTreeNode(
        Guid Id,
        string Title,
        string? Icon,
        Guid? ParentId,
        int SortOrder,
        bool IsDatabase,
        string? NotionId,
        DateTimeOffset? NotionArchivedAt)
    {
        public bool IsNotionSynced => !string.IsNullOrWhiteSpace(NotionId);
        public bool IsArchived => NotionArchivedAt.HasValue;
    }

    private List<WikiTreeNode> AllTreeNodes() =>
        WikiPages.Select(p => new WikiTreeNode(p.Id, p.Title, p.Icon, p.ParentWikiPageId, p.SortOrder, false, p.NotionId, p.NotionArchivedAt))
            .Concat(WikiDatabases.Select(d => new WikiTreeNode(d.Id, d.Title, d.Icon, d.ParentWikiPageId, d.SortOrder, true, d.NotionId, d.NotionArchivedAt)))
            .ToList();

    // Recursive depth-first flatten via ToLookup(ParentId), rendered as an indented flat
    // list with expand/collapse rather than a nested component - mirrors Pages.razor's
    // OrderedPagesByHierarchy()/GetPageDepth() for CMS pages.
    private List<WikiTreeNode> OrderedTreeNodes()
    {
        var byParent = AllTreeNodes().ToLookup(n => n.ParentId);
        var result = new List<WikiTreeNode>();

        void Visit(Guid? parentId)
        {
            foreach (var node in byParent[parentId].OrderBy(n => n.SortOrder))
            {
                result.Add(node);
                if (parentId is null || IsExpanded(parentId.Value))
                {
                    Visit(node.Id);
                }
            }
        }

        Visit(null);
        return result;
    }

    private bool HasChildren(Guid nodeId) => AllTreeNodes().Any(n => n.ParentId == nodeId);
    private bool IsExpanded(Guid nodeId) => _expandedPageIds.Contains(nodeId);
    private void ToggleExpanded(Guid nodeId)
    {
        if (!_expandedPageIds.Add(nodeId))
        {
            _expandedPageIds.Remove(nodeId);
        }
    }

    private int GetNodeDepth(WikiTreeNode node)
    {
        var byId = AllTreeNodes().ToDictionary(n => n.Id);
        var depth = 0;
        var current = (WikiTreeNode?)node;
        var guard = 0;
        while (current?.ParentId is { } parentId && byId.TryGetValue(parentId, out var parent) && guard++ < 64)
        {
            depth++;
            current = parent;
        }

        return depth;
    }

    // With no search query, the tree is shown collapsed to top-level + expanded branches.
    // Once searching, a matched child's ancestors may not themselves be expanded, so tree
    // order stops making sense - fall back to a flat alphabetical list of matches.
    private List<WikiTreeNode> FilteredAndOrderedNodes()
    {
        if (string.IsNullOrWhiteSpace(SearchQuery))
        {
            return OrderedTreeNodes();
        }

        return AllTreeNodes()
            .Where(n => n.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase))
            .OrderBy(n => n.Title, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

