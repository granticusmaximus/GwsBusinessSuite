    private static MarkupString HighlightMatches(string text, IReadOnlyList<string> terms)
    {
        var encoded = System.Net.WebUtility.HtmlEncode(text);
        if (terms.Count == 0) return new MarkupString(encoded);
        var pattern = string.Join('|', terms.OrderByDescending(term => term.Length)
            .Select(System.Text.RegularExpressions.Regex.Escape));
        var highlighted = System.Text.RegularExpressions.Regex.Replace(encoded, pattern,
            match => $"<mark class=\"sentinel-search-highlight\">{match.Value}</mark>",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        return new MarkupString(highlighted);
    }

    // Mirrors EditPage.razor's ParentPageOptions() for CMS pages - a BFS from the open page
    // excluding itself and every descendant, so the <select> can never offer a choice that
    // would create a cycle (ReorderPageAsync also guards this server-side).
    private List<WikiPage> WikiParentPageOptions()
    {
        if (!SelectedPageId.HasValue)
        {
            return WikiPages;
        }

        var byParent = WikiPages.ToLookup(p => p.ParentWikiPageId);
        var excluded = new HashSet<Guid> { SelectedPageId.Value };
        var frontier = new Queue<Guid>();
        frontier.Enqueue(SelectedPageId.Value);
        while (frontier.Count > 0)
        {
            foreach (var child in byParent[frontier.Dequeue()])
            {
                if (excluded.Add(child.Id)) frontier.Enqueue(child.Id);
            }
        }

        return WikiPages.Where(p => !excluded.Contains(p.Id)).ToList();
    }

    private string ParentWikiPageIdSelection
    {
        get => Editor.ParentWikiPageId?.ToString() ?? string.Empty;
        set => Editor.ParentWikiPageId = Guid.TryParse(value, out var id) ? id : null;
    }

    private static string DiffLineClass(string line) =>
        line.StartsWith('+') ? "text-success"
        : line.StartsWith('-') ? "text-danger"
        : line.StartsWith('~') ? "text-warning"
        : "text-secondary";

    public async ValueTask DisposeAsync()
    {
        if (_blockEditorInitialized && _blockEditorModule is not null)
        {
            try
            {
                await _blockEditorModule.InvokeVoidAsync("dispose", _blockEditorContainer);
                await _blockEditorModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // The circuit is already gone (e.g. browser closed); nothing to clean up client-side.
            }
        }

        _blockEditorRef?.Dispose();

        if (_wikiLinksInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("gwsWikiLinks.dispose");
            }
            catch (JSDisconnectedException)
            {
                // The circuit is already gone (e.g. browser closed); nothing to clean up client-side.
            }
        }

        _wikiLinksRef?.Dispose();
    }
}
