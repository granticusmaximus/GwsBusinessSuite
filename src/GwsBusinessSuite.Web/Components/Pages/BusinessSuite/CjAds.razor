@page "/cj-ads"
@rendermode InteractiveServer
@using GwsBusinessSuite.Application.CjAds
@inject ICjAdsService CjAdsService
@inject ILogger<CjAds> Logger

<PageTitle>CJ Ads Manager</PageTitle>

<div class="page-header">
  <h1><i class="bi bi-tags-fill me-2 text-primary"></i>CJ Ads Manager</h1>
  <p>Only your current CJ My Advertisers are shown below. Expand an advertiser to view active ads you can use in
    articles.</p>
</div>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
  <div class="alert alert-danger d-flex align-items-start gap-2 mb-4" role="alert">
    <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
    <div>@ErrorMessage</div>
  </div>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
  <div class="alert alert-info d-flex align-items-center gap-2 mb-4" role="alert">
    <i class="bi bi-info-circle-fill flex-shrink-0"></i>
    <div>@StatusMessage</div>
  </div>
}

<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between gap-2">
    <span class="fw-semibold">Connector</span>
    <span class="badge @(IsConnected ? "text-bg-success" : "text-bg-secondary")">@(IsConnected ? "Connected" : "Not Connected")</span>
  </div>
  <div class="card-body">
    <div class="d-flex flex-wrap gap-2">
        <button class="btn btn-primary d-inline-flex align-items-center gap-2" @onclick="OpenConnectorModal"
                disabled="@IsBusy">
        <i class="bi bi-link-45deg"></i>
        <span>Connect CJ Account</span>
      </button>
        <button class="btn btn-outline-secondary d-inline-flex align-items-center gap-2" @onclick="LoadPartners"
                disabled="@IsBusy">
        <i class="bi bi-arrow-repeat"></i>
          <span>Refresh My Advertisers</span>
      </button>
    </div>
    @if (!string.IsNullOrWhiteSpace(LastSyncSummary))
    {
      <p class="text-secondary small mb-0 mt-3">@LastSyncSummary</p>
    }
  </div>
</div>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between gap-2">
      <span class="fw-semibold">My Advertisers (Joined/Active)</span>
    <span class="badge text-bg-light">@FilteredPartners.Count</span>
  </div>
  <div class="card-body">
    <div class="row g-3 mb-3">
        <div class="col-md-8">
          <label class="form-label fw-semibold small">Search My Advertisers</label>
          <input class="form-control" @bind="SearchTerm" @bind:event="oninput" placeholder="Advertiser name or ID" />
      </div>
        <div class="col-md-4 d-flex align-items-end">
          <button class="btn btn-outline-secondary w-100" @onclick="ClearSearch">Clear Search</button>
      </div>
    </div>

    @if (FilteredPartners.Count == 0)
    {
        <p class="text-secondary mb-0">No joined/active advertisers found for the current view.</p>
    }
    else
    {
        <div class="accordion" id="cjAdvertiserAccordion">
          @foreach (var partner in FilteredPartners)
          {
            var panelId = $"advertiser-{partner.AdvertiserId}";
            var isExpanded = ExpandedAdvertiserIds.Contains(partner.AdvertiserId);
            var activeOffers = AdvertiserOffersById.TryGetValue(partner.AdvertiserId, out var loadedOffers)
              ? loadedOffers
              : new List<CjAffiliateOfferView>();

            <div class="accordion-item">
              <h2 class="accordion-header" id="@($"heading-{panelId}")">
                <button class="accordion-button @(isExpanded ? string.Empty : "collapsed")" type="button"
                        @onclick="() => ToggleAdvertiserAsync(partner)">
                  <div class="w-100 d-flex flex-wrap align-items-center justify-content-between gap-2">
                    <div>
                      <div class="fw-semibold">@partner.AdvertiserName</div>
                      <div class="small text-secondary font-monospace">@partner.AdvertiserId</div>
                    </div>
                    <div class="d-flex flex-wrap align-items-center gap-2">
                      <span
                      class="badge @GetRelationshipBadgeClass(partner.RelationshipStatus)">@NormalizeRelationshipStatus(partner.RelationshipStatus)</span>
                      <span class="badge text-bg-light">@partner.OfferCount active ads</span>
                      @if (!string.IsNullOrWhiteSpace(partner.PrimaryCategory))
                      {
                        <span class="badge text-bg-secondary">@partner.PrimaryCategory</span>
                      }
                    </div>
                  </div>
                </button>
              </h2>
              <div class="accordion-collapse collapse @(isExpanded ? "show" : string.Empty)">
                <div class="accordion-body">
                  @if (IsLoadingAdvertiserOffers && LoadingAdvertiserId == partner.AdvertiserId)
                  {
                    <p class="text-secondary mb-0">Loading active ads...</p>
                  }
                  else if (activeOffers.Count == 0)
                  {
                    <p class="text-secondary mb-0">No active ads were found for this advertiser.</p>
                  }
                  else
                  {
                    <div class="table-responsive">
                      <table class="table align-middle mb-0">
                        <thead>
                          <tr>
                            <th>Active Ad</th>
                            <th>Category</th>
                            <th>Ends</th>
                            <th class="text-end">Use In Article</th>
                          </tr>
                        </thead>
                        <tbody>
                          @foreach (var offer in activeOffers)
                          {
                            <tr>
                              <td>
                                <div class="fw-semibold">@offer.LinkName</div>
                                <div class="small text-secondary font-monospace">@offer.AdvertiserId</div>
                              </td>
                              <td>@(string.IsNullOrWhiteSpace(offer.Category) ? "-" : offer.Category)</td>
                              <td>@FormatPromotionEnd(offer.PromotionEndsAt)</td>
                              <td class="text-end">
                                @if (!string.IsNullOrWhiteSpace(offer.TrackingUrl))
                                {
                                  <a class="btn btn-sm btn-outline-success" href="@offer.TrackingUrl" target="_blank"
                                     rel="noopener noreferrer">Choose Ad</a>
                                }
                                else
                                {
                                  <span class="text-secondary small">n/a</span>
                                }
                              </td>
                            </tr>
                          }
                        </tbody>
                      </table>
                    </div>
                  }
                </div>
              </div>
            </div>
          }
        </div>
      }
    </div>
  </div>

@if (ShowConnectorModal)
{
  <div class="modal d-block" tabindex="-1" role="dialog" aria-modal="true">
    <div class="modal-dialog modal-lg" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Connect CJ.com Account</h5>
          <button type="button" class="btn-close" aria-label="Close" @onclick="CloseConnectorModal"></button>
        </div>
        <div class="modal-body">
            <p class="text-secondary">Enter your CJ Developer Key and Publisher ID (CID). Website ID is optional and is only
              used as an additional filter.</p>
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold small">Developer Key</label>
                  <input class="form-control" type="password" @bind="ConnectorDeveloperKey" autocomplete="off" />
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold small">Publisher ID (CID)</label>
                  <input class="form-control" @bind="ConnectorPublisherId" autocomplete="off" />
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold small">Website ID (Optional)</label>
                  <input class="form-control" @bind="ConnectorWebsiteId" autocomplete="off" />
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold small">Endpoint URL</label>
                  <input class="form-control" @bind="ConnectorEndpointUrl" />
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-semibold small">Max Results</label>
                  <input class="form-control" type="number" min="1" max="500" @bind="ConnectorMaxResults" />
                </div>
              </div>
              @if (!string.IsNullOrWhiteSpace(ConnectorMessage))
              {
                <div class="alert @(ConnectorMessageIsError ? "alert-danger" : "alert-info") mt-3 mb-0">@ConnectorMessage</div>
              }
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary" @onclick="CloseConnectorModal"
                      disabled="@IsBusy">Cancel</button>
              <button type="button" class="btn btn-outline-success" @onclick="SaveConnectorSettings" disabled="@IsBusy">
                <i class="bi bi-floppy-fill me-1"></i>Save Credentials
              </button>
              <button type="button" class="btn btn-outline-primary" @onclick="TestConnector" disabled="@IsBusy">Test
                Connection</button>
                <button type="button" class="btn btn-primary" @onclick="ConnectAndSyncPartners" disabled="@IsBusy">Connect And
                  Pull Partners</button>
                </div>
              </div>
            </div>
          </div>
          <div class="modal-backdrop fade show"></div>
        }

@code {
  private List<CjPartnerView> Partners { get; set; } = new();
  private readonly HashSet<string> ExpandedAdvertiserIds = new(StringComparer.OrdinalIgnoreCase);
  private readonly Dictionary<string, List<CjAffiliateOfferView>> AdvertiserOffersById =
new(StringComparer.OrdinalIgnoreCase);
  private bool IsLoadingAdvertiserOffers { get; set; }
  private string LoadingAdvertiserId { get; set; } = string.Empty;

  private bool IsBusy { get; set; }
  private bool IsConnected { get; set; }
  private bool ShowConnectorModal { get; set; }

  private string ErrorMessage { get; set; } = string.Empty;
  private string StatusMessage { get; set; } = string.Empty;
  private string LastSyncSummary { get; set; } = string.Empty;

  private string ConnectorDeveloperKey { get; set; } = string.Empty;
  private string ConnectorPublisherId { get; set; } = string.Empty;
  private string ConnectorWebsiteId { get; set; } = string.Empty;
  private string ConnectorEndpointUrl { get; set; } = "https://commissions.api.cj.com/query";
  private int ConnectorMaxResults { get; set; } = 100;
  private string ConnectorMessage { get; set; } = string.Empty;
  private bool ConnectorMessageIsError { get; set; }

  private string SearchTerm { get; set; } = string.Empty;

  private List<CjPartnerView> FilteredPartners =>
      Partners
          .Where(IsMyAdvertiser)
          .Where(partner =>
              string.IsNullOrWhiteSpace(SearchTerm) ||
              partner.AdvertiserName.Contains(SearchTerm.Trim(), StringComparison.OrdinalIgnoreCase) ||
              partner.AdvertiserId.Contains(SearchTerm.Trim(), StringComparison.OrdinalIgnoreCase))
          .OrderBy(partner => partner.AdvertiserName)
          .ToList();

  protected override async Task OnInitializedAsync()
  {
    await LoadSavedConnectorSettings();
    await LoadPartners();
  }

  private void OpenConnectorModal()
  {
    ConnectorMessage = string.Empty;
    ConnectorMessageIsError = false;
    ShowConnectorModal = true;
  }

  private async Task LoadSavedConnectorSettings()
  {
    try
    {
      var saved = await CjAdsService.GetConnectorSettingsAsync();
      if (saved is not null)
      {
        ConnectorDeveloperKey = saved.DeveloperKey;
        ConnectorPublisherId = saved.PublisherId;
        ConnectorWebsiteId = saved.WebsiteId;
        ConnectorEndpointUrl = saved.EndpointUrl;
        ConnectorMaxResults = saved.MaxResults;
      }
    }
    catch (Exception ex)
    {
      Logger.LogWarning(ex, "Could not load saved CJ connector settings.");
    }
  }

  private void CloseConnectorModal()
  {
    ShowConnectorModal = false;
  }

  private async Task LoadPartners()
  {
    try
    {
      Partners = (await CjAdsService.ListPartnersAsync("Joined", SearchTerm)).ToList();
      ExpandedAdvertiserIds.RemoveWhere(advertiserId => Partners.All(partner => !string.Equals(partner.AdvertiserId,
advertiserId, StringComparison.OrdinalIgnoreCase)));
      var removedKeys = AdvertiserOffersById.Keys.Where(advertiserId => Partners.All(partner =>
!string.Equals(partner.AdvertiserId, advertiserId, StringComparison.OrdinalIgnoreCase))).ToList();
      foreach (var removedKey in removedKeys)
      {
        AdvertiserOffersById.Remove(removedKey);
      }
    }
    catch (Exception ex)
    {
      Logger.LogError(ex, "Unable to load CJ advertisers.");
      ErrorMessage = $"Unable to load CJ advertisers. {ex.Message}";
    }
  }

  private async Task ToggleAdvertiserAsync(CjPartnerView partner)
  {
    if (ExpandedAdvertiserIds.Contains(partner.AdvertiserId))
    {
      ExpandedAdvertiserIds.Remove(partner.AdvertiserId);
      return;
    }

    ExpandedAdvertiserIds.Add(partner.AdvertiserId);

    if (AdvertiserOffersById.ContainsKey(partner.AdvertiserId))
    {
      return;
    }

    await LoadAdvertiserOffersAsync(partner);
  }

  private async Task LoadAdvertiserOffersAsync(CjPartnerView partner)
  {
    try
    {
      IsLoadingAdvertiserOffers = true;
      LoadingAdvertiserId = partner.AdvertiserId;
      var offers = await CjAdsService.GetOffersForAdvertiserAsync(partner.AdvertiserId, partner.AdvertiserName);
      AdvertiserOffersById[partner.AdvertiserId] = offers.ToList();
      StatusMessage = $"Loaded active ads for {partner.AdvertiserName}.";
      ErrorMessage = string.Empty;
    }
    catch (Exception ex)
    {
      Logger.LogError(ex, "Unable to load CJ ads for advertiser {AdvertiserId}.", partner.AdvertiserId);
      ErrorMessage = $"Unable to load ads for {partner.AdvertiserName}. {ex.Message}";
      AdvertiserOffersById[partner.AdvertiserId] = new List<CjAffiliateOfferView>();
    }
    finally
    {
      IsLoadingAdvertiserOffers = false;
      LoadingAdvertiserId = string.Empty;
    }
  }

  private async Task TestConnector()
  {
    await RunConnectorAction(async () =>
    {
      var result = await CjAdsService.TestConnectionAsync(BuildConnectorRequest());
      ConnectorMessageIsError = !result.IsSuccess;
      ConnectorMessage = result.Message;
      if (result.IsSuccess)
      {
        IsConnected = true;
        StatusMessage = $"CJ connection test succeeded. Partner preview count: {result.PartnerCountPreview}.";
      }
    });
  }

  private async Task ConnectAndSyncPartners()
  {
    await RunConnectorAction(async () =>
    {
      var sync = await CjAdsService.SyncPartnersAsync(BuildConnectorRequest());
      IsConnected = sync.IsSuccess;
      ConnectorMessageIsError = !sync.IsSuccess;
      ConnectorMessage = sync.Message;
      LastSyncSummary = $"My Advertisers: {sync.TotalReceived}. Created {sync.Created}, updated {sync.Updated}.";
      Partners = sync.Partners.Where(IsMyAdvertiser).ToList();
      ExpandedAdvertiserIds.Clear();
      AdvertiserOffersById.Clear();
      StatusMessage = "CJ My Advertisers pulled successfully.";
      ErrorMessage = string.Empty;
      await CjAdsService.SaveConnectorSettingsAsync(BuildSettingsView());
      ShowConnectorModal = false;
    });
  }

  private async Task RunConnectorAction(Func<Task> action)
  {
    ErrorMessage = string.Empty;
    StatusMessage = string.Empty;
    IsBusy = true;

    try
    {
      await action();
    }
    catch (Exception ex)
    {
      Logger.LogError(ex, "CJ connector action failed.");
      ErrorMessage = $"CJ connector action failed. {ex.Message}";
      ConnectorMessageIsError = true;
      ConnectorMessage = ex.Message;
    }
    finally
    {
      IsBusy = false;
    }
  }

  private CjPartnerSyncRequest BuildConnectorRequest()
  {
    return new CjPartnerSyncRequest
    {
      DeveloperKey = ConnectorDeveloperKey,
      PublisherId = ConnectorPublisherId,
      WebsiteId = ConnectorWebsiteId,
      EndpointUrl = ConnectorEndpointUrl,
      MaxResults = ConnectorMaxResults
    };
  }

  private CjConnectorSettingsView BuildSettingsView() => new()
  {
    DeveloperKey = ConnectorDeveloperKey,
    PublisherId = ConnectorPublisherId,
    WebsiteId = ConnectorWebsiteId,
    EndpointUrl = ConnectorEndpointUrl,
    MaxResults = ConnectorMaxResults
  };

  private async Task SaveConnectorSettings()
  {
    await RunConnectorAction(async () =>
    {
      await CjAdsService.SaveConnectorSettingsAsync(BuildSettingsView());
      ConnectorMessageIsError = false;
      ConnectorMessage = "Credentials saved.";
    });
  }

  private void ClearSearch()
  {
    SearchTerm = string.Empty;
  }

  private static bool IsMyAdvertiser(CjPartnerView partner)
  {
    var normalized = NormalizeRelationshipStatus(partner.RelationshipStatus);
    return normalized is "Joined" or "Active" or "Approved";
  }

  private static string FormatPromotionEnd(DateTimeOffset? promotionEndsAt)
  {
    return promotionEndsAt is null ? "-" : promotionEndsAt.Value.ToLocalTime().ToString("yyyy-MM-dd");
  }

  private static string NormalizeRelationshipStatus(string status)
  {
    if (string.IsNullOrWhiteSpace(status))
    {
      return "Unknown";
    }

    if (status.Equals("joined", StringComparison.OrdinalIgnoreCase))
    {
      return "Joined";
    }

    if (status.Equals("active", StringComparison.OrdinalIgnoreCase))
    {
      return "Active";
    }

    if (status.Equals("approved", StringComparison.OrdinalIgnoreCase))
    {
      return "Approved";
    }

    if (status.Equals("pending", StringComparison.OrdinalIgnoreCase))
    {
      return "Pending";
    }

    if (status.Equals("not joined", StringComparison.OrdinalIgnoreCase))
    {
      return "Not Joined";
    }

    return status;
  }

  private static string GetRelationshipBadgeClass(string status)
  {
    return NormalizeRelationshipStatus(status) switch
    {
      "Joined" => "text-bg-success",
      "Active" => "text-bg-success",
      "Approved" => "text-bg-success",
      "Pending" => "text-bg-warning",
      "Not Joined" => "text-bg-secondary",
      _ => "text-bg-light"
    };
  }
}
