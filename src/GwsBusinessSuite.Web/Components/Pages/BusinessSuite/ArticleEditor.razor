@page "/admin/article-editor"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "ContentAccess")]
@using Microsoft.AspNetCore.Authorization
@using GwsBusinessSuite.Domain.Entities
@using GwsBusinessSuite.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using System.Text.RegularExpressions
@using GwsBusinessSuite.Application.Settings
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISiteSettingsService SiteSettingsService
@inject NavigationManager Navigation
@inject ILogger<ArticleEditor> Logger

<PageTitle>Article Editor</PageTitle>

<div class="page-header d-flex align-items-start justify-content-between gap-3">
    <div>
        <h1><i class="bi bi-pencil me-2 text-primary"></i>Article Editor</h1>
        <p>Write and publish articles manually, or manage all articles regardless of source.</p>
    </div>
    <div class="d-inline-flex gap-2">
        <button class="btn btn-outline-secondary d-inline-flex align-items-center gap-2" @onclick="ToggleCategoryManager" disabled="@IsBusy">
            <i class="bi bi-tags"></i>
            <span>Manage Categories</span>
        </button>
        <button class="btn btn-primary d-inline-flex align-items-center gap-2" @onclick="CreateNewArticle" disabled="@IsBusy">
            <i class="bi bi-plus-lg"></i>
            <span>New Article</span>
        </button>
    </div>
</div>

@if (ShowCategoryManager)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3">
            <span class="fw-semibold">Categories</span>
        </div>
        <div class="card-body">
            <div class="d-flex gap-2 mb-3">
                <input class="form-control" style="max-width:280px" placeholder="New category name"
                       value="@NewCategoryName" @oninput="e => NewCategoryName = e.Value?.ToString() ?? string.Empty" />
                <button class="btn btn-sm btn-primary" @onclick="AddCategoryAsync" disabled="@IsBusy">Add</button>
            </div>
            @if (Categories.Count == 0)
            {
                <p class="text-secondary mb-0 small">No categories yet — articles default to "Uncategorized".</p>
            }
            else
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var cat in Categories)
                    {
                        <span class="badge text-bg-light d-inline-flex align-items-center gap-2 py-2 px-3">
                            @cat.Name
                            <button class="btn btn-sm p-0 border-0 text-danger lh-1" title="Delete category"
                                    @onclick="() => DeleteCategoryAsync(cat.Id)" disabled="@IsBusy">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </span>
                    }
                </div>
            }
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger d-flex align-items-start gap-2 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
        <div>@ErrorMessage</div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-info d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <div>@StatusMessage</div>
    </div>
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-bottom py-3 d-flex align-items-center gap-2">
        <span class="fw-semibold">@(ShowTrash ? "Trash" : "All Articles")</span>
        <span class="badge text-bg-secondary">@(ShowTrash ? TrashedArticles.Count : FilteredArticles.Count)</span>
        <button class="btn btn-sm @(ShowTrash ? "btn-secondary" : "btn-outline-secondary") ms-auto"
                @onclick="ToggleTrashViewAsync" disabled="@IsBusy">
            <i class="bi bi-trash3 me-1"></i>Trash@(TrashedArticles.Count > 0 ? $" ({TrashedArticles.Count})" : "")
        </button>
    </div>
    <div class="card-body">
        @if (!ShowTrash)
        {
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold small">Status</label>
                    <select class="form-select" @bind="StatusFilter">
                        <option value="">All</option>
                        <option value="Draft">Draft</option>
                        <option value="Published">Published</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold small">Source</label>
                    <select class="form-select" @bind="SourceFilter">
                        <option value="">All</option>
                        <option value="Manual">Manual</option>
                        <option value="OllamaGenerated">Ollama Generated</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold small">Category</label>
                    <select class="form-select" @bind="CategoryFilter">
                        <option value="">All</option>
                        <option value="uncategorized">Uncategorized</option>
                        @foreach (var cat in Categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold small">Search</label>
                    <input class="form-control" @bind="SearchTerm" @bind:event="oninput" placeholder="Filter by title" />
                </div>
            </div>

            @if (SelectedIds.Count > 0)
            {
                <div class="d-flex align-items-center gap-2 mb-3">
                    <select class="form-select form-select-sm" style="width:auto" @bind="BulkAction">
                        <option value="">Bulk actions</option>
                        <option value="trash">Move to Trash</option>
                    </select>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ApplyBulkActionAsync" disabled="@(IsBusy || string.IsNullOrEmpty(BulkAction))">Apply</button>
                    <span class="small text-secondary">@SelectedIds.Count selected</span>
                </div>
            }

            @if (Articles.Count == 0 && !IsBusy)
            {
                <p class="text-secondary mb-0">No articles yet. Click <strong>New Article</strong> to write your first one.</p>
            }
            else if (FilteredArticles.Count == 0)
            {
                <p class="text-secondary mb-0">No articles match the current filter.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0 wp-list-table">
                        <thead>
                            <tr>
                                <th style="width:2rem">
                                    <input type="checkbox" class="form-check-input" checked="@(SelectedIds.Count > 0 && SelectedIds.Count == FilteredArticles.Count)"
                                           @onchange="e => ToggleSelectAll((bool)(e.Value ?? false))" />
                                </th>
                                <th role="button" @onclick='() => SetSort("Title")'>Title @SortIndicator("Title")</th>
                                <th role="button" @onclick='() => SetSort("Status")'>Status @SortIndicator("Status")</th>
                                <th>Source</th>
                                <th role="button" @onclick='() => SetSort("Published")'>Published @SortIndicator("Published")</th>
                                <th role="button" @onclick='() => SetSort("Updated")'>Updated @SortIndicator("Updated")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var article in FilteredArticles)
                            {
                                <tr class="wp-list-row">
                                    <td>
                                        <input type="checkbox" class="form-check-input" checked="@SelectedIds.Contains(article.Id)"
                                               @onchange="e => ToggleSelect(article.Id, (bool)(e.Value ?? false))" />
                                    </td>
                                    <td>
                                        <div class="fw-semibold">
                                            <a href="/admin/article-editor/@article.Id">@article.Title</a>
                                        </div>
                                        <div class="small text-secondary font-monospace">/@article.Slug</div>
                                        <div class="wp-row-actions small">
                                            <a href="/admin/article-editor/@article.Id">Edit</a>
                                            <span class="text-secondary"> | </span>
                                            <button type="button" class="text-danger" @onclick="() => TrashArticleAsync(article.Id)">Trash</button>
                                            @if (article.Status == ArticleStatuses.Published && !IsScheduledArticle(article))
                                            {
                                                <span class="text-secondary"> | </span>
                                                <a href="/blog/@article.Slug" target="_blank">View</a>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge @(IsScheduledArticle(article) ? "text-bg-info" : GetStatusBadgeClass(article.Status))">
                                            @(IsScheduledArticle(article) ? "Scheduled" : article.Status)
                                        </span>
                                        @if (article.Status == ArticleStatuses.Draft)
                                        {
                                            <button class="btn btn-xs btn-link p-0 ms-1" @onclick="() => PublishArticle(article.Id)" disabled="@IsBusy">Publish</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-xs btn-link p-0 ms-1" @onclick="() => UnpublishArticle(article.Id)" disabled="@IsBusy">Unpublish</button>
                                        }
                                    </td>
                                    <td><span class="badge text-bg-light">@FormatSource(article.Source)</span></td>
                                    <td class="small">@(article.PublishedAt.HasValue ? FormatDate(article.PublishedAt.Value) : "—")</td>
                                    <td class="small">@FormatDate(article.UpdatedAt ?? article.CreatedAt)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else
        {
            @if (TrashedArticles.Count == 0)
            {
                <p class="text-secondary mb-0">Trash is empty.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0 wp-list-table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Trashed</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var article in TrashedArticles)
                            {
                                <tr class="wp-list-row">
                                    <td>
                                        <div class="fw-semibold">@article.Title</div>
                                        <div class="small text-secondary font-monospace">/@article.Slug</div>
                                    </td>
                                    <td class="small">@(article.TrashedAt.HasValue ? FormatDate(article.TrashedAt.Value) : "—")</td>
                                    <td class="text-end">
                                        <div class="d-inline-flex gap-2">
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => RestoreArticleAsync(article.Id)" disabled="@IsBusy">Restore</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => PermanentlyDeleteArticleAsync(article.Id)" disabled="@IsBusy">Delete Permanently</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<Article> Articles { get; set; } = new();
    private List<ArticleCategory> Categories { get; set; } = new();
    private bool IsBusy { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;
    private string StatusFilter { get; set; } = string.Empty;
    private string SourceFilter { get; set; } = string.Empty;
    private string CategoryFilter { get; set; } = string.Empty;
    private string SearchTerm { get; set; } = string.Empty;

    private bool ShowCategoryManager { get; set; }
    private string NewCategoryName { get; set; } = string.Empty;

    // ── List-table state: bulk select, sort, trash ──────────────────────────
    private HashSet<Guid> SelectedIds { get; set; } = new();
    private string BulkAction { get; set; } = string.Empty;
    private string SortColumn { get; set; } = "Updated";
    private bool SortDescending { get; set; } = true;
    private bool ShowTrash { get; set; }
    private List<Article> TrashedArticles { get; set; } = new();

    private IReadOnlyList<Article> FilteredArticles
    {
        get
        {
            IEnumerable<Article> query = Articles
                .Where(a => string.IsNullOrEmpty(StatusFilter) || a.Status == StatusFilter)
                .Where(a => string.IsNullOrEmpty(SourceFilter) || a.Source == SourceFilter)
                .Where(a => string.IsNullOrEmpty(CategoryFilter) ||
                            (CategoryFilter == "uncategorized" ? a.CategoryId is null : a.CategoryId == Guid.Parse(CategoryFilter)))
                .Where(a => string.IsNullOrEmpty(SearchTerm) ||
                            a.Title.Contains(SearchTerm.Trim(), StringComparison.OrdinalIgnoreCase));

            query = SortColumn switch
            {
                "Title" => SortDescending ? query.OrderByDescending(a => a.Title) : query.OrderBy(a => a.Title),
                "Status" => SortDescending ? query.OrderByDescending(a => a.Status) : query.OrderBy(a => a.Status),
                "Published" => SortDescending ? query.OrderByDescending(a => a.PublishedAt) : query.OrderBy(a => a.PublishedAt),
                _ => SortDescending ? query.OrderByDescending(a => a.UpdatedAt ?? a.CreatedAt) : query.OrderBy(a => a.UpdatedAt ?? a.CreatedAt),
            };

            return query.ToList();
        }
    }

    private void SetSort(string column)
    {
        if (SortColumn == column)
        {
            SortDescending = !SortDescending;
        }
        else
        {
            SortColumn = column;
            SortDescending = false;
        }
    }

    private string SortIndicator(string column) =>
        SortColumn != column ? "" : (SortDescending ? "▼" : "▲");

    private void ToggleSelect(Guid id, bool selected)
    {
        if (selected) SelectedIds.Add(id);
        else SelectedIds.Remove(id);
    }

    private void ToggleSelectAll(bool selected)
    {
        SelectedIds = selected ? FilteredArticles.Select(a => a.Id).ToHashSet() : new HashSet<Guid>();
    }

    private async Task ApplyBulkActionAsync()
    {
        if (BulkAction != "trash" || SelectedIds.Count == 0) return;
        var ids = SelectedIds.ToList();
        foreach (var id in ids)
        {
            await TrashArticleAsync(id, reload: false);
        }
        SelectedIds.Clear();
        BulkAction = string.Empty;
        await LoadArticles();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadArticles();
        await LoadCategoriesAsync();
        await LoadTrashedArticlesAsync();
    }

    private async Task LoadArticles()
    {
        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var rows = await db.Articles.Where(a => a.TrashedAt == null).ToListAsync();
            Articles = rows
                .OrderByDescending(a => a.UpdatedAt ?? a.CreatedAt)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load articles.");
            ErrorMessage = $"Unable to load articles. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task LoadCategoriesAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            Categories = await db.ArticleCategories.OrderBy(c => c.Name).ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load categories.");
        }
    }

    private void ToggleCategoryManager() => ShowCategoryManager = !ShowCategoryManager;

    private async Task LoadTrashedArticlesAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            // SQLite can't translate ORDER BY on a DateTimeOffset column, so order
            // client-side after materializing (same pattern used for the public /blog
            // listing in Program.cs).
            var rows = await db.Articles.Where(a => a.TrashedAt != null).ToListAsync();
            TrashedArticles = rows.OrderByDescending(a => a.TrashedAt).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load trashed articles.");
        }
    }

    private async Task ToggleTrashViewAsync()
    {
        ShowTrash = !ShowTrash;
        if (ShowTrash)
        {
            await LoadTrashedArticlesAsync();
        }
    }

    private async Task AddCategoryAsync()
    {
        if (string.IsNullOrWhiteSpace(NewCategoryName)) return;
        ErrorMessage = string.Empty;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.ArticleCategories.Add(new ArticleCategory
            {
                Name = NewCategoryName.Trim(),
                Slug = ToSlug(NewCategoryName)
            });
            await db.SaveChangesAsync();
            NewCategoryName = string.Empty;
            await LoadCategoriesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to add category.");
            ErrorMessage = $"Unable to add category. {ex.Message}";
        }
    }

    private async Task DeleteCategoryAsync(Guid id)
    {
        ErrorMessage = string.Empty;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var category = await db.ArticleCategories.FindAsync(id);
            if (category is null) return;
            // Articles referencing this category fall back to "Uncategorized" via the
            // CategoryId FK's SetNull delete behavior - no manual cleanup needed here.
            db.ArticleCategories.Remove(category);
            await db.SaveChangesAsync();
            await LoadCategoriesAsync();
            await LoadArticles();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete category.");
            ErrorMessage = $"Unable to delete category. {ex.Message}";
        }
    }

    private static string ToSlug(string title)
    {
        var s = title.ToLowerInvariant().Trim();
        s = Regex.Replace(s, @"[^a-z0-9\s-]", string.Empty);
        s = Regex.Replace(s, @"\s+", "-");
        return s.Trim('-');
    }

    private async Task CreateNewArticle()
    {
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;
        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var settings = await SiteSettingsService.GetSettingsAsync();
            var article = new Article
            {
                Title      = "Untitled Article",
                Slug       = $"untitled-{DateTimeOffset.UtcNow:yyyyMMddHHmmss}",
                Status     = ArticleStatuses.Draft,
                Source     = ArticleSource.Manual,
                CategoryId = settings.DefaultArticleCategoryId,
                CreatedBy  = "manual-editor"
            };
            if (!string.IsNullOrWhiteSpace(settings.DefaultAuthorByline))
            {
                article.Author = settings.DefaultAuthorByline;
            }
            db.Articles.Add(article);
            await db.SaveChangesAsync();
            Navigation.NavigateTo($"/admin/article-editor/{article.Id}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create new article.");
            ErrorMessage = $"Unable to create article. {ex.Message}";
            IsBusy = false;
        }
    }

    private void EditArticle(Guid id)
    {
        Navigation.NavigateTo($"/admin/article-editor/{id}");
    }

    private async Task PublishArticle(Guid id)
    {
        await RunAction(id, async (db, article) =>
        {
            article.Status      = ArticleStatuses.Published;
            article.PublishedAt ??= DateTimeOffset.UtcNow;
            article.UpdatedAt   = DateTimeOffset.UtcNow;
            article.UpdatedBy   = "manual-editor";
            await db.SaveChangesAsync();
            StatusMessage = $"'{article.Title}' is now live.";
        });
    }

    private async Task UnpublishArticle(Guid id)
    {
        await RunAction(id, async (db, article) =>
        {
            article.Status    = ArticleStatuses.Draft;
            article.UpdatedAt = DateTimeOffset.UtcNow;
            article.UpdatedBy = "manual-editor";
            await db.SaveChangesAsync();
            StatusMessage = $"'{article.Title}' moved back to Draft.";
        });
    }

    private async Task TrashArticleAsync(Guid id, bool reload = true)
    {
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;
        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var article = await db.Articles.FindAsync(id);
            if (article is null) { ErrorMessage = "Article not found."; return; }

            article.TrashedAt = DateTimeOffset.UtcNow;
            article.UpdatedAt = DateTimeOffset.UtcNow;
            article.UpdatedBy = "manual-editor";
            await db.SaveChangesAsync();
            StatusMessage = $"'{article.Title}' moved to Trash.";

            if (reload)
            {
                await LoadArticles();
                await LoadTrashedArticlesAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to trash article {Id}.", id);
            ErrorMessage = $"Unable to move to Trash. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task RestoreArticleAsync(Guid id)
    {
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;
        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var article = await db.Articles.FindAsync(id);
            if (article is null) { ErrorMessage = "Article not found."; return; }

            article.TrashedAt = null;
            article.UpdatedAt = DateTimeOffset.UtcNow;
            article.UpdatedBy = "manual-editor";
            await db.SaveChangesAsync();
            StatusMessage = $"'{article.Title}' restored.";
            await LoadArticles();
            await LoadTrashedArticlesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to restore article {Id}.", id);
            ErrorMessage = $"Unable to restore. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task PermanentlyDeleteArticleAsync(Guid id)
    {
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;
        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var article = await db.Articles.FindAsync(id);
            if (article is null) { ErrorMessage = "Article not found."; return; }
            if (article.TrashedAt is null)
            {
                ErrorMessage = "Move this article to Trash before deleting it permanently.";
                return;
            }

            db.Articles.Remove(article);
            await db.SaveChangesAsync();
            StatusMessage = $"'{article.Title}' deleted permanently.";
            await LoadTrashedArticlesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to permanently delete article {Id}.", id);
            ErrorMessage = $"Unable to delete. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task RunAction(Guid id, Func<ApplicationDbContext, Article, Task> action)
    {
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;
        IsBusy = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var article = await db.Articles.FindAsync(id);
            if (article is null)
            {
                ErrorMessage = "Article not found.";
                return;
            }
            await action(db, article);
            await LoadArticles();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Action failed for article {Id}.", id);
            ErrorMessage = $"Action failed. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        ArticleStatuses.Published => "text-bg-success",
        ArticleStatuses.Draft     => "text-bg-warning",
        _                         => "text-bg-secondary"
    };

    private static string FormatSource(string source) => source switch
    {
        ArticleSource.Manual          => "Manual",
        ArticleSource.OllamaGenerated => "Ollama",
        _                             => source
    };

    private static bool IsScheduledArticle(Article article) =>
        article.Status == ArticleStatuses.Published
        && article.PublishedAt is { } publishAt
        && publishAt > DateTimeOffset.UtcNow;

    private static string FormatDate(DateTimeOffset value) =>
        value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
}
