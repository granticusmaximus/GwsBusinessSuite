    private static LayoutSection CreateDefaultSection()
    {
        var section = new LayoutSection { Label = "Section", ColumnLayout = "full" };
        section.Columns = BuildColumnsForLayout("full");
        return section;
    }

    private static List<LayoutColumn> BuildColumnsForLayout(string layout) => layout switch
    {
        "half-half" => [new LayoutColumn { Span = 6 }, new LayoutColumn { Span = 6 }],
        "one-third-two-thirds" => [new LayoutColumn { Span = 4 }, new LayoutColumn { Span = 8 }],
        "two-thirds-one-third" => [new LayoutColumn { Span = 8 }, new LayoutColumn { Span = 4 }],
        "thirds" => [new LayoutColumn { Span = 4 }, new LayoutColumn { Span = 4 }, new LayoutColumn { Span = 4 }],
        _ => [new LayoutColumn { Span = 12 }]
    };

    private static void UpdateSectionColumnLayout(LayoutSection section, string newLayout)
    {
        if (section.ColumnLayout == newLayout) return;
        var allWidgets = section.Columns.SelectMany(c => c.Widgets).ToList();
        section.ColumnLayout = newLayout;
        section.Columns = BuildColumnsForLayout(newLayout);
        if (section.Columns.Count > 0)
            section.Columns[0].Widgets.AddRange(allWidgets);
    }

    // ── Widget CRUD ───────────────────────────────────────────────────────
    private void QuickAddWidget(string widgetType)
    {
        PushUndo();
        LayoutSection? targetSection = null;
        if (!string.IsNullOrEmpty(_selectedSectionId))
            targetSection = FindSection(_selectedSectionId);
        targetSection ??= _layout.Sections.LastOrDefault();

        if (targetSection is null)
        {
            targetSection = CreateDefaultSection();
            _layout.Sections.Add(targetSection);
        }

        LayoutColumn? targetColumn = null;
        if (!string.IsNullOrEmpty(_selectedWidgetId))
        {
            var (_, col) = FindWidgetLocation(_selectedWidgetId);
            if (col is not null && targetSection.Columns.Contains(col))
                targetColumn = col;
        }
        targetColumn ??= targetSection.Columns.FirstOrDefault();
        if (targetColumn is null) return;

        var widget = CreateDefaultWidget(widgetType);
        targetColumn.Widgets.Add(widget);
        SelectWidget(targetSection.Id, widget.Id);
    }

    private void MoveWidgetInColumn(string sectionId, string columnId, int index, int direction)
    {
        var col = FindSection(sectionId)?.Columns.FirstOrDefault(c => c.Id == columnId);
        if (col is null) return;
        var target = index + direction;
        if (target < 0 || target >= col.Widgets.Count) return;
        PushUndo();
        (col.Widgets[index], col.Widgets[target]) = (col.Widgets[target], col.Widgets[index]);
    }

    private void MoveSelectedWidgetUp()
    {
        if (string.IsNullOrEmpty(_selectedWidgetId)) return;
        var (sec, col) = FindWidgetLocation(_selectedWidgetId);
        if (sec is null || col is null) return;
        var idx = col.Widgets.FindIndex(w => w.Id == _selectedWidgetId);
        MoveWidgetInColumn(sec.Id, col.Id, idx, -1);
    }

    private void MoveSelectedWidgetDown()
    {
        if (string.IsNullOrEmpty(_selectedWidgetId)) return;
        var (sec, col) = FindWidgetLocation(_selectedWidgetId);
        if (sec is null || col is null) return;
        var idx = col.Widgets.FindIndex(w => w.Id == _selectedWidgetId);
        MoveWidgetInColumn(sec.Id, col.Id, idx, 1);
    }

    // ── Drag-and-drop reordering (Layers panel) ─────────────────────────────
    // Native HTML5 drag events — no JS interop or extra library needed. Reordering works
    // within a column, across columns, and across sections, since every drop handler
    // already has direct object references to both the source and target LayoutColumn.
    private string? _draggedWidgetId;
    private LayoutColumn? _draggedFromColumn;

    private void StartDragWidget(LayoutWidget widget, LayoutColumn fromColumn)
    {
        _draggedWidgetId = widget.Id;
        _draggedFromColumn = fromColumn;
    }

    private void EndDragWidget()
    {
        _draggedWidgetId = null;
        _draggedFromColumn = null;
    }

    private void DropWidgetOnto(string targetSectionId, LayoutColumn targetColumn, LayoutWidget targetWidget)
    {
        if (_draggedWidgetId is null || _draggedFromColumn is null || _draggedWidgetId == targetWidget.Id)
        {
            EndDragWidget();
            return;
        }

        var draggedWidget = _draggedFromColumn.Widgets.FirstOrDefault(w => w.Id == _draggedWidgetId);
        if (draggedWidget is null)
        {
            EndDragWidget();
            return;
        }

        PushUndo();

        // Dragging downward within the same column needs "insert after target" — "insert
        // before target" (the only case that matters cross-column) cancels out to a no-op
        // when the target was already the very next item, since removing the dragged widget
        // shifts everything after it up by one, landing the target back where it started.
        var draggedFromIndex = _draggedFromColumn.Widgets.IndexOf(draggedWidget);
        var targetIndexBeforeRemoval = targetColumn.Widgets.IndexOf(targetWidget);
        var isDraggingDownwardInSameColumn = ReferenceEquals(_draggedFromColumn, targetColumn)
            && targetIndexBeforeRemoval > draggedFromIndex;

        _draggedFromColumn.Widgets.Remove(draggedWidget);
        var targetIndex = targetColumn.Widgets.IndexOf(targetWidget);
        if (targetIndex < 0)
        {
            targetIndex = targetColumn.Widgets.Count;
        }
        else if (isDraggingDownwardInSameColumn)
        {
            targetIndex += 1;
        }
        targetColumn.Widgets.Insert(targetIndex, draggedWidget);

        SelectWidget(targetSectionId, draggedWidget.Id);
        EndDragWidget();
    }

    // ── Drag-and-drop reordering (Layers panel — sections) ──────────────────
    // Exact mirror of the widget drag-and-drop above, operating on _layout.Sections
    // instead of a column's Widgets list. dragReorder.js's global [draggable="true"]
    // listener already covers these elements too — no JS changes needed.
    private string? _draggedSectionId;

    private void StartDragSection(LayoutSection section) => _draggedSectionId = section.Id;

    private void EndDragSection() => _draggedSectionId = null;

    private void DropSectionOnto(LayoutSection targetSection)
    {
        if (_draggedSectionId is null || _draggedSectionId == targetSection.Id)
        {
            EndDragSection();
            return;
        }

        var dragged = _layout.Sections.FirstOrDefault(s => s.Id == _draggedSectionId);
        if (dragged is null)
        {
            EndDragSection();
            return;
        }

        PushUndo();

        var fromIndex = _layout.Sections.IndexOf(dragged);
        var targetIndexBeforeRemoval = _layout.Sections.IndexOf(targetSection);
        var isDraggingDownward = targetIndexBeforeRemoval > fromIndex;

        _layout.Sections.Remove(dragged);
        var targetIndex = _layout.Sections.IndexOf(targetSection);
        if (targetIndex < 0)
        {
            targetIndex = _layout.Sections.Count;
        }
        else if (isDraggingDownward)
        {
            targetIndex += 1;
        }
        _layout.Sections.Insert(targetIndex, dragged);

        SelectSection(dragged.Id);
        EndDragSection();
    }

    // ── Section CRUD (continued) ─────────────────────────────────────────────
    private void DuplicateSection(string sectionId)
    {
        var original = FindSection(sectionId);
        if (original is null) return;

        PushUndo();
        var clone = new LayoutSection
        {
            Id = Guid.NewGuid().ToString("N"),
            Label = original.Label,
            Background = original.Background,
            Padding = original.Padding,
            ColumnLayout = original.ColumnLayout,
            Columns = original.Columns.Select(col => new LayoutColumn
            {
                Id = Guid.NewGuid().ToString("N"),
                Span = col.Span,
                Widgets = col.Widgets.Select(w => new LayoutWidget
                {
                    Id = Guid.NewGuid().ToString("N"),
                    WidgetType = w.WidgetType,
                    Props = new Dictionary<string, string>(w.Props),
                    Style = new WidgetStyle
                    {
                        TextColor = w.Style.TextColor,
                        BackgroundColor = w.Style.BackgroundColor,
                        Padding = w.Style.Padding,
                        BorderRadius = w.Style.BorderRadius,
                        FontSize = w.Style.FontSize
                    }
                }).ToList()
            }).ToList()
        };

        var insertAt = _layout.Sections.IndexOf(original) + 1;
        _layout.Sections.Insert(insertAt, clone);
        SelectSection(clone.Id);
    }

    private void MoveSection(string sectionId, int direction)
    {
        var section = FindSection(sectionId);
        if (section is null) return;
        var index = _layout.Sections.IndexOf(section);
        var target = index + direction;
        if (target < 0 || target >= _layout.Sections.Count) return;
        PushUndo();
        (_layout.Sections[index], _layout.Sections[target]) = (_layout.Sections[target], _layout.Sections[index]);
    }

    private bool CanMoveSectionUp(string sectionId) => _layout.Sections.FindIndex(s => s.Id == sectionId) > 0;

    private bool CanMoveSectionDown(string sectionId)
    {
        var index = _layout.Sections.FindIndex(s => s.Id == sectionId);
        return index >= 0 && index < _layout.Sections.Count - 1;
    }

    // ── Section collapse/expand (Layers panel) ───────────────────────────────
    // Client-only display state, not persisted to BlocksJson — purely a convenience for
    // navigating pages with many widgets, resets to "all expanded" on next load.
    private readonly HashSet<string> _collapsedSectionIds = new();

    private bool IsSectionCollapsed(string sectionId) => _collapsedSectionIds.Contains(sectionId);

    private void ToggleSectionCollapsed(string sectionId)
    {
        if (!_collapsedSectionIds.Add(sectionId))
        {
            _collapsedSectionIds.Remove(sectionId);
        }
    }

    private void DuplicateWidget(string sectionId, string columnId, int index)
    {
        var col = FindSection(sectionId)?.Columns.FirstOrDefault(c => c.Id == columnId);
        if (col is null || index >= col.Widgets.Count) return;
        PushUndo();
        var orig = col.Widgets[index];
        var clone = new LayoutWidget
        {
            Id = Guid.NewGuid().ToString("N"),
            WidgetType = orig.WidgetType,
            Props = new Dictionary<string, string>(orig.Props)
        };
        col.Widgets.Insert(index + 1, clone);
        SelectWidget(sectionId, clone.Id);
    }

    private void DuplicateSelectedWidget()
    {
        if (string.IsNullOrEmpty(_selectedWidgetId)) return;
        var (sec, col) = FindWidgetLocation(_selectedWidgetId);
        if (sec is null || col is null) return;
        DuplicateWidget(sec.Id, col.Id, col.Widgets.FindIndex(w => w.Id == _selectedWidgetId));
    }

    private void DeleteWidget(string sectionId, string columnId, string widgetId)
    {
        PushUndo();
        var col = FindSection(sectionId)?.Columns.FirstOrDefault(c => c.Id == columnId);
        col?.Widgets.RemoveAll(w => w.Id == widgetId);
        if (_selectedWidgetId == widgetId) ClearSelection();
    }

    private void DeleteSelectedWidget()
    {
        if (string.IsNullOrEmpty(_selectedWidgetId)) return;
        var (sec, col) = FindWidgetLocation(_selectedWidgetId);
        if (sec is null || col is null) return;
        DeleteWidget(sec.Id, col.Id, _selectedWidgetId);
    }

    // ── Lookup helpers ────────────────────────────────────────────────────
    private LayoutSection? FindSection(string id) =>
        _layout.Sections.FirstOrDefault(s => s.Id == id);

    private LayoutWidget? FindWidget(string widgetId) =>
        _layout.Sections.SelectMany(s => s.Columns).SelectMany(c => c.Widgets)
            .FirstOrDefault(w => w.Id == widgetId);

    private (LayoutSection? Section, LayoutColumn? Column) FindWidgetLocation(string widgetId)
    {
        foreach (var s in _layout.Sections)
            foreach (var c in s.Columns)
                if (c.Widgets.Any(w => w.Id == widgetId))
                    return (s, c);
        return (null, null);
    }

    private static int GetSectionWidgetCount(LayoutSection section) =>
        section.Columns.Sum(c => c.Widgets.Count);

    // ── Prop helpers ──────────────────────────────────────────────────────
    private static string GetProp(LayoutWidget widget, string key, string defaultValue = "") =>
        widget.Props.TryGetValue(key, out var val) ? val : defaultValue;

    // Instance method (not static) so it can push live edits out to the canvas iframe as
    // they happen - every content edit, whether typed in the Inspector or made inline on
    // the canvas (Phase 3), funnels through this one method. _suppressCanvasSync is set
    // while applying an edit that originated FROM the iframe, so that push doesn't echo
    // straight back to the element the user is actively typing in.
    private bool _suppressCanvasSync;

    // forceNewUndoStep: false (the default, used by every @oninput-bound Inspector field)
    // collapses a burst of rapid keystrokes into the same widget+key into a single undo
    // step; true (used by discrete actions like Add/Remove Field and canvas inline edits,
    // which route through this same method) always starts a fresh step regardless of what
    // was being typed immediately beforehand.
    private void SetProp(LayoutWidget widget, string key, string value, bool forceNewUndoStep = false)
    {
        var editKey = $"{widget.Id}:{key}";
        if (forceNewUndoStep || editKey != _lastUndoEditKey)
        {
            PushUndo();
            _lastUndoEditKey = editKey;
        }
        widget.Props[key] = value;
        if (!_suppressCanvasSync)
        {
            _ = PushPropToCanvasAsync(widget.Id, key, value);
        }
    }

    private async Task PushPropToCanvasAsync(string widgetId, string key, string value)
    {
        if (!_bridgeInitialized) return;
        try
        {
            await JS.InvokeVoidAsync("gwsCmsBuilderBridge.sendToIframe",
                new { type = "cms:prop-changed", widgetId, prop = key, value });
        }
        catch (JSDisconnectedException)
        {
            // Circuit already gone - nothing left to push to.
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to push live edit to canvas for widget {WidgetId}.", widgetId);
        }
    }

    // ── Style helpers (Phase 6) ─────────────────────────────────────────────
    private static void SetStyleTextColor(LayoutWidget widget, string value) =>
        widget.Style.TextColor = value;

    private static void SetStyleBackgroundColor(LayoutWidget widget, string value) =>
        widget.Style.BackgroundColor = value;

    // ── Form widget field editor ─────────────────────────────────────────
    private static readonly string[] FormFieldTypes = ["text", "email", "tel", "textarea", "select", "checkbox"];

    private sealed record FormFieldDef(string Key, string Label, string Type, bool Required, List<string> Options);

    private static List<FormFieldDef> GetFormFields(LayoutWidget widget)
    {
        try
        {
            var raw = GetProp(widget, "fieldsJson");
            if (string.IsNullOrWhiteSpace(raw)) return [];

            var parsed = JsonSerializer.Deserialize<List<Dictionary<string, JsonElement>>>(raw);
            if (parsed is null) return [];

            return parsed.Select(f => new FormFieldDef(
                f.TryGetValue("key", out var k) ? k.GetString() ?? string.Empty : string.Empty,
                f.TryGetValue("label", out var l) ? l.GetString() ?? string.Empty : string.Empty,
                f.TryGetValue("type", out var t) ? t.GetString() ?? "text" : "text",
                f.TryGetValue("required", out var r) && r.ValueKind == JsonValueKind.True,
                f.TryGetValue("optionsJson", out var o) && o.ValueKind == JsonValueKind.String
                    ? JsonSerializer.Deserialize<List<string>>(o.GetString() ?? "[]") ?? []
                    : []
            )).ToList();
        }
        catch
        {
            return [];
        }
    }

    private void SaveFormFields(LayoutWidget widget, List<FormFieldDef> fields, bool forceNewUndoStep = false)
    {
        var json = JsonSerializer.Serialize(fields.Select(f => new
        {
            key = f.Key,
            label = f.Label,
            type = f.Type,
            required = f.Required,
            optionsJson = f.Options.Count > 0 ? JsonSerializer.Serialize(f.Options) : null
        }));
        SetProp(widget, "fieldsJson", json, forceNewUndoStep);
    }

    private void AddFormField(LayoutWidget widget)
    {
        var fields = GetFormFields(widget);
        var n = fields.Count + 1;
        fields.Add(new FormFieldDef($"field{n}", $"Field {n}", "text", false, []));
        SaveFormFields(widget, fields, forceNewUndoStep: true);
    }

    private void UpdateFormField(LayoutWidget widget, int index, Func<FormFieldDef, FormFieldDef> update)
    {
        var fields = GetFormFields(widget);
        if (index < 0 || index >= fields.Count) return;
        var updated = update(fields[index]);
        // Derive a stable field key from the label so submissions have a readable key,
        // falling back to the existing key if the label is blank.
        var derivedKey = string.IsNullOrWhiteSpace(updated.Label)
            ? updated.Key
            : new string(updated.Label.Trim().ToLowerInvariant()
                .Select(c => char.IsLetterOrDigit(c) ? c : '-').ToArray());
        fields[index] = updated with { Key = string.IsNullOrWhiteSpace(derivedKey) ? updated.Key : derivedKey };
        SaveFormFields(widget, fields);
    }

    private void RemoveFormField(LayoutWidget widget, int index)
    {
        var fields = GetFormFields(widget);
        if (index < 0 || index >= fields.Count) return;
        fields.RemoveAt(index);
        SaveFormFields(widget, fields, forceNewUndoStep: true);
    }

    // ── Accordion widget items ──────────────────────────────────────────────
    private sealed record AccordionItemDef(string Question, string Answer);

    private static List<AccordionItemDef> GetAccordionItems(LayoutWidget widget)
    {
        try
        {
            var raw = GetProp(widget, "itemsJson");
            if (string.IsNullOrWhiteSpace(raw)) return [];

            var parsed = JsonSerializer.Deserialize<List<Dictionary<string, JsonElement>>>(raw);
            if (parsed is null) return [];

            return parsed.Select(i => new AccordionItemDef(
                i.TryGetValue("question", out var q) ? q.GetString() ?? string.Empty : string.Empty,
                i.TryGetValue("answer", out var a) ? a.GetString() ?? string.Empty : string.Empty
            )).ToList();
        }
        catch
        {
            return [];
        }
    }

    private void SaveAccordionItems(LayoutWidget widget, List<AccordionItemDef> items, bool forceNewUndoStep = false)
    {
        var json = JsonSerializer.Serialize(items.Select(i => new { question = i.Question, answer = i.Answer }));
        SetProp(widget, "itemsJson", json, forceNewUndoStep);
    }

    private void AddAccordionItem(LayoutWidget widget)
    {
        var items = GetAccordionItems(widget);
        var n = items.Count + 1;
        items.Add(new AccordionItemDef($"Question {n}?", "Answer."));
        SaveAccordionItems(widget, items, forceNewUndoStep: true);
    }

    private void UpdateAccordionItem(LayoutWidget widget, int index, Func<AccordionItemDef, AccordionItemDef> update)
    {
        var items = GetAccordionItems(widget);
        if (index < 0 || index >= items.Count) return;
        items[index] = update(items[index]);
        SaveAccordionItems(widget, items);
    }

    private void RemoveAccordionItem(LayoutWidget widget, int index)
    {
        var items = GetAccordionItems(widget);
        if (index < 0 || index >= items.Count) return;
        items.RemoveAt(index);
        SaveAccordionItems(widget, items, forceNewUndoStep: true);
    }

