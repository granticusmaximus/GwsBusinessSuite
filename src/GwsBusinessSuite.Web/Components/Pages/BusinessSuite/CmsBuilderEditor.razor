@page "/cms-builder/editor/{PageKey}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using GwsBusinessSuite.Application.CmsBuilder
@inject IReactPageBuilderService ReactPageBuilderService
@inject ILogger<CmsBuilderEditor> Logger
@inject NavigationManager Navigation

<PageTitle>CMS Visual Builder</PageTitle>

<div class="studio-header page-header">
    <div>
        <div class="studio-kicker">Live page studio</div>
        <h1><i class="bi bi-braces-asterisk me-2 text-primary"></i>Visual Builder</h1>
        <p class="mb-1">Shape the managed React page in a live preview workspace with insert, layout, inspect, save, and
            publish controls.</p>
        @if (!string.IsNullOrWhiteSpace(RoutePath))
        {
            <p class="small text-secondary mb-0">Route: <span class="font-monospace">@RoutePath</span></p>
        }
        @if (!string.IsNullOrWhiteSpace(FilePath))
        {
            <p class="small text-secondary mb-0">File: <a href="@BuildFileOpenLink(FilePath)">@FilePath</a></p>
        }
    </div>

        <div class="studio-header-actions">
            <div class="studio-pills">
                <span class="studio-pill">@Elements.Count element@(Elements.Count == 1 ? string.Empty : "s")</span>
                <span class="studio-pill studio-pill-subtle">@GetViewportLabel()</span>
            </div>
        <button class="btn btn-outline-secondary" @onclick="BackToList">Back To Pages</button>
        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@IsBusy">Save</button>
        <button class="btn btn-outline-success" @onclick="PublishAsync" disabled="@IsBusy">Publish Changes</button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(StatusMessage))
{
    <div class="alert alert-info">@StatusMessage</div>
}

    <div class="studio-workspace">
        <aside class="studio-panel studio-panel-left">
            <div class="studio-panel-section">
                <div class="studio-panel-header">
                    <div>
                        <span class="studio-section-eyebrow">Insert</span>
                        <h2>Widgets</h2>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleSidebar">
                        @(SidebarCollapsed ? "Expand" : "Collapse")
                    </button>
                </div>

                @if (!SidebarCollapsed)
            {
                    <div class="studio-widget-grid">
                        @foreach (var elementType in ElementTypes)
                        {
                            <button class="studio-widget-card" draggable="true"
                                    @ondragstart="() => StartDragElementType(elementType)" @onclick="() => AddElement(elementType)">
                                <span class="studio-widget-icon"><i class="@GetElementIconClass(elementType)"></i></span>
                                <span class="studio-widget-copy">
                                    <strong>@GetElementTitle(elementType)</strong>
                                    <small>@GetElementTagline(elementType)</small>
                                </span>
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="studio-panel-section">
                <div class="studio-panel-header">
                    <div>
                        <span class="studio-section-eyebrow">Structure</span>
                        <h2>Layers</h2>
                    </div>
                </div>

                @if (Elements.Count == 0)
                {
                    <div class="studio-empty-card">
                        <p>No layers yet. Add a widget to start composing the page.</p>
                    </div>
            }
            else
            {
                    <div class="studio-layer-list">
                        @foreach (var element in Elements)
                    {
                            <button class="studio-layer-item @(element.Id == SelectedElementId ? "is-active" : string.Empty)"
                                    @onclick="() => SelectElement(element.Id)">
                                <span class="studio-layer-icon"><i
                                    class="@GetElementIconClass(element.ElementType ?? "paragraph")"></i></span>
                                    <span class="studio-layer-copy">
                                        <strong>@GetElementTitle(element.ElementType ?? "paragraph")</strong>
                                        <small>@GetLayerSummary(element)</small>
                                    </span>
                                </button>
                    }
                        </div>
            }
        </div>
            </aside>

            <section class="studio-stage-panel studio-panel" @ondragover:preventDefault="true" @ondrop="DropElementIntoCanvas">
                <div class="studio-stage-header">
                    <div>
                        <span class="studio-section-eyebrow">Preview</span>
                        <h2>Live canvas</h2>
                    </div>

                    <div class="studio-device-switcher">
                        <button class="studio-device-button @(PreviewViewport == "desktop" ? "is-active" : string.Empty)"
                                @onclick='() => SetPreviewViewport("desktop")'>
                            <i class="bi bi-laptop"></i>
                        </button>
                        <button class="studio-device-button @(PreviewViewport == "tablet" ? "is-active" : string.Empty)"
                                @onclick='() => SetPreviewViewport("tablet")'>
                            <i class="bi bi-tablet-landscape"></i>
                        </button>
                        <button class="studio-device-button @(PreviewViewport == "mobile" ? "is-active" : string.Empty)"
                                @onclick='() => SetPreviewViewport("mobile")'>
                            <i class="bi bi-phone"></i>
                        </button>
                    </div>
                </div>

                <div class="studio-stage-shell">
                    <div class="studio-stage-frame @GetViewportClass()">
                        <div class="studio-stage-browser">
                            <span></span><span></span><span></span>
                            <div class="studio-stage-route">@RoutePath</div>
                        </div>

                        <div class="studio-stage-canvas">
                            @if (Elements.Count == 0)
                            {
                                <div class="studio-canvas-empty">
                                    <div class="studio-empty-card studio-empty-card-center">
                                        <h3>Drop blocks into the canvas</h3>
                                        <p>The preview will update immediately as you add or edit managed React elements.</p>
                                    </div>
                                </div>
                            }
                            else
                    {
                                @foreach (var element in Elements)
                                {
                                    <button type="button" class="studio-preview-block @GetPreviewSelectionClass(element.Id)"
                                            @onclick="() => SelectElement(element.Id)">
                                        <div class="studio-preview-badge">@GetElementTitle(element.ElementType ?? "paragraph")</div>

                                        @switch ((element.ElementType ?? "paragraph").ToLowerInvariant())
                                        {
                                            case "heading":
                                                <h2 class="studio-preview-heading @(element.CssClass ?? string.Empty)">@element.Text</h2>
                                                break;
                                            case "button":
                                                <div class="studio-preview-button-wrap">
                                                    <span class="studio-preview-button @(element.CssClass ?? string.Empty)">@element.Text</span>
                                                </div>
                                                break;
                                            case "image":
                                                <div class="studio-preview-image-wrap">
                                                    <img class="studio-preview-image @(element.CssClass ?? string.Empty)"
                                                         src="@GetImageSource(element.Text)" alt="Preview image" />
                                                </div>
                                                break;
                                            case "paragraph":
                                            default:
                                                <p class="studio-preview-paragraph @(element.CssClass ?? string.Empty)">@element.Text</p>
                                                break;
                                        }
                                    </button>
                                }
                            }
                        </div>
                    </div>
                </div>
            </section>

            <aside class="studio-panel studio-panel-right">
                <div class="studio-panel-section">
                    <div class="studio-panel-header">
                        <div>
                            <span class="studio-section-eyebrow">Inspector</span>
                            <h2>Selected element</h2>
                        </div>
                    </div>

                    @if (SelectedElement is null)
                {
                        <div class="studio-empty-card">
                            <p>Select a block in the preview or layers panel to edit its content and placement.</p>
                        </div>
                }
                else
                {
                        <div class="studio-inspector-stack">
                            <div>
                                <label class="form-label small">Element type</label>
                                <select class="form-select" value="@SelectedElement.ElementType"
                                        @onchange="UpdateSelectedElementType">
                                    @foreach (var elementType in ElementTypes)
                                    {
                                        <option value="@elementType">@GetElementTitle(elementType)</option>
                                    }
                                </select>
                            </div>

                            <div>
                                <label class="form-label small">@GetContentLabel(SelectedElement.ElementType)</label>
                                <textarea class="form-control studio-inspector-textarea" value="@SelectedElement.Text"
                                          @oninput="(e) => UpdateElementText(SelectedElement.Id, e.Value?.ToString() ?? string.Empty)"></textarea>
                            </div>

                            <div>
                                <label class="form-label small">CSS class</label>
                                <input class="form-control" value="@SelectedElement.CssClass"
                                       @oninput="(e) => UpdateElementCss(SelectedElement.Id, e.Value?.ToString() ?? string.Empty)" />
                            </div>

                            <div class="studio-action-row">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="MoveSelectedUp"
                                        disabled="@(!CanMoveSelectedUp)">
                                    <i class="bi bi-arrow-up"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="MoveSelectedDown"
                                        disabled="@(!CanMoveSelectedDown)">
                                    <i class="bi bi-arrow-down"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="DuplicateSelected"
                                        disabled="@(SelectedElement is null)">Duplicate</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected"
                                        disabled="@(SelectedElement is null)">Delete</button>
                            </div>
                        </div>
                    }
                </div>

                <div class="studio-panel-section">
                    <div class="studio-panel-header">
                        <div>
                            <span class="studio-section-eyebrow">Publish</span>
                            <h2>Git workflow</h2>
                        </div>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshPublishStatusAsync"
                                disabled="@IsBusy">Refresh</button>
                    </div>

                    <div class="studio-publish-meta">Current branch: <span class="font-monospace">@PublishBranchName</span>
                    </div>
                    <label class="form-label small">Commit message</label>
                    <input class="form-control mb-3" @bind="PublishCommitMessage" placeholder="cms-builder publish updates" />

                    @if (ChangedFiles.Count == 0)
                    {
                        <div class="studio-empty-card">
                            <p>No React app changes are currently staged for a publish commit.</p>
                        </div>
                    }
                    else
                    {
                        <div class="studio-changes-list">
                            @foreach (var changedFile in ChangedFiles)
                            {
                                <div class="studio-change-item"><span class="font-monospace">@changedFile</span></div>
                            }
                        </div>
                    }
                </div>
            </aside>
</div>

@code {
    [Parameter] public string PageKey { get; set; } = string.Empty;

    private static readonly string[] ElementTypes = ["heading", "paragraph", "button", "image"];

    private List<VisualBuilderElement> Elements { get; set; } = new();
    private string DraggingElementType { get; set; } = string.Empty;
    private bool SidebarCollapsed { get; set; }
    private bool IsBusy { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;
    private string RoutePath { get; set; } = string.Empty;
    private string FilePath { get; set; } = string.Empty;
    private string PreviewViewport { get; set; } = "desktop";
    private string PublishCommitMessage { get; set; } = "cms-builder publish updates";
    private string PublishBranchName { get; set; } = "unknown";
    private List<string> ChangedFiles { get; set; } = new();
    private string SelectedElementId { get; set; } = string.Empty;

    private VisualBuilderElement? SelectedElement => Elements.FirstOrDefault(x => x.Id == SelectedElementId);
    private bool CanMoveSelectedUp => GetSelectedElementIndex() > 0;
    private bool CanMoveSelectedDown
    {
        get
        {
            var index = GetSelectedElementIndex();
            return index >= 0 && index < Elements.Count - 1;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadEditorAsync();
    }

    private async Task LoadEditorAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;

        try
        {
            var state = await ReactPageBuilderService.LoadEditorStateAsync(PageKey);
            if (state is null)
            {
                ErrorMessage = $"Page '{PageKey}' was not found in the active React app.";
                return;
            }

            Elements = state.Elements.ToList();
            RoutePath = state.RoutePath;
            FilePath = state.FilePath;
            SelectedElementId = Elements.FirstOrDefault()?.Id ?? string.Empty;
            StatusMessage = $"Loaded visual builder for {state.PageKey}.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[{ExType}] Unable to load visual builder state for page {PageKey}.", ex.GetType().Name, PageKey);
            ErrorMessage = $"Unable to load page editor. [{ex.GetType().Name}] {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }

        // Refresh publish status separately so a git failure never blocks editor load.
        try
        {
            await RefreshPublishStatusAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Unable to load publish status for page {PageKey}.", PageKey);
            PublishBranchName = "unavailable";
        }
    }

    private void ToggleSidebar()
    {
        SidebarCollapsed = !SidebarCollapsed;
    }

    private void StartDragElementType(string elementType)
    {
        DraggingElementType = elementType;
    }

    private void DropElementIntoCanvas(DragEventArgs _)
    {
        if (string.IsNullOrWhiteSpace(DraggingElementType))
        {
            return;
        }

        AddElement(DraggingElementType);
        DraggingElementType = string.Empty;
    }

    private void AddElement(string elementType)
    {
        var element = new VisualBuilderElement
        {
            ElementType = elementType,
            Text = elementType switch
            {
                "heading" => "Heading text",
                "button" => "Click me",
                "image" => "https://via.placeholder.com/1200x630",
                _ => "Paragraph text"
            },
            CssClass = string.Empty
        };

        Elements.Add(element);
        SelectedElementId = element.Id;
    }

    private void RemoveElement(string id)
    {
        var index = Elements.FindIndex(x => x.Id == id);
        if (index >= 0)
        {
            Elements.RemoveAt(index);
            SelectedElementId = Elements.ElementAtOrDefault(Math.Max(0, index - 1))?.Id ?? Elements.FirstOrDefault()?.Id ??
string.Empty;
        }
    }

    private void SelectElement(string id)
    {
        SelectedElementId = id;
    }

    private void UpdateElementText(string id, string value)
    {
        var element = Elements.FirstOrDefault(x => x.Id == id);
        if (element is not null)
        {
            element.Text = value;
        }
    }

    private void UpdateElementCss(string id, string value)
    {
        var element = Elements.FirstOrDefault(x => x.Id == id);
        if (element is not null)
        {
            element.CssClass = value;
        }
    }

    private void UpdateSelectedElementType(ChangeEventArgs args)
    {
        if (SelectedElement is null)
        {
            return;
        }

        var value = args.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(value))
        {
            SelectedElement.ElementType = value;
        }
    }

    private void DeleteSelected()
    {
        if (!string.IsNullOrWhiteSpace(SelectedElementId))
        {
            RemoveElement(SelectedElementId);
        }
    }

    private void DuplicateSelected()
    {
        if (SelectedElement is null)
        {
            return;
        }

        var index = GetSelectedElementIndex();
        if (index < 0)
        {
            return;
        }

        var clone = new VisualBuilderElement
        {
            Id = Guid.NewGuid().ToString("N"),
            ElementType = SelectedElement.ElementType,
            Text = SelectedElement.Text,
            CssClass = SelectedElement.CssClass
        };

        Elements.Insert(index + 1, clone);
        SelectedElementId = clone.Id;
    }

    private void MoveSelectedUp()
    {
        MoveSelected(-1);
    }

    private void MoveSelectedDown()
    {
        MoveSelected(1);
    }

    private void MoveSelected(int direction)
    {
        var index = GetSelectedElementIndex();
        var targetIndex = index + direction;
        if (index < 0 || targetIndex < 0 || targetIndex >= Elements.Count)
        {
            return;
        }

        (Elements[index], Elements[targetIndex]) = (Elements[targetIndex], Elements[index]);
    }

    private int GetSelectedElementIndex()
    {
        if (string.IsNullOrWhiteSpace(SelectedElementId))
        {
            return -1;
        }

        return Elements.FindIndex(element => element.Id == SelectedElementId);
    }

    private async Task SaveAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            var result = await ReactPageBuilderService.SaveAsync(new ReactPageSaveRequest
            {
                PageKey = PageKey,
                Elements = Elements,
                PerformedBy = "cms-builder-ui"
            });

            StatusMessage = result.GitSummary;
            await RefreshPublishStatusAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to save visual builder page {PageKey}.", PageKey);
            ErrorMessage = $"Unable to save changes. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void BackToList()
    {
        Navigation.NavigateTo("/cms-builder");
    }

    private static string BuildFileOpenLink(string filePath)
    {
        return $"vscode://file/{Uri.EscapeDataString(filePath)}";
    }

    private void SetPreviewViewport(string viewport)
    {
        PreviewViewport = viewport;
    }

    private string GetViewportClass()
    {
        return PreviewViewport switch
        {
            "tablet" => "is-tablet",
            "mobile" => "is-mobile",
            _ => "is-desktop"
        };
    }

    private string GetViewportLabel()
    {
        return PreviewViewport switch
        {
            "tablet" => "Tablet preview",
            "mobile" => "Mobile preview",
            _ => "Desktop preview"
        };
    }

    private static string GetElementIconClass(string elementType)
    {
        return elementType.ToLowerInvariant() switch
        {
            "heading" => "bi bi-type-h1",
            "button" => "bi bi-hand-index-thumb",
            "image" => "bi bi-image",
            _ => "bi bi-text-paragraph"
        };
    }

    private static string GetElementTitle(string elementType)
    {
        return elementType.ToLowerInvariant() switch
        {
            "heading" => "Heading",
            "button" => "Button",
            "image" => "Image",
            _ => "Paragraph"
        };
    }

    private static string GetElementTagline(string elementType)
    {
        return elementType.ToLowerInvariant() switch
        {
            "heading" => "Hero titles and section labels",
            "button" => "Primary actions and CTAs",
            "image" => "Product imagery and diagrams",
            _ => "Supporting copy and descriptions"
        };
    }

    private static string GetLayerSummary(VisualBuilderElement element)
    {
        var content = element.Text ?? string.Empty;
        if (content.Length <= 48)
        {
            return content;
        }

        return content[..48] + "...";
    }

    private string GetPreviewSelectionClass(string elementId)
    {
        return elementId == SelectedElementId ? "is-selected" : string.Empty;
    }

    private static string GetContentLabel(string elementType)
    {
        return elementType.ToLowerInvariant() switch
        {
            "image" => "Image URL",
            "button" => "Button label",
            _ => "Content"
        };
    }

    private static string GetImageSource(string? value)
    {
        return string.IsNullOrWhiteSpace(value)
            ? "https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=1200&q=80"
            : value;
    }

    private async Task RefreshPublishStatusAsync()
    {
        var status = await ReactPageBuilderService.GetPublishStatusAsync();
        PublishBranchName = status.CurrentBranch;
        ChangedFiles = status.ChangedFiles;
    }

    private async Task PublishAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        StatusMessage = string.Empty;

        try
        {
            var result = await ReactPageBuilderService.PublishAsync(new ReactPublishRequest
            {
                CommitMessage = PublishCommitMessage,
                IncludeOnlyReactAppChanges = true
            });

            StatusMessage = result.Summary;
            await RefreshPublishStatusAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to publish changes for page {PageKey}.", PageKey);
            ErrorMessage = $"Unable to publish changes. {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }
}
