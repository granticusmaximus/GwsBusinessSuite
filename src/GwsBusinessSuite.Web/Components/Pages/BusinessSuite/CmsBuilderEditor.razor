    private void SelectSection(string sectionId)
    {
        _selectedSectionId = sectionId;
        _selectedWidgetId = string.Empty;
    }

    private void SelectWidget(string sectionId, string widgetId)
    {
        _selectedSectionId = sectionId;
        _selectedWidgetId = widgetId;
