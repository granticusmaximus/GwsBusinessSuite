@page "/admin/canvas/editor/{PageId:guid}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = "ContributorAccess")]
@implements IAsyncDisposable
@using Microsoft.AspNetCore.Authorization
@using GwsBusinessSuite.Application.CmsBuilder
@using GwsBusinessSuite.Domain.Entities
@using System.Text.Json
@inject ICmsBuilderService CmsBuilderService
@inject IMediaLibraryService MediaLibraryService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<CmsBuilderEditor> Logger

<PageTitle>Canvas Studio — @(_page?.Title ?? "Loading…")</PageTitle>

<div class="studio-shell">

@* ── Header ─────────────────────────────────────────────────────────────── *@
<div class="studio-header page-header">
    <div>
        <div class="studio-kicker">Live page studio</div>
        <h1><i class="bi bi-grid-1x2 me-2 text-primary"></i>@(_page?.Title ?? "Canvas Studio")</h1>
        <p class="mb-0">Add sections and widgets, edit their content, and save — changes go live immediately, no rebuild or deploy.</p>
        @if (_site is not null && _page is not null)
        {
            <p class="small text-secondary mb-0 mt-1">Live at: <span class="font-monospace">/@CurrentFullPath</span></p>
        }
    </div>
    <div class="studio-header-actions">
        <div class="studio-pills">
            @if (_page is not null)
            {
                <span class="studio-pill @(_page.Status == CmsPageStatuses.Published ? "" : "studio-pill-subtle")">@(_page.Status == CmsPageStatuses.Published ? "Published" : "Draft")</span>
            }
            <span class="studio-pill">@_layout.Sections.Count section@(_layout.Sections.Count == 1 ? "" : "s")</span>
            <span class="studio-pill studio-pill-subtle">@TotalWidgetCount widget@(TotalWidgetCount == 1 ? "" : "s")</span>
            <span class="studio-pill studio-pill-subtle">@GetViewportLabel()</span>
        </div>
        <div class="studio-device-switcher">
            <button class="studio-device-button" @onclick="Undo" disabled="@(!CanUndo)" title="Undo (Ctrl+Z)">
                <i class="bi bi-arrow-counterclockwise"></i>
            </button>
            <button class="studio-device-button" @onclick="Redo" disabled="@(!CanRedo)" title="Redo (Ctrl+Shift+Z)">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
        <button class="btn btn-outline-secondary" @onclick="BackToList">Back</button>
        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@(_isBusy || _page is null)">
            <i class="bi bi-cloud-check me-1"></i>@(_isBusy ? "Saving…" : "Save")
        </button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger d-flex align-items-start gap-2 mb-3">
        <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
        <div>@_errorMessage</div>
    </div>
}
@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <div class="alert alert-info d-flex align-items-center gap-2 mb-3">
        <i class="bi bi-info-circle-fill flex-shrink-0"></i>
        <div>@_statusMessage</div>
    </div>
}

@if (_isLoading)
{
    <div class="canvas-loading">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-secondary">Loading…</p>
    </div>
}
else if (_page is null)
{
    <div class="canvas-empty-state">
        <div class="canvas-empty-icon"><i class="bi bi-exclamation-triangle"></i></div>
        <h3>Page not found</h3>
        <p>This page may have been deleted. <a href="/admin/pages">Back to Pages</a>.</p>
    </div>
}
else
{
@* ── Workspace ───────────────────────────────────────────────────────────── *@
<div class="studio-workspace">

    @* ── LEFT PANEL ─────────────────────────────────────────────────────── *@
    <aside class="studio-panel studio-panel-left">
        <div class="studio-tab-strip">
            <button class="studio-tab @(_leftTab == "widgets" ? "is-active" : "")" @onclick='() => _leftTab = "widgets"'>
                <i class="bi bi-grid-3x2-gap me-1"></i>Widgets
            </button>
            <button class="studio-tab @(_leftTab == "layers" ? "is-active" : "")" @onclick='() => _leftTab = "layers"'>
                <i class="bi bi-layers me-1"></i>Layers
            </button>
        </div>

        @if (_leftTab == "widgets")
        {
            <div class="studio-panel-section">
                <div class="studio-section-eyebrow mb-2 px-1">Click to add to the selected section</div>
                <div class="studio-widget-grid">
                    @foreach (var wt in WidgetCatalog)
                    {
                        <button class="studio-widget-card" @onclick="() => QuickAddWidget(wt.Type)">
                            <span class="studio-widget-icon"><i class="@wt.Icon"></i></span>
                            <span class="studio-widget-copy">
                                <strong>@wt.Title</strong>
                                <small>@wt.Tagline</small>
                            </span>
                        </button>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="studio-panel-section">
                <button class="btn btn-sm btn-outline-primary w-100 mb-3" @onclick="AddSectionAtEnd">
                    <i class="bi bi-plus-lg me-1"></i>Add Section
                </button>
                @if (_layout.Sections.Count == 0)
                {
                    <div class="studio-empty-card">
                        <p>No sections yet. Click "Add Section" to start building this page.</p>
                    </div>
                }
                else
                {
                    <div class="studio-layer-list">
                        @foreach (var section in _layout.Sections)
                        {
                            var isCollapsed = IsSectionCollapsed(section.Id);
                            <div class="studio-layer-section-group @(_draggedSectionId == section.Id ? "is-dragging" : "")"
                                 draggable="true"
                                 @ondragstart="() => StartDragSection(section)"
                                 @ondragend="EndDragSection"
                                 @ondragover:preventDefault
                                 @ondrop="() => DropSectionOnto(section)">
                                <div class="studio-layer-item studio-layer-section-item @(_selectedSectionId == section.Id && string.IsNullOrEmpty(_selectedWidgetId) ? "is-active" : "")">
                                    <button type="button" class="studio-layer-collapse-toggle" title="@(isCollapsed ? "Expand" : "Collapse")"
                                            @onclick="() => ToggleSectionCollapsed(section.Id)" @onclick:stopPropagation>
                                        <i class="bi @(isCollapsed ? "bi-chevron-right" : "bi-chevron-down")"></i>
                                    </button>
                                    <button type="button" class="studio-layer-item-main" @onclick="() => SelectSection(section.Id)">
                                        <span class="studio-layer-icon studio-layer-icon-sm studio-layer-drag-handle">
                                            <i class="bi bi-grip-vertical"></i>
                                        </span>
                                        <span class="studio-layer-icon"><i class="bi bi-layout-text-window"></i></span>
                                        <span class="studio-layer-copy">
                                            <strong>@(section.Label)</strong>
                                            <small>@GetColumnLayoutLabel(section.ColumnLayout) · @GetSectionWidgetCount(section) widget@(GetSectionWidgetCount(section) == 1 ? "" : "s")</small>
                                        </span>
                                    </button>
                                </div>
                                @if (!isCollapsed)
                                {
                                    @foreach (var col in section.Columns)
                                    {
                                        @foreach (var w in col.Widgets)
                                        {
                                            <button class="studio-layer-item studio-layer-widget-item @(_selectedWidgetId == w.Id ? "is-active" : "") @(_draggedWidgetId == w.Id ? "is-dragging" : "")"
                                                    draggable="true"
                                                    @onclick="() => SelectWidget(section.Id, w.Id)"
                                                    @ondragstart="() => StartDragWidget(w, col)"
                                                    @ondragstart:stopPropagation
                                                    @ondragend="EndDragWidget"
                                                    @ondragover:preventDefault
                                                    @ondrop="() => DropWidgetOnto(section.Id, col, w)"
                                                    @ondrop:stopPropagation>
                                                <span class="studio-layer-icon studio-layer-icon-sm studio-layer-drag-handle">
                                                    <i class="bi bi-grip-vertical"></i>
                                                </span>
                                                <span class="studio-layer-icon studio-layer-icon-sm">
                                                    <i class="@GetWidgetIconClass(w.WidgetType)"></i>
                                                </span>
                                                <span class="studio-layer-copy">
                                                    <strong>@GetWidgetTypeLabel(w.WidgetType)</strong>
                                                    <small>@GetWidgetLayerSummary(w)</small>
                                                </span>
                                            </button>
                                        }
                                    }
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </aside>

    @* ── CENTER — Live Preview ────────────────────────────────────────────── *@
    <section class="studio-stage-panel studio-panel">
        <div class="studio-stage-header">
            <div class="studio-stage-header-left">
                <span class="studio-section-eyebrow">Live Preview</span>
                <span class="studio-stage-url font-monospace">/@CurrentFullPath</span>
            </div>
            <div class="studio-stage-header-right">
                <div class="studio-device-switcher">
                    <button class="studio-device-button @(_previewViewport == "desktop" ? "is-active" : "")"
                            @onclick='() => _previewViewport = "desktop"' title="Desktop">
                        <i class="bi bi-laptop"></i>
                    </button>
                    <button class="studio-device-button @(_previewViewport == "tablet" ? "is-active" : "")"
                            @onclick='() => _previewViewport = "tablet"' title="Tablet">
                        <i class="bi bi-tablet-landscape"></i>
                    </button>
                    <button class="studio-device-button @(_previewViewport == "mobile" ? "is-active" : "")"
                            @onclick='() => _previewViewport = "mobile"' title="Mobile">
                        <i class="bi bi-phone"></i>
                    </button>
                </div>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ReloadPreview" title="Reload preview">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
        </div>

        <div class="studio-stage-shell">
            <div class="studio-stage-frame @GetViewportClass()">
                <div class="studio-stage-browser">
                    <span></span><span></span><span></span>
                    <div class="studio-stage-route">/@CurrentFullPath</div>
                </div>

                <iframe id="cms-builder-iframe" class="studio-live-iframe"
                        src="@BuildIframeUrl()"
                        title="Live preview — @_page.Title"></iframe>
            </div>
        </div>
        <p class="small text-secondary px-2 mb-0">
            <i class="bi bi-info-circle me-1"></i>Preview updates on save or reload — edits here aren't pushed live until you click Save.
        </p>
    </section>

    @* ── RIGHT PANEL — Inspector ──────────────────────────────────────────── *@
    <aside class="studio-panel studio-panel-right">
        <div class="studio-tab-strip">
            <button class="studio-tab is-active" disabled>
                <i class="bi bi-pencil-square me-1"></i>Inspector
            </button>
        </div>

        <div class="studio-panel-section">
            @if (!string.IsNullOrEmpty(_selectedWidgetId))
            {
                @* Widget inspector *@
                var selWidget = FindWidget(_selectedWidgetId);
                @if (selWidget is not null)
                {
                    <div class="studio-inspector-stack">
                        <div class="studio-inspector-header">
                            <span class="studio-widget-icon studio-widget-icon-sm">
                                <i class="@GetWidgetIconClass(selWidget.WidgetType)"></i>
                            </span>
                            <div>
                                <div class="fw-semibold">@GetWidgetTypeLabel(selWidget.WidgetType)</div>
                                <div class="small text-secondary">Widget properties</div>
                            </div>
                        </div>

                        @* ── Per-type inspector fields ─────────────────────── *@
                        @if (selWidget.WidgetType == "hero")
                        {
                            <div>
                                <label class="form-label small fw-semibold">Headline</label>
                                <input class="form-control" value='@GetProp(selWidget, "headline")'
                                       @oninput='(e) => SetProp(selWidget, "headline", e.Value?.ToString() ?? string.Empty)' />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Subline</label>
                                <textarea class="form-control studio-inspector-textarea-sm"
                                          value='@GetProp(selWidget, "subline")'
                                          @oninput='(e) => SetProp(selWidget, "subline", e.Value?.ToString() ?? string.Empty)'></textarea>
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">CTA 1 Label</label>
                                <input class="form-control" value='@GetProp(selWidget, "cta1Label")'
                                       @oninput='(e) => SetProp(selWidget, "cta1Label", e.Value?.ToString() ?? string.Empty)' />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">CTA 1 URL</label>
                                <input class="form-control font-monospace" value='@GetProp(selWidget, "cta1Href", "#")'
                                       @oninput='(e) => SetProp(selWidget, "cta1Href", e.Value?.ToString() ?? "#")' />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">CTA 2 Label</label>
                                <input class="form-control" value='@GetProp(selWidget, "cta2Label")'
                                       @oninput='(e) => SetProp(selWidget, "cta2Label", e.Value?.ToString() ?? string.Empty)' />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">CTA 2 URL</label>
                                <input class="form-control font-monospace" value='@GetProp(selWidget, "cta2Href", "#")'
                                       @oninput='(e) => SetProp(selWidget, "cta2Href", e.Value?.ToString() ?? "#")' />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Alignment</label>
                                <select class="form-select" value='@GetProp(selWidget, "align", "left")'
                                        @onchange='(e) => SetProp(selWidget, "align", e.Value?.ToString() ?? "left")'>
                                    <option value="left">Left</option>
                                    <option value="center">Center</option>
                                </select>
                            </div>
                        }
                        else if (selWidget.WidgetType == "heading")
                        {
                            <div>
                                <label class="form-label small fw-semibold">Text</label>
                                <input class="form-control" value='@GetProp(selWidget, "text")'
                                       @oninput='(e) => SetProp(selWidget, "text", e.Value?.ToString() ?? string.Empty)' />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Level</label>
                                <select class="form-select" value='@GetProp(selWidget, "level", "h2")'
                                        @onchange='(e) => SetProp(selWidget, "level", e.Value?.ToString() ?? "h2")'>
                                    <option value="h1">H1 — Page title</option>
                                    <option value="h2">H2 — Section title</option>
                                    <option value="h3">H3 — Sub-section</option>
                                    <option value="h4">H4 — Card heading</option>
                                </select>
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Alignment</label>
                                <select class="form-select" value='@GetProp(selWidget, "align", "left")'
                                        @onchange='(e) => SetProp(selWidget, "align", e.Value?.ToString() ?? "left")'>
                                    <option value="left">Left</option>
                                    <option value="center">Center</option>
                                    <option value="right">Right</option>
                                </select>
                            </div>
                        }
                        else if (selWidget.WidgetType == "paragraph")
                        {
                            <div>
                                <label class="form-label small fw-semibold">Text</label>
                                <textarea class="form-control studio-inspector-textarea" value='@GetProp(selWidget, "text")'
                                          @oninput='(e) => SetProp(selWidget, "text", e.Value?.ToString() ?? string.Empty)'></textarea>
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Alignment</label>
                                <select class="form-select" value='@GetProp(selWidget, "align", "left")'
                                        @onchange='(e) => SetProp(selWidget, "align", e.Value?.ToString() ?? "left")'>
                                    <option value="left">Left</option>
                                    <option value="center">Center</option>
                                    <option value="right">Right</option>
                                </select>
                            </div>
                        }
                        else if (selWidget.WidgetType == "richtext")
                        {
                            <div>
                                <label class="form-label small fw-semibold">Content (Markdown)</label>
                                <textarea class="form-control studio-inspector-textarea font-monospace" rows="8" value='@GetProp(selWidget, "content")'
                                          @oninput='(e) => SetProp(selWidget, "content", e.Value?.ToString() ?? string.Empty)'
                                          placeholder="**Bold**, *italics*, [links](https://example.com), lists, etc."></textarea>
                                <div class="small text-secondary mt-1">Supports Markdown — the same formatting used in blog posts.</div>
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Preview</label>
                                <div class="studio-richtext-preview">
                                    @((MarkupString)PublicSiteHtmlRenderer.RenderMarkdown(GetProp(selWidget, "content")))
                                </div>
                            </div>
                        }
                        else if (selWidget.WidgetType == "button")
                        {
                            <div>
                                <label class="form-label small fw-semibold">Label</label>
                                <input class="form-control" value='@GetProp(selWidget, "label", "Button")'
                                       @oninput='(e) => SetProp(selWidget, "label", e.Value?.ToString() ?? string.Empty)' />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">URL</label>
                                <input class="form-control font-monospace" value='@GetProp(selWidget, "href", "#")'
                                       @oninput='(e) => SetProp(selWidget, "href", e.Value?.ToString() ?? "#")' />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Style</label>
                                <select class="form-select" value='@GetProp(selWidget, "variant", "primary")'
                                        @onchange='(e) => SetProp(selWidget, "variant", e.Value?.ToString() ?? "primary")'>
                                    <option value="primary">Primary</option>
                                    <option value="secondary">Secondary</option>
                                    <option value="outline-primary">Outline Primary</option>
                                    <option value="outline-secondary">Outline Secondary</option>
                                    <option value="success">Success</option>
                                    <option value="link">Link</option>
                                </select>
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Size</label>
                                <select class="form-select" value='@GetProp(selWidget, "size", "md")'
                                        @onchange='(e) => SetProp(selWidget, "size", e.Value?.ToString() ?? "md")'>
                                    <option value="sm">Small</option>
                                    <option value="md">Medium</option>
                                    <option value="lg">Large</option>
                                </select>
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Alignment</label>
                                <select class="form-select" value='@GetProp(selWidget, "align", "left")'
                                        @onchange='(e) => SetProp(selWidget, "align", e.Value?.ToString() ?? "left")'>
                                    <option value="left">Left</option>
                                    <option value="center">Center</option>
                                    <option value="right">Right</option>
                                </select>
                            </div>
                            <div class="form-check mt-1">
                                <input class="form-check-input" type="checkbox" id="btnNewTab"
                                       checked="@(GetProp(selWidget, "openInNewTab") == "true")"
                                       @onchange='(e) => SetProp(selWidget, "openInNewTab", ((bool)(e.Value ?? false)) ? "true" : "false")' />
                                <label class="form-check-label small" for="btnNewTab">Open in new tab</label>
                            </div>
                        }
                        else if (selWidget.WidgetType == "image")
                        {
                            <div>
                                <label class="form-label small fw-semibold">Image URL</label>
                                <div class="d-flex gap-2">
                                    <input class="form-control font-monospace" value='@GetProp(selWidget, "src")'
                                           @oninput='(e) => SetProp(selWidget, "src", e.Value?.ToString() ?? string.Empty)'
                                           placeholder="https://…" />
                                    <button type="button" class="btn btn-sm btn-outline-secondary flex-shrink-0" @onclick="ToggleMediaPickerAsync">
                                        <i class="bi bi-images"></i>
                                    </button>
                                </div>
                            </div>

                            @if (_showMediaPicker)
                            {
                                <div class="studio-media-picker">
                                    @if (!string.IsNullOrEmpty(_mediaPickerError))
                                    {
                                        <div class="text-danger small mb-2">@_mediaPickerError</div>
                                    }
                                    else if (_mediaAssets.Count == 0)
                                    {
                                        <p class="text-secondary small mb-0">No media uploaded yet. Upload images from Canvas's Media Library panel.</p>
                                    }
                                    else
                                    {
                                        <div class="studio-media-picker-grid">
                                            @foreach (var asset in _mediaAssets)
                                            {
                                                <button type="button" class="studio-media-picker-item" title="@asset.FileName"
                                                        @onclick="() => SelectMediaAsset(selWidget, asset)">
                                                    <img src="@asset.Url" alt="@asset.AltText" />
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            <div>
                                <label class="form-label small fw-semibold">Alt Text</label>
                                <input class="form-control" value='@GetProp(selWidget, "alt")'
                                       @oninput='(e) => SetProp(selWidget, "alt", e.Value?.ToString() ?? string.Empty)' />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Caption</label>
                                <input class="form-control" value='@GetProp(selWidget, "caption")'
                                       @oninput='(e) => SetProp(selWidget, "caption", e.Value?.ToString() ?? string.Empty)' />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Width</label>
                                <select class="form-select" value='@GetProp(selWidget, "width", "full")'
                                        @onchange='(e) => SetProp(selWidget, "width", e.Value?.ToString() ?? "full")'>
                                    <option value="full">Full width</option>
                                    <option value="auto">Auto</option>
                                </select>
                            </div>
                        }
                        else if (selWidget.WidgetType == "card")
                        {
                            <div>
                                <label class="form-label small fw-semibold">Title</label>
                                <input class="form-control" value='@GetProp(selWidget, "title")'
                                       @oninput='(e) => SetProp(selWidget, "title", e.Value?.ToString() ?? string.Empty)' />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Body</label>
                                <textarea class="form-control studio-inspector-textarea" value='@GetProp(selWidget, "body")'
                                          @oninput='(e) => SetProp(selWidget, "body", e.Value?.ToString() ?? string.Empty)'></textarea>
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Image URL</label>
                                <input class="form-control font-monospace" value='@GetProp(selWidget, "imageSrc")'
                                       @oninput='(e) => SetProp(selWidget, "imageSrc", e.Value?.ToString() ?? string.Empty)'
                                       placeholder="https://…" />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Link URL</label>
                                <input class="form-control font-monospace" value='@GetProp(selWidget, "link")'
                                       @oninput='(e) => SetProp(selWidget, "link", e.Value?.ToString() ?? string.Empty)' />
                            </div>
                        }
                        else if (selWidget.WidgetType == "testimonial")
                        {
                            <div>
                                <label class="form-label small fw-semibold">Quote</label>
                                <textarea class="form-control studio-inspector-textarea" value='@GetProp(selWidget, "quote")'
                                          @oninput='(e) => SetProp(selWidget, "quote", e.Value?.ToString() ?? string.Empty)'></textarea>
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Author Name</label>
                                <input class="form-control" value='@GetProp(selWidget, "authorName")'
                                       @oninput='(e) => SetProp(selWidget, "authorName", e.Value?.ToString() ?? string.Empty)' />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Author Role / Company</label>
                                <input class="form-control" value='@GetProp(selWidget, "authorRole")'
                                       @oninput='(e) => SetProp(selWidget, "authorRole", e.Value?.ToString() ?? string.Empty)' />
                            </div>
                        }
                        else if (selWidget.WidgetType == "accordion")
                        {
                            <div>
                                <label class="form-label small fw-semibold d-flex align-items-center justify-content-between">
                                    Items
                                    <button type="button" class="btn btn-xs btn-outline-primary" @onclick="() => AddAccordionItem(selWidget)">
                                        <i class="bi bi-plus-lg"></i> Add item
                                    </button>
                                </label>
                                @{ var accordionItems = GetAccordionItems(selWidget); }
                                @if (accordionItems.Count == 0)
                                {
                                    <p class="small text-secondary mb-0">No items yet — click "Add item" to build this FAQ.</p>
                                }
                                else
                                {
                                    @for (var i = 0; i < accordionItems.Count; i++)
                                    {
                                        var index = i;
                                        var item = accordionItems[index];
                                        <div class="studio-form-field-editor">
                                            <div class="d-flex gap-2 mb-2">
                                                <input class="form-control form-control-sm" placeholder="Question" value="@item.Question"
                                                       @oninput="(e) => UpdateAccordionItem(selWidget, index, i => i with { Question = e.Value?.ToString() ?? string.Empty })" />
                                                <button type="button" class="btn btn-sm btn-outline-danger flex-shrink-0" @onclick="() => RemoveAccordionItem(selWidget, index)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                            <textarea class="form-control form-control-sm" rows="2" placeholder="Answer"
                                                      @oninput="(e) => UpdateAccordionItem(selWidget, index, i => i with { Answer = e.Value?.ToString() ?? string.Empty })">@item.Answer</textarea>
                                        </div>
                                    }
                                }
                            </div>
                        }
                        else if (selWidget.WidgetType == "spacer")
                        {
                            <div>
                                <label class="form-label small fw-semibold">Height (px)</label>
                                <input class="form-control" type="number" min="0" max="400"
                                       value='@GetProp(selWidget, "height", "48")'
                                       @oninput='(e) => SetProp(selWidget, "height", e.Value?.ToString() ?? "48")' />
                            </div>
                        }
                        else if (selWidget.WidgetType == "divider")
                        {
                            <div>
                                <label class="form-label small fw-semibold">Style</label>
                                <select class="form-select" value='@GetProp(selWidget, "style", "solid")'
                                        @onchange='(e) => SetProp(selWidget, "style", e.Value?.ToString() ?? "solid")'>
                                    <option value="solid">Solid</option>
                                    <option value="dashed">Dashed</option>
                                    <option value="dotted">Dotted</option>
                                </select>
                            </div>
                        }
                        else if (selWidget.WidgetType == "html")
                        {
                            <div>
                                <label class="form-label small fw-semibold">HTML Content</label>
                                <textarea class="form-control studio-inspector-textarea font-monospace"
                                          value='@GetProp(selWidget, "content")'
                                          @oninput='(e) => SetProp(selWidget, "content", e.Value?.ToString() ?? string.Empty)'
                                          spellcheck="false"></textarea>
                            </div>
                        }
                        else if (selWidget.WidgetType == "form")
                        {
                            <div>
                                <label class="form-label small fw-semibold">Submit Button Label</label>
                                <input class="form-control" value='@GetProp(selWidget, "submitLabel", "Submit")'
                                       @oninput='(e) => SetProp(selWidget, "submitLabel", e.Value?.ToString() ?? "Submit")' />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold d-flex align-items-center justify-content-between">
                                    Fields
                                    <button type="button" class="btn btn-xs btn-outline-primary" @onclick="() => AddFormField(selWidget)">
                                        <i class="bi bi-plus-lg"></i> Add field
                                    </button>
                                </label>
                                @{ var fields = GetFormFields(selWidget); }
                                @if (fields.Count == 0)
                                {
                                    <p class="small text-secondary mb-0">No fields yet — click "Add field" to build this form.</p>
                                }
                                else
                                {
                                    @for (var i = 0; i < fields.Count; i++)
                                    {
                                        var index = i;
                                        var field = fields[index];
                                        <div class="studio-form-field-editor">
                                            <div class="d-flex gap-2 mb-2">
                                                <input class="form-control form-control-sm" placeholder="Label" value="@field.Label"
                                                       @oninput="(e) => UpdateFormField(selWidget, index, f => f with { Label = e.Value?.ToString() ?? string.Empty })" />
                                                <select class="form-select form-select-sm" style="max-width:9rem"
                                                        @onchange='(e) => UpdateFormField(selWidget, index, f => f with { Type = e.Value?.ToString() ?? "text" })'>
                                                    @foreach (var t in FormFieldTypes)
                                                    {
                                                        <option value="@t" selected="@(field.Type == t)">@t</option>
                                                    }
                                                </select>
                                                <button type="button" class="btn btn-sm btn-outline-danger flex-shrink-0" @onclick="() => RemoveFormField(selWidget, index)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                            @if (field.Type == "select")
                                            {
                                                <input class="form-control form-control-sm mb-2" placeholder="Comma-separated options"
                                                       value="@string.Join(", ", field.Options)"
                                                       @oninput="(e) => UpdateFormField(selWidget, index, f => f with { Options = (e.Value?.ToString() ?? string.Empty).Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).ToList() })" />
                                            }
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="@($"field-required-{selWidget.Id}-{index}")"
                                                       checked="@field.Required"
                                                       @onchange="(e) => UpdateFormField(selWidget, index, f => f with { Required = (bool)(e.Value ?? false) })" />
                                                <label class="form-check-label small" for="@($"field-required-{selWidget.Id}-{index}")">Required</label>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }

                        @* Style — applies uniformly across every widget type, layered on top of the
                           Content fields above and the site's global design tokens (Phase 5). *@
                        <hr class="my-2" />
                        <div class="small text-secondary fw-semibold text-uppercase mb-1" style="letter-spacing:.05em;">Style</div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small fw-semibold d-flex align-items-center justify-content-between">
                                    Text Color
                                    @if (!string.IsNullOrWhiteSpace(selWidget.Style.TextColor))
                                    {
                                        <button type="button" class="btn btn-link btn-xs p-0" @onclick='() => SetStyleTextColor(selWidget, "")'>Reset</button>
                                    }
                                </label>
                                <input type="color" class="form-control form-control-color w-100"
                                       value="@(string.IsNullOrWhiteSpace(selWidget.Style.TextColor) ? "#0f172a" : selWidget.Style.TextColor)"
                                       @oninput="(e) => SetStyleTextColor(selWidget, e.Value?.ToString() ?? string.Empty)" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-semibold d-flex align-items-center justify-content-between">
                                    Background
                                    @if (!string.IsNullOrWhiteSpace(selWidget.Style.BackgroundColor))
                                    {
                                        <button type="button" class="btn btn-link btn-xs p-0" @onclick='() => SetStyleBackgroundColor(selWidget, "")'>Reset</button>
                                    }
                                </label>
                                <input type="color" class="form-control form-control-color w-100"
                                       value="@(string.IsNullOrWhiteSpace(selWidget.Style.BackgroundColor) ? "#ffffff" : selWidget.Style.BackgroundColor)"
                                       @oninput="(e) => SetStyleBackgroundColor(selWidget, e.Value?.ToString() ?? string.Empty)" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-semibold">Padding</label>
                                <select class="form-select form-select-sm" value="@selWidget.Style.Padding"
                                        @onchange='(e) => selWidget.Style.Padding = e.Value?.ToString() ?? "none"'>
                                    <option value="none">None</option>
                                    <option value="sm">Small</option>
                                    <option value="md">Medium</option>
                                    <option value="lg">Large</option>
                                    <option value="xl">Extra Large</option>
                                </select>
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-semibold">Corner Radius</label>
                                <select class="form-select form-select-sm" value="@selWidget.Style.BorderRadius"
                                        @onchange='(e) => selWidget.Style.BorderRadius = e.Value?.ToString() ?? "none"'>
                                    <option value="none">None</option>
                                    <option value="sm">Small</option>
                                    <option value="md">Medium</option>
                                    <option value="lg">Large</option>
                                    <option value="full">Full (pill)</option>
                                </select>
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-semibold">Font Size</label>
                                <select class="form-select form-select-sm" value="@selWidget.Style.FontSize"
                                        @onchange='(e) => selWidget.Style.FontSize = e.Value?.ToString() ?? "default"'>
                                    <option value="default">Default</option>
                                    <option value="sm">Small</option>
                                    <option value="md">Medium</option>
                                    <option value="lg">Large</option>
                                    <option value="xl">Extra Large</option>
                                </select>
                            </div>
                        </div>

                        @* Action row *@
                        <div class="studio-action-row mt-1">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="MoveSelectedWidgetUp"
                                    disabled="@(!CanMoveSelectedWidgetUp)">
                                <i class="bi bi-arrow-up"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="MoveSelectedWidgetDown"
                                    disabled="@(!CanMoveSelectedWidgetDown)">
                                <i class="bi bi-arrow-down"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="DuplicateSelectedWidget">
                                <i class="bi bi-copy me-1"></i>Dup
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelectedWidget">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                }
            }
            else if (!string.IsNullOrEmpty(_selectedSectionId))
            {
                @* Section inspector *@
                var sel = FindSection(_selectedSectionId);
                @if (sel is not null)
                {
                    <div class="studio-inspector-stack">
                        <div class="studio-inspector-header">
                            <span class="studio-widget-icon studio-widget-icon-sm">
                                <i class="bi bi-layout-text-window"></i>
                            </span>
                            <div>
                                <div class="fw-semibold">Section Settings</div>
                                <div class="small text-secondary">@sel.Label</div>
                            </div>
                        </div>
                        <div>
                            <label class="form-label small fw-semibold">Label</label>
                            <input class="form-control" value="@sel.Label"
                                   @oninput="(e) => sel.Label = e.Value?.ToString() ?? sel.Label" />
                        </div>
                        <div>
                            <label class="form-label small fw-semibold">Column Layout</label>
                            <select class="form-select" value="@sel.ColumnLayout"
                                    @onchange="(e) => UpdateSectionColumnLayout(sel, e.Value?.ToString() ?? sel.ColumnLayout)">
                                <option value="full">Full Width</option>
                                <option value="half-half">Two Equal Columns (50/50)</option>
                                <option value="one-third-two-thirds">1/3 + 2/3</option>
                                <option value="two-thirds-one-third">2/3 + 1/3</option>
                                <option value="thirds">Three Equal Columns</option>
                            </select>
                        </div>
                        <div>
                            <label class="form-label small fw-semibold">Background</label>
                            <select class="form-select" @bind="sel.Background">
                                <option value="transparent">Transparent</option>
                                <option value="light">Light</option>
                                <option value="dark">Dark</option>
                                <option value="accent">Accent (Brand Blue)</option>
                            </select>
                        </div>
                        <div>
                            <label class="form-label small fw-semibold">Vertical Padding</label>
                            <select class="form-select" @bind="sel.Padding">
                                <option value="none">None</option>
                                <option value="sm">Small</option>
                                <option value="md">Medium</option>
                                <option value="lg">Large</option>
                                <option value="xl">XL</option>
                            </select>
                        </div>
                        <div class="studio-action-row mt-1">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => MoveSection(_selectedSectionId, -1)"
                                    disabled="@(!CanMoveSectionUp(_selectedSectionId))">
                                <i class="bi bi-arrow-up"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => MoveSection(_selectedSectionId, 1)"
                                    disabled="@(!CanMoveSectionDown(_selectedSectionId))">
                                <i class="bi bi-arrow-down"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => DuplicateSection(_selectedSectionId)">
                                <i class="bi bi-copy me-1"></i>Dup
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSection(_selectedSectionId)">
                                <i class="bi bi-trash me-1"></i>Delete Section
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="studio-empty-card">
                    <p>Click a section header or widget to edit its properties here.</p>
                </div>
            }
        </div>
    </aside>
</div>
}

</div>

@code {
    [Parameter] public Guid PageId { get; set; }

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    // ── Data ──────────────────────────────────────────────────────────────
    private PageLayout _layout = new();

    // ── Undo/redo ─────────────────────────────────────────────────────────
    // In-memory only, capped, lost on page reload - matches the scope of every other
    // page builder's undo stack (not a substitute for CmsPageRevision's persisted history).
    // A capped stack of full-layout JSON snapshots is simple and cheap enough at this
    // page's realistic size that a diff-based structure isn't worth the complexity.
    private const int MaxUndoDepth = 50;
    private readonly List<string> _undoStack = new();
    private readonly List<string> _redoStack = new();
    // Tracks which (widget, prop) a burst of rapid oninput keystrokes is currently editing,
    // so typing a sentence produces one undo step instead of one per character - reset to
    // null by PushUndo() itself, so any discrete action (a button click, a drop) always
    // starts a fresh step regardless of what text field was focused beforehand.
    private string? _lastUndoEditKey;

    private bool CanUndo => _undoStack.Count > 0;
    private bool CanRedo => _redoStack.Count > 0;

    private void PushUndo()
    {
        _undoStack.Add(JsonSerializer.Serialize(_layout, JsonOptions));
        if (_undoStack.Count > MaxUndoDepth) _undoStack.RemoveAt(0);
        _redoStack.Clear();
        _lastUndoEditKey = null;
    }

    [JSInvokable]
    public async Task Undo()
    {
        if (_undoStack.Count == 0) return;
        var snapshot = _undoStack[^1];
        _undoStack.RemoveAt(_undoStack.Count - 1);
        _redoStack.Add(JsonSerializer.Serialize(_layout, JsonOptions));
        _layout = JsonSerializer.Deserialize<PageLayout>(snapshot, JsonOptions) ?? new();
        _lastUndoEditKey = null;
        RestoreSelectionIfStillPresent();
        StateHasChanged();
        await SaveAsync();
    }

    [JSInvokable]
    public async Task Redo()
    {
        if (_redoStack.Count == 0) return;
        var snapshot = _redoStack[^1];
        _redoStack.RemoveAt(_redoStack.Count - 1);
        _undoStack.Add(JsonSerializer.Serialize(_layout, JsonOptions));
        _layout = JsonSerializer.Deserialize<PageLayout>(snapshot, JsonOptions) ?? new();
        _lastUndoEditKey = null;
        RestoreSelectionIfStillPresent();
        StateHasChanged();
        await SaveAsync();
    }

    // Undoing/redoing a text edit shouldn't collapse the Inspector back to "nothing
    // selected" - the whole point is to show the widget with its reverted content. Only
    // fall back to clearing selection when the previously-selected node genuinely no
    // longer exists in the restored layout (e.g. undoing the Add that created it).
    private void RestoreSelectionIfStillPresent()
    {
        if (!string.IsNullOrEmpty(_selectedWidgetId) && FindWidget(_selectedWidgetId) is not null)
        {
            return;
        }
        if (!string.IsNullOrEmpty(_selectedSectionId) && FindSection(_selectedSectionId) is not null)
        {
            _selectedWidgetId = string.Empty;
            return;
        }
        ClearSelection();
    }

    private CmsPage? _page;
    private CmsSite? _site;
    private List<CmsPage> _allPagesInSite = new();
    private bool _isLoading = true;
    private bool _isBusy;
    private string _statusMessage = string.Empty;
    private string _errorMessage = string.Empty;

    // ── Selection ─────────────────────────────────────────────────────────
    private string _selectedSectionId = string.Empty;
    private string _selectedWidgetId = string.Empty;

    // ── UI panels ─────────────────────────────────────────────────────────
    private string _leftTab = "widgets";
    private string _previewViewport = "desktop";
    private long _previewTimestamp = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();

    // ── Computed ──────────────────────────────────────────────────────────
    private int TotalWidgetCount => _layout.Sections
        .SelectMany(s => s.Columns)
        .SelectMany(c => c.Widgets)
        .Count();

    private bool CanMoveSelectedWidgetUp
    {
        get
        {
            if (string.IsNullOrEmpty(_selectedWidgetId)) return false;
            var (_, col) = FindWidgetLocation(_selectedWidgetId);
            if (col is null) return false;
            return col.Widgets.FindIndex(w => w.Id == _selectedWidgetId) > 0;
        }
    }

    private bool CanMoveSelectedWidgetDown
    {
        get
        {
            if (string.IsNullOrEmpty(_selectedWidgetId)) return false;
            var (_, col) = FindWidgetLocation(_selectedWidgetId);
            if (col is null) return false;
            var idx = col.Widgets.FindIndex(w => w.Id == _selectedWidgetId);
            return idx >= 0 && idx < col.Widgets.Count - 1;
        }
    }

    // ── Widget catalog ────────────────────────────────────────────────────
    private record WidgetDef(string Type, string Icon, string Title, string Tagline);

    private static readonly WidgetDef[] WidgetCatalog =
    [
        new("hero",        "bi bi-stars",                  "Hero",        "Full-width headline + CTAs"),
        new("heading",     "bi bi-type-h1",                "Heading",     "H1–H4 title text"),
        new("paragraph",   "bi bi-text-paragraph",         "Paragraph",   "Body copy"),
        new("richtext",    "bi bi-file-richtext",          "Rich Text",   "Markdown: bold, links, lists, etc."),
        new("button",      "bi bi-hand-index-thumb",       "Button",      "CTA or navigation link"),
        new("image",       "bi bi-image",                  "Image",       "Photo or graphic"),
        new("card",        "bi bi-card-heading",           "Card",        "Title + body + optional image"),
        new("testimonial", "bi bi-chat-quote",             "Testimonial", "Quote + author"),
        new("accordion",   "bi bi-list-nested",            "Accordion",   "Collapsible FAQ-style items"),
        new("form",        "bi bi-ui-checks",              "Form",        "Custom fields, posts to submissions"),
        new("spacer",      "bi bi-arrows-expand-vertical", "Spacer",      "Vertical whitespace"),
        new("divider",     "bi bi-dash-lg",                "Divider",     "Horizontal rule"),
        new("html",        "bi bi-code-slash",             "HTML",        "Raw HTML block"),
    ];

    // ── Lifecycle ─────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync() => await LoadAsync();

    // ── Live-preview click-to-select bridge ─────────────────────────────────
    // See wwwroot/js/cms-builder-bridge.js and CmsBlockHtmlRenderer.BuildEditModeScript
    // for the other two-thirds of this - the iframe (rendered with ?edit=1) posts clicks
    // back here via postMessage; this pushes selection changes that originated elsewhere
    // (the Layers tree) back into the iframe so its outline stays in sync.
    private DotNetObjectReference<CmsBuilderEditor>? _bridgeRef;
    private bool _bridgeInitialized;
    private string _lastSyncedSelectionKey = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _page is not null)
        {
            _bridgeRef = DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("gwsCmsBuilderBridge.init", _bridgeRef);
                _bridgeInitialized = true;
            }
            catch (JSDisconnectedException)
            {
                // Circuit tore down before init reached the client - nothing to clean up.
            }
        }

        var currentKey = $"{_selectedSectionId}|{_selectedWidgetId}";
        if (_bridgeInitialized && currentKey != _lastSyncedSelectionKey)
        {
            _lastSyncedSelectionKey = currentKey;
            try
            {
                await JS.InvokeVoidAsync("gwsCmsBuilderBridge.sendToIframe",
                    new { type = "cms:sync-selection", widgetId = _selectedWidgetId });
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }

    [JSInvokable]
    public Task OnIframeReady() => Task.CompletedTask;

    [JSInvokable]
    public Task OnSectionSelectedFromIframe(string sectionId)
    {
        SelectSection(sectionId);
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnWidgetSelectedFromIframe(string sectionId, string widgetId)
    {
        SelectWidget(sectionId, widgetId);
        StateHasChanged();
        return Task.CompletedTask;
    }

    // Fired on blur of a contenteditable element in the canvas (see BuildEditModeScript).
    // _suppressCanvasSync stops SetProp from immediately pushing this same value straight
    // back to the iframe element the user just finished typing in.
    [JSInvokable]
    public Task OnWidgetPropEditedFromIframe(string sectionId, string widgetId, string propKey, string value)
    {
        var widget = FindWidget(widgetId);
        if (widget is null) return Task.CompletedTask;

        _suppressCanvasSync = true;
        try
        {
            SetProp(widget, propKey, value, forceNewUndoStep: true);
        }
        finally
        {
            _suppressCanvasSync = false;
        }

        SelectWidget(sectionId, widgetId);
        StateHasChanged();
        return Task.CompletedTask;
    }

    // Fired once, on mouseup, at the end of a canvas drag (see the 'cms:drop' handler in
    // CmsBlockHtmlRenderer.BuildEditModeScript - the drag itself is tracked entirely inside
    // the iframe's own document, since a mousedown that lands there keeps the browser
    // routing subsequent mousemove/mouseup events to that document for the rest of the
    // gesture regardless of what's stacked on top of the iframe in the parent page).
    // Reorders the widget within/across columns using the same "compute the target index
    // AFTER removing the dragged widget" approach as DropWidgetOnto, then autosaves
    // immediately - per the approved plan, a structural reorder needs the iframe reloaded to
    // reflect the new column/section layout (unlike a text edit, which patches live without
    // a reload), and unlike Save-button edits, a drag-drop shouldn't require a separate
    // explicit Save to take effect, matching WordPress/Elementor's own behavior.
    [JSInvokable]
    public async Task OnCanvasDropAsync(string draggedWidgetId, string targetWidgetId, bool insertAfter)
    {
        if (string.IsNullOrEmpty(draggedWidgetId) || string.IsNullOrEmpty(targetWidgetId) || draggedWidgetId == targetWidgetId)
        {
            return;
        }

        var (_, fromColumn) = FindWidgetLocation(draggedWidgetId);
        var draggedWidget = fromColumn?.Widgets.FirstOrDefault(w => w.Id == draggedWidgetId);
        if (fromColumn is null || draggedWidget is null)
        {
            return;
        }

        var (toSection, toColumn) = FindWidgetLocation(targetWidgetId);
        if (toColumn is null)
        {
            return;
        }

        PushUndo();
        fromColumn.Widgets.Remove(draggedWidget);

        var targetIndex = toColumn.Widgets.FindIndex(w => w.Id == targetWidgetId);
        if (targetIndex < 0)
        {
            toColumn.Widgets.Add(draggedWidget);
        }
        else
        {
            toColumn.Widgets.Insert(insertAfter ? targetIndex + 1 : targetIndex, draggedWidget);
        }

        SelectWidget(toSection?.Id ?? string.Empty, draggedWidget.Id);
        StateHasChanged();
        await SaveAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_bridgeInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("gwsCmsBuilderBridge.dispose");
            }
            catch (JSDisconnectedException)
            {
                // Circuit already gone - nothing left to dispose client-side.
            }
        }
        _bridgeRef?.Dispose();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorMessage = string.Empty;
        try
        {
            _page = await CmsBuilderService.GetPageAsync(PageId);
            if (_page is null)
            {
                return;
            }

            _site = await CmsBuilderService.GetSiteAsync(_page.SiteId);
            _allPagesInSite = (await CmsBuilderService.ListPagesAsync(_page.SiteId)).ToList();
            _layout = ParseLayout(_page.BlocksJson);
            _statusMessage = $"Loaded '{_page.Title}'.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load page {PageId}.", PageId);
            _errorMessage = $"Failed to load page. {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static PageLayout ParseLayout(string blocksJson)
    {
        try
        {
            return JsonSerializer.Deserialize<PageLayout>(
                string.IsNullOrWhiteSpace(blocksJson) ? "{}" : blocksJson, JsonOptions) ?? new PageLayout();
        }
        catch
        {
            return new PageLayout();
        }
    }

    // ── Save ──────────────────────────────────────────────────────────────
    private async Task SaveAsync()
    {
        if (_page is null) return;

        _isBusy = true;
        _errorMessage = string.Empty;
        _statusMessage = string.Empty;
        try
        {
            var editor = new CmsPageEditorModel
            {
                PageId = _page.Id,
                SiteId = _page.SiteId,
                ParentPageId = _page.ParentPageId,
                Title = _page.Title,
                Slug = _page.Slug,
                BlocksJson = JsonSerializer.Serialize(_layout, JsonOptions),
                MetaTitle = _page.MetaTitle,
                MetaDescription = _page.MetaDescription,
                OgImageUrl = _page.OgImageUrl,
                CustomCss = _page.CustomCss,
                Status = _page.Status
            };
            _page = await CmsBuilderService.SavePageAsync(editor);
            _statusMessage = "Saved — live now.";
            ReloadPreview();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save page {PageId}.", PageId);
            _errorMessage = $"Failed to save. {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ReloadPreview() =>
        _previewTimestamp = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();

    private string CurrentFullPath => _page is null ? string.Empty : CmsBuilderService.BuildFullPath(_page, _allPagesInSite);

    private string BuildIframeUrl() =>
        _site is null || _page is null
            ? "about:blank"
            : $"/cms/{_site.Slug}/{CurrentFullPath}?_t={_previewTimestamp}&edit=1";

