@page "/admin/canvas/editor/{PageKey}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = "ContributorAccess")]
@using Microsoft.AspNetCore.Authorization
@using GwsBusinessSuite.Application.CmsBuilder
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@inject IPageLayoutService PageLayoutService
@inject IMediaLibraryService MediaLibraryService
@inject IReactPageBuilderService ReactPageBuilderService
@inject IOptions<CmsBuilderOptions> CmsOptions
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<CmsBuilderEditor> Logger
@implements IAsyncDisposable

<PageTitle>Visual Builder — @PageKey</PageTitle>

<div class="studio-shell">

@* ── Header ─────────────────────────────────────────────────────────────── *@
<div class="studio-header page-header">
    <div>
        <div class="studio-kicker">Live page studio</div>
        <h1><i class="bi bi-grid-1x2 me-2 text-primary"></i>Visual Builder</h1>
        <p class="mb-0">Drag, drop, and configure sections to compose your React page. Saves to a layout JSON alongside your page file.</p>
        @if (!string.IsNullOrWhiteSpace(_routePath))
        {
            <p class="small text-secondary mb-0 mt-1">Route: <span class="font-monospace">@_routePath</span></p>
        }
    </div>
    <div class="studio-header-actions">
        <div class="studio-pills">
            <span class="studio-pill">@_layout.Sections.Count section@(_layout.Sections.Count == 1 ? "" : "s")</span>
            <span class="studio-pill studio-pill-subtle">@TotalWidgetCount widget@(TotalWidgetCount == 1 ? "" : "s")</span>
            <span class="studio-pill studio-pill-subtle">@GetViewportLabel()</span>
        </div>
        <button class="btn btn-outline-secondary" @onclick="BackToList">Back</button>
        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_isBusy">
            <i class="bi bi-floppy me-1"></i>Save Layout
        </button>
        <button class="btn btn-outline-success" @onclick="PublishAsync" disabled="@(_isBusy || _isPublishBusy)">
            <i class="bi bi-cloud-upload me-1"></i>Publish
        </button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger d-flex align-items-start gap-2 mb-3">
        <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
        <div>@_errorMessage</div>
    </div>
}
@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <div class="alert alert-info d-flex align-items-center gap-2 mb-3">
        <i class="bi bi-info-circle-fill flex-shrink-0"></i>
        <div>@_statusMessage</div>
    </div>
}

@* ── Workspace ───────────────────────────────────────────────────────────── *@
<div class="studio-workspace">

    @* ── LEFT PANEL ─────────────────────────────────────────────────────── *@
    <aside class="studio-panel studio-panel-left">
        <div class="studio-tab-strip">
            <button class="studio-tab @(_leftTab == "widgets" ? "is-active" : "")" @onclick='() => _leftTab = "widgets"'>
                <i class="bi bi-grid-3x2-gap me-1"></i>Widgets
            </button>
            <button class="studio-tab @(_leftTab == "layers" ? "is-active" : "")" @onclick='() => _leftTab = "layers"'>
                <i class="bi bi-layers me-1"></i>Layers
            </button>
        </div>

        @if (_leftTab == "widgets")
        {
            <div class="studio-panel-section">
                <div class="studio-section-eyebrow mb-2 px-1">Click to add · Drag onto canvas</div>
                <div class="studio-widget-grid">
                    @foreach (var wt in WidgetCatalog)
                    {
                        <button class="studio-widget-card" draggable="true"
                                @ondragstart="() => StartNewWidgetDrag(wt.Type)"
                                @ondragend="EndDrag"
                                @onclick="() => QuickAddWidget(wt.Type)">
                            <span class="studio-widget-icon"><i class="@wt.Icon"></i></span>
                            <span class="studio-widget-copy">
                                <strong>@wt.Title</strong>
                                <small>@wt.Tagline</small>
                            </span>
                        </button>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="studio-panel-section">
                @if (_layout.Sections.Count == 0)
                {
                    <div class="studio-empty-card">
                        <p>No sections yet. Start adding to the canvas.</p>
                    </div>
                }
                else
                {
                    <div class="studio-layer-list">
                        @foreach (var section in _layout.Sections)
                        {
                            <div class="studio-layer-section-group">
                                <button class="studio-layer-item studio-layer-section-item @(_selectedSectionId == section.Id && string.IsNullOrEmpty(_selectedWidgetId) ? "is-active" : "")"
                                        @onclick="() => SelectSection(section.Id)">
                                    <span class="studio-layer-icon"><i class="bi bi-layout-text-window"></i></span>
                                    <span class="studio-layer-copy">
                                        <strong>@(section.Label)</strong>
                                        <small>@GetColumnLayoutLabel(section.ColumnLayout) · @GetSectionWidgetCount(section) widget@(GetSectionWidgetCount(section) == 1 ? "" : "s")</small>
                                    </span>
                                </button>
                                @foreach (var col in section.Columns)
                                {
                                    @foreach (var w in col.Widgets)
                                    {
                                        <button class="studio-layer-item studio-layer-widget-item @(_selectedWidgetId == w.Id ? "is-active" : "")"
                                                @onclick="() => SelectWidget(section.Id, w.Id)">
                                            <span class="studio-layer-icon studio-layer-icon-sm">
                                                <i class="@GetWidgetIconClass(w.WidgetType)"></i>
                                            </span>
                                            <span class="studio-layer-copy">
                                                <strong>@GetWidgetTypeLabel(w.WidgetType)</strong>
                                                <small>@GetWidgetLayerSummary(w)</small>
                                            </span>
                                        </button>
                                    }
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </aside>

    @* ── CENTER — Live React App ─────────────────────────────────────────── *@
    <section class="studio-stage-panel studio-panel">
        <div class="studio-stage-header">
            <div class="studio-stage-header-left">
                <span class="studio-section-eyebrow">React Frontend</span>
                <span class="studio-stage-url font-monospace">@_reactDevServerUrl@_routePath</span>
            </div>
            <div class="studio-stage-header-right">
                <button class='studio-edit-toggle @(_editModeEnabled ? "is-active" : "")'
                        @onclick='() => { _editModeEnabled = !_editModeEnabled; ReloadPreview(); }'
                        title="@(_editModeEnabled ? "Edit mode on — widgets are clickable" : "Edit mode off")">
                    <i class='bi @(_editModeEnabled ? "bi-pencil-fill" : "bi-eye") me-1'></i>
                    @(_editModeEnabled ? "Editing" : "Viewing")
                </button>
                <div class="studio-device-switcher">
                    <button class="studio-device-button @(_previewViewport == "desktop" ? "is-active" : "")"
                            @onclick='() => _previewViewport = "desktop"' title="Desktop">
                        <i class="bi bi-laptop"></i>
                    </button>
                    <button class="studio-device-button @(_previewViewport == "tablet" ? "is-active" : "")"
                            @onclick='() => _previewViewport = "tablet"' title="Tablet">
                        <i class="bi bi-tablet-landscape"></i>
                    </button>
                    <button class="studio-device-button @(_previewViewport == "mobile" ? "is-active" : "")"
                            @onclick='() => _previewViewport = "mobile"' title="Mobile">
                        <i class="bi bi-phone"></i>
                    </button>
                </div>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ReloadPreview" title="Reload">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
        </div>

        <div class="studio-stage-shell">
            <div class="studio-stage-frame @GetViewportClass()">
                <div class="studio-stage-browser">
                    <span></span><span></span><span></span>
                    <div class="studio-stage-route">@_reactDevServerUrl@_routePath</div>
                </div>

                @if (_isLoading)
                {
                    <div class="canvas-loading">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-3 text-secondary">Loading…</p>
                    </div>
                }
                else if (string.IsNullOrWhiteSpace(_reactDevServerUrl))
                {
                    <div class="canvas-empty-state">
                        <div class="canvas-empty-icon"><i class="bi bi-display"></i></div>
                        <h3>Dev server not configured</h3>
                        <p>Set <code>CmsBuilder:ReactDevServerUrl</code> in <code>appsettings.Development.json</code> to point at your running React app (e.g. <code>http://localhost:5173</code>).</p>
                    </div>
                }
                else
                {
                    <iframe id="cms-builder-iframe"
                            class="studio-live-iframe"
                            src="@BuildIframeUrl()"
                            title="Live React app — @PageKey"></iframe>
                }
            </div>
        </div>
    </section>

    @* ── RIGHT PANEL ─────────────────────────────────────────────────────── *@
    <aside class="studio-panel studio-panel-right">
        <div class="studio-tab-strip">
            <button class="studio-tab @(_rightTab == "inspector" ? "is-active" : "")" @onclick='() => _rightTab = "inspector"'>
                <i class="bi bi-pencil-square me-1"></i>Inspector
            </button>
            <button class="studio-tab @(_rightTab == "publish" ? "is-active" : "")"
                    @onclick='() => { _rightTab = "publish"; _ = RefreshPublishStatusAsync(); }'>
                <i class="bi bi-cloud-upload me-1"></i>Publish
            </button>
        </div>

        @* Inspector tab *@
        @if (_rightTab == "inspector")
        {
            <div class="studio-panel-section">
                @if (!string.IsNullOrEmpty(_selectedWidgetId))
                {
                    @* Widget inspector *@
                    var selWidget = FindWidget(_selectedWidgetId);
                    @if (selWidget is not null)
                    {
                        <div class="studio-inspector-stack">
                            <div class="studio-inspector-header">
                                <span class="studio-widget-icon studio-widget-icon-sm">
                                    <i class="@GetWidgetIconClass(selWidget.WidgetType)"></i>
                                </span>
                                <div>
                                    <div class="fw-semibold">@GetWidgetTypeLabel(selWidget.WidgetType)</div>
                                    <div class="small text-secondary">Widget properties</div>
                                </div>
                            </div>

                            @* ── Per-type inspector fields ─────────────────────── *@
                            @if (selWidget.WidgetType == "hero")
                            {
                                <div>
                                    <label class="form-label small fw-semibold">Headline</label>
                                    <input class="form-control" value='@GetProp(selWidget, "headline")'
                                           @oninput='(e) => SetProp(selWidget, "headline", e.Value?.ToString() ?? string.Empty)' />
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">Subline</label>
                                    <textarea class="form-control studio-inspector-textarea-sm"
                                              value='@GetProp(selWidget, "subline")'
                                              @oninput='(e) => SetProp(selWidget, "subline", e.Value?.ToString() ?? string.Empty)'></textarea>
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">CTA 1 Label</label>
                                    <input class="form-control" value='@GetProp(selWidget, "cta1Label")'
                                           @oninput='(e) => SetProp(selWidget, "cta1Label", e.Value?.ToString() ?? string.Empty)' />
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">CTA 1 URL</label>
                                    <input class="form-control font-monospace" value='@GetProp(selWidget, "cta1Href", "#")'
                                           @oninput='(e) => SetProp(selWidget, "cta1Href", e.Value?.ToString() ?? "#")' />
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">CTA 2 Label</label>
                                    <input class="form-control" value='@GetProp(selWidget, "cta2Label")'
                                           @oninput='(e) => SetProp(selWidget, "cta2Label", e.Value?.ToString() ?? string.Empty)' />
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">CTA 2 URL</label>
                                    <input class="form-control font-monospace" value='@GetProp(selWidget, "cta2Href", "#")'
                                           @oninput='(e) => SetProp(selWidget, "cta2Href", e.Value?.ToString() ?? "#")' />
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">Alignment</label>
                                    <select class="form-select" value='@GetProp(selWidget, "align", "left")'
                                            @onchange='(e) => SetProp(selWidget, "align", e.Value?.ToString() ?? "left")'>
                                        <option value="left">Left</option>
                                        <option value="center">Center</option>
                                    </select>
                                </div>
                            }
                            else if (selWidget.WidgetType == "heading")
                            {
                                <div>
                                    <label class="form-label small fw-semibold">Text</label>
                                    <input class="form-control" value='@GetProp(selWidget, "text")'
                                           @oninput='(e) => SetProp(selWidget, "text", e.Value?.ToString() ?? string.Empty)' />
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">Level</label>
                                    <select class="form-select" value='@GetProp(selWidget, "level", "h2")'
                                            @onchange='(e) => SetProp(selWidget, "level", e.Value?.ToString() ?? "h2")'>
                                        <option value="h1">H1 — Page title</option>
                                        <option value="h2">H2 — Section title</option>
                                        <option value="h3">H3 — Sub-section</option>
                                        <option value="h4">H4 — Card heading</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">Alignment</label>
                                    <select class="form-select" value='@GetProp(selWidget, "align", "left")'
                                            @onchange='(e) => SetProp(selWidget, "align", e.Value?.ToString() ?? "left")'>
                                        <option value="left">Left</option>
                                        <option value="center">Center</option>
                                        <option value="right">Right</option>
                                    </select>
                                </div>
                            }
                            else if (selWidget.WidgetType == "paragraph")
                            {
                                <div>
                                    <label class="form-label small fw-semibold">Text</label>
                                    <textarea class="form-control studio-inspector-textarea" value='@GetProp(selWidget, "text")'
                                              @oninput='(e) => SetProp(selWidget, "text", e.Value?.ToString() ?? string.Empty)'></textarea>
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">Alignment</label>
                                    <select class="form-select" value='@GetProp(selWidget, "align", "left")'
                                            @onchange='(e) => SetProp(selWidget, "align", e.Value?.ToString() ?? "left")'>
                                        <option value="left">Left</option>
                                        <option value="center">Center</option>
                                        <option value="right">Right</option>
                                    </select>
                                </div>
                            }
                            else if (selWidget.WidgetType == "button")
                            {
                                <div>
                                    <label class="form-label small fw-semibold">Label</label>
                                    <input class="form-control" value='@GetProp(selWidget, "label", "Button")'
                                           @oninput='(e) => SetProp(selWidget, "label", e.Value?.ToString() ?? string.Empty)' />
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">URL</label>
                                    <input class="form-control font-monospace" value='@GetProp(selWidget, "href", "#")'
                                           @oninput='(e) => SetProp(selWidget, "href", e.Value?.ToString() ?? "#")' />
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">Style</label>
                                    <select class="form-select" value='@GetProp(selWidget, "variant", "primary")'
                                            @onchange='(e) => SetProp(selWidget, "variant", e.Value?.ToString() ?? "primary")'>
                                        <option value="primary">Primary</option>
                                        <option value="secondary">Secondary</option>
                                        <option value="outline-primary">Outline Primary</option>
                                        <option value="outline-secondary">Outline Secondary</option>
                                        <option value="success">Success</option>
                                        <option value="link">Link</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">Size</label>
                                    <select class="form-select" value='@GetProp(selWidget, "size", "md")'
                                            @onchange='(e) => SetProp(selWidget, "size", e.Value?.ToString() ?? "md")'>
                                        <option value="sm">Small</option>
                                        <option value="md">Medium</option>
                                        <option value="lg">Large</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">Alignment</label>
                                    <select class="form-select" value='@GetProp(selWidget, "align", "left")'
                                            @onchange='(e) => SetProp(selWidget, "align", e.Value?.ToString() ?? "left")'>
                                        <option value="left">Left</option>
                                        <option value="center">Center</option>
                                        <option value="right">Right</option>
                                    </select>
                                </div>
                                <div class="form-check mt-1">
                                    <input class="form-check-input" type="checkbox" id="btnNewTab"
                                           checked="@(GetProp(selWidget, "openInNewTab") == "true")"
                                           @onchange='(e) => SetProp(selWidget, "openInNewTab", ((bool)(e.Value ?? false)) ? "true" : "false")' />
                                    <label class="form-check-label small" for="btnNewTab">Open in new tab</label>
                                </div>
                            }
                            else if (selWidget.WidgetType == "image")
                            {
                                <div>
                                    <label class="form-label small fw-semibold">Image URL</label>
                                    <div class="d-flex gap-2">
                                        <input class="form-control font-monospace" value='@GetProp(selWidget, "src")'
                                               @oninput='(e) => SetProp(selWidget, "src", e.Value?.ToString() ?? string.Empty)'
                                               placeholder="https://…" />
                                        <button type="button" class="btn btn-sm btn-outline-secondary flex-shrink-0" @onclick="ToggleMediaPickerAsync">
                                            <i class="bi bi-images"></i>
                                        </button>
                                    </div>
                                </div>

                                @if (_showMediaPicker)
                                {
                                    <div class="studio-media-picker">
                                        @if (!string.IsNullOrEmpty(_mediaPickerError))
                                        {
                                            <div class="text-danger small mb-2">@_mediaPickerError</div>
                                        }
                                        else if (_mediaAssets.Count == 0)
                                        {
                                            <p class="text-secondary small mb-0">No media uploaded yet. Upload images from Canvas's Media Library panel.</p>
                                        }
                                        else
                                        {
                                            <div class="studio-media-picker-grid">
                                                @foreach (var asset in _mediaAssets)
                                                {
                                                    <button type="button" class="studio-media-picker-item" title="@asset.FileName"
                                                            @onclick="() => SelectMediaAsset(selWidget, asset)">
                                                        <img src="@asset.Url" alt="@asset.AltText" />
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                }

                                <div>
                                    <label class="form-label small fw-semibold">Alt Text</label>
                                    <input class="form-control" value='@GetProp(selWidget, "alt")'
                                           @oninput='(e) => SetProp(selWidget, "alt", e.Value?.ToString() ?? string.Empty)' />
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">Caption</label>
                                    <input class="form-control" value='@GetProp(selWidget, "caption")'
                                           @oninput='(e) => SetProp(selWidget, "caption", e.Value?.ToString() ?? string.Empty)' />
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">Width</label>
                                    <select class="form-select" value='@GetProp(selWidget, "width", "full")'
                                            @onchange='(e) => SetProp(selWidget, "width", e.Value?.ToString() ?? "full")'>
                                        <option value="full">Full width</option>
                                        <option value="auto">Auto</option>
                                    </select>
                                </div>
                            }
                            else if (selWidget.WidgetType == "card")
                            {
                                <div>
                                    <label class="form-label small fw-semibold">Title</label>
                                    <input class="form-control" value='@GetProp(selWidget, "title")'
                                           @oninput='(e) => SetProp(selWidget, "title", e.Value?.ToString() ?? string.Empty)' />
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">Body</label>
                                    <textarea class="form-control studio-inspector-textarea" value='@GetProp(selWidget, "body")'
                                              @oninput='(e) => SetProp(selWidget, "body", e.Value?.ToString() ?? string.Empty)'></textarea>
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">Image URL</label>
                                    <input class="form-control font-monospace" value='@GetProp(selWidget, "imageSrc")'
                                           @oninput='(e) => SetProp(selWidget, "imageSrc", e.Value?.ToString() ?? string.Empty)'
                                           placeholder="https://…" />
                                </div>
                                <div>
                                    <label class="form-label small fw-semibold">Link URL</label>
                                    <input class="form-control font-monospace" value='@GetProp(selWidget, "link")'
                                           @oninput='(e) => SetProp(selWidget, "link", e.Value?.ToString() ?? string.Empty)' />
                                </div>
                            }
                            else if (selWidget.WidgetType == "spacer")
                            {
                                <div>
                                    <label class="form-label small fw-semibold">Height (px)</label>
                                    <input class="form-control" type="number" min="0" max="400"
                                           value='@GetProp(selWidget, "height", "48")'
                                           @oninput='(e) => SetProp(selWidget, "height", e.Value?.ToString() ?? "48")' />
                                </div>
                            }
                            else if (selWidget.WidgetType == "divider")
                            {
                                <div>
                                    <label class="form-label small fw-semibold">Style</label>
                                    <select class="form-select" value='@GetProp(selWidget, "style", "solid")'
                                            @onchange='(e) => SetProp(selWidget, "style", e.Value?.ToString() ?? "solid")'>
                                        <option value="solid">Solid</option>
                                        <option value="dashed">Dashed</option>
                                        <option value="dotted">Dotted</option>
                                    </select>
                                </div>
                            }
                            else if (selWidget.WidgetType == "html")
                            {
                                <div>
                                    <label class="form-label small fw-semibold">HTML Content</label>
                                    <textarea class="form-control studio-inspector-textarea font-monospace"
                                              value='@GetProp(selWidget, "content")'
                                              @oninput='(e) => SetProp(selWidget, "content", e.Value?.ToString() ?? string.Empty)'
                                              spellcheck="false"></textarea>
                                </div>
                            }

                            @* Action row *@
                            <div class="studio-action-row mt-1">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="MoveSelectedWidgetUp"
                                        disabled="@(!CanMoveSelectedWidgetUp)">
                                    <i class="bi bi-arrow-up"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="MoveSelectedWidgetDown"
                                        disabled="@(!CanMoveSelectedWidgetDown)">
                                    <i class="bi bi-arrow-down"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="DuplicateSelectedWidget">
                                    <i class="bi bi-copy me-1"></i>Dup
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelectedWidget">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                }
                else if (!string.IsNullOrEmpty(_selectedSectionId))
                {
                    @* Section inspector *@
                    var sel = FindSection(_selectedSectionId);
                    @if (sel is not null)
                    {
                        <div class="studio-inspector-stack">
                            <div class="studio-inspector-header">
                                <span class="studio-widget-icon studio-widget-icon-sm">
                                    <i class="bi bi-layout-text-window"></i>
                                </span>
                                <div>
                                    <div class="fw-semibold">Section Settings</div>
                                    <div class="small text-secondary">@sel.Label</div>
                                </div>
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Label</label>
                                <input class="form-control" value="@sel.Label"
                                       @oninput="(e) => sel.Label = e.Value?.ToString() ?? sel.Label" />
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Column Layout</label>
                                <select class="form-select" value="@sel.ColumnLayout"
                                        @onchange="(e) => UpdateSectionColumnLayout(sel, e.Value?.ToString() ?? sel.ColumnLayout)">
                                    <option value="full">Full Width</option>
                                    <option value="half-half">Two Equal Columns (50/50)</option>
                                    <option value="one-third-two-thirds">1/3 + 2/3</option>
                                    <option value="two-thirds-one-third">2/3 + 1/3</option>
                                    <option value="thirds">Three Equal Columns</option>
                                </select>
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Background</label>
                                <select class="form-select" @bind="sel.Background">
                                    <option value="transparent">Transparent</option>
                                    <option value="light">Light</option>
                                    <option value="dark">Dark</option>
                                    <option value="accent">Accent (Brand Blue)</option>
                                </select>
                            </div>
                            <div>
                                <label class="form-label small fw-semibold">Vertical Padding</label>
                                <select class="form-select" @bind="sel.Padding">
                                    <option value="none">None</option>
                                    <option value="sm">Small</option>
                                    <option value="md">Medium</option>
                                    <option value="lg">Large</option>
                                    <option value="xl">XL</option>
                                </select>
                            </div>
                            <div class="studio-action-row mt-1">
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSection(_selectedSectionId)">
                                    <i class="bi bi-trash me-1"></i>Delete Section
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="studio-empty-card">
                        <p>Click a section header or widget to edit its properties here.</p>
                    </div>
                }
            </div>
        }

        @* Publish tab *@
        else
        {
            <div class="studio-panel-section">
                <div class="studio-panel-header">
                    <div>
                        <span class="studio-section-eyebrow">Git Workflow</span>
                        <h2>Publish</h2>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshPublishStatusAsync"
                            disabled="@_isPublishBusy">Refresh</button>
                </div>
                <div class="studio-publish-meta">Branch: <span class="font-monospace">@_publishBranchName</span></div>
                <label class="form-label small fw-semibold">Commit message</label>
                <input class="form-control mb-3" @bind="_publishCommitMessage" placeholder="canvas: update layout" />
                @if (_changedFiles.Count == 0)
                {
                    <div class="studio-empty-card">
                        <p>No React app file changes staged for commit.</p>
                    </div>
                }
                else
                {
                    <div class="studio-changes-list mb-3">
                        @foreach (var f in _changedFiles)
                        {
                            <div class="studio-change-item"><span class="font-monospace">@f</span></div>
                        }
                    </div>
                    <button class="btn btn-success w-100" @onclick="PublishAsync"
                            disabled="@(_isBusy || _isPublishBusy)">
                        <i class="bi bi-cloud-upload me-1"></i>Commit &amp; Push
                    </button>
                }
            </div>
        }
    </aside>
</div>

</div>

@code {
    [Parameter] public string PageKey { get; set; } = string.Empty;

    // ── Data ──────────────────────────────────────────────────────────────
    private PageLayout _layout = new();
    private bool _isLoading = true;
    private bool _isBusy;
    private string _statusMessage = string.Empty;
    private string _errorMessage = string.Empty;

    // ── Selection ─────────────────────────────────────────────────────────
    private string _selectedSectionId = string.Empty;
    private string _selectedWidgetId = string.Empty;

    // ── Drag state ────────────────────────────────────────────────────────
    private string _draggingNewWidgetType = string.Empty;
    private string _draggingWidgetId = string.Empty;
    private string _draggingWidgetSectionId = string.Empty;
    private string _draggingWidgetColumnId = string.Empty;
    private string _dragOverSectionId = string.Empty;
    private string _dragOverColumnId = string.Empty;
    private int _dragOverIndex = -1;
    private bool _isDragging;

    // ── UI panels ─────────────────────────────────────────────────────────
    private string _leftTab = "widgets";
    private string _rightTab = "inspector";
    private string _previewViewport = "desktop";

    // ── Live iframe ───────────────────────────────────────────────────────
    private string _reactDevServerUrl = string.Empty;
    private bool _editModeEnabled = true;
    private IJSObjectReference? _jsBridge;
    private DotNetObjectReference<CmsBuilderEditor>? _dotNetRef;
    private bool _bridgeInitialized;

    // ── Publish ───────────────────────────────────────────────────────────
    private string _routePath = string.Empty;
    private long _previewTimestamp = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
    private string _publishCommitMessage = "canvas: update page layout";
    private string _publishBranchName = "unknown";
    private List<string> _changedFiles = new();
    private bool _isPublishBusy;

    // ── Computed ──────────────────────────────────────────────────────────
    private int TotalWidgetCount => _layout.Sections
        .SelectMany(s => s.Columns)
        .SelectMany(c => c.Widgets)
        .Count();

    private bool CanMoveSelectedWidgetUp
    {
        get
        {
            if (string.IsNullOrEmpty(_selectedWidgetId)) return false;
            var (_, col) = FindWidgetLocation(_selectedWidgetId);
            if (col is null) return false;
            return col.Widgets.FindIndex(w => w.Id == _selectedWidgetId) > 0;
        }
    }

    private bool CanMoveSelectedWidgetDown
    {
        get
        {
            if (string.IsNullOrEmpty(_selectedWidgetId)) return false;
            var (_, col) = FindWidgetLocation(_selectedWidgetId);
            if (col is null) return false;
            var idx = col.Widgets.FindIndex(w => w.Id == _selectedWidgetId);
            return idx >= 0 && idx < col.Widgets.Count - 1;
        }
    }

    // ── Widget catalog ────────────────────────────────────────────────────
    private record WidgetDef(string Type, string Icon, string Title, string Tagline);

    private static readonly WidgetDef[] WidgetCatalog =
    [
        new("hero",      "bi bi-stars",                    "Hero",      "Full-width headline + CTAs"),
        new("heading",   "bi bi-type-h1",                  "Heading",   "H1–H4 title text"),
        new("paragraph", "bi bi-text-paragraph",           "Paragraph", "Body copy"),
        new("button",    "bi bi-hand-index-thumb",         "Button",    "CTA or navigation link"),
        new("image",     "bi bi-image",                    "Image",     "Photo or graphic"),
        new("card",      "bi bi-card-heading",             "Card",      "Title + body + optional image"),
        new("spacer",    "bi bi-arrows-expand-vertical",   "Spacer",    "Vertical whitespace"),
        new("divider",   "bi bi-dash-lg",                  "Divider",   "Horizontal rule"),
        new("html",      "bi bi-code-slash",               "HTML",      "Raw HTML block"),
    ];

    // ── Lifecycle ─────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _reactDevServerUrl = (CmsOptions.Value.ReactDevServerUrl ?? string.Empty).TrimEnd('/');
        await LoadAsync();
        try { await RefreshPublishStatusAsync(); }
        catch { _publishBranchName = "unavailable"; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_bridgeInitialized)
        {
            _bridgeInitialized = true;
            try
            {
                _dotNetRef = DotNetObjectReference.Create(this);
                _jsBridge = await JS.InvokeAsync<IJSObjectReference>(
                    "import", "/js/cms-builder-bridge.js");
                await _jsBridge.InvokeVoidAsync("init", _dotNetRef);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "CMS bridge JS init failed — postMessage selection disabled.");
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_jsBridge is not null)
            {
                await _jsBridge.InvokeVoidAsync("dispose");
                await _jsBridge.DisposeAsync();
            }
        }
        catch { /* ignore disposal errors */ }
        _dotNetRef?.Dispose();
    }

    // ── iframe bridge callbacks ────────────────────────────────────────────
    [JSInvokable]
    public void OnWidgetSelectedFromIframe(string sectionId, string widgetId)
    {
        SelectWidget(sectionId, widgetId);
        StateHasChanged();
    }

    [JSInvokable]
    public void OnSectionSelectedFromIframe(string sectionId)
    {
        SelectSection(sectionId);
        StateHasChanged();
    }

    [JSInvokable]
    public void OnIframeReady()
    {
        // iframe signaled edit-mode ready; nothing to do yet
    }

    // ── iframe URL ────────────────────────────────────────────────────────
    private string BuildIframeUrl()
    {
        var base_ = _reactDevServerUrl;
        var path = string.IsNullOrWhiteSpace(_routePath) ? "/" : _routePath;
        var sep = path.Contains('?') ? "&" : "?";
        var editParam = _editModeEnabled ? $"{sep}cms_edit=1" : string.Empty;
        return $"{base_}{path}{editParam}&_t={_previewTimestamp}";
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorMessage = string.Empty;
        try
        {
            _layout = await PageLayoutService.LoadLayoutAsync(PageKey);
            _routePath = _layout.RoutePath;
            _statusMessage = $"Loaded layout for {PageKey}.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load layout for {PageKey}.", PageKey);
            _errorMessage = $"Failed to load layout. {ex.Message}";
            _layout = new PageLayout { PageKey = PageKey };
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Save / Publish ────────────────────────────────────────────────────
    private async Task SaveAsync()
    {
        _isBusy = true;
        _errorMessage = string.Empty;
        _statusMessage = string.Empty;
        try
        {
            await PageLayoutService.SaveLayoutAsync(_layout);
            _statusMessage = $"Layout saved for {PageKey}.";
            try { await RefreshPublishStatusAsync(); } catch { /* non-fatal */ }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save layout for {PageKey}.", PageKey);
            _errorMessage = $"Failed to save layout. {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task PublishAsync()
    {
        _isPublishBusy = true;
        _errorMessage = string.Empty;
        _statusMessage = string.Empty;
        try
        {
            await PageLayoutService.SaveLayoutAsync(_layout);
            var result = await ReactPageBuilderService.PublishAsync(new ReactPublishRequest
            {
                CommitMessage = _publishCommitMessage,
                IncludeOnlyReactAppChanges = true
            });
            _statusMessage = result.Summary;
            await RefreshPublishStatusAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to publish {PageKey}.", PageKey);
            _errorMessage = $"Publish failed. {ex.Message}";
        }
        finally
        {
            _isPublishBusy = false;
        }
    }

    private async Task RefreshPublishStatusAsync()
    {
        var status = await ReactPageBuilderService.GetPublishStatusAsync();
        _publishBranchName = status.CurrentBranch;
        _changedFiles = status.ChangedFiles;
    }

    private void ReloadPreview() =>
        _previewTimestamp = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();

    // ── Selection ─────────────────────────────────────────────────────────
    private void SelectSection(string sectionId)
    {
        _selectedSectionId = sectionId;
        _selectedWidgetId = string.Empty;
        _rightTab = "inspector";
    }

    private void SelectWidget(string sectionId, string widgetId)
    {
        _selectedSectionId = sectionId;
        _selectedWidgetId = widgetId;
        _rightTab = "inspector";
    }

    private void ClearSelection()
    {
        _selectedSectionId = string.Empty;
        _selectedWidgetId = string.Empty;
    }

    // ── Section CRUD ──────────────────────────────────────────────────────
    private void AddSectionAtEnd()
    {
        var section = CreateDefaultSection();
        _layout.Sections.Add(section);
        SelectSection(section.Id);
    }

    private void AddSectionAbove(string sectionId)
    {
        var idx = _layout.Sections.FindIndex(s => s.Id == sectionId);
        if (idx < 0) return;
        var section = CreateDefaultSection();
        _layout.Sections.Insert(idx, section);
        SelectSection(section.Id);
    }

    private void AddSectionBelow(string sectionId)
    {
        var idx = _layout.Sections.FindIndex(s => s.Id == sectionId);
        var section = CreateDefaultSection();
        _layout.Sections.Insert(idx < 0 ? _layout.Sections.Count : idx + 1, section);
        SelectSection(section.Id);
    }

    private void DeleteSection(string sectionId)
    {
        _layout.Sections.RemoveAll(s => s.Id == sectionId);
        if (_selectedSectionId == sectionId) ClearSelection();
    }

    private static LayoutSection CreateDefaultSection()
    {
        var section = new LayoutSection { Label = "Section", ColumnLayout = "full" };
        section.Columns = BuildColumnsForLayout("full");
        return section;
    }

    private static List<LayoutColumn> BuildColumnsForLayout(string layout) => layout switch
    {
        "half-half" => [new LayoutColumn { Span = 6 }, new LayoutColumn { Span = 6 }],
        "one-third-two-thirds" => [new LayoutColumn { Span = 4 }, new LayoutColumn { Span = 8 }],
        "two-thirds-one-third" => [new LayoutColumn { Span = 8 }, new LayoutColumn { Span = 4 }],
        "thirds" => [new LayoutColumn { Span = 4 }, new LayoutColumn { Span = 4 }, new LayoutColumn { Span = 4 }],
        _ => [new LayoutColumn { Span = 12 }]
    };

    private static void UpdateSectionColumnLayout(LayoutSection section, string newLayout)
    {
        if (section.ColumnLayout == newLayout) return;
        var allWidgets = section.Columns.SelectMany(c => c.Widgets).ToList();
        section.ColumnLayout = newLayout;
        section.Columns = BuildColumnsForLayout(newLayout);
        if (section.Columns.Count > 0)
            section.Columns[0].Widgets.AddRange(allWidgets);
    }

    // ── Widget CRUD ───────────────────────────────────────────────────────
    private void QuickAddWidget(string widgetType)
    {
        LayoutSection? targetSection = null;
        if (!string.IsNullOrEmpty(_selectedSectionId))
            targetSection = FindSection(_selectedSectionId);
        targetSection ??= _layout.Sections.LastOrDefault();

        if (targetSection is null)
        {
            targetSection = CreateDefaultSection();
            _layout.Sections.Add(targetSection);
        }

        LayoutColumn? targetColumn = null;
        if (!string.IsNullOrEmpty(_selectedWidgetId))
        {
            var (_, col) = FindWidgetLocation(_selectedWidgetId);
            if (col is not null && targetSection.Columns.Contains(col))
                targetColumn = col;
        }
        targetColumn ??= targetSection.Columns.FirstOrDefault();
        if (targetColumn is null) return;

        var widget = CreateDefaultWidget(widgetType);
        targetColumn.Widgets.Add(widget);
        SelectWidget(targetSection.Id, widget.Id);
    }

    private void MoveWidgetInColumn(string sectionId, string columnId, int index, int direction)
    {
        var col = FindSection(sectionId)?.Columns.FirstOrDefault(c => c.Id == columnId);
        if (col is null) return;
        var target = index + direction;
        if (target < 0 || target >= col.Widgets.Count) return;
        (col.Widgets[index], col.Widgets[target]) = (col.Widgets[target], col.Widgets[index]);
    }

    private void MoveSelectedWidgetUp()
    {
        if (string.IsNullOrEmpty(_selectedWidgetId)) return;
        var (sec, col) = FindWidgetLocation(_selectedWidgetId);
        if (sec is null || col is null) return;
        var idx = col.Widgets.FindIndex(w => w.Id == _selectedWidgetId);
        MoveWidgetInColumn(sec.Id, col.Id, idx, -1);
    }

    private void MoveSelectedWidgetDown()
    {
        if (string.IsNullOrEmpty(_selectedWidgetId)) return;
        var (sec, col) = FindWidgetLocation(_selectedWidgetId);
        if (sec is null || col is null) return;
        var idx = col.Widgets.FindIndex(w => w.Id == _selectedWidgetId);
        MoveWidgetInColumn(sec.Id, col.Id, idx, 1);
    }

    private void DuplicateWidget(string sectionId, string columnId, int index)
    {
        var col = FindSection(sectionId)?.Columns.FirstOrDefault(c => c.Id == columnId);
        if (col is null || index >= col.Widgets.Count) return;
        var orig = col.Widgets[index];
        var clone = new LayoutWidget
        {
            Id = Guid.NewGuid().ToString("N"),
            WidgetType = orig.WidgetType,
            Props = new Dictionary<string, string>(orig.Props)
        };
        col.Widgets.Insert(index + 1, clone);
        SelectWidget(sectionId, clone.Id);
    }

    private void DuplicateSelectedWidget()
    {
        if (string.IsNullOrEmpty(_selectedWidgetId)) return;
        var (sec, col) = FindWidgetLocation(_selectedWidgetId);
        if (sec is null || col is null) return;
        DuplicateWidget(sec.Id, col.Id, col.Widgets.FindIndex(w => w.Id == _selectedWidgetId));
    }

    private void DeleteWidget(string sectionId, string columnId, string widgetId)
    {
        var col = FindSection(sectionId)?.Columns.FirstOrDefault(c => c.Id == columnId);
        col?.Widgets.RemoveAll(w => w.Id == widgetId);
        if (_selectedWidgetId == widgetId) ClearSelection();
    }

    private void DeleteSelectedWidget()
    {
        if (string.IsNullOrEmpty(_selectedWidgetId)) return;
        var (sec, col) = FindWidgetLocation(_selectedWidgetId);
        if (sec is null || col is null) return;
        DeleteWidget(sec.Id, col.Id, _selectedWidgetId);
    }

    // ── Drag-drop ─────────────────────────────────────────────────────────
    private void StartNewWidgetDrag(string widgetType)
    {
        _draggingNewWidgetType = widgetType;
        _draggingWidgetId = string.Empty;
        _isDragging = true;
    }

    private void StartWidgetDrag(string widgetId, string sectionId, string columnId)
    {
        _draggingWidgetId = widgetId;
        _draggingWidgetSectionId = sectionId;
        _draggingWidgetColumnId = columnId;
        _draggingNewWidgetType = string.Empty;
        _isDragging = true;
    }

    private void EndDrag()
    {
        _isDragging = false;
        _draggingNewWidgetType = string.Empty;
        _draggingWidgetId = string.Empty;
        _draggingWidgetSectionId = string.Empty;
        _draggingWidgetColumnId = string.Empty;
        _dragOverSectionId = string.Empty;
        _dragOverColumnId = string.Empty;
        _dragOverIndex = -1;
    }

    private void SetDragOver(string sectionId, string columnId, int index)
    {
        _dragOverSectionId = sectionId;
        _dragOverColumnId = columnId;
        _dragOverIndex = index;
    }

    private bool IsDropZoneActive(string sectionId, string columnId, int index) =>
        _isDragging &&
        _dragOverSectionId == sectionId &&
        _dragOverColumnId == columnId &&
        _dragOverIndex == index;

    private void Drop(string sectionId, string columnId, int insertIndex)
    {
        if (!string.IsNullOrEmpty(_draggingNewWidgetType))
        {
            var col = FindSection(sectionId)?.Columns.FirstOrDefault(c => c.Id == columnId);
            if (col is not null)
            {
                var widget = CreateDefaultWidget(_draggingNewWidgetType);
                col.Widgets.Insert(Math.Clamp(insertIndex, 0, col.Widgets.Count), widget);
                SelectWidget(sectionId, widget.Id);
            }
        }
        else if (!string.IsNullOrEmpty(_draggingWidgetId))
        {
            var srcCol = FindSection(_draggingWidgetSectionId)?.Columns.FirstOrDefault(c => c.Id == _draggingWidgetColumnId);
            var dstCol = FindSection(sectionId)?.Columns.FirstOrDefault(c => c.Id == columnId);
            if (srcCol is null || dstCol is null) { EndDrag(); return; }

            var widget = srcCol.Widgets.FirstOrDefault(w => w.Id == _draggingWidgetId);
            if (widget is null) { EndDrag(); return; }

            srcCol.Widgets.Remove(widget);
            dstCol.Widgets.Insert(Math.Clamp(insertIndex, 0, dstCol.Widgets.Count), widget);
            SelectWidget(sectionId, widget.Id);
        }

        EndDrag();
    }

    // ── Lookup helpers ────────────────────────────────────────────────────
    private LayoutSection? FindSection(string id) =>
        _layout.Sections.FirstOrDefault(s => s.Id == id);

    private LayoutWidget? FindWidget(string widgetId) =>
        _layout.Sections.SelectMany(s => s.Columns).SelectMany(c => c.Widgets)
            .FirstOrDefault(w => w.Id == widgetId);

    private (LayoutSection? Section, LayoutColumn? Column) FindWidgetLocation(string widgetId)
    {
        foreach (var s in _layout.Sections)
            foreach (var c in s.Columns)
                if (c.Widgets.Any(w => w.Id == widgetId))
                    return (s, c);
        return (null, null);
    }

    private static int GetSectionWidgetCount(LayoutSection section) =>
        section.Columns.Sum(c => c.Widgets.Count);

    // ── Prop helpers ──────────────────────────────────────────────────────
    private static string GetProp(LayoutWidget widget, string key, string defaultValue = "") =>
        widget.Props.TryGetValue(key, out var val) ? val : defaultValue;

    private void SetProp(LayoutWidget widget, string key, string value)
    {
        widget.Props[key] = value;
        _ = PushWidgetUpdateAsync(widget);
    }

    // ── Media library picker ────────────────────────────────────────────────
    private bool _showMediaPicker;
    private string _mediaPickerError = string.Empty;
    private List<MediaAssetSummary> _mediaAssets = new();

    private async Task ToggleMediaPickerAsync()
    {
        _showMediaPicker = !_showMediaPicker;
        if (!_showMediaPicker)
        {
            return;
        }

        _mediaPickerError = string.Empty;
        try
        {
            _mediaAssets = (await MediaLibraryService.ListAsync()).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load media library for the widget inspector picker.");
            _mediaPickerError = $"Unable to load media library. {ex.Message}";
        }
    }

    private void SelectMediaAsset(LayoutWidget widget, MediaAssetSummary asset)
    {
        SetProp(widget, "src", asset.Url);
        if (string.IsNullOrWhiteSpace(GetProp(widget, "alt")) && !string.IsNullOrWhiteSpace(asset.AltText))
        {
            SetProp(widget, "alt", asset.AltText);
        }

        _showMediaPicker = false;
    }

    private async Task PushWidgetUpdateAsync(LayoutWidget widget)
    {
        if (_jsBridge is null || !_editModeEnabled) return;
        try
        {
            await _jsBridge.InvokeVoidAsync("sendToIframe", new
            {
                type = "cms:update-props",
                widgetId = widget.Id,
                props = widget.Props
            });
        }
        catch { /* non-fatal: iframe may not be in edit mode */ }
    }

    // ── Widget factory ────────────────────────────────────────────────────
    private static LayoutWidget CreateDefaultWidget(string type) => type switch
    {
        "heading"   => new() { WidgetType = "heading",   Props = new() { ["level"] = "h2", ["text"] = "Heading",                      ["align"] = "left" } },
        "paragraph" => new() { WidgetType = "paragraph", Props = new() { ["text"] = "Your paragraph text here.",                       ["align"] = "left" } },
        "button"    => new() { WidgetType = "button",    Props = new() { ["label"] = "Click me",  ["href"] = "#", ["variant"] = "primary", ["size"] = "md", ["align"] = "left" } },
        "image"     => new() { WidgetType = "image",     Props = new() { ["src"] = "",  ["alt"] = "", ["caption"] = "", ["width"] = "full" } },
        "hero"      => new() { WidgetType = "hero",      Props = new() { ["headline"] = "Your Headline", ["subline"] = "Your supporting description.", ["cta1Label"] = "Get Started", ["cta1Href"] = "#", ["cta2Label"] = "", ["cta2Href"] = "", ["align"] = "left" } },
        "card"      => new() { WidgetType = "card",      Props = new() { ["title"] = "Card Title", ["body"] = "Card description text.", ["imageSrc"] = "", ["link"] = "" } },
        "spacer"    => new() { WidgetType = "spacer",    Props = new() { ["height"] = "48" } },
        "divider"   => new() { WidgetType = "divider",   Props = new() { ["style"] = "solid" } },
        "html"      => new() { WidgetType = "html",      Props = new() { ["content"] = "<p>Custom HTML content here.</p>" } },
        _           => new() { WidgetType = "paragraph", Props = new() { ["text"] = "Content", ["align"] = "left" } }
    };

    // ── CSS helpers ───────────────────────────────────────────────────────
    private string GetViewportClass() => _previewViewport switch
    {
        "tablet" => "is-tablet",
        "mobile" => "is-mobile",
        _ => "is-desktop"
    };

    private string GetViewportLabel() => _previewViewport switch
    {
        "tablet" => "Tablet",
        "mobile" => "Mobile",
        _ => "Desktop"
    };

    private static string GetColumnLayoutLabel(string layout) => layout switch
    {
        "half-half"             => "50/50",
        "one-third-two-thirds"  => "1/3 + 2/3",
        "two-thirds-one-third"  => "2/3 + 1/3",
        "thirds"                => "33/33/33",
        _                       => "Full"
    };

    private static string GetWidgetTypeLabel(string type) => type switch
    {
        "heading"   => "Heading",
        "paragraph" => "Paragraph",
        "button"    => "Button",
        "image"     => "Image",
        "hero"      => "Hero",
        "card"      => "Card",
        "spacer"    => "Spacer",
        "divider"   => "Divider",
        "html"      => "HTML",
        _           => type
    };

    private static string GetWidgetIconClass(string type) => type switch
    {
        "heading"   => "bi bi-type-h1",
        "paragraph" => "bi bi-text-paragraph",
        "button"    => "bi bi-hand-index-thumb",
        "image"     => "bi bi-image",
        "hero"      => "bi bi-stars",
        "card"      => "bi bi-card-heading",
        "spacer"    => "bi bi-arrows-expand-vertical",
        "divider"   => "bi bi-dash-lg",
        "html"      => "bi bi-code-slash",
        _           => "bi bi-square"
    };

    private static string GetWidgetLayerSummary(LayoutWidget w)
    {
        var raw = w.WidgetType switch
        {
            "heading"   => GetPropStatic(w, "text", "Heading"),
            "paragraph" => GetPropStatic(w, "text", ""),
            "button"    => GetPropStatic(w, "label", "Button"),
            "image"     => GetPropStatic(w, "alt", GetPropStatic(w, "src", "Image")),
            "hero"      => GetPropStatic(w, "headline", "Hero"),
            "card"      => GetPropStatic(w, "title", "Card"),
            "spacer"    => $"{GetPropStatic(w, "height", "48")}px",
            "html"      => "Custom HTML",
            _           => w.WidgetType
        };
        return raw.Length <= 38 ? raw : raw[..38] + "…";
    }

    private static string GetPropStatic(LayoutWidget w, string key, string def) =>
        w.Props.TryGetValue(key, out var v) ? v : def;

    private void BackToList() => Navigation.NavigateTo("/admin/canvas");
}
