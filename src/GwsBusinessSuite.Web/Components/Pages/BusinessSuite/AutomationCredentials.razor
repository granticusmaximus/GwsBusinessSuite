@page "/admin/automation/credentials"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "AdminOnly")]
@using GwsBusinessSuite.Application.Automation
@inject IAutomationCredentialService CredentialService
@inject ILogger<AutomationCredentials> Logger

<PageTitle>Automation Credentials</PageTitle>

<div class="page-header d-flex flex-wrap justify-content-between align-items-start gap-3">
    <div><a class="small text-decoration-none" href="/admin/automation"><i class="bi bi-arrow-left me-1"></i>Workflows</a><h1 class="mt-2"><i class="bi bi-key-fill me-2 text-primary"></i>Credentials</h1><p>Protected secrets available to workflow nodes. Stored values are never displayed again.</p></div>
    <button class="btn btn-primary" @onclick="OpenCreate"><i class="bi bi-plus-lg me-1"></i>New credential</button>
</div>

@if (!string.IsNullOrWhiteSpace(_message)) { <div class="alert @(_error ? "alert-danger" : "alert-info")">@_message</div> }

<div class="card border-0 shadow-sm">
    <div class="table-responsive"><table class="table align-middle mb-0"><thead><tr><th>Name</th><th>Type</th><th>Description</th><th>Last used</th><th>Updated</th></tr></thead><tbody>
        @if (_credentials.Count == 0) { <tr><td colspan="5" class="text-center text-secondary py-5">No workflow credentials have been created.</td></tr> }
        @foreach (var credential in _credentials)
        {
            <tr><td><i class="bi bi-shield-lock-fill text-success me-2"></i><strong>@credential.Name</strong></td><td><code>@credential.TypeKey</code></td><td>@(string.IsNullOrWhiteSpace(credential.Description) ? "—" : credential.Description)</td><td>@Format(credential.LastUsedAt)</td><td>@Format(credential.UpdatedAt)</td></tr>
        }
    </tbody></table></div>
</div>

@if (_showCreate)
{
    <div class="modal-backdrop fade show"></div><div class="modal d-block" tabindex="-1" role="dialog" aria-modal="true"><div class="modal-dialog modal-lg"><div class="modal-content">
        <div class="modal-header"><h2 class="modal-title h5">New protected credential</h2><button class="btn-close" @onclick="CloseCreate" aria-label="Close"></button></div>
        <div class="modal-body">
            <div class="alert alert-warning small"><i class="bi bi-shield-lock-fill me-1"></i>The JSON below is encrypted with the app's persisted Data Protection key ring. It will not be shown after saving and never enters workflow or execution JSON.</div>
            <div class="row g-3"><div class="col-md-6"><label class="form-label fw-semibold">Name</label><input class="form-control" @bind="_name" placeholder="Production API headers" /></div><div class="col-md-6"><label class="form-label fw-semibold">Type key</label><input class="form-control" @bind="_typeKey" placeholder="httpHeader" /></div><div class="col-12"><label class="form-label fw-semibold">Description</label><input class="form-control" @bind="_description" /></div><div class="col-12"><label class="form-label fw-semibold">Secret JSON</label><textarea class="form-control font-monospace" rows="9" @bind="_data"></textarea><div class="form-text">HTTP nodes accept <code>{"headers":{"Authorization":"Bearer ..."}}</code>. Webhook triggers accept <code>{"secret":"..."}</code>.</div></div></div>
        </div>
        <div class="modal-footer"><button class="btn btn-outline-secondary" @onclick="CloseCreate">Cancel</button><button class="btn btn-primary" @onclick="Save" disabled="@_busy">Encrypt and save</button></div>
    </div></div></div>
}

@code {
    private List<AutomationCredentialSummary> _credentials = [];
    private bool _showCreate, _busy, _error;
    private string _message = "", _name = "", _typeKey = "httpHeader", _description = "", _data = "{\n  \"headers\": {\n    \"Authorization\": \"Bearer replace-me\"\n  }\n}";
    protected override async Task OnInitializedAsync() => await Load();
    private async Task Load() => _credentials = (await CredentialService.ListAsync()).ToList();
    private void OpenCreate() { _name = ""; _typeKey = "httpHeader"; _description = ""; _data = "{\n  \"headers\": {\n    \"Authorization\": \"Bearer replace-me\"\n  }\n}"; _showCreate = true; }
    private void CloseCreate() => _showCreate = false;
    private async Task Save()
    {
        _busy = true; _message = ""; _error = false;
        try { await CredentialService.SaveAsync(null, _name, _typeKey, _data, _description); await Load(); _showCreate = false; _message = "Credential encrypted and saved."; }
        catch (Exception ex) { Logger.LogError(ex, "Unable to save automation credential."); _message = ex.Message; _error = true; }
        finally { _busy = false; }
    }
    private static string Format(DateTimeOffset? value) => value?.ToLocalTime().ToString("MMM d, yyyy h:mm tt") ?? "Never";
}
