@page "/admin"

<PageTitle>GWS Business Suite</PageTitle>

<div class="page-header">
    <h1>Dashboard</h1>
    <p>Your AI-assisted business operating system.</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="gws-stat-icon bg-primary-subtle text-primary mb-3">
                    <i class="bi bi-file-earmark-text"></i>
                </div>
                <div class="fs-2 fw-bold lh-1 mb-1">0</div>
                <div class="fw-semibold text-dark" style="font-size:.85rem;">Articles</div>
                <div class="text-muted mt-1" style="font-size:.78rem;">Drafts awaiting generation</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="gws-stat-icon bg-success-subtle text-success mb-3">
                    <i class="bi bi-tags-fill"></i>
                </div>
                <div class="fs-2 fw-bold lh-1 mb-1">0</div>
                <div class="fw-semibold text-dark" style="font-size:.85rem;">CJ Ads</div>
                <div class="text-muted mt-1" style="font-size:.78rem;">Partner ads synced</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="gws-stat-icon bg-warning-subtle text-warning mb-3">
                    <i class="bi bi-cloud-upload-fill"></i>
                </div>
                <div class="fs-2 fw-bold lh-1 mb-1">0</div>
                <div class="fw-semibold text-dark" style="font-size:.85rem;">Deployments</div>
                <div class="text-muted mt-1" style="font-size:.78rem;">Tracked apps</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="gws-stat-icon bg-info-subtle text-info mb-3">
                    <i class="bi bi-cpu-fill"></i>
                </div>
                <div class="fs-2 fw-bold lh-1 mb-1">&#x2713;</div>
                <div class="fw-semibold text-dark" style="font-size:.85rem;">Ollama</div>
                <div class="text-muted mt-1" style="font-size:.78rem;">llama3.2 &amp; qwen2.5-coder</div>
            </div>
        </div>
    </div>
</div>

<div class="text-uppercase text-muted fw-semibold mb-3" style="font-size:.65rem; letter-spacing:.1em;">Modules</div>

<div class="row g-3">
    @foreach (var module in Modules)
    {
        <div class="col-md-6 col-xl-4">
            <a class="card border-0 shadow-sm h-100 text-decoration-none gws-module-card" href="@module.Url">
                <div class="card-body d-flex align-items-start gap-3">
                    <div class="gws-module-icon @module.IconClass">
                        <i class="bi @module.Icon"></i>
                    </div>
                    <div>
                        <div class="fw-semibold text-dark mb-1" style="font-size:.9rem;">@module.Title</div>
                        <div class="text-muted" style="font-size:.8rem;">@module.Description</div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

@code {
    private sealed record DashboardModule(string Title, string Description, string Url, string Icon, string IconClass);

    private readonly List<DashboardModule> Modules =
    [
        new("Content Studio", "Generate SEO articles, review drafts, publish live to the blog, and manage affiliate placements.", "/admin/content-studio", "bi-pencil-square", "bg-primary-subtle text-primary"),
        new("CJ Ads Manager", "Review partner ads and choose affiliate links to insert into articles.", "/admin/cj-ads",
"bi-tags-fill", "bg-success-subtle text-success"),
        new("App Registry", "Track all apps, statuses, subdomains, and local ports in one place.", "/admin/app-registry",
"bi-grid-1x2-fill", "bg-info-subtle text-info"),
        new("CRM", "Track leads, contacts, companies, notes, and future client opportunities.", "/admin/crm", "bi-people-fill",
"bg-indigo-subtle text-primary"),
        new("Knowledge Base", "Create internal documentation, wiki pages, and operating procedures.", "/admin/wiki",
"bi-journal-bookmark-fill", "bg-warning-subtle text-warning"),
        new("CMS Builder", "Create WordPress-inspired sites, pages, blocks, templates, and subdomains.", "/admin/cms-builder",
"bi-layout-three-columns", "bg-danger-subtle text-danger"),
        new("Deployments", "Track Docker apps, DigitalOcean droplets, Cloudflare tunnels, and ports.", "/admin/deployments",
"bi-cloud-upload-fill", "bg-info-subtle text-info"),
        new("Ollama Console", "Test local model connectivity and prompt workflows.", "/admin/ollama-console", "bi-cpu-fill",
"bg-secondary-subtle text-secondary"),
        new("User Management", "Create accounts, assign roles, and control portal access.", "/admin/users", "bi-person-fill-gear",
"bg-dark-subtle text-dark"),
    ];
}
