@page "/admin"
@attribute [Authorize(Policy = "PortalAccess")]
@using GwsBusinessSuite.Application.AdminPortal
@using GwsBusinessSuite.Domain.Entities
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IAdminPortalSummaryService SummaryService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Dashboard · GWS Business Suite</PageTitle>

<div class="page-header gws-dashboard-header">
    <div>
        <span class="gws-eyebrow">@DateTimeOffset.Now.ToString("dddd, MMMM d")</span>
        <h1>Good @GreetingPeriod()</h1>
        <p>@DashboardDescription</p>
    </div>
    <div class="gws-dashboard-quick-actions" aria-label="Quick actions">
        <a class="btn btn-primary" href="/admin/article-editor"><i class="bi bi-pencil-square me-1" aria-hidden="true"></i>Manage posts</a>
        <a class="btn btn-outline-secondary" href="/admin/content-studio"><i class="bi bi-magic me-1" aria-hidden="true"></i>Generate draft</a>
    </div>
</div>

<section aria-labelledby="attention-heading" class="mb-5">
    <div class="gws-section-heading">
        <div><span class="gws-eyebrow">Today</span><h2 id="attention-heading">Needs attention</h2></div>
        <span class="text-secondary small">Live operational counts</span>
    </div>
    <div class="row g-3">
        @foreach (var item in AttentionItems)
        {
            <div class="col-sm-6 col-xl-3">
                <a class="card gws-attention-card h-100 text-decoration-none" href="@item.Url">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <span class="gws-stat-icon @item.IconClass"><i class="bi @item.Icon" aria-hidden="true"></i></span>
                            <i class="bi bi-arrow-up-right gws-card-arrow" aria-hidden="true"></i>
                        </div>
                        <div class="gws-attention-count">@item.Count</div>
                        <div class="fw-semibold">@item.Title</div>
                        <div class="text-secondary small mt-1">@item.Description</div>
                    </div>
                </a>
            </div>
        }
    </div>
</section>

<section aria-labelledby="workspace-heading">
    <div class="gws-section-heading">
        <div><span class="gws-eyebrow">Workspace</span><h2 id="workspace-heading">Pick up where you left off</h2></div>
    </div>
    <div class="row g-3">
        @foreach (var module in Modules)
        {
            <div class="col-md-6 col-xl-4">
                <a class="card h-100 text-decoration-none gws-module-card" href="@module.Url">
                    <div class="card-body d-flex align-items-start gap-3">
                        <div class="gws-module-icon @module.IconClass"><i class="bi @module.Icon" aria-hidden="true"></i></div>
                        <div class="min-w-0">
                            <div class="fw-semibold mb-1">@module.Title</div>
                            <div class="text-secondary small">@module.Description</div>
                        </div>
                        <i class="bi bi-chevron-right gws-module-chevron ms-auto" aria-hidden="true"></i>
                    </div>
                </a>
            </div>
        }
    </div>
</section>

@code {
    private int _pendingDrafts;
    private int _pendingComments;
    private int _dueFollowUps;
    private int _unreadAlerts;
    private string _role = string.Empty;

    private IReadOnlyList<AttentionItem> AttentionItems
    {
        get
        {
            var items = new List<AttentionItem>
            {
                new("Drafts to review", "Ready for editorial review", _pendingDrafts, "/admin/content-studio", "bi-file-earmark-check", "bg-primary-subtle text-primary"),
                new("Comments", "Waiting for moderation", _pendingComments, "/admin/comments", "bi-chat-left-text", "bg-info-subtle text-info")
            };

            if (IsAdmin)
            {
                items.Add(new("Follow-ups", "Due or overdue in CRM", _dueFollowUps, "/admin/crm", "bi-calendar2-check", "bg-warning-subtle text-warning"));
                items.Add(new("System alerts", "Unread container alerts", _unreadAlerts, "/admin/docker-health", "bi-heart-pulse", _unreadAlerts > 0 ? "bg-danger-subtle text-danger" : "bg-success-subtle text-success"));
            }

            return items;
        }
    }

    private IReadOnlyList<DashboardModule> Modules
    {
        get
        {
            var modules = new List<DashboardModule>
            {
                new("Publishing", "Write posts, generate drafts, and moderate reader comments.", "/admin/article-editor", "bi-pencil-square", "bg-primary-subtle text-primary")
            };

            if (IsContributorOrAbove)
            {
                modules.Add(new("Site design", "Manage media, pages, menus, and the public-site appearance.", "/admin/pages", "bi-layout-three-columns", "bg-success-subtle text-success"));
                modules.Add(new("Podcasts", "Organize saved shows, episodes, and listening progress.", "/admin/podcasts", "bi-mic-fill", "bg-warning-subtle text-warning"));
            }

            if (IsAdmin)
            {
                modules.Add(new("Relationships", "Manage contacts, follow-ups, comments, and portal users.", "/admin/crm", "bi-people-fill", "bg-info-subtle text-info"));
                modules.Add(new("Intelligence", "Monitor media, community news, and government activity.", "/admin/news-intelligence", "bi-newspaper", "bg-warning-subtle text-warning"));
                modules.Add(new("Affiliate revenue", "Manage CJ campaigns, placement suggestions, and analytics.", "/admin/affiliate-analytics", "bi-graph-up-arrow", "bg-success-subtle text-success"));
                modules.Add(new("Sentinel", "Open your connected workspace for documents, databases, and operational knowledge.", "/admin/sentinel", "bi-journal-bookmark-fill", "bg-secondary-subtle text-secondary"));
                modules.Add(new("Operations", "Review containers, Ollama models, broadcasts, and deployments.", "/admin/docker-health", "bi-box-seam", "bg-danger-subtle text-danger"));
            }

            return modules;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _role = authenticationState.User.FindFirst(ClaimTypes.Role)?.Value ?? string.Empty;

        var summary = await SummaryService.GetAsync(includeAdminMetrics: IsAdmin);
        _pendingDrafts = summary.PendingDrafts;
        _pendingComments = summary.PendingComments;
        _dueFollowUps = summary.DueFollowUps;
        _unreadAlerts = summary.UnreadSystemAlerts;
    }

    private string DashboardDescription => IsAdmin
        ? "Here’s what needs your attention across the business today."
        : "Here’s what needs your attention in your publishing workspace today.";

    private bool IsAdmin => _role == AppRoles.Admin;
    private bool IsContributorOrAbove => _role is AppRoles.Admin or AppRoles.Contributor;

    private static string GreetingPeriod()
    {
        var hour = DateTime.Now.Hour;
        if (hour < 12) return "morning";
        return hour < 18 ? "afternoon" : "evening";
    }

    private sealed record AttentionItem(string Title, string Description, int Count, string Url, string Icon, string IconClass);
    private sealed record DashboardModule(string Title, string Description, string Url, string Icon, string IconClass);
}
