@using GwsBusinessSuite.Application.AdminPortal
@using GwsBusinessSuite.Domain.Entities
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject IAdminPortalSummaryService SummaryService

<nav class="gws-nav" aria-label="Primary">
    <NavLink class="gws-nav-link gws-nav-home" href="admin" Match="NavLinkMatch.All" title="Dashboard">
        <i class="bi bi-grid-1x2-fill" aria-hidden="true"></i>
        <span class="gws-nav-link-copy"><span>Home</span><small>Your work at a glance</small></span>
    </NavLink>

    <details class="gws-nav-group" open="@IsGroupOpen(PublishingPrefixes)">
        <summary><span>Publishing</span><i class="bi bi-chevron-right" aria-hidden="true"></i></summary>
        <div class="gws-nav-group-items">
            <NavLink class="gws-nav-link" href="admin/article-editor" title="All Posts">
                <i class="bi bi-pencil-square" aria-hidden="true"></i>
                <span class="gws-nav-link-copy"><span>Posts</span><small>Write and publish</small></span>
            </NavLink>
            <NavLink class="gws-nav-link" href="admin/content-studio" title="Content Studio">
                <i class="bi bi-magic" aria-hidden="true"></i>
                <span class="gws-nav-link-copy"><span>Content Studio</span><small>AI-assisted drafts</small></span>
                @if (_pendingDraftCount > 0) { <span class="gws-nav-count">@_pendingDraftCount</span> }
            </NavLink>
            <NavLink class="gws-nav-link" href="admin/app-generation" title="AI App Builder">
                <i class="bi bi-stars" aria-hidden="true"></i>
                <span class="gws-nav-link-copy"><span>AI Page Builder</span><small>Draft new site pages</small></span>
            </NavLink>
            @if (IsContributorOrAbove)
            {
                <NavLink class="gws-nav-link" href="admin/media" title="Media Library">
                    <i class="bi bi-images" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Media</span><small>Images for posts and pages</small></span>
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/pages" title="Pages">
                    <i class="bi bi-layout-three-columns" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Pages</span><small>Build and organize pages</small></span>
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/appearance/menus" title="Menus">
                    <i class="bi bi-list" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Menus</span><small>Header and footer navigation</small></span>
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/appearance/customize" title="Appearance">
                    <i class="bi bi-palette" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Appearance</span><small>Brand, fonts and CSS</small></span>
                </NavLink>
            }
        </div>
    </details>

    <details class="gws-nav-group" open="@IsGroupOpen(RelationshipPrefixes)">
        <summary><span>Relationships</span><i class="bi bi-chevron-right" aria-hidden="true"></i></summary>
        <div class="gws-nav-group-items">
            <NavLink class="gws-nav-link" href="admin/comments" title="Comments">
                <i class="bi bi-chat-left-text" aria-hidden="true"></i>
                <span class="gws-nav-link-copy"><span>Comments</span><small>Moderate visitor replies</small></span>
                @if (_pendingCommentCount > 0) { <span class="gws-nav-count">@_pendingCommentCount</span> }
            </NavLink>
            @if (IsAdmin)
            {
                <NavLink class="gws-nav-link" href="admin/crm" title="CRM">
                    <i class="bi bi-people-fill" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>CRM</span><small>Contacts and activity</small></span>
                    @if (_dueFollowUpCount > 0) { <span class="gws-nav-count">@_dueFollowUpCount</span> }
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/users" title="User Management">
                    <i class="bi bi-person-gear" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Users</span><small>Accounts and roles</small></span>
                </NavLink>
            }
        </div>
    </details>

    @if (IsAdmin)
    {
        <details class="gws-nav-group" open="@IsGroupOpen(IntelligencePrefixes)">
            <summary><span>Intelligence</span><i class="bi bi-chevron-right" aria-hidden="true"></i></summary>
            <div class="gws-nav-group-items">
                <NavLink class="gws-nav-link" href="admin/news-intelligence" title="Media Watch">
                    <i class="bi bi-newspaper" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Media Watch</span><small>AI-curated topic feeds</small></span>
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/government-intelligence" title="Civic Watch">
                    <i class="bi bi-building" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Civic Watch</span><small>Community and government</small></span>
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/podcasts" title="Podcast Directory">
                    <i class="bi bi-mic-fill" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Podcasts</span><small>Saved shows and episodes</small></span>
                </NavLink>
            </div>
        </details>

        <details class="gws-nav-group" open="@IsGroupOpen(OperationsPrefixes)">
            <summary><span>Operations</span><i class="bi bi-chevron-right" aria-hidden="true"></i></summary>
            <div class="gws-nav-group-items">
                <NavLink class="gws-nav-link" href="admin/automation" title="Workflow Automation">
                    <i class="bi bi-diagram-3-fill" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Automation</span><small>Build and run workflows</small></span>
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/cj-ads" title="CJ Ads">
                    <i class="bi bi-tags-fill" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>CJ Ads</span><small>Affiliate campaigns</small></span>
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/affiliate-suggestions" title="Affiliate Suggestions">
                    <i class="bi bi-link-45deg" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Suggestions</span><small>AI-matched placements</small></span>
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/affiliate-analytics" title="Affiliate Analytics">
                    <i class="bi bi-graph-up-arrow" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Analytics</span><small>Clicks and commission</small></span>
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/app-generation-queue" title="AI App Queue">
                    <i class="bi bi-inbox-fill" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Approval Queue</span><small>Review generated plans</small></span>
                    @if (_pendingAppGenerationCount > 0) { <span class="gws-nav-count">@_pendingAppGenerationCount</span> }
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/sentinel" title="Sentinel">
                    <i class="bi bi-journal-bookmark-fill" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Sentinel</span><small>Connected workspace</small></span>
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/cms-knowledge" title="Builder Reference">
                    <i class="bi bi-journal-richtext" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Builder Reference</span><small>CMS workflow notes</small></span>
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/live-show" title="Live Show">
                    <i class="bi bi-camera-video-fill" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Live Show</span><small>Broadcast studio</small></span>
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/ollama-console" title="Ollama Console">
                    <i class="bi bi-cpu-fill" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Ollama</span><small>Local model console</small></span>
                </NavLink>
                <NavLink class="gws-nav-link" href="admin/docker-health" title="Docker Management">
                    <i class="bi bi-box-seam" aria-hidden="true"></i>
                    <span class="gws-nav-link-copy"><span>Docker</span><small>Containers and deployment</small></span>
                    @if (_unreadDockerAlertCount > 0) { <span class="gws-nav-count gws-nav-count-danger">@_unreadDockerAlertCount</span> }
                </NavLink>
            </div>
        </details>

        <div class="gws-nav-footer">
            <NavLink class="gws-nav-link" href="admin/settings" title="Settings">
                <i class="bi bi-gear-fill" aria-hidden="true"></i>
                <span class="gws-nav-link-copy"><span>Settings</span><small>Portal preferences</small></span>
            </NavLink>
        </div>
    }
</nav>

@code {
    private static readonly string[] PublishingPrefixes = ["admin/article", "admin/content-studio", "admin/app-generation", "admin/media", "admin/pages", "admin/appearance"];
    private static readonly string[] RelationshipPrefixes = ["admin/comments", "admin/crm", "admin/users"];
    private static readonly string[] IntelligencePrefixes = ["admin/news-intelligence", "admin/government-intelligence", "admin/podcasts"];
    private static readonly string[] OperationsPrefixes = ["admin/automation", "admin/cj-ads", "admin/affiliate", "admin/app-generation-queue", "admin/sentinel", "admin/wiki", "admin/cms-knowledge", "admin/live-show", "admin/ollama", "admin/docker"];

    private string _role = string.Empty;
    private int _pendingCommentCount;
    private int _unreadDockerAlertCount;
    private int _pendingDraftCount;
    private int _dueFollowUpCount;
    private int _pendingAppGenerationCount;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        _role = state.User.FindFirst(ClaimTypes.Role)?.Value ?? string.Empty;
        if (state.User.Identity?.IsAuthenticated != true) return;

        var summary = await SummaryService.GetAsync(IsAdmin);
        _pendingCommentCount = summary.PendingComments;
        _unreadDockerAlertCount = summary.UnreadSystemAlerts;
        _pendingDraftCount = summary.PendingDrafts;
        _dueFollowUpCount = summary.DueFollowUps;
        _pendingAppGenerationCount = summary.PendingAppApprovals;
    }

    private bool IsGroupOpen(IEnumerable<string> prefixes)
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri);
        return prefixes.Any(prefix => path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsAdmin => _role == AppRoles.Admin;
    private bool IsContributorOrAbove => _role is AppRoles.Admin or AppRoles.Contributor;
}
