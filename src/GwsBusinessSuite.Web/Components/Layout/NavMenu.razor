@using GwsBusinessSuite.Application.Comments
@using GwsBusinessSuite.Application.DockerHealth
@using GwsBusinessSuite.Domain.Entities
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject AuthenticationStateProvider AuthProvider
@inject ICommentService CommentService
@inject IDockerHealthService DockerHealthService

<nav class="gws-nav">
    @if (IsAdmin)
    {
        <NavLink class="gws-nav-link" href="admin" Match="NavLinkMatch.All">
            <i class="bi bi-speedometer2"></i>
            <span class="gws-nav-link-copy">
                <span>Dashboard</span>
                <small>Suite overview</small>
            </span>
        </NavLink>
    }

    <div class="gws-nav-section">Posts</div>

    <NavLink class="gws-nav-link" href="admin/article-editor">
        <i class="bi bi-pencil"></i>
        <span class="gws-nav-link-copy">
            <span>All Posts</span>
            <small>Write &amp; publish</small>
        </span>
    </NavLink>

    <NavLink class="gws-nav-link" href="admin/content-studio">
        <i class="bi bi-magic"></i>
        <span class="gws-nav-link-copy">
            <span>Generate with AI</span>
            <small>Ollama-assisted drafts</small>
        </span>
    </NavLink>

    @if (IsContributorOrAbove)
    {
        <div class="gws-nav-section">Media</div>

        <NavLink class="gws-nav-link" href="admin/media">
            <i class="bi bi-images"></i>
            <span class="gws-nav-link-copy">
                <span>Media Library</span>
                <small>Images for posts &amp; pages</small>
            </span>
        </NavLink>

        <div class="gws-nav-section">Pages</div>

        <NavLink class="gws-nav-link" href="admin/pages">
            <i class="bi bi-layout-three-columns"></i>
            <span class="gws-nav-link-copy">
                <span>Pages</span>
                <small>Create &amp; edit site pages</small>
            </span>
        </NavLink>

        <div class="gws-nav-section">Appearance</div>

        <NavLink class="gws-nav-link" href="admin/appearance/menus">
            <i class="bi bi-list"></i>
            <span class="gws-nav-link-copy">
                <span>Menus</span>
                <small>Header &amp; footer navigation</small>
            </span>
        </NavLink>

        <NavLink class="gws-nav-link" href="admin/appearance/customize">
            <i class="bi bi-palette"></i>
            <span class="gws-nav-link-copy">
                <span>Customize</span>
                <small>Accent color, fonts &amp; CSS</small>
            </span>
        </NavLink>
    }

    <div class="gws-nav-section">Comments</div>

    <NavLink class="gws-nav-link" href="admin/comments">
        <i class="bi bi-chat-left-text"></i>
        <span class="gws-nav-link-copy">
            <span>Comments@(_pendingCommentCount > 0 ? $" ({_pendingCommentCount})" : "")</span>
            <small>Moderate visitor comments</small>
        </span>
    </NavLink>

    @if (IsAdmin)
    {
        <div class="gws-nav-section">Users</div>

        <NavLink class="gws-nav-link" href="admin/users">
            <i class="bi bi-people-fill"></i>
            <span class="gws-nav-link-copy">
                <span>User Management</span>
                <small>Accounts &amp; roles</small>
            </span>
        </NavLink>

        <div class="gws-nav-section">Tools</div>

        <NavLink class="gws-nav-link" href="admin/cj-ads">
            <i class="bi bi-tags-fill"></i>
            <span class="gws-nav-link-copy">
                <span>CJ Ads</span>
                <small>Affiliate campaigns</small>
            </span>
        </NavLink>

        <NavLink class="gws-nav-link" href="admin/crm">
            <i class="bi bi-people-fill"></i>
            <span class="gws-nav-link-copy">
                <span>CRM</span>
                <small>Contacts and activity</small>
            </span>
        </NavLink>

        <NavLink class="gws-nav-link" href="admin/wiki">
            <i class="bi bi-journal-bookmark-fill"></i>
            <span class="gws-nav-link-copy">
                <span>Knowledge Base</span>
                <small>Operational reference</small>
            </span>
        </NavLink>

        <NavLink class="gws-nav-link" href="admin/live-show">
            <i class="bi bi-camera-video-fill"></i>
            <span class="gws-nav-link-copy">
                <span>Live Show</span>
                <small>Camera broadcast studio</small>
            </span>
        </NavLink>

        <NavLink class="gws-nav-link" href="admin/news-intelligence">
            <i class="bi bi-newspaper"></i>
            <span class="gws-nav-link-copy">
                <span>News Intelligence</span>
                <small>AI-curated topic feeds</small>
            </span>
        </NavLink>

        <NavLink class="gws-nav-link" href="admin/ollama-console">
            <i class="bi bi-cpu-fill"></i>
            <span class="gws-nav-link-copy">
                <span>Ollama Console</span>
                <small>Local model console</small>
            </span>
        </NavLink>

        <NavLink class="gws-nav-link" href="admin/docker-health">
            <i class="bi bi-box-seam"></i>
            <span class="gws-nav-link-copy">
                <span>Docker Health@(_unreadDockerAlertCount > 0 ? $" ({_unreadDockerAlertCount})" : "")</span>
                <small>Container status &amp; alerts</small>
            </span>
        </NavLink>

        <div class="gws-nav-section">Settings</div>

        <NavLink class="gws-nav-link" href="admin/settings">
            <i class="bi bi-gear-fill"></i>
            <span class="gws-nav-link-copy">
                <span>General</span>
                <small>Site, reading, writing, media &amp; AI</small>
            </span>
        </NavLink>
    }
</nav>

@code {
    private string _role = string.Empty;
    private int _pendingCommentCount;
    private int _unreadDockerAlertCount;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        _role = state.User.FindFirst(ClaimTypes.Role)?.Value ?? string.Empty;

        if (state.User.Identity?.IsAuthenticated == true)
        {
            _pendingCommentCount = await CommentService.CountPendingAsync();
            _unreadDockerAlertCount = await DockerHealthService.CountUnreadAlertsAsync();
        }
    }

    private bool IsAdmin              => _role == AppRoles.Admin;
    private bool IsContributorOrAbove => _role is AppRoles.Admin or AppRoles.Contributor;
}
