@inherits LayoutComponentBase
@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized>
        <div class="gws-layout @(IsBuilderRoute ? "gws-builder-mode" : "")">
            @if (!IsBuilderRoute)
            {
                <aside class="gws-sidebar">
                    <NavMenu />
                </aside>
            }

            <div class="gws-body">
                @if (!IsBuilderRoute)
                {
                    <header class="gws-topbar">
                        <div class="gws-topbar-left">
                            <button class="gws-sidebar-toggle" type="button" title="Collapse sidebar">
                                <i class="bi bi-layout-sidebar-inset"></i>
                            </button>
                            <div>
                                <div class="gws-topbar-kicker">Engineering workspace</div>
                                <div class="gws-topbar-title">GWS Business Suite</div>
                            </div>
                        </div>

                        <div class="gws-topbar-actions">
                            <span class="gws-topbar-pill">
                                <i class="bi bi-circle-fill"></i>
                                Local build
                            </span>
                            <span class="gws-topbar-pill gws-topbar-pill-subtle">Blazor + React</span>
                            <a class="gws-topbar-button" href="/auth/logout">Sign Out</a>
                        </div>
                    </header>
                }

                <main class="gws-content @(IsBuilderRoute ? "gws-content-builder" : "")">
                    @Body
                </main>
            </div>
        </div>
    </Authorized>

    <NotAuthorized>
        <main class="gws-login-shell-full">
            @Body
        </main>
    </NotAuthorized>
</AuthorizeView>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="fw-semibold">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private bool IsBuilderRoute =>
        Navigation.ToBaseRelativePath(Navigation.Uri).StartsWith("admin/canvas", StringComparison.OrdinalIgnoreCase);
}
