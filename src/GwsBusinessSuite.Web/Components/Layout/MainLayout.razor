@inherits LayoutComponentBase
@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized Context="authState">
        <div class="gws-layout @(IsBuilderRoute ? "gws-builder-mode" : "")">
            @if (!IsBuilderRoute)
            {
                <header class="gws-admin-bar">
                    <div class="gws-admin-bar-brand">
                        <img src="favicon.svg" alt="" class="gws-admin-bar-icon" />
                        <span>GWS Business Suite</span>
                    </div>
                    <div class="gws-admin-bar-actions">
                        <NotificationBell @rendermode="InteractiveServer" />
                        <span class="gws-admin-bar-user">
                            <i class="bi bi-person-circle"></i>
                            @authState.User.Identity?.Name
                        </span>
                        <a class="gws-admin-bar-link" href="/auth/logout">Sign Out</a>
                    </div>
                </header>
            }

            <div class="gws-layout-body">
                @if (!IsBuilderRoute)
                {
                    <aside class="gws-sidebar">
                        <NavMenu />
                    </aside>
                }

                <div class="gws-body">
                    <main class="gws-content @(IsBuilderRoute ? "gws-content-builder" : "")">
                        @Body
                    </main>
                </div>
            </div>
        </div>
    </Authorized>

    <NotAuthorized>
        <main class="gws-login-shell-full">
            @Body
        </main>
    </NotAuthorized>
</AuthorizeView>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="fw-semibold">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private bool IsBuilderRoute =>
        Navigation.ToBaseRelativePath(Navigation.Uri).StartsWith("admin/canvas", StringComparison.OrdinalIgnoreCase);
}
