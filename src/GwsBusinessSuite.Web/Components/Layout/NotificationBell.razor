@using GwsBusinessSuite.Application.DockerHealth
@implements IDisposable
@inject IDockerHealthService DockerHealthService
@inject DockerHealthNotifier Notifier
@inject NavigationManager Navigation

<div class="notif-bell-wrap">
    <button type="button" class="notif-bell-btn" @onclick="ToggleOpen" title="Notifications"
            aria-label="Notifications" aria-expanded="@IsOpen">
        <i class="bi bi-bell-fill" aria-hidden="true"></i>
        @if (UnreadCount > 0)
        {
            <span class="notif-bell-badge">@(UnreadCount > 9 ? "9+" : UnreadCount.ToString())</span>
        }
    </button>

    @if (IsOpen)
    {
        <div class="notif-bell-panel">
            <div class="notif-bell-panel-header">
                <span>Notifications</span>
                @if (UnreadCount > 0)
                {
                    <button type="button" class="notif-bell-mark-all" @onclick="MarkAllReadAsync">Mark all as read</button>
                }
            </div>
            @if (RecentAlerts.Count == 0)
            {
                <div class="notif-bell-empty">No alerts. All containers healthy.</div>
            }
            else
            {
                @foreach (var alert in RecentAlerts)
                {
                    <div class="notif-bell-item @(alert.IsRead ? "" : "notif-bell-item-unread")">
                        <a href="javascript:void(0)" class="notif-bell-item-link"
                           @onclick="() => OpenAlertAsync(alert)" @onclick:preventDefault>
                            <div class="notif-bell-item-title">@alert.ContainerName</div>
                            <div class="notif-bell-item-message">@alert.Message</div>
                            <div class="notif-bell-item-time">@alert.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</div>
                        </a>
                        @if (!alert.IsRead)
                        {
                            <button type="button" class="notif-bell-mark-read" title="Mark as read"
                                    @onclick="() => MarkReadAsync(alert)" @onclick:stopPropagation>
                                <i class="bi bi-check2"></i>
                            </button>
                        }
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private bool IsOpen { get; set; }
    private int UnreadCount { get; set; }
    private List<DockerHealthAlertView> RecentAlerts { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        UnreadCount = await DockerHealthService.CountUnreadAlertsAsync();
        RecentAlerts = (await DockerHealthService.ListAlertsAsync(unreadOnly: false)).Take(10).ToList();
        Notifier.OnAlert += HandleAlert;
    }

    private void HandleAlert(DockerHealthAlertView alert)
    {
        _ = InvokeAsync(() =>
        {
            RecentAlerts.Insert(0, alert);
            if (RecentAlerts.Count > 10) RecentAlerts.RemoveAt(RecentAlerts.Count - 1);
            UnreadCount++;
            StateHasChanged();
        });
    }

    private void ToggleOpen()
    {
        IsOpen = !IsOpen;
    }

    // DockerHealthAlertView's members are init-only, so an already-read alert is
    // represented by swapping in a new instance rather than mutating the existing one.
    private static DockerHealthAlertView AsRead(DockerHealthAlertView alert) => new()
    {
        Id = alert.Id,
        ContainerName = alert.ContainerName,
        Severity = alert.Severity,
        Message = alert.Message,
        IsRead = true,
        CreatedAt = alert.CreatedAt,
    };

    private async Task MarkReadAsync(DockerHealthAlertView alert)
    {
        if (alert.IsRead)
        {
            return;
        }

        await DockerHealthService.MarkAlertReadAsync(alert.Id);
        var index = RecentAlerts.FindIndex(a => a.Id == alert.Id);
        if (index >= 0)
        {
            RecentAlerts[index] = AsRead(alert);
        }

        UnreadCount = Math.Max(0, UnreadCount - 1);
    }

    private async Task MarkAllReadAsync()
    {
        await DockerHealthService.MarkAllAlertsReadAsync();
        RecentAlerts = RecentAlerts.Select(a => a.IsRead ? a : AsRead(a)).ToList();
        UnreadCount = 0;
    }

    private async Task OpenAlertAsync(DockerHealthAlertView alert)
    {
        if (!alert.IsRead)
        {
            await MarkReadAsync(alert);
        }

        IsOpen = false;
        Navigation.NavigateTo($"/admin/docker-health/{Uri.EscapeDataString(alert.ContainerName)}");
    }

    public void Dispose()
    {
        Notifier.OnAlert -= HandleAlert;
    }
}
