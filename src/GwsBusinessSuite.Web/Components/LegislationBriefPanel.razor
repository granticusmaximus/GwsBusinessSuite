@using GwsBusinessSuite.Application.GovernmentIntelligence

<details class="mt-3 pt-3 border-top">
    <summary class="fw-semibold" style="cursor:pointer;">@SummaryLabel</summary>
    <div class="mt-3 p-3 border rounded bg-light">
        <div class="d-flex justify-content-between gap-2 flex-wrap text-uppercase small text-secondary">
            <span class="fw-bold">@Brief.Kind</span>
            <span>@Brief.Jurisdiction</span>
        </div>

        <h5 class="my-2">@GetHeadline()</h5>
        <p class="text-secondary">@Brief.Summary</p>
        <div class="text-secondary small">Status: @Brief.Status</div>

        <div class="d-flex flex-column gap-3 mt-3">
            @if (Brief.Facts.Count > 0)
            {
                <section class="border rounded p-3 bg-white">
                    <h6 class="text-uppercase small text-secondary mb-3">Key facts</h6>
                    <dl class="d-flex flex-column gap-2 mb-0">
                        @foreach (var fact in Brief.Facts)
                        {
                            <div>
                                <dt class="text-uppercase small text-secondary">@fact.Label</dt>
                                <dd class="mb-0 mt-1">@fact.Value</dd>
                            </div>
                        }
                    </dl>
                </section>
            }

            @if (Brief.Timeline.Count > 0)
            {
                <section class="border rounded p-3 bg-white">
                    <h6 class="text-uppercase small text-secondary mb-3">Timeline</h6>
                    <div class="d-flex flex-column gap-3">
                        @foreach (var item in Brief.Timeline)
                        {
                            <article>
                                <div class="d-flex justify-content-between gap-2 flex-wrap">
                                    <strong>@item.Label</strong>
                                    <span class="text-secondary small">@item.When</span>
                                </div>
                                <p class="text-secondary mt-1 mb-0">@item.Detail</p>
                            </article>
                        }
                    </div>
                </section>
            }
        </div>

        @if (Brief.Links.Count > 0)
        {
            <div class="d-flex flex-wrap gap-2 mt-3">
                @foreach (var link in Brief.Links)
                {
                    <a class="btn btn-outline-dark btn-sm" href="@link.Url" target="_blank" rel="noopener noreferrer" title="@link.Description">
                        @link.Title
                    </a>
                }
            </div>
        }
    </div>
</details>

@code {
    [Parameter, EditorRequired]
    public LegislationDetailBrief Brief { get; set; } = null!;

    [Parameter]
    public string SummaryLabel { get; set; } = "Open legislation brief";

    private string GetHeadline()
    {
        if (string.IsNullOrWhiteSpace(Brief.Measure) ||
            string.Equals(Brief.Measure, Brief.Title, StringComparison.OrdinalIgnoreCase))
        {
            return Brief.Title;
        }

        return $"{Brief.Measure} · {Brief.Title}";
    }
}
