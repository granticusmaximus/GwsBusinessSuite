@using System.Text.Json
@using GwsBusinessSuite.Application.CmsBuilder
@using Markdig

@if (!string.IsNullOrWhiteSpace(ParseError))
{
    <div class="alert alert-danger mb-0">@ParseError</div>
}
else if (Layout is null || Layout.Sections.Count == 0)
{
    <div class="cms-block-preview-empty">
        <i class="bi bi-layout-text-window-reverse"></i>
        <div>
            <strong>No sections to preview.</strong>
            <div class="text-secondary">Add a section with widgets to render the page preview.</div>
        </div>
    </div>
}
else
{
    <div class="cms-block-preview-stack">
        @foreach (var section in Layout.Sections)
        {
            <div>
                <div class="small text-secondary fw-semibold mb-2 text-uppercase" style="letter-spacing:.05em;">
                    @(string.IsNullOrWhiteSpace(section.Label) ? "Section" : section.Label)
                </div>
                @foreach (var column in section.Columns)
                {
                    @foreach (var widget in column.Widgets)
                    {
                        <section class="cms-block-preview-card mb-3">
                            @RenderWidget(widget)
                        </section>
                    }
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public string BlocksJson { get; set; } = "[]";

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private PageLayout? Layout { get; set; }
    private string ParseError { get; set; } = string.Empty;

    protected override void OnParametersSet()
    {
        ParseError = string.Empty;
        Layout = null;

        try
        {
            Layout = JsonSerializer.Deserialize<PageLayout>(
                string.IsNullOrWhiteSpace(BlocksJson) ? "{}" : BlocksJson.Trim(), JsonOptions);
        }
        catch (Exception ex)
        {
            ParseError = $"Unable to parse page layout. {ex.Message}";
        }
    }

    private RenderFragment RenderWidget(LayoutWidget widget) => __builder =>
    {
        var p = widget.Props;

        switch (widget.WidgetType)
        {
            case "hero":
                <div class="cms-block-hero">
                    <span class="cms-block-chip">Hero</span>
                    <h3>@Get(p, "headline", "New hero section")</h3>
                    <p>@Get(p, "subline", "Add a concise promise or intro for this page.")</p>
                    @if (!string.IsNullOrWhiteSpace(Get(p, "cta1Label")))
                    {
                        <button type="button" class="btn btn-primary btn-sm">@Get(p, "cta1Label")</button>
                    }
                </div>
                break;
            case "heading":
                <span class="cms-block-chip">Heading</span>
                <h3>@Get(p, "text", "Heading text")</h3>
                break;
            case "paragraph":
                <span class="cms-block-chip">Paragraph</span>
                <p>@Get(p, "text", "Paragraph text.")</p>
                break;
            case "button":
                <span class="cms-block-chip">Button</span>
                <div><button type="button" class="btn btn-primary btn-sm">@Get(p, "label", "Button label")</button></div>
                break;
            case "image":
                <span class="cms-block-chip">Image</span>
                @if (!string.IsNullOrWhiteSpace(Get(p, "src")))
                {
                    <img src="@Get(p, "src")" alt="@Get(p, "alt")" style="max-width:100%;border-radius:12px;" />
                }
                else
                {
                    <div class="small text-secondary">No image source set.</div>
                }
                break;
            case "card":
                <span class="cms-block-chip">Card</span>
                <h3>@Get(p, "title", "Card title")</h3>
                <p>@Get(p, "body", "Card body text.")</p>
                break;
            case "spacer":
                <span class="cms-block-chip">Spacer</span>
                <div class="small text-secondary">@GetInt(p, "height", 48)px of vertical space.</div>
                break;
            case "divider":
                <span class="cms-block-chip">Divider</span>
                <hr />
                break;
            case "html":
                <span class="cms-block-chip">HTML</span>
                <pre class="cms-block-json mb-0">@Get(p, "content", "<!-- empty -->")</pre>
                break;
            case "form":
                <div class="cms-block-callout">
                    <span class="cms-block-chip">Form</span>
                    <h3>@Get(p, "submitLabel", "Form")</h3>
                    <div class="cms-block-form-grid">
                        @foreach (var field in ParseFormFields(Get(p, "fieldsJson")))
                        {
                            <div class="small text-secondary">
                                @field.Label
                                @if (field.Required)
                                {
                                    <text> *</text>
                                }
                                <span class="text-muted"> (@field.Type)</span>
                            </div>
                        }
                        @if (ParseFormFields(Get(p, "fieldsJson")).Count == 0)
                        {
                            <div class="small text-secondary">No fields defined yet.</div>
                        }
                    </div>
                </div>
                break;
            default:
                <span class="cms-block-chip">Unknown widget</span>
                <div class="small text-secondary mb-2">Widget type: @widget.WidgetType</div>
                break;
        }
    };

    private sealed record FormFieldPreview(string Label, string Type, bool Required);

    private static List<FormFieldPreview> ParseFormFields(string fieldsJson)
    {
        try
        {
            var nodes = JsonSerializer.Deserialize<List<Dictionary<string, JsonElement>>>(
                string.IsNullOrWhiteSpace(fieldsJson) ? "[]" : fieldsJson);
            if (nodes is null) return [];

            return nodes.Select(f => new FormFieldPreview(
                f.TryGetValue("label", out var l) ? l.GetString() ?? string.Empty : string.Empty,
                f.TryGetValue("type", out var t) ? t.GetString() ?? "text" : "text",
                f.TryGetValue("required", out var r) && r.ValueKind == JsonValueKind.True
            )).Where(f => !string.IsNullOrWhiteSpace(f.Label)).ToList();
        }
        catch
        {
            return [];
        }
    }

    private static string Get(IReadOnlyDictionary<string, string> p, string key, string fallback = "") =>
        p.TryGetValue(key, out var v) && !string.IsNullOrWhiteSpace(v) ? v : fallback;

    private static int GetInt(IReadOnlyDictionary<string, string> p, string key, int fallback) =>
        p.TryGetValue(key, out var v) && int.TryParse(v, out var result) ? result : fallback;
}
