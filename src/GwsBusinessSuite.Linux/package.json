{
  "name": "gws-business-suite-linux",
  "version": "1.0.0",
  "private": true,
  "description": "Linux desktop companion for GWS Business Suite",
  "author": {
    "name": "Grant Watson",
    "email": "grant@gwsapp.net"
  },
  "homepage": "https://github.com/granticusmaximus/GwsBusinessSuite",
  "desktopName": "net.gwsapp.businesssuite.desktop",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "dist:linux": "electron-builder --linux AppImage deb rpm"
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "net.gwsapp.businesssuite",
    "productName": "GWS Business Suite",
    "artifactName": "GWS-Business-Suite-${version}-${arch}.${ext}",
    "files": [
      "main.cjs",
      "offline.html",
      "package.json"
    ],
    "linux": {
      "category": "Office",
      "synopsis": "GWS Business Suite synchronized workspace",
      "description": "A synchronized Sentinel workspace for GWS Business Suite.",
      "maintainer": "Grant Watson <grant@gwsapp.net>",
      "vendor": "GWS Business Suite",
      "executableName": "gws-business-suite",
      "icon": "build/icons",
      "syncDesktopName": true,
      "target": ["AppImage", "deb", "rpm"]
    }
  }
}
