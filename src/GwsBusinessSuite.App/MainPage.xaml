<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GwsBusinessSuite.App.MainPage"
             BackgroundColor="#141210"
             Shell.NavBarIsVisible="False">

    <Grid>
        <!-- The hosted Blazor UI is the product UI on every platform. -->
        <WebView x:Name="WorkspaceView"
                 Navigating="OnWorkspaceNavigating"
                 Navigated="OnWorkspaceNavigated" />

        <Grid x:Name="LoadingOverlay"
              BackgroundColor="#141210"
              InputTransparent="False">
            <VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="14">
                <Border WidthRequest="48"
                        HeightRequest="48"
                        Padding="0"
                        BackgroundColor="#231F1D"
                        Stroke="#66501F"
                        StrokeShape="RoundRectangle 12">
                    <Label Text="S"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           TextColor="#FBBF24"
                           FontAttributes="Bold"
                           FontSize="21" />
                </Border>
                <ActivityIndicator Color="#F59E0B" IsRunning="True" />
                <Label Text="Opening GWS Business Suite"
                       TextColor="#A8A29E"
                       FontSize="13" />
            </VerticalStackLayout>
        </Grid>

        <Grid x:Name="StatusOverlay"
              Padding="24"
              BackgroundColor="#141210"
              IsVisible="False"
              InputTransparent="False">
            <Border MaximumWidthRequest="480"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Padding="28"
                    BackgroundColor="#1C1917"
                    Stroke="#292524"
                    StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="14">
                    <Border WidthRequest="42"
                            HeightRequest="42"
                            Padding="0"
                            HorizontalOptions="Start"
                            BackgroundColor="#2B2215"
                            Stroke="#66501F"
                            StrokeShape="RoundRectangle 10">
                        <Label Text="S"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center"
                               TextColor="#FBBF24"
                               FontAttributes="Bold"
                               FontSize="18" />
                    </Border>
                    <Label Text="GWS Business Suite is temporarily unavailable"
                           TextColor="#FAFAF9"
                           FontAttributes="Bold"
                           FontSize="22" />
                    <Label x:Name="StatusMessage"
                           Text="Check your internet connection and confirm that the GWS server is running."
                           TextColor="#A8A29E"
                           FontSize="14"
                           LineHeight="1.45" />
                    <Button Text="Reconnect"
                            Margin="0,6,0,0"
                            Padding="18,11"
                            HorizontalOptions="Start"
                            BackgroundColor="#F59E0B"
                            TextColor="#1C1917"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            Clicked="OnRefreshClicked" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
